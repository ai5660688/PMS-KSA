@{
    Layout = null;
    var msg = (string?)ViewBag.Message ?? "Processing, please wait...";
    var returnTo = (string?)ViewBag.ReturnTo ?? "Dashboard";
    var returnUrl = Url.Action(returnTo, "Home");
    var returnText = returnTo == "Dashboard" ? "Back to Dashboard" : "Continue";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>PMS - Loading</title>
    <link rel="icon" type="image/png" href="~/img/title_logo.png">
    <link rel="stylesheet" href="~/css/LoginInConLoginStyle.css">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        .Login-wrap { max-width: 900px; margin: 40px auto; background:#fff; border-radius:12px; padding:24px; box-shadow:0 10px 30px rgba(0,0,0,0.08); }
        .center { text-align:center; }
        .spinner { width:64px; height:64px; border:6px solid #e9eef5; border-top-color:#1769aa; border-radius:50%; margin:16px auto 24px; animation:spin 1s linear infinite; }
        @@keyframes spin { to { transform: rotate(360deg); } }
        .btn { display:inline-block; padding:12px 20px; background:#1769aa; color:#fff; border-radius:8px; text-decoration:none; }
        .btn:hover { background:#135a91; }
    </style>
</head>
<body>
    <h1>
        <img src="~/img/PMS_logo.png" alt="Logo" class="main-logo">
    </h1>
    <div class="container-wrapper">
        <div class="Login-wrap">
            <div class="center">
                <div class="spinner"></div>
                <h2>Your message has been sent</h2>
                <p>@msg</p>
                <a class="btn" href="@returnUrl">@returnText</a>
            </div>
        </div>
    </div>
    <div class="footer">
        <div class="footer-center">
            This system is strictly restricted to authorized users only.<br>
            © 2025 Piping Management System. All rights reserved.
        </div>
        <div class="footer-right">
            <img src="~/img/work-smarter-not-harder.jpg?v=3" alt="Logo" class="footer-logo" />
        </div>
    </div>
    <script>
        setTimeout(function(){ window.location.href = "@returnUrl"; }, 2500);
    </script>
</body>
</html>