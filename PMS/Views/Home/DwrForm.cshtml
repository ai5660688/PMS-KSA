                                                }
                                                @foreach (var t in tackersCapA)
                                                {
                                                    if (hasSelCapA && string.Equals(t.Symbol, selCapA, System.StringComparison.OrdinalIgnoreCase))
                                                    {
                                                        <option value="@t.Symbol" selected="selected">@t.Symbol</option>
