                                        @if(!string.Equals(headerView, "DWG", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <td class="col-dwg row-actions"><button type="button" class="open-dwg-row btn btn-outline" data-layout="@r.LayoutNumber" data-sheet="@r.Sheet">Open DWG</button></td>
                                        }
