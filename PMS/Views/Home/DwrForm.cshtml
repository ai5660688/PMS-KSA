        }
    </div>

    <!-- Anti-forgery token and all DWR-specific scripts are included inside the fragment so they can be injected when fragment is loaded into DailyWelding -->
    <div style="display:none">@antiForgery</div>
    <script>
        // Minimal wiring: save to DWR endpoint for Daily Welding
        const token=document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        function status(msg,ok){
            const host=document.getElementById('statusMsg');
            if(host){ host.textContent=msg; host.style.color=ok?'#176d8a':'#b40000'; if(ok) setTimeout(()=>{ if(host.textContent===msg) host.textContent=''; },2500); }
            const e=document.getElementById('dfrMsg');
            if(e){ e.textContent=msg; e.style.color=ok?'#176d8a':'#b40000'; if(ok) setTimeout(()=>{ if(e.textContent===msg) e.textContent=''; },2500);} 
        }
        // Centralized response handling to match Daily Fit-up messaging
        function handleBulkUpdateResponse(resp){
            try{
                document.querySelectorAll('#fitupTable tbody tr.validation-skip').forEach(r=> r.classList.remove('validation-skip'));
                const updated = Number(resp && resp.updated) || 0;
                const skipped = Number(resp && resp.skipped) || 0;
                const errors = Array.isArray(resp && resp.errors) ? resp.errors : [];
                errors.forEach(err => {
                    const id = err && (err.id || err.Id || err.JointId);
                    if(id!==undefined && id!==null){
                        const tr = document.querySelector(`#fitupTable tbody tr[data-id='${id}']`);
                        if(tr) tr.classList.add('validation-skip');
                    }
                });
                let mainMsg = '';
                if(skipped>0){
                    if(updated>0) mainMsg = `Saved ${updated} row(s). Skipped ${skipped} row(s).`;
                    else mainMsg = `Skipped ${skipped} row(s).`;
                } else {
                    if(updated>0) mainMsg = `Saved ${updated} row(s) successfully.`;
                    else mainMsg = 'No changes saved.';
                }
                if(errors.length>0 && errors[0].message){
                    const firstMsg = String(errors[0].message).replace(/^Skipped:\s*/i,'')
                    status(`${mainMsg} ${firstMsg}`, skipped===0 && updated>0);
                } else {
                    status(mainMsg, skipped===0 && updated>0);
                }
            } catch(e){ console.error('handleBulkUpdateResponse error', e); }
        }
        (function(){
            const table = document.getElementById('fitupTable');
            function markDirty(el){ try{ const tr = el.closest('tr'); if(tr){ tr.dataset.dirty='1'; tr.classList.add('dirty'); } } catch(e){} }
            function getFieldValue(input){
                if(!input) return null;
                const name = input.getAttribute('data-name') || input.name || '';
                let value = null;
                if(input.tagName === 'SELECT'){ value = input.value; }
                else if(input.type === 'checkbox'){ value = input.checked; }
                else { value = input.value; }
                // normalize blanks to null for non-checkbox
                if(input.type !== 'checkbox' && typeof value === 'string'){
                    const t = value.trim();
                    value = t.length ? t : null;
                }
                // coerce numeric-like fields
                try{
                    if(value != null){
                        if(name === 'PreheatTempC'){
                            const f = parseFloat(value);
                            value = isNaN(f) ? null : f;
                        }
                        else if(name === 'RFI_ID_DWR'){
                            const i = parseInt(value, 10);
                            value = isNaN(i) ? null : i;
                        }
                    }
                }catch{}
                return { name, value };
            }
            function collectRowPayload(tr){
                const id = parseInt(tr?.dataset?.id||'0',10) || 0;
                const payload = { JointId: id };
                // helper to find input/select by data-name within this row
                const q = (name) => tr.querySelector('[data-name="' + name + '"]');

                if (id <= 0) return payload;

                // FitupReport (Welding Report)
                try {
                    const fr = q('FitupReport');
                    if (fr) { const v = (fr.value || '').toString().trim(); payload.FitupReport = v.length ? v : null; }
                } catch {}

                // RFI -> RfiId and optional RfiDisplay
                try {
                    const rfi = q('RFI_ID_DWR');
                    if (rfi) {
                        const v = (rfi.value || '').toString().trim();
                        const vi = parseInt(v, 10);
                        payload.RfiId = (!isNaN(vi) && vi > 0) ? vi : null;
                        try {
                            const opt = rfi.options[rfi.selectedIndex];
                            const displayAttr = opt ? (opt.getAttribute('data-display') || opt.text) : null;
                            const display = displayAttr ? displayAttr.toString().trim() : null;
                            payload.RfiDisplay = display && display.length ? display : null;
                        } catch(e) { /* ignore */ }
                    }
                } catch {}

                // Dates
                try { const d1 = q('DATE_WELDED'); payload.FitupDate = d1 && d1.value ? d1.value : null; } catch {}
                try { const d2 = q('ACTUAL_DATE_WELDED'); payload.ActualDate = d2 && d2.value ? d2.value : null; } catch {}

                // WPS: prefer data-wps-id when present, always send text as Wps
                try {
                    const wps = q('WPS_ID_DWR');
                    if (wps) {
                        if (wps.tagName === 'SELECT') {
                            const sel = wps;
                            const opt = sel.options[sel.selectedIndex];
                            const wid = opt ? parseInt(opt.getAttribute('data-wps-id') || '', 10) : NaN;
                            payload.WpsId = (!isNaN(wid) && wid > 0) ? wid : null;
                            const text = (sel.value || '').toString().trim(); payload.Wps = text.length ? text : null;
                        } else {
                            const text = (wps.value || '').toString().trim(); payload.Wps = text.length ? text : null;
                        }
                    }
                } catch {}

                // Tack welders and related DWR fields
                try {
                    ['TackWelder','TackWelderB','TackWelderFillA','TackWelderFillB','TackWelderCapA','TackWelderCapB'].forEach(n => {
                        const el = q(n);
                        if (el) { const v = (el.value || '').toString().trim(); if (v.length) payload[n] = v; }
                    });
                } catch {}

                // Preheat numeric
                try { const p = q('PreheatTempC'); if (p) { const f = parseFloat(p.value); payload.PreheatTempC = isNaN(f) ? null : f; } } catch {}

                // IP_or_T and Open_Closed
                try { const ip = q('IP_or_T'); if (ip) { const v = (ip.value||'').toString().trim(); payload.IP_or_T = v.length ? v : null; } } catch {}
                try { const oc = q('Open_Closed'); if (oc) { const v = (oc.value||'').toString().trim(); payload.Open_Closed = v.length ? v : null; } } catch {}

                // Flags
                try { const del = q('Deleted'); if (del) payload.Deleted = (del.type === 'checkbox') ? del.checked : ((del.value||'')==='true'); } catch {}
                try { const can = q('Cancelled'); if (can) payload.Cancelled = (can.type === 'checkbox') ? can.checked : ((can.value||'')==='true'); } catch {}
                try { const conf = q('FitupConfirmed'); if (conf) payload.FitupConfirmed = (conf.type === 'checkbox') ? conf.checked : ((conf.value||'')==='true'); } catch {}

                // Remarks
                try { const rm = q('Remarks'); if (rm) { const v = (rm.value||'').toString().trim(); payload.Remarks = v.length ? v : null; } } catch {}

                return payload;
            }
            function onChange(e){ const t = e.target; if(!t) return; if(t.matches('input[data-name], select[data-name]')){ markDirty(t); } }
            if(table){
                table.addEventListener('change', onChange);
                table.addEventListener('input', onChange);
            }

            // Mirror header tacker auto-fill inside the table: Root A drives other tacker selects in the same row
            if(table){
                const dependentNames = ['TackWelderB','TackWelderFillA','TackWelderFillB','TackWelderCapA','TackWelderCapB'];
                function findMatchingOption(selectEl, sourceValue){
                    if(!selectEl) return null;
                    const opts = Array.from(selectEl.options);
                    if(!sourceValue) return '';
                    const trimmed = sourceValue.trim();
                    if(!trimmed) return '';
                    const exact = opts.find(o => (o.value || '').trim() === sourceValue);
                    if(exact) return exact.value;
                    const ciExact = opts.find(o => (o.value || '').trim().toLowerCase() === trimmed.toLowerCase());
                    if(ciExact) return ciExact.value;
                    const textMatch = opts.find(o => (o.text || '').trim().toLowerCase() === trimmed.toLowerCase());
                    if(textMatch) return textMatch.value;
                    const partial = opts.find(o => (o.text || '').toLowerCase().includes(trimmed.toLowerCase()));
                    if(partial) return partial.value;
                    return null;
                }
                function syncRowTackers(rootSelect){
                    if(!rootSelect) return;
                    const row = rootSelect.closest('tr');
                    if(!row) return;
                    const sourceValue = (rootSelect.value || '').trim();
                    dependentNames.forEach(name => {
                        const target = row.querySelector(`select[data-name="${name}"]`);
                        if(!target) return;
                        const nextValue = sourceValue ? findMatchingOption(target, sourceValue) : '';
                        if(sourceValue && nextValue === null) return;
                        const appliedValue = sourceValue ? nextValue : '';
                        if(target.value !== appliedValue){
                            target.value = appliedValue;
                            target.dispatchEvent(new Event('change',{ bubbles:true }));
                        }
                    });
                }
                table.addEventListener('change', function(e){
                    const target = e.target;
                    if(target && target.matches('select[data-name="TackWelder"]')){
                        syncRowTackers(target);
                    }
                });
            }
             window.__collectDwrDirtyPayload = function(){
                 const dirty=[...document.querySelectorAll('#fitupTable tbody tr')].filter(r=>r.dataset.dirty==='1');
                 return dirty.map(collectRowPayload);
             };
         })();
        // Improved save loop: prevent re-entrancy, debounce rapid clicks, disable buttons during save
        let __saving = false;
        let __saveTimer = null;
        async function save(){
            // simple debounce: collapse multiple clicks into one within 200ms
            if(__saveTimer){ clearTimeout(__saveTimer); }
            return new Promise(resolve => {
                __saveTimer = setTimeout(async ()=>{
                    if(__saving) { resolve(); return; }
                    const dirtyPayload = (typeof window.__collectDwrDirtyPayload==='function') ? window.__collectDwrDirtyPayload() : [];
                    if(!dirtyPayload || dirtyPayload.length===0){ status('No changes saved.', false); resolve(); return; }
                    __saving = true;
                    // disable save buttons while saving
                    const btns = [document.getElementById('btnSave'), document.getElementById('saveAllBtn')].filter(Boolean);
                    btns.forEach(b=>{ try{ if(!b.dataset.prevText){ b.dataset.prevText = b.textContent || ''; } b.disabled = true; b.classList.add('disabled'); b.textContent = 'Saving...'; }catch{} });
                    status(`Saving ${dirtyPayload.length} row(s)...`, true);
                    try{
                        const res = await fetch('/Home/BulkUpdateDwrRows',{ method:'POST', headers:{ 'Content-Type':'application/json','RequestVerificationToken': token }, body: JSON.stringify(dirtyPayload) });
                        if(res.ok){
                            let payload = null;
                            try { payload = await res.json(); } catch { payload = { updated: dirtyPayload.length, skipped: 0, errors: [] }; }
                            handleBulkUpdateResponse(payload);
                        } else {
                            // try to read error text
                            let t='Save failed';
                            try { t = await res.text(); } catch{}
                            status(t || 'Save failed', false);
                        }
                    }
                    catch(e){ status('Error saving',false); }
                    finally{
                        __saving = false;
                        btns.forEach(b=>{ try{ b.disabled = false; b.classList.remove('disabled'); if(Object.prototype.hasOwnProperty.call(b.dataset,'prevText')){ b.textContent = b.dataset.prevText; delete b.dataset.prevText; } }catch{} });
                        resolve();
                    }
                }, 200);
            });
        }
        // Expose save globally so welding toolbar forwarding can call it
        window.save = save;
        (function(){
            const standaloneBtn = document.getElementById('btnSave');
            const hostBtn = document.getElementById('saveAllBtn');
            standaloneBtn?.addEventListener('click', (e)=>{ e.preventDefault(); save(); });
            hostBtn?.addEventListener('click', (e)=>{ e.preventDefault(); save(); });
        })();
        // Formatting helpers (sticky/frozen + bottom scroll sync) adapted from DailyFitup
        (function(){
            // Prevent double initialization if fragment is injected multiple times
            const frag = document.getElementById('dwr-table-fragment');
            if(frag && frag.dataset.init==='1') return;
            if(frag) frag.dataset.init='1';

            function resizeBottomScroll(){
                const inner=document.getElementById('bottomScrollInner');
                const table=document.getElementById('fitupTable');
                const bottom=document.getElementById('bottomScroll');
                if(inner && table){ inner.style.width = table.scrollWidth + 'px'; }
                if(bottom){ const max = bottom.scrollWidth - bottom.clientWidth; if(bottom.scrollLeft > max){ bottom.scrollLeft = Math.max(0,max); } }
            }
            function bindScrollSync(){
                const bottom=document.getElementById('bottomScroll');
                const wrapper=document.getElementById('tableWrapper');
                if(!bottom||!wrapper||bottom.dataset.bound) return;
                bottom.addEventListener('scroll',()=>{ wrapper.scrollLeft = bottom.scrollLeft; });
                wrapper.addEventListener('scroll',()=>{ bottom.scrollLeft = wrapper.scrollLeft; });
                bottom.dataset.bound='1';
            }
            let frozenMeta=[];
            function computeFrozenLefts(){
                frozenMeta=[]; const table=document.getElementById('fitupTable'); if(!table) return; const row=table.querySelector('thead tr'); if(!row) return; const frozenCells=[...row.querySelectorAll('[data-frozen="1"], .frozen-col')]; let left=0; frozenCells.forEach(c=>{ const w=c.getBoundingClientRect().width; frozenMeta.push({el:c,left}); left+=w; }); applyFrozenPositions();
            }
            function applyFrozenPositions(){ const table=document.getElementById('fitupTable'); if(!table) return; frozenMeta.forEach(m=>{ const cls=[...m.el.classList].find(x=>x.startsWith('col-')); if(!cls) return; table.querySelectorAll('th.'+cls+', td.'+cls).forEach(cell=>{ cell.style.left=m.left+'px'; cell.style.position='sticky'; }); }); }
            function markFrozen(){ const table=document.getElementById('fitupTable'); if(!table) return; const classes=['col-sn','col-layout','col-locjoint','col-wtype']; classes.forEach(cls=>{ table.querySelectorAll('th.'+cls+', td.'+cls).forEach(cell=>{ cell.dataset.frozen='1'; cell.classList.add('frozen-col'); }); }); computeFrozenLefts(); }
            function init(){ markFrozen(); bindScrollSync(); resizeBottomScroll(); window.addEventListener('resize', resizeBottomScroll); }
            if(document.readyState==='loading') document.addEventListener('DOMContentLoaded', init); else init();

            // Keep bottom scroll width in sync when table content changes
            try {
                const tableInner = document.getElementById('tableInner');
                if(tableInner && !tableInner.dataset.observing){
                    const mo = new MutationObserver(()=>{ resizeBottomScroll(); });
                    mo.observe(tableInner, { childList: true, subtree: true });
                    tableInner.dataset.observing = '1';
                }
            } catch {}
        })();
        // Fallback: ensure per-row "Open DWG" buttons work even if external DWG script isn't initialized
        (function(){
            if(window.__dwrRowDwgBound==='1') return;
            window.__dwrRowDwgBound='1';
            function safeStatus(msg, ok){ try{ if(typeof window.showStatus==='function') window.showStatus(msg, ok); else if(msg) console[(ok?'log':'warn')](msg); }catch{} }
            document.addEventListener('click', function(e){
                const btn = e.target && e.target.closest && e.target.closest('.open-dwg-row');
                if(!btn) return;
                e.preventDefault();
                try{
                    const pid = (document.getElementById('projectSelect')?.value || '').trim();
                    if(!pid){ safeStatus('Select Project first', false); return; }
                    const tr = btn.closest('tr');
                    const layout = (btn.dataset.layout || tr?.querySelector('.col-layout')?.textContent || '').trim();
                    let sheet = (btn.dataset.sheet || '').trim();
                    if(!sheet && tr){
                        const sheetInp = tr.querySelector('input[data-name="Sheet"], select[data-name="Sheet"]');
                        sheet = (sheetInp?.value || sheetInp?.textContent || tr.querySelector('.col-sheet')?.textContent || '').trim();
                    }
                    if(!layout){ safeStatus('Layout missing for this row', false); return; }
                    const url = '/Home/OpenLatestDrawing?projectId=' + encodeURIComponent(pid) + '&layout=' + encodeURIComponent(layout) + (sheet?('&sheet=' + encodeURIComponent(sheet)):'');
                    const w = window.open(url, '_blank');
                    if(!w) window.location.href = url;
                }catch(err){ console.debug('Open DWG fallback error', err); }
            });
        })();
     </script>

    </div> <!-- end #dwr-table-fragment -->

