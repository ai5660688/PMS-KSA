                                        <td class="col-del chk-cell"><input type="checkbox" data-name="Deleted" name="Deleted" @(renderDeleted?"checked":null) @((locked || disableDelCan)?"disabled":null) aria-label="Deleted" /></td>
                                        <td class="col-can chk-cell"><input type="checkbox" data-name="Cancelled" name="Cancelled" @(renderCancelled?"checked":null) @((locked || disableDelCan)?"disabled":null) aria-label="Cancelled" /></td>
                                        <td class="col-conf chk-cell"><input type="checkbox" data-name="FitupConfirmed" name="FitupConfirmed" @(renderConfirmed?"checked":null) @(locked?"disabled":null) aria-label="Confirmed" /></td>
                                        <td class="col-remarks"><input data-name="Remarks" name="Remarks" value="@renderRemarks" @(locked?"disabled":null) aria-label="Remarks" /></td>
                                        <td class="col-openclosed">
                                            @{ 
