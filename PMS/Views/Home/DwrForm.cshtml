                                            else if (string.Equals(renderOcVal2, "Closed", System.StringComparison.OrdinalIgnoreCase))
                                            {
                                                <select data-name="Open_Closed" name="Open_Closed" @(locked?"disabled":null) aria-label="Open or Closed">
