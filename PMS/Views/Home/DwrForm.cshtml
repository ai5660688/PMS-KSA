                                        <td class="col-capb">
                                            <select data-name="TackWelderCapB" name="TackWelderCapB" @(locked?"disabled":null) aria-label="Cap B">
                                                @{
                                                    var tackersCapB = tackerOptions;
                                                    var selCapB = dwrCapB ?? string.Empty;
                                                    var hasSelCapB = !string.IsNullOrWhiteSpace(selCapB);
                                                }
                                                @if (!hasSelCapB)
                                                {
                                                    <option value="" selected="selected"></option>
                                                }
                                                else
                                                {
                                                    <option value=""></option>
                                                }
                                                @foreach (var t in tackersCapB)
                                                {
                                                    if (hasSelCapB && string.Equals(t.Symbol, selCapB, System.StringComparison.OrdinalIgnoreCase))
                                                    {
                                                        <option value="@t.Symbol" selected="selected">@t.Symbol</option>
                                                    }
                                                    else
