                                        <td class="col-preheat">
                                            <input data-name="PreheatTempC" name="PreheatTempC" autocomplete="off" inputmode="decimal" value="@displayPreheat" @(locked?"disabled":null) aria-label="Preheat Temp °C" />
                                        </td>
                                        <td class="col-iport">
                                            @{
                                                var renderIP = (dwrIPorT ?? string.Empty).Trim();
                                                var ipOptions = (Model?.IpOrTOptions ?? new List<string>())
                                                    .Where(o => !string.IsNullOrWhiteSpace(o))
                                                    .Select(o => o.Trim())
                                                    .Distinct(StringComparer.OrdinalIgnoreCase)
                                                    .OrderBy(o => o, StringComparer.OrdinalIgnoreCase)
                                                    .ToList();
                                                var hasIpOptions = ipOptions.Count > 0;
                                                var optionMatched = hasIpOptions && ipOptions.Any(o => string.Equals(o, renderIP, StringComparison.OrdinalIgnoreCase));
                                                var optionBuilder = new System.Text.StringBuilder();
                                                void AppendOption(string value, bool selected, string display)
                                                {
                                                    var encodedValue = System.Net.WebUtility.HtmlEncode(value ?? string.Empty);
                                                    var encodedDisplay = System.Net.WebUtility.HtmlEncode(display ?? string.Empty);
                                                    optionBuilder.Append("<option value=\"").Append(encodedValue).Append("\"");
                                                    if (selected)
                                                    {
                                                        optionBuilder.Append(" selected=\"selected\"");
                                                    }
                                                    optionBuilder.Append(">")
                                                                 .Append(encodedDisplay)
                                                                 .Append("</option>");
                                                }

                                                AppendOption("IP", string.Equals(renderIP, "IP", StringComparison.OrdinalIgnoreCase), "IP");
                                                AppendOption("T", string.Equals(renderIP, "T", StringComparison.OrdinalIgnoreCase), "T");

                                                if (hasIpOptions)
                                                {
                                                    foreach (var opt in ipOptions)
                                                    {
                                                        AppendOption(opt, string.Equals(opt, renderIP, StringComparison.OrdinalIgnoreCase), opt);
                                                    }
                                                    if (!string.IsNullOrWhiteSpace(renderIP) && !optionMatched && !string.Equals(renderIP, "IP", StringComparison.OrdinalIgnoreCase) && !string.Equals(renderIP, "T", StringComparison.OrdinalIgnoreCase))
                                                    {
                                                        AppendOption(renderIP, true, renderIP);
                                                    }
                                                }

                                                // trailing blank option as default
                                                AppendOption(string.Empty, string.IsNullOrWhiteSpace(renderIP), " ");
                                            }
                                            <select data-name="IP_or_T" name="IP_or_T" @(locked?"disabled":null) aria-label="IP or T">@Html.Raw(optionBuilder.ToString())</select>
                                        </td>
                                        @{
