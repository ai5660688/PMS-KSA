@model PMS.Models.DfrDailyFitupViewModel
@{
    Layout = null;
    var antiForgery = Html.AntiForgeryToken();
    DateTime? parsedFilterDate = null;
    DateTime? parsedHeaderDate = null;
    if(!string.IsNullOrWhiteSpace(Model.SearchFitupDate) && DateTime.TryParse(Model.SearchFitupDate, out var _sf)) { parsedFilterDate = _sf.Date; }
    if(!string.IsNullOrWhiteSpace(Model.FitupDateHeader) && DateTime.TryParse(Model.FitupDateHeader, out var _hh)) { parsedHeaderDate = _hh.Date; }

    // Helper lists (preserve server ordering unless noted)
    var sortedLocationOptions = (Model.LocationOptions ?? new List<string>()).OrderBy(x => x).ToList();
    var sortedJAddOptions = (Model.JAddOptions ?? new List<string>()).OrderBy(x => x).ToList();
    var sortedWeldTypeOptions = Model.WeldTypeOptions ?? new List<string>();
    var sortedMaterialDescriptions = Model.MaterialDescriptions ?? new List<string>();
    var sortedMaterialGrades = (Model.MaterialGrades ?? new List<string>()).ToList();
    var tackerOptions = Model?.TackerOptions ?? new List<PMS.Models.WelderSymbolOption>();

    // Determine current header view to optionally hide Layout column when DWG is selected
    var headerView = Context.Request.Query["headerView"].ToString();
    var showLayoutCol = !string.Equals(headerView, "DWG", StringComparison.OrdinalIgnoreCase);

    // Build small header metadata for fragment so AJAX loader can copy header values
    var isAllLocation = string.Equals(Model?.SelectedLocation, "All", StringComparison.OrdinalIgnoreCase);
    var dwrQrShop = Model?.FitupReportShop ?? string.Empty;
    var dwrQrField = Model?.FitupReportField ?? string.Empty;
    var dwrQrThreaded = Model?.FitupReportThreaded ?? string.Empty;
    var dwrQrHeaderSingle = Model?.FitupReportHeader ?? string.Empty;
    var dwrQrCombined = string.Join(" / ", new[]{ dwrQrShop ?? string.Empty, dwrQrField ?? string.Empty, dwrQrThreaded ?? string.Empty }.Where(x => !string.IsNullOrWhiteSpace(x)));
    var headerCombinedValue = !string.IsNullOrWhiteSpace(dwrQrCombined)
        ? dwrQrCombined
        : string.Join(" / ", new[]{ Model?.FitupReportShop ?? string.Empty, Model?.FitupReportField ?? string.Empty, Model?.FitupReportThreaded ?? string.Empty }.Where(x => !string.IsNullOrWhiteSpace(x)));
    var selLocForHeader = (Model?.SelectedLocation ?? string.Empty).Trim();
    var headerSingleValue = string.Empty;
    if(string.Equals(selLocForHeader, "Shop", StringComparison.OrdinalIgnoreCase))
    {
        headerSingleValue = !string.IsNullOrWhiteSpace(dwrQrShop) ? dwrQrShop : (Model?.FitupReportShop ?? string.Empty);
    }
    else if(string.Equals(selLocForHeader, "Field", StringComparison.OrdinalIgnoreCase))
    {
        headerSingleValue = !string.IsNullOrWhiteSpace(dwrQrField) ? dwrQrField : (Model?.FitupReportField ?? string.Empty);
    }
    else if(string.Equals(selLocForHeader, "Threaded", StringComparison.OrdinalIgnoreCase))
    {
        headerSingleValue = !string.IsNullOrWhiteSpace(dwrQrThreaded) ? dwrQrThreaded : (Model?.FitupReportThreaded ?? string.Empty);
    }
    if(string.IsNullOrWhiteSpace(headerSingleValue)) { headerSingleValue = !string.IsNullOrWhiteSpace(dwrQrHeaderSingle) ? dwrQrHeaderSingle : (Model?.FitupReportHeader ?? string.Empty); }

    // Format header date values to datetime-local when present
    string headerDateInputValue = string.Empty;
    if(!string.IsNullOrWhiteSpace(Model?.FitupDateHeader))
    {
        var fmt = new[] { "dd-MMM-yyyy hh:mm tt", "dd-MMM-yyyy H:mm", "yyyy-MM-dd'T'HH:mm", "yyyy-MM-dd HH:mm", "dd-MMM-yyyy" };
        if(DateTime.TryParseExact(Model.FitupDateHeader, fmt, System.Globalization.CultureInfo.InvariantCulture, System.Globalization.DateTimeStyles.None, out var _hdr))
        {
            headerDateInputValue = _hdr.ToString("yyyy-MM-dd'T'HH:mm");
        }
    }

    // Guarded rows count to avoid null reference when Model.Rows is null
    var rowCount = Model?.Rows?.Count ?? 0;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <title>PMS - DWR Editor</title>
    <link rel="icon" type="image/png" href="~/img/title_logo.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="~/css/DashboardStyle.css" />
    <link rel="stylesheet" href="~/css/DailyWelding.css" />
    <link rel="stylesheet" href="~/css/DfrForm.css" />
</head>
<body>
    @await Html.PartialAsync("~/Views/Shared/_DashboardHeader.cshtml")

    <!-- Fragment start: contains only the DWR table + antiforgery + required scripts -->
    <div id="dwr-table-fragment">
    <div class="dfr-form-wrap">

        @* Hidden header metadata so DailyWelding AJAX loader can copy header values (welding report inputs and reference boxes) *@
        <div id="dwr-fragment-meta" style="display:none;">
            @* Render the same visibility/disabled attributes as the main page so the AJAX loader can copy them back into the header *@
            <input id="weldingReportCombinedInput" value="@headerCombinedValue" style="display:@(isAllLocation ? "" : "none")" @(isAllLocation ? null : "disabled") aria-label="Welding Report Combined" autocomplete="off" />
            <input id="weldingReportHeaderInput" value="@headerSingleValue" style="display:@(isAllLocation ? "none" : "")" @(isAllLocation ? "disabled" : null) aria-label="Welding Report" autocomplete="off" />
            <label id="weldingReportLabel" for="@(isAllLocation ? "weldingReportCombinedInput" : "weldingReportHeaderInput")">@(isAllLocation ? "Welding Report (WS/FW/TH)" : "Welding Report")</label>
            @* Include header fitup/actual date inputs formatted for datetime-local *@
            <input id="fitupDateInput" value="@headerDateInputValue" aria-label="Welding Date" />
            <input id="actualDateInput" value="@headerDateInputValue" aria-label="Actual Welding Date" />
            @* Carry headerView so consumer can tailor UI if needed *@
            <input id="headerViewMeta" value="@headerView" aria-label="Header View" />
        </div>

        @* Hidden reference boxes section to allow DailyWelding to copy header values *@
        <div class="ref-line" style="display:none;">
            <div class="ref-boxes">
                <div class="ref-box"><span>Line Class: @Model?.LineClass</span></div>
                <div class="ref-box"><span>Material: @Model?.LineMaterial</span></div>
                <div class="ref-box"><span>Category: @Model?.LineCategory</span></div>
                <div class="ref-box"><span>RT Shop: @(Model?.RtShop is double rs ? (rs * 100).ToString("0.##") + "%" : null)</span></div>
                <div class="ref-box"><span>RT Field: @(Model?.RtField is double rf ? (rf * 100).ToString("0.##") + "%" : null)</span></div>
                <div class="ref-box"><span>PWHT Y/N: @(Model?.PwhtYN == true ? "Y" : Model?.PwhtYN == false ? "N" : null)</span></div>
                <div class="ref-box"><span>PWHT >20mm: @(Model?.Pwht20mm is bool p20 ? (p20 ? "Y" : "N") : null)</span></div>
                <div class="ref-box"><span>REV: @Model?.LsRev</span></div>
            </div>
        </div>

        @* Header and form removed: DailyWelding page provides the header/filter UI. Only render the table here. *@

        @if (rowCount == 0)
        {
            <div>
                @if (string.Equals(headerView, "DWG", StringComparison.OrdinalIgnoreCase))
                {
                    <text>No rows loaded. Enter layout &amp; sheet then Load.</text>
                }
                else if (string.Equals(headerView, "Date", StringComparison.OrdinalIgnoreCase))
                {
                    <text>Select Date view then press Load.</text>
                }
                else if (string.Equals(headerView, "Report", StringComparison.OrdinalIgnoreCase))
                {
                    <text>Select Report view, enter a report filter (optional) then press Load.</text>
                }
                else
                {
                    <text>No data.</text>
                }
            </div>
        }
        else
        {
            <div class="scroll-sync" id="scrollSync">
                <div class="table-wrapper" id="tableWrapper">
                    <div class="table-inner" id="tableInner">
                        <table class="fitup" id="fitupTable">
                            <thead>
                                <tr>
                                    <th class="col-sn">S/N</th>
                                    @if (showLayoutCol) { <th class="col-layout">Layout</th> }
                                    <th class="col-locjoint">Location / Joint</th>
                                    <th class="col-wtype">Weld Type</th>
                                    <th class="col-sheet">Sheet</th>
                                    <th class="col-spno">SP. No.</th>
                                    <th class="col-dia">Dia. In.</th>
                                    <th class="col-olThick">Actual Thick.</th>
                                    <th class="col-matA">Material A</th>
                                    <th class="col-matB">Material B</th>
                                    <th class="col-frep">Welding Report</th>
                                    <th class="col-rfi">RFI No.</th>
                                    <th class="col-fdate">Welding Date</th>
                                    <th class="col-actualdate">Actual Date</th>
                                    <th class="col-wps">WPS</th>
                                    <th class="col-roota">ROOT A</th>
                                    <th class="col-rootb">ROOT B</th>
                                    <th class="col-filla">FILL A</th>
                                    <th class="col-fillb">FILL B</th>
                                    <th class="col-capa">CAP A</th>
                                    <th class="col-capb">CAP B</th>
                                    <th class="col-preheat">Preheat Temp ⁰C</th>
                                    <th class="col-iport">IP or T</th>
                                    <th class="col-del">Deleted</th>
                                    <th class="col-can">Cancelled</th>
                                    <th class="col-conf">Confirmed</th>
                                    <th class="col-remarks">Remarks</th>
                                    <th class="col-openclosed">Open/Closed</th>
                                    <th class="col-updby">Updated By</th>
                                    <th class="col-upddate">Updated Date</th>
                                    @if(!string.Equals(headerView, "DWG", StringComparison.OrdinalIgnoreCase)) { <th class="col-dwg">DWG</th> }
                                    <th class="col-clear">Clear</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    var sn = 0;
                                    var rows = Model?.Rows ?? new List<PMS.Models.DfrRowVm>();
                                }
                                @foreach (var r in rows)
                                {
                                    // row FitupDate defaults from header/filter are no longer applied to welding view; show blank unless DWR has a date
                                    var rowFitupDateValue = string.Empty;

                                    // Prefer DWR values when present on the row; otherwise blank
                                    double? preheatVal = null;
                                    string displayPreheat = string.Empty;
                                    object? displayUpdatedBy = null;
                                    string? displayUpdatedDate = null;
                                    var displayWeldingReport = string.Empty;

                                    // New: DWR-backed overrides
                                    int? dwrRfiId = null;
                                    string? dwrRfiNo = null;
                                    string? dwrFitupDateValue = null; // DATE_WELDED
                                    string? dwrActualDateValue = null; // ACTUAL_DATE_WELDED
                                    int? dwrWpsId = null;
                                    string? dwrWpsText = null;
                                    string? dwrRootA = null; string? dwrRootB = null; string? dwrFillA = null; string? dwrFillB = null; string? dwrCapA = null; string? dwrCapB = null;
                                    string? dwrIPorT = null;
                                    bool? dwrConfirmed = null;
                                    bool? dwrCancelled = null;
                                    string? dwrRemarks = null;
                                        string? dwrOpenClosed = null;

                                    try {
                                        var t = r.GetType();
                                        // PREHEAT
                                        var preheatProp = t.GetProperty("PREHEAT_TEMP_C")
                                            ?? t.GetProperty("PREHEAT_TEMPC")
                                            ?? t.GetProperty("PREHEAT_TEMP")
                                            ?? t.GetProperty("PREHEAT_C")
                                            ?? t.GetProperties().FirstOrDefault(p => p.Name.IndexOf("PREHEAT", StringComparison.OrdinalIgnoreCase) >= 0 && p.Name.IndexOf("TEMP", StringComparison.OrdinalIgnoreCase) >= 0);

                                        object? rawPreheatValue = null;
                                        if (preheatProp != null)
                                        {
                                            rawPreheatValue = preheatProp.GetValue(r);
                                        }
                                        else
                                        {
                                            try
                                            {
                                                if (r is System.Collections.IDictionary idict)
                                                {
                                                    foreach (System.Collections.DictionaryEntry de in idict)
                                                    {
                                                        var key = (de.Key ?? string.Empty).ToString() ?? string.Empty;
                                                        if (key.IndexOf("PREHEAT", StringComparison.OrdinalIgnoreCase) >= 0 && key.IndexOf("TEMP", StringComparison.OrdinalIgnoreCase) >= 0)
                                                        {
                                                            rawPreheatValue = de.Value;
                                                            break;
                                                        }
                                                    }
                                                }
                                                else if (t.Name == "DataRowView")
                                                {
                                                    try
                                                    {
                                                        var dr = t.GetProperty("Row")?.GetValue(r);
                                                        if (dr != null)
                                                        {
                                                            var table = dr.GetType().GetProperty("Table")?.GetValue(dr);
                                                            if (table != null)
                                                            {
                                                                var columns = table.GetType().GetProperty("Columns")?.GetValue(table) as System.Collections.IEnumerable;
                                                                if (columns != null)
                                                                {
                                                                    foreach (var col in columns)
                                                                    {
                                                                        var colName = col?.GetType().GetProperty("ColumnName")?.GetValue(col)?.ToString() ?? string.Empty;
                                                                         if (colName.IndexOf("PREHEAT", StringComparison.OrdinalIgnoreCase) >= 0 && colName.IndexOf("TEMP", StringComparison.OrdinalIgnoreCase) >= 0)
                                                                        {
                                                                            rawPreheatValue = dr.GetType().GetProperty("Item", new[] { typeof(string) })?.GetValue(dr, new object[] { colName });
                                                                            break;
                                                                        }
                                                                    }
                                                                }
                                                            }
                                                        }
                                                    }
                                                    catch { /* ignore fallback errors */ }
                                                }
                                            }
                                            catch { /* ignore */ }
                                        }

                                        if (object.ReferenceEquals(rawPreheatValue, System.DBNull.Value)) rawPreheatValue = null;
                                        if (rawPreheatValue != null)
                                        {
                                            var v = rawPreheatValue;
                                            if (v is double dd) preheatVal = dd;
                                            else if (v is float ff) preheatVal = (double)ff;
                                            else if (v is decimal dec) preheatVal = (double)dec;
                                            else if (v is int iInt) preheatVal = iInt;
                                            else if (v is long lLong) preheatVal = lLong;
                                            else if (v is short sShort) preheatVal = sShort;
                                            else
                                            {
                                                var s = v?.ToString()?.Trim();
                                                if (!string.IsNullOrWhiteSpace(s) && double.TryParse(s, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var pd))
                                                {
                                                    preheatVal = pd;
                                                }
                                            }
                                        }

                                        displayPreheat = preheatVal.HasValue
                                            ? preheatVal.Value.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)
                                            : string.Empty;

                                        // Updated By / Date should come from DWR via controller; otherwise blank
                                        try { displayUpdatedBy = r.UpdatedBy; displayUpdatedDate = r.UpdatedDate; } catch { }

                                        // Welding Report from DWR
                                        var qrProperty = t.GetProperty("POST_VISUAL_INSPECTION_QR_NO")
                                            ?? t.GetProperty("PostVisualInspectionQrNo")
                                            ?? t.GetProperty("Post_Visual_Inspection_QR_No")
                                            ?? t.GetProperty("FitupReport")
                                            ?? t.GetProperty("POST_VISUAL_INSPECTION_QR_NO_DWR");
                                        var qrVal = qrProperty?.GetValue(r)?.ToString();
                                        displayWeldingReport = !string.IsNullOrWhiteSpace(qrVal) ? qrVal : string.Empty;

                                        // RFI from DWR only (do not fallback to DFR RFI_ID)
                                        var rfiProperty = t.GetProperty("RFI_ID_DWR")
                                            ?? t.GetProperty("RfiIdDwr")
                                            ?? t.GetProperty("RfiId")
                                            ?? t.GetProperty("RFI_ID");
                                        var rfiVal = rfiProperty?.GetValue(r);
                                        if(rfiVal != null && int.TryParse(rfiVal.ToString(), out var iv)) { dwrRfiId = iv; }
                                        try {
                                            if (dwrRfiId.HasValue && dwrRfiId.Value > 0)
                                            {
                                                var opt = ((Model?.RfiOptions) ?? new List<PMS.Models.RfiOption>()).FirstOrDefault(o => o.Id == dwrRfiId.Value);
                                                dwrRfiNo = opt?.Value;
                                                if (string.IsNullOrWhiteSpace(dwrRfiNo)) dwrRfiNo = opt?.Display ?? null;
                                            }
                                        } catch { }

                                        // DATE_WELDED
                                        var dateProperty = t.GetProperty("DATE_WELDED")
                                            ?? t.GetProperty("Date_Welded")
                                            ?? t.GetProperty("DateWelded")
                                            ?? t.GetProperty("DATE_WELDED_D")
                                            ?? t.GetProperty("FitupDate");
                                        var dateVal = dateProperty?.GetValue(r);
                                        if(dateVal is DateTime dwdt) { dwrFitupDateValue = dwdt.ToString("yyyy-MM-dd'T'HH:mm"); }
                                        else if(DateTime.TryParse(dateVal?.ToString(), out var parsedDW)) { dwrFitupDateValue = parsedDW.ToString("yyyy-MM-dd'T'HH:mm"); }

                                        // ACTUAL_DATE_WELDED
                                        var actualProperty = t.GetProperty("ACTUAL_DATE_WELDED")
                                            ?? t.GetProperty("ActualDateWelded")
                                            ?? t.GetProperty("Actual_Date_Welded")
                                            ?? t.GetProperty("ActualDate");
                                        var actualVal = actualProperty?.GetValue(r);
                                        if(actualVal is DateTime adt) { dwrActualDateValue = adt.ToString("yyyy-MM-dd'T'HH:mm"); }
                                        else if(DateTime.TryParse(actualVal?.ToString(), out var parsedAD)) { dwrActualDateValue = parsedAD.ToString("yyyy-MM-dd'T'HH:mm"); }

                                        // WPS (DWR only)
                                        var wpsIdProperty = t.GetProperty("WPS_ID_DWR")
                                            ?? t.GetProperty("WpsIdDwr");
                                        var wpsIdVal = wpsIdProperty?.GetValue(r);
                                        if(wpsIdVal != null && int.TryParse(wpsIdVal.ToString(), out var wv)) { dwrWpsId = wv; }
                                        var wpsTextProperty = t.GetProperty("WPS_DWR")
                                            ?? t.GetProperty("WpsDwr")
                                            ?? t.GetProperty("WPS")
                                            ?? t.GetProperty("Wps");
                                        var wpsTextVal = wpsTextProperty?.GetValue(r)?.ToString();
                                        if (dwrWpsId.HasValue && !string.IsNullOrWhiteSpace(wpsTextVal))
                                        {
                                            dwrWpsText = wpsTextVal;
                                        }

                                        // ROOT/FILL/CAP - try common name variants
                                        string? TryGetStringProp(string name1, string? name2 = null, string? name3 = null)
                                         {
                                             var p = t.GetProperty(name1) ?? (name2 != null ? t.GetProperty(name2) : null) ?? (name3 != null ? t.GetProperty(name3) : null);
                                             return p != null ? p.GetValue(r)?.ToString() : null;
                                         }

                                        dwrRootA = TryGetStringProp("ROOT_A", "RootA", "ROOTA") ?? TryGetStringProp("ROOT_A_DWR");
                                        dwrRootB = TryGetStringProp("ROOT_B", "RootB", "ROOTB") ?? TryGetStringProp("ROOT_B_DWR");
                                        dwrFillA = TryGetStringProp("FILL_A", "FillA", "FILLA") ?? TryGetStringProp("FILL_A_DWR");
                                        dwrFillB = TryGetStringProp("FILL_B", "FillB", "FILLB") ?? TryGetStringProp("FILL_B_DWR");
                                        dwrCapA = TryGetStringProp("CAP_A", "CapA", "CAPA") ?? TryGetStringProp("CAP_A_DWR");
                                        dwrCapB = TryGetStringProp("CAP_B", "CapB", "CAPB") ?? TryGetStringProp("CAP_B_DWR");

                                        // IP or T
                                        var ipProperty = t.GetProperty("IP_or_T") ?? t.GetProperty("IPOrT") ?? t.GetProperty("IP_or_Tech") ?? t.GetProperty("IP_or_T_DWR");
                                        var ipVal = ipProperty?.GetValue(r)?.ToString(); dwrIPorT = string.IsNullOrWhiteSpace(ipVal) ? null : ipVal;

                                        // Confirmed (Weld_Confirmed)
                                        var confProperty = t.GetProperty("Weld_Confirmed") ?? t.GetProperty("WELD_CONFIRMED");
                                        var confVal = confProperty?.GetValue(r);
                                        if(confVal != null && bool.TryParse(confVal.ToString(), out var cb)) dwrConfirmed = cb;

                                        // Cancelled - best-effort
                                        var cancProperty = t.GetProperty("Cancelled") ?? t.GetProperty("CANCELLED") ?? t.GetProperty("Weld_Cancelled");
                                        var cancVal = cancProperty?.GetValue(r);
                                        if(cancVal != null && bool.TryParse(cancVal.ToString(), out var canb)) dwrCancelled = canb;

                                        // Remarks
                                        var remProperty = t.GetProperty("DWR_REMARKS") ?? t.GetProperty("DwrRemarks") ?? t.GetProperty("Remarks") ?? t.GetProperty("DwrRemarksDisplay");
                                        var remVal = remProperty?.GetValue(r)?.ToString(); dwrRemarks = string.IsNullOrWhiteSpace(remVal) ? null : remVal;

                                        // Open/Closed
                                        var ocProperty = t.GetProperty("Open_Closed") ?? t.GetProperty("OpenClosed") ?? t.GetProperty("OPEN_CLOSED");
                                        var ocVal = ocProperty?.GetValue(r)?.ToString(); dwrOpenClosed = string.IsNullOrWhiteSpace(ocVal) ? null : ocVal;

                                    } catch { /* best-effort reflection - ignore */ }

                                    // Determine normalized location code for this row: WS/FW/TH
                                    string __locCode = "";
                                    try {
                                        var rawLoc = r.Location?.Trim() ?? string.Empty;
                                        var wt = r.WeldType?.Trim() ?? string.Empty;
                                        if (!string.IsNullOrWhiteSpace(wt) && wt.ToUpperInvariant().Contains("TH")) { __locCode = "TH"; }
                                        else if (!string.IsNullOrWhiteSpace(rawLoc)) {
                                            var up = rawLoc.ToUpperInvariant();
                                            if (up.Contains("SHOP") || up.Contains("WORK") || up.StartsWith("WS")) __locCode = "WS";
                                            else __locCode = "FW";
                                        }
                                    } catch { }

                                    // Determine values used in rendering (prefer DWR values only)
                                    var renderFitupDate = !string.IsNullOrWhiteSpace(dwrFitupDateValue) ? dwrFitupDateValue : string.Empty;
                                    var renderActualDate = !string.IsNullOrWhiteSpace(dwrActualDateValue) ? dwrActualDateValue : string.Empty;
                                    var renderRfiId = dwrRfiId; // DWR only
                                    var renderRfiNo = dwrRfiNo;  // DWR only
                                    var renderWpsId = dwrWpsId;
                                    // Resolve WPS text strictly from DWR data; when only an Id exists, use header options to display that Id's text
                                    var renderWpsStr = !string.IsNullOrWhiteSpace(dwrWpsText)
                                        ? dwrWpsText
                                        : ((renderWpsId.HasValue && renderWpsId.Value > 0)
                                            ? (((Model?.WpsOptions) ?? new List<PMS.Models.WpsOption>()).FirstOrDefault(o => o.Id == renderWpsId.Value)?.Wps ?? string.Empty)
                                            : string.Empty);

                                    // Preheat already normalized above (blank when missing)
                                    // UpdatedBy/UpdatedDate already sourced from DWR via controller (blank when missing)
                                    var renderRemarks = dwrRemarks ?? string.Empty; // DWR only
                                    var renderConfirmed = dwrConfirmed ?? false; // DWR only
                                    var renderCancelled = dwrCancelled ?? false; // DWR only
                                    var renderDeleted = r.Deleted; // keep deleted from DFR as a row state
                                    var missingFitupDate = string.IsNullOrWhiteSpace(r.FitupDate);

                                    var locked = renderConfirmed || missingFitupDate;

                                    // Build merged Location/Joint/J-Add column
                                    string mergedLocJoint = string.Empty;
                                    try {
                                        var loc = r.Location?.Trim() ?? string.Empty;
                                        var joint = r.WeldNumber?.Trim() ?? string.Empty;
                                        var jadd = r.JAdd?.Trim() ?? string.Empty;
                                        var basePart = string.IsNullOrWhiteSpace(loc) ? joint : (string.IsNullOrWhiteSpace(joint) ? loc : (loc + "-" + joint));
                                        if(string.IsNullOrWhiteSpace(jadd) || string.Equals(jadd, "NEW", StringComparison.OrdinalIgnoreCase))
                                        {
                                            mergedLocJoint = basePart;
                                        }
                                        else
                                        {
                                            mergedLocJoint = basePart + "-" + jadd;
                                        }
                                    } catch { mergedLocJoint = (r.Location + "-" + r.WeldNumber + (string.IsNullOrWhiteSpace(r.JAdd)?"":"-"+r.JAdd)); }

                                     <tr data-id="@r.JointId" data-location-code="@__locCode" class="@(locked ? "locked" : string.Empty) @(missingFitupDate ? "missing-fitup" : string.Empty)">
                                        <td class="col-sn">@(++sn)</td>
                                        @if (showLayoutCol) { <td class="col-layout">@r.LayoutNumber</td> }
                                        <td class="col-locjoint @(r.DfrOnHold ? "hold-alert" : null)">@mergedLocJoint</td>
                                        @* Hidden normalized location cell for client scripts *@
                                        <td class="col-location" style="display:none">@__locCode</td>
                                        <td class="col-wtype">@r.WeldType</td>
                                        <td class="col-sheet @(r.SheetOnHold ? "hold-alert" : null)">@r.Sheet</td>
                                        <td class="col-spno @(r.SpOnHold ? "hold-alert" : null)">@r.SpoolNo</td>
                                        <td class="col-dia">@r.DiaIn</td>
                                        <td class="col-olThick">@r.OlThick</td>
                                        <td class="col-matA">@r.MaterialA</td>
                                        <td class="col-matB">@r.MaterialB</td>
                                        <td class="col-frep"><input data-name="FitupReport" name="FitupReport" value="@displayWeldingReport" @(locked ? "disabled" : null) aria-label="Welding Report" autocomplete="off" /></td>
                                        <td class="col-rfi">
                                            @{
                                                // Render a minimal per-row RFI select. The full option list is fetched asynchronously per-row
                                                // by dailywelding.js via GetWeldingRfiOptions. If this row already has a DWR RFI saved, render a
                                                // single selected fallback option so the UI shows the saved value until the async loader runs.
                                                var rfiIdVal = renderRfiId ?? 0;
                                                var hasDwrRfi = rfiIdVal > 0;
                                                var fallbackText = hasDwrRfi ? (!string.IsNullOrWhiteSpace(renderRfiNo) ? renderRfiNo : rfiIdVal.ToString(System.Globalization.CultureInfo.InvariantCulture)) : string.Empty;
                                            }
                                            <select data-name="RFI_ID_DWR" data-rfi-name="RfiId" name="RFI_ID_DWR" class="rfi-async-select rfi-select" data-project="@(Model?.SelectedProjectId ?? 0)" data-fitupdate="@(Model?.FitupDateHeader ?? string.Empty)" data-placeholder="&#160;" @(locked ? "disabled" : null) aria-label="RFI No.">
                                                @* Start with a visible blank option *@
                                                @if (!hasDwrRfi)
                                                {
                                                        <option value="" data-display="" selected="selected">&nbsp;</option>
                                                }
                                                else
                                                {
                                                        <option value="" data-display="">&nbsp;</option>
                                                }
                                                @* If this row has a saved DWR RFI id, render it as a fallback selected option so it's visible until async load populates list *@
                                                @if (hasDwrRfi)
                                                {
                                                    var fbEncoded = System.Net.WebUtility.HtmlEncode(fallbackText ?? string.Empty);
                                                    <option value="@rfiIdVal" data-display="@fbEncoded" selected="selected">@fallbackText</option>
                                                }
                                            </select>
                                         </td>
                                        <td class="col-fdate"><input type="datetime-local" data-name="DATE_WELDED" name="DATE_WELDED" value="@renderFitupDate" @(locked?"disabled":null) aria-label="Welding Date" /></td>
                                        <td class="col-actualdate"><input type="datetime-local" data-name="ACTUAL_DATE_WELDED" name="ACTUAL_DATE_WELDED" value="@renderActualDate" @(locked?"disabled":null) aria-label="Actual Date" /></td>
                                        <td class="col-wps" data-col="wps">
                                            @{
                                                var baseWpsCandidates = r.WpsCandidates ?? new List<PMS.Models.WpsOption>();
                                                var selectedWps = renderWpsStr ?? string.Empty;
                                                var selectedId = renderWpsId;
                                                var effectiveCandidates = baseWpsCandidates;
                                                if ((effectiveCandidates == null || effectiveCandidates.Count == 0) && !string.IsNullOrWhiteSpace(selectedWps))
                                                {
                                                    effectiveCandidates = new List<PMS.Models.WpsOption>
                                                    {
                                                        new PMS.Models.WpsOption { Id = selectedId ?? 0, Wps = selectedWps }
                                                    };
                                                }
                                                var hasCandidates = effectiveCandidates != null && effectiveCandidates.Count > 0;
                                                bool CandidateMatches(PMS.Models.WpsOption opt)
                                                    => !string.IsNullOrWhiteSpace(selectedWps)
                                                       && string.Equals(opt.Wps, selectedWps, StringComparison.OrdinalIgnoreCase);
                                                var hasSelectedCandidate = hasCandidates && effectiveCandidates!.Any(opt => CandidateMatches(opt) || (selectedId.HasValue && opt.Id == selectedId.Value));
                                            }
                                            @if (hasCandidates)
                                            {
                                                <select data-name="WPS_ID_DWR" name="WPS_ID_DWR" class="wps-select" style="width:160px" @(locked?"disabled":null)>
                                                    @foreach (var cand in effectiveCandidates!)
                                                    {
                                                        var optionTitle = $"t: {cand.ThicknessRange ?? string.Empty} PWHT: {(cand.Pwht == true ? "Y" : "N" )}";
                                                        var isSelected = CandidateMatches(cand) || (selectedId.HasValue && cand.Id == selectedId.Value);
                                                        if (isSelected)
                                                        {
                                                            <option data-wps-id="@cand.Id" value="@cand.Wps" title="@optionTitle" selected="selected">@cand.Wps</option>
                                                        }
                                                        else
                                                        {
                                                            <option data-wps-id="@cand.Id" value="@cand.Wps" title="@optionTitle">@cand.Wps</option>
                                                        }
                                                    }
                                                    @if (!hasSelectedCandidate && !string.IsNullOrWhiteSpace(selectedWps))
                                                    {
                                                        <option data-wps-id="@(selectedId ?? 0)" value="@selectedWps" selected="selected" title="Saved">@selectedWps</option>
                                                    }
                                                    @if (string.IsNullOrWhiteSpace(selectedWps))
                                                    {
                                                        <option value="" selected="selected"></option>
                                                    }
                                                    else
                                                    {
                                                        <option value=""></option>
                                                    }
                                                </select>
                                            }
                                            else
                                            {
                                                <input data-name="WPS_ID_DWR" name="WPS_ID_DWR" value="@selectedWps" @(locked?"disabled":null) style="width:160px" autocomplete="off" />
                                            }
                                        </td>
