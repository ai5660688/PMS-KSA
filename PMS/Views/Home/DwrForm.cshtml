                                                @{
                                                    var tackers = tackerOptions;
                                                    var selRootA = dwrRootA ?? string.Empty;
                                                    var hasSelRootA = !string.IsNullOrWhiteSpace(selRootA);
                                                }
                                                @if (!hasSelRootA)
                                                {
                                                    <option value="" selected="selected"></option>
                                                }
                                                else
                                                {
