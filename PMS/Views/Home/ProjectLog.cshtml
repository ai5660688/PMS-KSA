@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model IEnumerable<PMS.Models.Project>
@{
    Layout = null;
    ViewData["Title"] = "Project Log";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>PMS - Project Log</title>
    <link rel="icon" type="image/png" href="~/img/title_logo.png">
    <link rel="stylesheet" href="~/css/DashboardStyle.css" asp-append-version="true">
    <style>
        .page { width:90%; margin:20px auto; background:#fff; border-radius:8px; box-shadow:0 4px 12px rgba(0,0,0,.1); padding:20px; }
        .page-title { color:#176d8a; font-size:2em; margin:0 0 16px 0; padding-bottom:10px; border-bottom:2px solid #e6f6fa; }
        .grid { display:grid; grid-template-columns: repeat(auto-fill,minmax(240px,1fr)); gap:12px; }
        .form-group { display:flex; flex-direction:column; gap:6px; }
        label { font-weight:600; color:#176d8a; font-size:.9rem; }
        .form-control { padding:8px 12px; border:1px solid #cce7ef; border-radius:4px; background:#fff; color:#176d8a; font-size:.9rem; width:100%; box-sizing:border-box; }
        .form-control:focus { outline:none; border-color:#1f99be; box-shadow:0 0 0 2px rgba(31,153,190,.2); }
        .actions { display:flex; gap:8px; justify-content:flex-end; margin-top:12px; }
        .btn { padding:8px 14px; border:none; border-radius:4px; cursor:pointer; font-weight:600; transition:.2s; }
        .btn-primary { background:#1f99be; color:#fff; } .btn-primary:hover{ background:#176d8a; }
        .btn-danger { background:#cc0000; color:#fff; } .btn-danger:hover{ background:#a30000; }
        .btn-secondary { background:#7a9aa8; color:#fff; }
        .btn-outline { background:#fff; color:#176d8a; border:1px solid #1f99be; }
        .btn-outline:hover { background:#1f99be; color:#fff; }
        .user-table { width:100%; border-collapse:collapse; margin-top:20px; }
        .user-table th { background-color:#e6f6fa; color:#176d8a; padding:10px 12px; text-align:left; position:sticky; top:0; }
        .user-table td { padding:10px 12px; border-bottom:1px solid #e6f6fa; color:#1a6d86; }
        .user-table th, .user-table td { font-size:.9rem; }
        /* Match WelderList flash message appearance */
        .msg { margin:0 0 12px 0; font-weight:400; font-size:0.875rem; display:block; }
        .msg.text-danger { color: #cc0000; }
        .msg-success { color: #27ae60; font-weight:400; font-size:0.875rem; display:block; }
        .row-actions { display:flex; gap:8px; }
        .modal { display:none; position:fixed; top:0; left:0; width:100%; height:100%; background-color:rgba(0,0,0,0.5); z-index:10000; justify-content:center; align-items:center; }
        .modal-content { background:#fff; padding:25px; border-radius:8px; width:90%; max-width:600px; max-height:80vh; overflow-y:auto; box-shadow:0 4px 20px rgba(0,0,0,0.15); }
        .modal-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; padding-bottom:15px; border-bottom:1px solid #e6f6fa; }
        .modal-title { color:#176d8a; font-size:1.4rem; margin:0; }
        .close-modal { background:none; border:none; font-size:1.5rem; cursor:pointer; color:#176d8a; }
        .modal-actions { display:flex; justify-content:flex-end; gap:10px; margin-top:20px; padding-top:15px; border-top:1px solid #e6f6fa; }
        .filter-bar { display:flex; gap:10px; flex-wrap:wrap; align-items:center; margin-top:25px; }
        .filter-bar input { flex:1 1 260px; }
        .count { font-size:.8rem; color:#176d8a; }
    </style>
</head>
<body>
    @await Html.PartialAsync("_DashboardHeader")

    <div class="page">
        <h1 class="page-title">Project Log</h1>

        @if (TempData["Msg"] is string m)
        {
            var isSuccess = System.Text.RegularExpressions.Regex.IsMatch(m ?? "", "(successfully|saved|uploaded|updated|added)", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            var css = isSuccess ? "msg msg-success" : "msg text-danger";
            <div class="@css" role="status" aria-live="polite">@m</div>
        }

        <form asp-action="SaveProject" asp-controller="Home" method="post" id="projectForm">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="err"></div>
            <div class="grid">
                <div class="form-group">
                    <label for="Project_ID">Project ID</label>
                    <input class="form-control" id="Project_ID" name="Project_ID" type="number" min="1" required placeholder="Enter Project ID" />
                </div>
                <div class="form-group">
                    <label for="Project_Name">Project Name</label>
                    <input class="form-control" id="Project_Name" name="Project_Name" maxlength="50" required />
                </div>
                <div class="form-group">
                    <label for="Client">Client</label>
                    <input class="form-control" id="Client" name="Client" maxlength="30" />
                </div>
                <div class="form-group">
                    <label for="Contractor_Project_No">Contractor Project No</label>
                    <input class="form-control" id="Contractor_Project_No" name="Contractor_Project_No" maxlength="10" />
                </div>
                <div class="form-group">
                    <label for="Contractor">Contractor</label>
                    <input class="form-control" id="Contractor" name="Contractor" maxlength="30" />
                </div>
                <div class="form-group">
                    <label for="PO_No">PO No</label>
                    <input class="form-control" id="PO_No" name="PO_No" maxlength="20" />
                </div>
                <div class="form-group">
                    <label for="WS_Location">WS Location</label>
                    <input class="form-control" id="WS_Location" name="WS_Location" maxlength="30" />
                </div>
                <div class="form-group">
                    <label for="FW_Location">FW Location</label>
                    <input class="form-control" id="FW_Location" name="FW_Location" maxlength="30" />
                </div>
                <div class="form-group">
                    <label for="BI_JO">BI/JO</label>
                    <input class="form-control" id="BI_JO" name="BI_JO" maxlength="20" />
                </div>
                <div class="form-group">
                    <label for="Contract_No">Contract No</label>
                    <input class="form-control" id="Contract_No" name="Contract_No" maxlength="20" />
                </div>
                <div class="form-group">
                    <label for="Welders_Project_ID">Welders Project ID</label>
                    <input class="form-control" id="Welders_Project_ID" name="Welders_Project_ID" type="number" min="0" />
                </div>
                <div class="form-group">
                    <label for="Line_Sheet">Line / Sheet</label>
                    <select id="Line_Sheet" name="Line_Sheet" class="form-control">
                        <option value="">-- Select --</option>
                        <option value="Line">Line</option>
                        <option value="Sheet">Sheet</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="Project_Type">Project Type</label>
                    <input class="form-control" id="Project_Type" name="Project_Type" maxlength="15" />
                </div>
                <div class="form-group">
                    <label for="ARAMCO_NON">ARAMCO / NON</label>
                    <input class="form-control" id="ARAMCO_NON" name="ARAMCO_NON" maxlength="15" />
                </div>
                <div class="form-group">
                    <label for="Default_P">Default Project</label>
                    <div style="display:flex; align-items:center; gap:8px;">
                        <input type="checkbox" id="Default_P" name="Default_P" value="true" />
                        <span class="count">Mark as default</span>
                    </div>
                </div>
            </div>
            <div class="actions">
                <button type="button" class="btn btn-secondary" onclick="clearProjectForm()">Clear</button>
                <button type="submit" class="btn btn-primary">Save Project</button>
            </div>
        </form>

        <div class="filter-bar">
            <input id="searchBox" class="form-control" type="text" placeholder="Search by ID or Project Name..." autocomplete="off" />
            <div class="filter-actions" style="display:flex; gap:8px; align-items:center;">
                <button id="downloadBtn" type="button" class="btn btn-outline">Download Excel</button>
                <span id="rowCount" class="count"></span>
            </div>
        </div>

        <table class="user-table" id="projectsTable">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Project Name</th>
                    <th>Contractor Project</th>
                    <th>Client</th>
                    <th>Contractor</th>
                    <th>PO No</th>
                    <th>WS Loc</th>
                    <th>FW Loc</th>
                    <th>BI/JO</th>
                    <th>Contract No</th>
                    <th>Welders Project ID</th>
                    <th>Line / Sheet</th>
                    <th>Project Type</th>
                    <th>ARAMCO / NON</th>
                    <th>Default</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var p in (Model ?? System.Linq.Enumerable.Empty<PMS.Models.Project>()))
            {
                <tr data-id="@p.Project_ID">
                    <td>@p.Project_ID</td>
                    <td>@p.Project_Name</td>
                    <td>@p.Contractor_Project_No</td>
                    <td>@p.Client</td>
                    <td>@p.Contractor</td>
                    <td>@p.PO_No</td>
                    <td>@p.WS_Location</td>
                    <td>@p.FW_Location</td>
                    <td>@p.BI_JO</td>
                    <td>@p.Contract_No</td>
                    <td>@p.Welders_Project_ID</td>
                    <td>@p.Line_Sheet</td>
                    <td>@p.Project_Type</td>
                    <td>@p.ARAMCO_NON</td>
                    <td>@(p.Default_P ? "Yes" : "No")</td>
                    <td>
                        <div class="row-actions">
                            <button type="button" class="btn btn-primary" onclick="editProject(this)">Edit</button>
                            <form asp-action="DeleteProject" asp-controller="Home" method="post" class="delete-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@p.Project_ID" />
                                <button type="submit" class="btn btn-danger">Del</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    <div class="modal" id="confirmDeleteModal">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title">Confirm Delete</h2>
                <button class="close-modal" type="button" onclick="closeDeleteModal()">&times;</button>
            </div>
            <p id="confirmDeleteMessage" style="color:#176d8a; margin:0 0 16px 0;"></p>
            <div class="modal-actions">
                <button type="button" class="btn" onclick="closeDeleteModal()">Cancel</button>
                <button type="button" class="btn btn-danger" onclick="confirmDelete()">Delete</button>
            </div>
        </div>
    </div>

    @await Html.PartialAsync("_DashboardFooter")

    <script>
        function byId(id){ return document.getElementById(id); }
        function clearProjectForm() {
            ['Project_ID','Project_Name','Client','Contractor_Project_No','Contractor','PO_No','WS_Location','FW_Location','BI_JO','Contract_No','Welders_Project_ID','Line_Sheet','Project_Type','ARAMCO_NON','Default_P']
              .forEach(i=>{ const el=byId(i); if(!el) return; if(el.type === 'checkbox') el.checked = false; else el.value=''; });
        }
        function editProject(btn) {
            const tr = btn.closest('tr');
            const tds = tr.children;
            byId('Project_ID').value = tr.dataset.id;
            byId('Project_Name').value = tds[1].textContent.trim();
            byId('Contractor_Project_No').value = tds[2].textContent.trim();
            byId('Client').value = tds[3].textContent.trim();
            byId('Contractor').value = tds[4].textContent.trim();
            byId('PO_No').value = tds[5].textContent.trim();
            byId('WS_Location').value = tds[6].textContent.trim();
            byId('FW_Location').value = tds[7].textContent.trim();
            byId('BI_JO').value = tds[8].textContent.trim();
            byId('Contract_No').value = tds[9].textContent.trim();
            byId('Welders_Project_ID').value = (tds[10] ? tds[10].textContent.trim() : '');
            byId('Line_Sheet').value = (tds[11] ? tds[11].textContent.trim() : '');
            byId('Project_Type').value = (tds[12] ? tds[12].textContent.trim() : '');
            byId('ARAMCO_NON').value = (tds[13] ? tds[13].textContent.trim() : '');
            const defaultCell = (tds[14] ? tds[14].textContent.trim().toLowerCase() : '');
            const defaultChecked = defaultCell === 'yes' || defaultCell === 'true' || defaultCell === '1';
            const defaultEl = byId('Default_P');
            if (defaultEl) defaultEl.checked = defaultChecked;
            window.scrollTo({top:0, behavior:'smooth'});
            setTimeout(()=> byId('Project_ID')?.focus(), 250);
        }

        // Filtering
        const searchInput = byId('searchBox');
        const table = byId('projectsTable');
        const rowCountEl = byId('rowCount');
        function applyFilter(){
            const q = (searchInput.value||'').trim().toLowerCase();
            let shown=0; let total=0;
            table.querySelectorAll('tbody tr').forEach(tr=>{
                total++;
                const id = (tr.children[0]?.textContent||'').toLowerCase();
                const name = (tr.children[1]?.textContent||'').toLowerCase();
                const match = !q || id.includes(q) || name.includes(q);
                tr.style.display = match ? '' : 'none';
                if(match) shown++;
            });
            rowCountEl.textContent = `${shown}/${total}`;
        }
        searchInput?.addEventListener('input', applyFilter);
        applyFilter();

        byId('downloadBtn')?.addEventListener('click', ()=> {
            const q = encodeURIComponent(searchInput.value.trim());
            const url = q ? `/Home/ExportProjects?q=${q}` : '/Home/ExportProjects';
            window.location = url;
        });

        // Delete modal behavior
        let pendingDeleteForm = null;
        function openDeleteModal(form) {
            pendingDeleteForm = form;
            const tr = form.closest('tr');
            const id = tr?.dataset?.id || '';
            const name = tr?.children?.[1]?.textContent?.trim() || '';
            const msg = name ? `Are you sure you want to delete project "${name}" (ID ${id})?` : `Are you sure you want to delete project ID ${id}?`;
            byId('confirmDeleteMessage').textContent = msg;
            byId('confirmDeleteModal').style.display = 'flex';
        }
        function closeDeleteModal() {
            byId('confirmDeleteModal').style.display = 'none';
            pendingDeleteForm = null;
        }
        function confirmDelete() { if(pendingDeleteForm) pendingDeleteForm.submit(); closeDeleteModal(); }
        document.querySelectorAll('form.delete-form').forEach(f=>{
            f.addEventListener('submit', function(e){ e.preventDefault(); openDeleteModal(this); });
        });
        window.addEventListener('click', function(e){ const modal=byId('confirmDeleteModal'); if(e.target===modal) closeDeleteModal(); });
    </script>
</body>
</html>