 // Update sheet and spool selects based on current DWG and Sheet selection
 let _hier = null;
 function updateDependentSelects(){
 if(!_hier) _hier = buildHierarchyFromTable();
 const dwgSel = document.getElementById('dwgBox');
 const sheetSel = document.getElementById('sheetBox');
 const spoolSel = document.getElementById('spoolBox');
 if(!dwgSel || !sheetSel || !spoolSel) return;
 // prefer the displayed text but also keep the underlying value available
 const dwgText = (dwgSel.selectedOptions && dwgSel.selectedOptions[0] && (dwgSel.selectedOptions[0].text||'').trim()) || (dwgSel.value || '').trim();
 const dwgValue = (dwgSel.value || '').toString().trim();
 const sheetText = (sheetSel.selectedOptions && sheetSel.selectedOptions[0] && (sheetSel.selectedOptions[0].text||'').trim()) || sheetSel.value || '';
 if(!dwgText){
 // no DWG selected: disable sheet and spool and populate spool from table SPOOL column so Spool reflects SPOOL at the table
 sheetSel.disabled = true;
 const tableSpools = (Array.isArray(serverSpoolOptions) && serverSpoolOptions.length) ? serverSpoolOptions.slice() : getSpoolsFromTable();
 populateSelectWithItems(spoolSel, tableSpools, true);
 spoolSel.disabled = !(tableSpools && tableSpools.length);
 return;
 }

 // Prefer server-provided mapping when available
 let serverEntry = null;
 try {
 if(Array.isArray(serverSpoolMap) && serverSpoolMap.length){
 // try matching by Dwg field against both displayed text and option value (trimmed)
 serverEntry = serverSpoolMap.find(e => {
 const key = ((e.Dwg || e.dwg || '') + '').toString().trim();
 return key && (key === dwgText || key === dwgValue || key.toLowerCase() === dwgText.toLowerCase() || key.toLowerCase() === dwgValue.toLowerCase());
 });
 }
 } catch(e){ serverEntry = null; }

 if(serverEntry){
 // Build sheet list from server mapping
 const sheets = (serverEntry.Sheets || serverEntry.sheets || []).map(s => (s.Sheet || s.sheet || '').trim()).filter(s => s);
 if(sheets.length){
 populateSelectWithItems(sheetSel, sheets.sort((a,b)=> a.localeCompare(b)), true); sheetSel.disabled = false;
 // If a sheet selected & present, populate spools for that sheet; otherwise use dwg-level spools
 const sheetObj = (serverEntry.Sheets || serverEntry.sheets || []).find(s => ((s.Sheet || s.sheet || '') + '').trim() === sheetText || ((s.Sheet || s.sheet || '') + '').trim() === sheetSel.value);
 const spForSheet = sheetObj ? (sheetObj.Spools || sheetObj.spools || []).slice() : [];
 const dwgSpools = (serverEntry.Spools || serverEntry.spools || []).slice();
 if(sheetText && spForSheet.length){ populateSelectWithItems(spoolSel, spForSheet.sort((a,b)=> a.localeCompare(b)), true); spoolSel.disabled = false; }
 else { populateSelectWithItems(spoolSel, dwgSpools.sort((a,b)=> a.localeCompare(b)), true); spoolSel.disabled = !(dwgSpools && dwgSpools.length); }
 } else {
 // no sheets in server mapping -> use dwg spools if any
 const dwgSpools = (serverEntry.Spools || serverEntry.spools || []).slice();
 populateSelectWithItems(sheetSel, [], true); sheetSel.disabled = true;
 populateSelectWithItems(spoolSel, dwgSpools.sort((a,b)=> a.localeCompare(b)), true); spoolSel.disabled = !(dwgSpools && dwgSpools.length);
 }
 return;
 }

 // Fallback to table-derived mapping when server mapping not present
 // prefer exact DWG key, but also allow entries under '__NO_DWG__' for spools without DWG
 // Try robust lookup: attempt exact match, trimmed, case-insensitive, and normalized (strip %) keys
 const findEntryKey = (key) => {
 if(!key) return null;
 const candidates = Object.keys(_hier || {});
 const want = key.toString().trim();
 const wantLower = want.toLowerCase();
 for(let i=0;i<candidates.length;i++){
 const k = candidates[i];
 if(k === want) return k;
 if((k || '').toString().trim() === want) return k;
 if((k || '').toString().trim().toLowerCase() === wantLower) return k;
 // try normalized compare (strip %)
 if((k || '').toString().trim().replace(/%/g,'').toLowerCase() === wantLower.replace(/%/g,'')) return k;
 }
 return null;
 };
 let entryKey = findEntryKey(dwgText) || findEntryKey(dwgValue);
 // if no entryKey found in table-derived hierarchy, clear selects instead of falling back to __NO_DWG__
 if(!entryKey){
 // selected DWG not found in table - clear
 populateSelectWithItems(sheetSel, [], true); sheetSel.disabled = true;
 populateSelectWithItems(spoolSel, [], true); spoolSel.disabled = true;
 return;
 }
 let entry = _hier[entryKey];
 if(!entry){
 populateSelectWithItems(sheetSel, [], true); sheetSel.disabled = true;
 populateSelectWithItems(spoolSel, [], true); spoolSel.disabled = true;
 return;
 }
 // populate sheet list for this DWG
 const sheets = entry.sheetList || [];
 if(sheets.length){
 populateSelectWithItems(sheetSel, sheets, true); sheetSel.disabled = false;
 // if a sheet selected, ensure it's present, else clear spool to appropriate for DWG
 if(sheetText && sheets.includes(sheetText)){
 // populate spools for that sheet
 const spForSheet = entry.sheets[sheetText] || [];
 populateSelectWithItems(spoolSel, spForSheet.length ? spForSheet : entry.spools, true);
 spoolSel.disabled = !( (spForSheet && spForSheet.length) || (entry.spools && entry.spools.length) );
 } else {
 // no sheet selected -> show all spools for this DWG
 populateSelectWithItems(spoolSel, entry.spools || [], true);
 spoolSel.disabled = !(entry.spools && entry.spools.length);
 }
 } else {
 // no sheets for this DWG: disable sheet and populate spools
 populateSelectWithItems(sheetSel, [], true); sheetSel.disabled = true;
 populateSelectWithItems(spoolSel, entry.spools || [], true); spoolSel.disabled = !(entry.spools && entry.spools.length);
 }
 }

