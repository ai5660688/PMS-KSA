 d = normalizeDwgValue((''+r[idxDwg]).trim());
 }
 // SHEET: normalize to3-digit form preserving trailing letters
 let s = '';
 if(idxSheet >=0 && r[idxSheet] !== undefined && (''+r[idxSheet]).trim()){
 s = normalizeSheetValue((''+r[idxSheet]).trim());
 }
 // SPOOL: normalize to2-digit form preserving trailing letters
 let sp = '';
 if(idxSpool >=0 && r[idxSpool] !== undefined && (''+r[idxSpool]).trim()){
 sp = normalizeSpoolValue((''+r[idxSpool]).trim());
 }
 // Only add rows that have at least one identifying value
