@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model System.Data.DataTable
@{
 Layout = "_LayoutDashboard";
 ViewData["Title"] = "Shop Spool Status (Log)";

 // Helper to format option display to match table cell formatting
 string FormatForDisplay(string? raw)
 {
 if (string.IsNullOrWhiteSpace(raw)) return string.Empty;
 var v = raw.Trim();
 if (DateTime.TryParse(v, out var dtv)) return dtv.ToString("yyyy-MM-dd");
 if (int.TryParse(v, out _)) return v; // numeric keep as-is
 if (double.TryParse(v, out _)) return v;
 return v; // default: trimmed string
 }
}

@section Head {
 <link rel="stylesheet" href="/css/spoolReleaseLog.css" />
 <style>
 /* Consolidated header style with suitable bottom spacing */
 h1 {
 color: #176d8a;
 font-size:1.4rem; /* increased for better visibility */
 line-height:1.2;
 margin:0 0 24px 0; /* top and bottom margins equal */
 font-weight:700;
 letter-spacing:0.2px;
 }

 .toolbar {
 margin-bottom:12px;
 display: flex;
 gap:10px;
 align-items: center;
 flex-wrap: wrap;
 }

 .spool-layout {
 width:98%;
 margin:14px auto 0; /* remove bottom margin on the outer layout */
 padding:14px 14px 0; /* remove bottom padding so table sits flush */
 box-sizing: border-box;
 max-width:1500px;
 }

 .table-wrap {
 overflow: auto; /* allow horizontal scroll when table wider than container */
 -webkit-overflow-scrolling: touch;
 max-width:100%;
 max-height:495px; /* increased to make table taller */
 margin:0; /* ensure no margin around scroller */
 padding:0; /* ensure no padding inside scroller */
 background: #fff; /* match table background so no visible gap */
 }

 /* Scrollbar styling: make thumb use same color as the title */
 .table-wrap::-webkit-scrollbar {
 height:18px; /* horizontal scrollbar height (increased) */
 width:18px; /* vertical scrollbar width (increased) */
 }
 .table-wrap::-webkit-scrollbar-track {
 background: #f0fbff; /* subtle track matching header bg */
 }
 .table-wrap::-webkit-scrollbar-thumb {
 background: #176d8a; /* same as title color */
 border-radius:10px;
 border:4px solid #fff; /* give thumb some breathing room */
 }
 .table-wrap::-webkit-scrollbar-thumb:hover {
 background: #125a6e; /* slightly darker on hover */
 }
 /* Firefox: use auto width (wider than 'thin') and same colors */
 .table-wrap {
 scrollbar-width: auto;
 scrollbar-color: #176d8a #f0fbff;
 }

 /* Make selects match table font, sizing and scroll appearance */
 .search, .searchable-select {
 font-family: inherit; /* inherit from page / table */
 font-size: .95rem; /* increased for readability */
 color: #176d8a;
 background: #fff;
 border:1px solid #e6f6fa;
 padding:4px 8px;
 line-height:1.4;
 -webkit-appearance: none;
 appearance: none;
 border-radius:4px;
 box-sizing:border-box;
 display: inline-block; /* allow width: auto to size correctly */
 }
 /* ensure options inherit font styling */
 select.searchable-select option {
 font-family: inherit;
 font-size: .86rem;
 color: #176d8a;
 white-space: nowrap;
 }
 /* Focus/open state: make border black while interacting */
 .searchable-select:focus, .searchable-select:active {
 border-color: #000 !important;
 box-shadow:0002px rgba(0,0,0,0.06);
 outline: none;
 }

 /* Scrollbar for select dropdowns (WebKit browsers) */
 select.searchable-select::-webkit-scrollbar { width:12px; height:12px; }
 select.searchable-select::-webkit-scrollbar-track { background: #f0fbff; }
 select.searchable-select::-webkit-scrollbar-thumb { background: #176d8a; border-radius:8px; border:3px solid #fff; }
 select.searchable-select::-webkit-scrollbar-thumb:hover { background: #125a6e; }
 /* Firefox */
 select.searchable-select { scrollbar-width: thin; scrollbar-color: #176d8a #f0fbff; }

 /* Let the table size to its content (fit to data) but never exceed container width */
 table {
 width: auto;
 max-width:100%;
 border-collapse: collapse;
 background: #fff;
 box-shadow: none; /* remove table shadow so no visual gap appears under scroller */
 table-layout: auto; /* allow columns to size based on content */
 margin:0; /* remove any table margin */
 border-bottom: none;
 border-spacing:0;
 }

 /* remove any extra spacing around table sections */
 thead, tbody, tr, th, td { margin:0; }

 th, td {
 /* reduced padding to lower row height */
 padding:6px 8px; /* slightly increased padding to match larger font */
 border:1px solid #e6f6fa;
 font-size: .86rem; /* increased table font-size for better readability */
 box-sizing: border-box;
 white-space: nowrap; /* keep data on single line to size columns to content */
 }

 /* ensure last row sits flush with scroller bottom */
 tbody tr:last-child td { padding-bottom:0; }

 /* allow wrapping in specific cells if needed by removing nowrap class */
 td.wrap {
 white-space: normal;
 }

 th {
 background: #f0fbff;
 text-align: left;
 position: sticky;
 top:0;
 z-index:3;
 }

 tr:hover { background: #f8fcff; }

 .btn {
 padding:6px 12px;
 border: none;
 border-radius:4px;
 cursor: pointer;
 font-weight:600;
 text-decoration: none;
 }

 .btn-outline { background: #fff; color: #176d8a; border:1px solid #1f99be; }
 .btn-outline:hover { background:#1f99be; color:#fff; }
 a.btn, a.btn:link, a.btn:visited, a.btn:hover, a.btn:focus, a.btn:active { text-decoration:none; }

 .search { padding:4px 8px; border:1px solid #cce7ef; border-radius:4px; font-size: .9rem; }
 .search:focus, .btn:focus, select:focus { outline: none; box-shadow:0 0 0 rgba(31,153,190,0); }

 .mono { font-family: Consolas, Monaco, monospace; font-size: .8rem; }
 .col-serial { width:55px; text-align: center; font-weight:600; }

 .header-fixed { vertical-align: middle; }
 .w110 { width:110px; }
 .w130 { width:130px; }
 .w90 { width:90px; }
 .w350 { width:350px; }
 .searchable-select { -webkit-appearance: auto; appearance: auto; }
 .nowrap { white-space: nowrap; }

 .filters { display: flex; gap:8px; align-items: center; flex-wrap: wrap; }
 .filters .field { display: flex; gap:6px; align-items: center; }
 .filters label { font-size: .78rem; color: #176d8a; font-weight:600; margin-right:6px; }
 .right-controls { margin-left: auto; }

 /* Status multi-checkbox dropdown styled to match table */
 .status-dropdown {
 display: none;
 position: absolute;
 left:0;
 top:34px;
 background: #fff;
 border:1px solid #e6f6fa;
 padding:0;
 max-height:260px;
 overflow: auto;
 min-width:260px;
 z-index:1200;
 box-sizing: border-box;
 }
 .status-dropdown .status-item {
 padding:6px 8px;
 border-bottom:1px solid #e6f6fa;
 display: flex;
 align-items: center;
 gap:8px;
 font-size: .86rem;
 color: #176d8a;
 background: #fff;
 }
 .status-dropdown .status-item:last-child { border-bottom: none; }
 .status-dropdown label { cursor: pointer; width:100%; }
 .status-checkbox { width:16px; height:16px; accent-color: #176d8a; margin-right:8px; }

 /* Use same scrollbar visuals as table-wrap */
 .status-dropdown::-webkit-scrollbar { width:12px; height:12px; }
 .status-dropdown::-webkit-scrollbar-track { background: #f0fbff; }
 .status-dropdown::-webkit-scrollbar-thumb { background: #176d8a; border-radius:8px; border:3px solid #fff; }
 .status-dropdown::-webkit-scrollbar-thumb:hover { background: #125a6e; }
 .status-dropdown { scrollbar-width: thin; scrollbar-color: #176d8a #f0fbff; }

 /* Searchable select dropdown widget */
 .ss-wrap { position:relative; display:inline-block; vertical-align:middle; }
 .ss-wrap.w350 { width:350px; min-width:350px; }
 .ss-wrap.w130 { width:130px; }
 .ss-wrap.w110 { width:110px; }
 .ss-wrap.w90  { width:90px; min-width:90px; }
 .ss-input { width:100%; box-sizing:border-box; cursor:pointer; font-family:inherit; font-size:.95rem; color:#176d8a; background:#fff; border:1px solid #e6f6fa; padding:4px 8px; line-height:1.4; border-radius:4px; }
 .ss-input:focus { cursor:text; border-color:#000; outline:none; }
 .ss-list { display:none; position:absolute; left:0; right:0; top:100%; z-index:1200; background:#fff; border:1px solid #176d8a; border-top:none; border-radius:0 0 6px 6px; max-height:220px; overflow-y:auto; box-shadow:0 4px 10px rgba(0,0,0,.12); }
 .ss-item { padding:6px 10px; cursor:pointer; font-size:.86rem; color:#176d8a; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
 .ss-item:hover, .ss-item.ss-highlight { background:#e6f6fa; }
 .ss-item.ss-active { font-weight:700; }
 .ss-empty { padding:6px 10px; font-size:.85rem; color:#999; font-style:italic; }
 .ss-open .ss-input { border-radius:4px 4px 0 0; border-color:#176d8a; }
 .ss-list::-webkit-scrollbar { width:12px; }
 .ss-list::-webkit-scrollbar-track { background:#f0fbff; }
 .ss-list::-webkit-scrollbar-thumb { background:#176d8a; border-radius:8px; border:3px solid #fff; }
 .ss-list::-webkit-scrollbar-thumb:hover { background:#125a6e; }
 .ss-list { scrollbar-width:thin; scrollbar-color:#176d8a #f0fbff; }

 /* Responsive tweaks */
 @@media (max-width:900px) {
 .filters { flex-direction: column; align-items: flex-start; gap:6px; }
 .right-controls { margin-left:0; width:100%; }
 .button-wrapper {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 10px;
 }

 .w350 { width:100%; }
 .ss-wrap.w350 { width:100%; min-width:0; }
 .w110, .w130, .w90 { width: auto; }
 table { min-width:0; }
 th, td { font-size: .95rem; white-space: normal; }
 }
 </style>
}

<div class="spool-layout">
 <h1>Shop Spool Status (Log)</h1>
 <div class="toolbar">
 <div class="left-controls">
 <div class="filters">
 <div class="field">
 <label for="statusBox">Status</label>
 <div style="position:relative; display:inline-block">
 <button type="button" id="statusToggle" class="search header-fixed w110 searchable-select" aria-expanded="false">Status <span id="statusCount" style="font-weight:600; margin-left:6px;">(0)</span></button>
 <div id="statusDropdown" class="status-dropdown">
 @{ 
 var statusOpts = ViewBag.StatusOptions as IEnumerable<string> ?? Enumerable.Empty<string>();
 var prefixes = ViewBag.StatusPrefixes as System.Collections.Generic.IDictionary<string,string> ?? new System.Collections.Generic.Dictionary<string,string>(System.StringComparer.OrdinalIgnoreCase);
 var orderedStatuses = statusOpts
 .Select(s => new { Status = s, Prefix = prefixes.TryGetValue(s, out var p) ? (p ?? string.Empty) : string.Empty })
 .OrderBy(x => string.IsNullOrWhiteSpace(x.Prefix) ? char.MaxValue : char.ToUpperInvariant(x.Prefix[0]))
 .ThenBy(x => x.Status, StringComparer.OrdinalIgnoreCase)
 .ToList();
 }
 @foreach(var item in orderedStatuses)
 {
 var s = item.Status; var tv = FormatForDisplay(s); var pref = !string.IsNullOrWhiteSpace(item.Prefix) ? item.Prefix + " " : string.Empty;
 <div class="status-item"><label><input type="checkbox" class="status-checkbox" data-val="@Html.Encode((s ?? string.Empty).Trim())" />@Html.Encode(pref + tv)</label></div>
 }
 </div>
 </div>
 <input type="hidden" id="statusBox" value="" />
 </div>
 <div class="field">
 <label for="dwgBox">DWG</label>
 <select id="dwgBox" class="search header-fixed w130 searchable-select">
 <option value=""></option>
 @{ var dwgOpts = ViewBag.DwgOptions as IEnumerable<string> ?? Enumerable.Empty<string>(); }
 @foreach(var d in dwgOpts) { var dv = FormatForDisplay(d); <option value="@Html.Encode((d ?? string.Empty).Trim())">@Html.Encode(dv)</option> }
 </select>
 </div>
 <div class="field">
 <label for="sheetBox">Sheet</label>
 <select id="sheetBox" class="search header-fixed w90 searchable-select" disabled>
 <option value=""></option>
 @{ var sheetOpts = ViewBag.SheetOptions as IEnumerable<string> ?? Enumerable.Empty<string>(); }
 @foreach(var s in sheetOpts) { var sh = FormatForDisplay(s); <option value="@Html.Encode((s ?? string.Empty).Trim())">@Html.Encode(sh)</option> }
 </select>
 </div>
 <div class="field">
 <label for="spoolBox">Spool</label>
 <select id="spoolBox" class="search header-fixed w110 searchable-select" disabled>
 <option value=""></option>
 @{ var spoolOpts = ViewBag.SpoolOptions as IEnumerable<string> ?? Enumerable.Empty<string>(); }
 @foreach(var sp in spoolOpts) { var spv = FormatForDisplay(sp); <option value="@Html.Encode((sp ?? string.Empty).Trim())">@Html.Encode(spv)</option> }
 </select>
 </div>

 <div class="button-wrapper">
 <button type="button" id="btnExport" class="btn btn-outline">Download</button>
 <button type="button" id="btnUpload" class="btn btn-outline">Upload</button>
 <button type="button" id="btnDownloadTemplate" class="btn btn-outline">Template</button>
 <button type="button" id="btnClear" class="btn btn-outline">Clear</button>
 </div>
 <input type="file" id="uploadExcel" accept=".xlsx,.xls,.csv" style="display:none" />
 <div id="statusSuggestions" role="listbox" aria-label="Status suggestions" hidden></div>
 </div>
 </div>

 <div class="right-controls">
 <div class="field">
 <label for="projectBox">Project</label>
 <select id="projectBox" class="search header-fixed w350 searchable-select col-project-input">
 @{ var projects = ViewBag.ProjectsSelect as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>(); var defaultPid = ViewBag.DefaultProjectId as int?; }
 @foreach(var p in projects) { var label = (p.Label ?? string.Empty).ToString(); var val = p.Id.ToString(); if(defaultPid.HasValue && p.Id == defaultPid.Value) { <option value="@Html.Encode(val)" selected>@Html.Encode(FormatForDisplay(label))</option> } else { <option value="@Html.Encode(val)">@Html.Encode(FormatForDisplay(label))</option> } }
 </select>
 </div>
 </div>
 </div>

 <div class="table-wrap">
 <table id="logTable">
 <thead>
 <tr>
 <th class="col-serial">S/N</th>
 @foreach (System.Data.DataColumn c in Model.Columns)
 {
 <th>@c.ColumnName</th>
 }
 </tr>
 </thead>
 <tbody>
 @{
 var i =0;
 }
 @foreach (System.Data.DataRow r in Model.Rows)
 {
 i++;
 <tr>
 <td class="col-serial">@i</td>
 @foreach (System.Data.DataColumn c in Model.Columns)
 {
 var val = r[c];
 if (val == null || val == System.DBNull.Value)
 {
 <td></td>
 }
 else if (val is DateTime dt)
 {
 <td class="nowrap">@dt.ToString("yyyy-MM-dd")</td>
 }
 else
 {
 // If this is a STATUS-like column, prefix the value with group letter (e.g. A-) when available
 var colName = (c.ColumnName ?? string.Empty).Trim();
 if (!string.IsNullOrEmpty(colName) && colName.IndexOf("STATUS", StringComparison.OrdinalIgnoreCase) >=0)
 {
 var sstr = val?.ToString()?.Trim() ?? string.Empty;
 var statusPrefixes = ViewBag.StatusPrefixes as System.Collections.Generic.IDictionary<string,string> ?? new System.Collections.Generic.Dictionary<string,string>(System.StringComparer.OrdinalIgnoreCase);
 var pref = statusPrefixes.TryGetValue(sstr, out var p) && !string.IsNullOrWhiteSpace(p) ? p + " " : string.Empty;
 <td>@Html.Encode(pref + FormatForDisplay(sstr))</td>
 }
 else
 {
 <td>@val</td>
 }
 }
 }
 </tr>
 }
 </tbody>
 </table>
 </div>
</div>

@section Scripts {
 <script type="application/json" id="serverSpoolMap_json">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.SpoolMap ?? new object()))</script>
 <script type="application/json" id="serverSpoolOptions_json">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.SpoolOptions ?? new string[0]))</script>
 <script src="https://cdn.jsdelivr.net/npm/xlsx/dist/xlsx.full.min.js"></script>
 <script>
 // Read server-provided JSON safely (keeps Razor markers out of JS parsing to avoid TS1109)
 function readServerJson(id, fallback){
 var el = document.getElementById(id);
 if(!el) return fallback;
 var txt = el.textContent || el.innerText || '';
 try { return txt ? JSON.parse(txt) : fallback; } catch(e) { console.error('Invalid server JSON for', id, e); return fallback; }
 }
 var serverSpoolMap = readServerJson('serverSpoolMap_json', {});
 var serverSpoolOptions = readServerJson('serverSpoolOptions_json', []);
 
 // Searchable dropdown widget: wraps a native <select> with a text input + filterable list.
 // Safe to call multiple times (e.g. after populateSelectWithItems) – re-initialises if already wrapped.
 function makeSearchableSelect(sel){
 if(!sel) return;
 // If already wrapped, just rebuild items and sync text
 if(sel._ssWidget){
 sel._ssWidget.rebuild();
 return;
 }
 sel.style.display='none';
 var wrap = document.createElement('div');
 wrap.className = 'ss-wrap';
 if(sel.classList.contains('w350')) wrap.classList.add('w350');
 else if(sel.classList.contains('w130')) wrap.classList.add('w130');
 else if(sel.classList.contains('w110')) wrap.classList.add('w110');
 else if(sel.classList.contains('w90')) wrap.classList.add('w90');
 sel.parentNode.insertBefore(wrap, sel);
 wrap.appendChild(sel);
 var input = document.createElement('input');
 input.type='text'; input.className='ss-input'; input.setAttribute('autocomplete','off'); input.setAttribute('spellcheck','false'); input.placeholder='';
 wrap.appendChild(input);
 var list = document.createElement('div'); list.className='ss-list'; wrap.appendChild(list);
 var items=[], highlighted=-1, open=false;
 function buildItems(){ items=[]; Array.from(sel.options).forEach(function(opt){ items.push({value:opt.value, text:opt.text||opt.value}); }); }
 function syncInputText(){ var idx=sel.selectedIndex; input.value=idx>=0&&sel.options[idx]?(sel.options[idx].text||sel.options[idx].value):''; }
 function render(filter){ list.innerHTML=''; highlighted=-1; var lc=(filter||'').toLowerCase(); var count=0;
 items.forEach(function(item,i){ if(lc&&!(item.text||'').toLowerCase().includes(lc)) return;
 var div=document.createElement('div'); div.className='ss-item'; div.textContent=item.text; div.dataset.idx=String(i);
 if(item.value===sel.value) div.classList.add('ss-active');
 div.addEventListener('mousedown',function(e){ e.preventDefault(); pick(i); }); list.appendChild(div); count++; });
 if(count===0){ var em=document.createElement('div'); em.className='ss-empty'; em.textContent='No match'; list.appendChild(em); } }
 function pick(idx){ if(idx<0||idx>=items.length) return; sel.value=items[idx].value; syncInputText(); close(); sel.dispatchEvent(new Event('change',{bubbles:true})); }
 function show(){ if(open) return; open=true; render(input.value!==(items[sel.selectedIndex]?items[sel.selectedIndex].text:'')?input.value:''); list.style.display='block'; wrap.classList.add('ss-open'); }
 function close(){ open=false; list.style.display='none'; wrap.classList.remove('ss-open'); highlighted=-1; }
 function highlightItem(dir){ var visible=list.querySelectorAll('.ss-item'); if(!visible.length) return;
 if(dir==='down') highlighted=highlighted<visible.length-1?highlighted+1:0; else highlighted=highlighted>0?highlighted-1:visible.length-1;
 visible.forEach(function(el,i){ el.classList.toggle('ss-highlight',i===highlighted); }); if(visible[highlighted]) visible[highlighted].scrollIntoView({block:'nearest'}); }
 input.addEventListener('focus',function(){ buildItems(); input.select(); show(); });
 input.addEventListener('input',function(){ buildItems(); show(); render(input.value); });
 input.addEventListener('keydown',function(e){
 if(e.key==='ArrowDown'){ e.preventDefault(); if(!open){show();render('');} highlightItem('down'); }
 else if(e.key==='ArrowUp'){ e.preventDefault(); highlightItem('up'); }
 else if(e.key==='Enter'){ e.preventDefault(); if(open&&highlighted>=0){ var vis=list.querySelectorAll('.ss-item'); if(vis[highlighted]){ var idx=parseInt(vis[highlighted].dataset.idx,10); pick(idx); } } }
 else if(e.key==='Escape'){ syncInputText(); close(); input.blur(); }
 else if(e.key==='Tab'){ syncInputText(); close(); } });
 input.addEventListener('blur',function(){ setTimeout(function(){ if(!wrap.contains(document.activeElement)){ syncInputText(); close(); } },150); });
 var mo=new MutationObserver(function(){ buildItems(); syncInputText(); if(open) render(input.value); });
 mo.observe(sel,{childList:true,subtree:true});
 buildItems(); syncInputText();
 sel._ssWidget={rebuild:function(){ buildItems(); syncInputText(); if(open) render(input.value); }};
 sel.dataset.searchable='1';
 }
 // Apply searchable behavior to header selects (exclude status checkbox control)
 ['dwgBox','sheetBox','spoolBox','projectBox'].forEach(function(id){ var el=document.getElementById(id); if(el) makeSearchableSelect(el); });

 // Normalization helpers
 // Normalize sheet to3 digits, preserving trailing letter: e.g. '5' -> '005', '5A' -> '005A'
 function normalizeSheetValue(v){
 if(!v && v !==0) return '';
 var s = (''+v).toString().trim();
 if(!s) return '';
 var m = s.match(/^([0-9]+)([A-Za-z])?$/);
 if(m){
 var num = m[1];
 var letter = m[2] || '';
 return num.toString().padStart(3,'0') + letter;
 }
 return s.toLowerCase().trim();
 }
 // Normalize spool to2 digits, preserving trailing letter: e.g. '5' -> '05', '5A' -> '05A'
 function normalizeSpoolValue(v){
 if(!v && v !==0) return '';
 var s = (''+v).toString().trim();
 if(!s) return '';
 var m = s.match(/^([0-9]+)([A-Za-z])?$/);
 if(m){
 var num = m[1];
 var letter = m[2] || '';
 return num.toString().padStart(2,'0') + letter;
 }
 return s.toLowerCase().trim();
 }
 // DWG normalization: strip percent wildcards used in templates like %DWG%
 function normalizeDwgValue(v){ if(!v && v !==0) return ''; return (''+v).toString().trim().replace(/%/g, ''); }

 // Small helper: trigger export with current filter selections
function getSelectedValueOrText(id){
 // For status multi-select, return comma-separated selected texts
 if(id === 'statusBox'){
 const checks = Array.from(document.querySelectorAll('#statusDropdown .status-checkbox:checked'));
 if(!checks.length) return '';
 return checks.map(cb => (cb.dataset.val || cb.value || '').trim()).join(',');
 }
 const el = document.getElementById(id);
 if(!el) return '';
 // For project, always use the option value (numeric ID) so filtering matches table Project column
 if(id === 'projectBox') return el.value || '';
 const opt = el.selectedOptions && el.selectedOptions[0];
 if(opt){ const t = (opt.text || '').trim(); if(t) return t; }
 return el.value || '';
}

 // When user changes project, reload the page with the selected project id
 function reloadForProject(sel){
 if(!sel) return;
 const val = (sel.value || '').trim();
 const url = new URL(window.location.href);
 if(val) url.searchParams.set('projectId', val); else url.searchParams.delete('projectId');
 window.location.href = url.toString();
 }
 
 // Filtering: map header names to column indices and filter tbody rows
 function buildColumnMap(){
 const map = {};
 const ths = Array.from(document.querySelectorAll('#logTable thead th'));
 ths.forEach((th, idx) => {
 const key = (th.textContent || '').trim().toLowerCase();
 if(key.includes('status')) map.status = idx;
 if(key.includes('layout') || key.includes('dwg')) map.dwg = idx;
 if(key.includes('sheet')) map.sheet = idx;
 // Prefer a SPOOL column that is not a completion/date column
 if(key.includes('spool') && !key.includes('completion') && !key.includes('complete') && !key.includes('date')) map.spool = idx;
 if(key.includes('project')) map.project = idx;
 });
 return map;
 }

 // Filter table rows based on selected filter values
 function filterTable(){
 const map = buildColumnMap();
 const statusValRaw = getSelectedValueOrText('statusBox');
 const statusVals = statusValRaw ? statusValRaw.split(',').map(s=>s.trim().toLowerCase()).filter(s=>s) : [];
 const dwgVal = getSelectedValueOrText('dwgBox').toLowerCase();
 const sheetVal = getSelectedValueOrText('sheetBox').toLowerCase();
 const spoolVal = getSelectedValueOrText('spoolBox').toLowerCase();
 const projVal = getSelectedValueOrText('projectBox').toLowerCase();
 const tbody = document.querySelectorAll('#logTable tbody tr');
 // If all filters empty, show all
 if(statusVals.length ===0 && !dwgVal && !sheetVal && !spoolVal && !projVal){ tbody.forEach(r => r.style.display = ''); return; }
 tbody.forEach(row => {
 let show = true;
 const cells = row.querySelectorAll('td');
 function match(idx, val){ if(!val) return true; if(idx === undefined) return true; const c = cells[idx]; if(!c) return false; return (c.textContent || '').trim().toLowerCase().includes(val); }
 // Status matching: when multiple selected, accept if any selected value is present in the cell
 if(statusVals.length){ const sidx = map.status; if(sidx === undefined) { show = false; } else { const c = (cells[sidx] && (cells[sidx].textContent || '').trim().toLowerCase()) || ''; if(!statusVals.some(sv => c.includes(sv))) show = false; } }
 if(!match(map.dwg, dwgVal)) show = false;
 if(!match(map.sheet, sheetVal)) show = false;
 if(!match(map.spool, spoolVal)) show = false;
 if(!match(map.project, projVal)) show = false;
 row.style.display = show ? '' : 'none';
 });
 }

 // Helper: extract unique spools from table SPOOL column
 function getSpoolsFromTable(){
 const map = buildColumnMap();
 let spoolIdx = map.spool;
 // Fallback: if buildColumnMap didn't detect spool column, scan header cells for 'spool' but avoid completion/date columns
 if (spoolIdx === undefined) {
 const ths = Array.from(document.querySelectorAll('#logTable thead th'));
 for (let i =0; i < ths.length; i++){
 const key = (ths[i].textContent || '').trim().toLowerCase();
 if (key.includes('spool') && !key.includes('completion') && !key.includes('complete') && !key.includes('date')) { spoolIdx = i; break; }
 }
 }
 const rows = Array.from(document.querySelectorAll('#logTable tbody tr'));
 const set = new Set();
 if (spoolIdx === undefined) return [];
 rows.forEach(r => {
 const cells = r.querySelectorAll('td');
 const td = cells[spoolIdx];
 const spool = (td && (td.textContent || '').trim()) || '';
 if(spool) set.add(spool);
 });
 return Array.from(set).sort((a,b)=> a.localeCompare(b));
 }

 // Build DWG -> Sheet -> Spool hierarchy from table rows (fallback only)
 function buildHierarchyFromTable(){
 const map = buildColumnMap();
 const dwgIdx = map.dwg, sheetIdx = map.sheet, spoolIdx = map.spool;
 const rows = Array.from(document.querySelectorAll('#logTable tbody tr'));
 const hierarchy = { }; // dwg -> sheet -> Set(spools)
 rows.forEach(r => {
 const cells = r.querySelectorAll('td');
 const dwg = (cells[dwgIdx] && (cells[dwgIdx].textContent || '').trim()) || '';
 const sheet = (cells[sheetIdx] && (cells[sheetIdx].textContent || '').trim()) || '';
 const spool = (cells[spoolIdx] && (cells[spoolIdx].textContent || '').trim()) || '';
 // include rows that have spool even when dwg missing (so spools without DWG are not lost)
 if(!dwg && !spool) return;
 const key = dwg || '__NO_DWG__';
 if(!hierarchy[key]) hierarchy[key] = { sheets: {}, spools: new Set() };
 if(sheet){ hierarchy[key].sheets[sheet] = hierarchy[key].sheets[sheet] || new Set(); if(spool) hierarchy[key].sheets[sheet].add(spool); }
 if(spool) hierarchy[key].spools.add(spool);
 });
 // Convert sets to arrays for easier consumption
 Object.keys(hierarchy).forEach(d => {
 const s = hierarchy[d]; s.spools = Array.from(s.spools).sort((a,b)=> a.localeCompare(b));
 Object.keys(s.sheets).forEach(sh => { s.sheets[sh] = Array.from(s.sheets[sh]).sort((a,b)=> a.localeCompare(b)); });
 s.sheetList = Object.keys(s.sheets).sort((a,b)=> a.localeCompare(b));
 });
 return hierarchy;
 }

