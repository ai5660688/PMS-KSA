 function applyUploadFilter(uploaded){
 // uploaded: array of { dwg, sheet, spool }
 const map = buildColumnMap();
 const dwgIdx = map.dwg, sheetIdx = map.sheet, spoolIdx = map.spool;
 const rows = Array.from(document.querySelectorAll('#logTable tbody tr'));
 rows.forEach(tr => {
 const cells = tr.querySelectorAll('td');
 const rawDwg = (dwgIdx !== undefined && cells[dwgIdx]) ? (cells[dwgIdx].textContent || '').trim() : '';
 const rawSheet = (sheetIdx !== undefined && cells[sheetIdx]) ? (cells[sheetIdx].textContent || '').trim() : '';
 const rawSpool = (spoolIdx !== undefined && cells[spoolIdx]) ? (cells[spoolIdx].textContent || '').trim() : '';
 let show = false; // start hidden; show if any uploaded row matches this table row

 // normalize table row values
 const rowDwgNorm = normalizeDwgValue(rawDwg).toLowerCase();
 const rowSheetNorm = normalizeSheetValue(rawSheet).toLowerCase();
 const rowSpoolNorm = normalizeSpoolValue(rawSpool).toLowerCase();

 // For each uploaded triple, check all non-empty fields must match the row
 for(let j=0;j<uploaded.length;j++){
 const u = uploaded[j] || {};
 // DWG: if provided, allow substring contains either side
 let okDwg = true;
 if(u.dwg){
 const uD = (''+u.dwg).toLowerCase();
 if(!rowDwgNorm || (!rowDwgNorm.includes(uD) && !uD.includes(rowDwgNorm))) okDwg = false;
 }
 // SHEET: if provided, must equal normalized form
 let okSheet = true;
 if(u.sheet){
 const uS = (''+u.sheet).toLowerCase();
 if(uS !== rowSheetNorm) okSheet = false;
 }
 // SPOOL: if provided, must equal normalized form
 let okSpool = true;
 if(u.spool){
 const uSp = (''+u.spool).toLowerCase();
 if(uSp !== rowSpoolNorm) okSpool = false;
 }
 if(okDwg && okSheet && okSpool){ show = true; break; }
 }
 tr.style.display = show ? '' : 'none';
 });
 }

