 // Function to compute and set optimal width for a select based on its longest option text
 function resizeSelectToContent(sel){
 if(!sel) return;
 // When the searchable widget is active, resize the wrapper instead
 var target = sel._ssWidget ? sel.closest('.ss-wrap') : sel;
 if(!target) return;
 // create a hidden measurement element using the select/input font
 const meas = document.createElement('span');
 var measureEl = sel._ssWidget ? target.querySelector('.ss-input') || target : sel;
 const selStyles = window.getComputedStyle(measureEl);
 meas.style.font = selStyles.font || (selStyles.fontSize + ' ' + selStyles.fontFamily);
 meas.style.visibility = 'hidden';
 meas.style.whiteSpace = 'nowrap';
 meas.style.position = 'absolute';
 meas.style.left = '-9999px';
 document.body.appendChild(meas);
 let maxW =0;
 for(let i=0;i<sel.options.length;i++){
 meas.textContent = sel.options[i].text || sel.options[i].value || '';
 const w = meas.getBoundingClientRect().width;
 if(w > maxW) maxW = w;
 }
 document.body.removeChild(meas);
 // compute extra space for padding, borders and dropdown arrow
 const padLeft = parseFloat(selStyles.paddingLeft ||0);
 const padRight = parseFloat(selStyles.paddingRight ||0);
 const borderLeft = parseFloat(selStyles.borderLeftWidth ||0);
 const borderRight = parseFloat(selStyles.borderRightWidth ||0);
 // add extra for native dropdown arrow / caret ~28px
 const extra =28;
 const total = Math.ceil(maxW + padLeft + padRight + borderLeft + borderRight + extra);
 // constrain within reasonable bounds
 const minW =72; const maxWAllowed =600;
 const finalW = Math.max(minW, Math.min(maxWAllowed, total));
 target.style.width = finalW + 'px';
 }

