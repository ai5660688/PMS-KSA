@* Plan:
   - Replace Razor values on the <script> tag with a hidden element carrying data-* attributes.
   - Read values from that element in JS to avoid TS parsing attributes on the <script> tag.
   - Keep the rest of the file unchanged.
*@
@{
    Layout = null;
    var message = ViewBag.Message ?? "Please wait...";
    var returnUrl = ViewBag.ReturnUrl ?? Url.Action("Dashboard", "Home");
    var returnText = ViewBag.ReturnText ?? "Continue";
    var delayMs = ViewBag.DelayMs ?? 500; // reduced from 2000ms
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>PMS - Loading</title>
    <link rel="icon" type="image/png" href="~/img/title_logo.png">
    <link rel="stylesheet" href="~/css/LoadingToLDashboardStyle.css">
    <!-- Prefetch the destination to speed up navigation -->
    <link rel="prefetch" href="@returnUrl" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        .loading-wrap { max-width: 900px; margin: 0 auto; background:#fff; border-radius:12px; padding:24px; box-shadow:0 10px 30px rgba(0,0,0,0.08); }
        .center { text-align:center; }
        .spinner { width:64px; height:64px; border:6px solid #e9eef5; border-top-color:#1769aa; border-radius:50%; margin:16px auto 24px; animation:spin 1s linear infinite; }
        /* In Razor, escape at-rules with a double at-sign (e.g., @@keyframes) */
        @@keyframes spin {
            to { transform: rotate(360deg); }
        }
        /* Removed .btn styles as the button is no longer rendered */
    </style>
</head>
<body>
    <h1>
        <img src="~/img/PMS_logo.png" alt="Logo" class="main-logo">
    </h1>

    <div class="container-wrapper">
        <div class="loading-wrap">
            <div class="center">
                <img src="~/img/jafurah.jpg" alt="Jafurah" class="project-image" />
                <div class="spinner"></div>
                <h2>@message</h2>
                @* "Go to Dashboard" button removed *@
            </div>
        </div>
    </div>

    <div class="footer">
        <div class="footer-center">
            This system is strictly restricted to authorized users only.<br>
            © 2025 Piping Management System. All rights reserved.
        </div>
        <div class="footer-right">
            <img src="~/img/work-smarter-not-harder.jpg?v=3" alt="Logo" class="footer-logo" />
        </div>
    </div>

    <span id="redirect-data" data-delay="@delayMs" data-return-url="@returnUrl" hidden></span>
    <script>
        (function () {
            const el = document.getElementById('redirect-data');
            const delay = parseInt((el?.dataset.delay ?? '0'), 10) || 0;
            const url = el?.dataset.returnUrl || '/';
            const go = () => window.location.replace(url);
            if (delay <= 0) go();
            else setTimeout(go, delay);
        })();
    </script>
</body>
</html>