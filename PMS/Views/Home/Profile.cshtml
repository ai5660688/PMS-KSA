@model PMS.Models.PMSLogin
@{
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
    ViewData["Title"] = "My Profile";
    var successMsg = TempData["ProfileMessage"] as string;
    var errorMsg = TempData["ProfileError"] as string;
}

@section Head {
<style>
    /* ===== Container ===== */
    .profile-container {
        max-width: 660px;
        margin: 36px auto;
        background: #faf2e3;
        border: 1px solid #e6d9bc;
        border-radius: 10px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.12);
        padding: 36px 40px 32px 40px;
    }

    /* ===== Title / Avatar Area ===== */
    .profile-header {
        text-align: center;
        margin-bottom: 28px;
    }
    .profile-avatar {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background: linear-gradient(135deg, #1f99be, #176d8a);
        color: #fff;
        font-size: 1.8em;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 12px auto;
        text-transform: uppercase;
        letter-spacing: 1px;
        box-shadow: 0 3px 10px rgba(31,153,190,0.25);
    }
    .profile-title {
        color: #176d8a;
        font-size: 1.6em;
        font-weight: 700;
        margin: 0;
    }
    .profile-title-sub {
        color: #888;
        font-size: 0.92em;
        margin-top: 2px;
    }

    /* ===== Messages ===== */
    .profile-msg {
        text-align: center;
        padding: 10px 14px;
        border-radius: 6px;
        margin-bottom: 20px;
        font-weight: 600;
        font-size: 0.95em;
    }
    .profile-msg.success { background: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
    .profile-msg.error   { background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }

    /* ===== Section Headers ===== */
    .profile-section-title {
        color: #176d8a;
        font-size: 1.1em;
        font-weight: 700;
        margin: 0 0 18px 0;
        padding-bottom: 8px;
        border-bottom: 2px solid #1f99be;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .profile-section-title .section-icon {
        font-size: 1.15em;
    }

    /* ===== Read-only Info Grid ===== */
    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px 24px;
        margin-bottom: 20px;
    }
    .info-item {}
    .info-item .info-label {
        color: #176d8a;
        font-weight: 600;
        font-size: 0.85em;
        text-transform: uppercase;
        letter-spacing: 0.4px;
        margin-bottom: 3px;
    }
    .info-item .info-value {
        padding: 8px 10px;
        background: #eef7fa;
        border: 1px solid #d4e9f0;
        border-radius: 6px;
        color: #444;
        font-size: 0.97em;
        min-height: 20px;
    }

    /* ===== Editable Form Fields ===== */
    .form-row {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 14px;
    }
    .form-row label {
        flex: 0 0 130px;
        color: #176d8a;
        font-weight: 600;
        font-size: 0.97em;
        text-align: left;
    }
    .form-row input[type="text"],
    .form-row input[type="email"],
    .form-row input[type="password"] {
        flex: 1 1 auto;
        min-width: 0;
        padding: 9px 11px;
        border: 1.5px solid #176d8a;
        border-radius: 5px;
        font-size: 1em;
        color: #176d8a;
        background: #fff;
        box-sizing: border-box;
        transition: border-color 0.3s, box-shadow 0.3s;
    }
    .form-row input:focus {
        border-color: #1f99be;
        box-shadow: 0 0 8px rgba(31,153,190,0.3);
        outline: none;
    }

    /* ===== Divider ===== */
    .profile-divider {
        border: none;
        border-top: 1px dashed #c4b99b;
        margin: 28px 0 24px 0;
    }

    /* ===== Buttons ===== */
    .profile-actions {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 22px;
    }
    .btn-save {
        min-width: 170px;
        padding: 11px 24px;
        background: #1f99be;
        color: #fff;
        border: none;
        border-radius: 5px;
        font-size: 1.05em;
        font-weight: 700;
        cursor: pointer;
        box-shadow: 0 3px 8px rgba(31,153,190,0.25);
        transition: background 0.3s, transform 0.2s, box-shadow 0.3s;
    }
    .btn-save:hover {
        background: #176d8a;
        transform: translateY(-2px);
        box-shadow: 0 5px 12px rgba(31,153,190,0.35);
    }
    .btn-save:active { transform: translateY(0); }
    .btn-back {
        color: #1f99be;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.97em;
        transition: color 0.2s;
    }
    .btn-back:hover { color: #176d8a; text-decoration: underline; }

    /* ===== Password Rules (matches SignUp) ===== */
    .password-rules {
        width: 100%;
        margin: 6px 0 0 144px;
        padding-left: 18px;
        font-size: 0.88em;
        color: #6b7280;
    }
    .password-rules li { list-style: disc; }
    .password-rules li.valid { color: #3c763d; font-weight: bold; }
    .password-rules li.invalid { color: #a94442; }

    /* ===== Password Mismatch (matches SignUp) ===== */
    .password-match-error {
        color: #ED1E4D;
        font-size: 0.88em;
        display: none;
        margin: 6px 0 0 144px;
        text-decoration: underline;
        font-style: italic;
        font-weight: bold;
    }

    .form-row.confirm-password { margin-bottom: 24px; }
    .form-row.confirm-password.has-error { margin-bottom: 8px; }

    /* ===== Responsive ===== */
    @@media (max-width: 600px) {
        .profile-container { padding: 20px 16px 20px 16px; margin: 16px 8px; }
        .info-grid { grid-template-columns: 1fr; gap: 10px; }
        .form-row { flex-direction: column; align-items: stretch; gap: 4px; }
        .form-row label { flex: none; }
        .password-rules, .password-match-error { margin-left: 0; }
    }
</style>
}

@{
    var initials = "";
    var fn = (Model.FirstName ?? "").Trim();
    var ln = (Model.LastName ?? "").Trim();
    if (fn.Length > 0) initials += fn[0];
    if (ln.Length > 0) initials += ln[0];
    if (string.IsNullOrEmpty(initials)) initials = "?";
}

<div class="profile-container">
    <!-- Header with avatar -->
    <div class="profile-header">
        <div class="profile-avatar">@initials</div>
        <div class="profile-title">@fn @ln</div>
        <div class="profile-title-sub">@Model.Position</div>
    </div>

    @if (!string.IsNullOrWhiteSpace(successMsg))
    {
        <div class="profile-msg success">@successMsg</div>
    }
    @if (!string.IsNullOrWhiteSpace(errorMsg))
    {
        <div class="profile-msg error">@errorMsg</div>
    }

    <!-- ===== Account Information (read-only) ===== -->
    <div class="profile-section-title"><span class="section-icon">&#128100;</span> Account Information</div>
    <div class="info-grid">
        <div class="info-item">
            <div class="info-label">Username</div>
            <div class="info-value">@Model.UserName</div>
        </div>
        <div class="info-item">
            <div class="info-label">First Name</div>
            <div class="info-value">@(Model.FirstName ?? "—")</div>
        </div>
        <div class="info-item">
            <div class="info-label">Last Name</div>
            <div class="info-value">@(Model.LastName ?? "—")</div>
        </div>
        <div class="info-item">
            <div class="info-label">Company</div>
            <div class="info-value">@(Model.Company ?? "—")</div>
        </div>
        <div class="info-item">
            <div class="info-label">Member Since</div>
            <div class="info-value">@(Model.CreatedDate?.ToString("dd MMM yyyy") ?? "—")</div>
        </div>
    </div>

    <hr class="profile-divider" />

    <!-- ===== Edit Details ===== -->
    <div class="profile-section-title"><span class="section-icon">&#9998;</span> Edit Details</div>
    <form asp-action="ProfileUpdate" asp-controller="Home" method="post">
        @Html.AntiForgeryToken()

        <div class="form-row">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" value="@Model.Email" maxlength="50" />
        </div>

        <div class="form-row">
            <label for="position">Position</label>
            <input type="text" id="position" name="position" value="@Model.Position" maxlength="50" />
        </div>

        <div class="profile-actions">
            <a asp-action="Dashboard" asp-controller="Home" class="btn-back">&#8592; Back to Dashboard</a>
            <button type="submit" class="btn-save">Save Changes</button>
        </div>
    </form>

    <hr class="profile-divider" />

    <!-- ===== Change Password ===== -->
    <div class="profile-section-title"><span class="section-icon">&#128274;</span> Change Password</div>
    <form id="pwdForm" asp-action="ChangePassword" asp-controller="Home" method="post">
        @Html.AntiForgeryToken()

        <div class="form-row">
            <label for="currentPassword">Current Password</label>
            <input type="password" id="currentPassword" name="currentPassword" required autocomplete="current-password" />
        </div>

        <div class="form-row" style="flex-wrap:wrap;">
            <label for="newPassword">New Password</label>
            <input
                type="password"
                id="newPassword"
                name="newPassword"
                minlength="8"
                maxlength="20"
                autocomplete="new-password"
                pattern="^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[^\da-zA-Z])(?=\S+$).{8,20}$"
                required />
            <ul class="password-rules" id="pwdRules">
                <li data-rule="length">8–20 characters</li>
                <li data-rule="upper">At least one uppercase letter (A–Z)</li>
                <li data-rule="lower">At least one lowercase letter (a–z)</li>
                <li data-rule="digit">At least one number (0–9)</li>
                <li data-rule="special">At least one special character (!&#64;&#35;&#36;&hellip;)</li>
                <li data-rule="space">No spaces</li>
            </ul>
        </div>

        <div class="form-row confirm-password" style="flex-wrap:wrap;">
            <label for="confirmPassword">Confirm Password</label>
            <input type="password" id="confirmPassword" name="confirmPassword" maxlength="20" autocomplete="new-password" required />
            <p id="passwordMismatch" class="password-match-error">Passwords do not match.</p>
        </div>

        <div class="profile-actions">
            <span></span>
            <button type="submit" class="btn-save">Change Password</button>
        </div>
    </form>
</div>

@section Scripts {
<script>
    (function () {
        var pwd = document.getElementById('newPassword');
        var cpwd = document.getElementById('confirmPassword');
        var msg = document.getElementById('passwordMismatch');
        var group = document.querySelector('.form-row.confirm-password');
        var form = document.getElementById('pwdForm');
        var rulesList = document.getElementById('pwdRules');
        var rules = {
            length: function (v) { return v.length >= 8 && v.length <= 20; },
            upper:  function (v) { return /[A-Z]/.test(v); },
            lower:  function (v) { return /[a-z]/.test(v); },
            digit:  function (v) { return /\d/.test(v); },
            special:function (v) { return /[^\da-zA-Z]/.test(v); },
            space:  function (v) { return !/\s/.test(v); }
        };

        function updateRules() {
            if (!pwd || !rulesList) return true;
            var val = pwd.value || '';
            var ok = true;
            Object.keys(rules).forEach(function (key) {
                var li = rulesList.querySelector('li[data-rule="' + key + '"]');
                var pass = rules[key](val);
                if (li) { li.classList.toggle('valid', pass); li.classList.toggle('invalid', !pass); }
                ok = ok && pass;
            });
            return ok;
        }

        function validateMatch() {
            if (!pwd || !cpwd || !msg) return true;
            var same = pwd.value === cpwd.value;
            msg.style.display = same ? 'none' : 'block';
            if (group) group.classList.toggle('has-error', !same);
            return same;
        }

        if (pwd) pwd.addEventListener('input', function () { updateRules(); validateMatch(); });
        if (cpwd) cpwd.addEventListener('input', validateMatch);

        if (form) {
            form.addEventListener('submit', function (e) {
                var passOk = updateRules();
                var matchOk = validateMatch();
                if (!passOk || !matchOk) e.preventDefault();
            });
        }
        updateRules();
    })();
</script>
}
