@model PMS.Models.DwgFile
@{
 Layout = "_LayoutDashboard";
 ViewData["Title"] = "Edit Drawing";
}

@section Head {
 <style>
 h1 { color:#176d8a; }
 .layout { width:90%; margin:20px auto; }
 .card { background:#fff; padding:18px 20px 20px; border-radius:8px; box-shadow:02px 6px rgba(0,0,0,.1); }
 .row { display:flex; gap:14px; flex-wrap:wrap; }
 .form-field { display:flex; flex-direction:column; margin-bottom:12px; min-width:260px; }
 label { font-weight:600; color:#176d8a; margin-bottom:6px; }
 input[type="text"], input[type="number"], select { padding:8px 10px; border:1px solid #cce7ef; border-radius:4px; }
 .actions { display:flex; gap:10px; margin-top:14px; }
 .btn { padding:6px 12px; border:none; border-radius:4px; cursor:pointer; font-weight:600; text-decoration:none; }
 .btn-primary { background:#1f99be; color:#fff; }
 .btn-outline { background:#fff; color:#176d8a; border:1px solid #1f99be; }
 .meta { color:#176d8a; margin-bottom:12px; }
 .small { font-size:.85rem; color:#5a7f8e; }
 </style>
}

<div class="layout">
 <h1>Edit Drawing</h1>
 <div class="card">
 <div class="meta small">
 Project: @ViewBag.ProjectId | Mode: @ViewBag.Mode | Layout: @ViewBag.Layout @if (ViewBag.Mode as string == "Sheet") {<text>| Sheet: @ViewBag.Sheet</text>}
 </div>
 <form asp-action="EditDrawing" asp-controller="Home" method="post">
 @Html.AntiForgeryToken()
 <input type="hidden" name="id" value="@Model.Id" />
 <div class="row">
 <div class="form-field">
 <label for="fileName">File Name</label>
 <input id="fileName" name="fileName" type="text" value="@Model.FileName" maxlength="100" />
 </div>
 <div class="form-field">
 <label for="revisionTag">Revision Tag</label>
 <input id="revisionTag" name="revisionTag" type="text" value="@Model.RevisionTag" maxlength="20" />
 </div>
 </div>
 <div class="actions">
 <button type="submit" class="btn btn-primary">Save</button>
 <a class="btn btn-outline" href="@Url.Action("Drawings","Home", new { projectId = ViewBag.ProjectId, layout = ViewBag.Layout, sheet = ViewBag.Sheet })">Cancel</a>
 </div>
 </form>
 </div>
</div>
