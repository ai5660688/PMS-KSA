 var uploaded=[]; for(var i=1;i<rows.length;i++){ var r = rows[i]||[]; var d = idxD>=0 && r[idxD] !== undefined && (''+r[idxD]).trim() ? normalizeDwgValue((''+r[idxD]).trim()) : ''; var s = idxS>=0 && r[idxS] !== undefined && (''+r[idxS]).trim() ? normalizeSheetValue((''+r[idxS]).trim()) : ''; var sp = idxSp>=0 && r[idxSp] !== undefined && (''+r[idxSp]).trim() ? normalizeSpoolValue((''+r[idxSp]).trim()) : ''; if(d||s||sp) uploaded.push({ dwg: d, sheet: s, spool: sp }); }
 if(!uploaded.length){ alert('No DWG/SHEET/SPOOL data found'); return; } applyUploadFilter(uploaded);
 }catch(err){ console.error(err); alert('Failed to parse file'); } }; rdr2.readAsText(f,'utf-8'); }
