 // CSV parser
 function parseCSV(text){ var rows=[]; var row=[]; var cur=''; var inQuotes=false; for(var i=0;i<text.length;i++){ var ch = text[i]; if(ch==='"'){ if(inQuotes && text[i+1]==='"'){ cur+='"'; i++; } else { inQuotes = !inQuotes; } } else if(ch==='\n' || ch==='\r'){ if(inQuotes){ cur += ch; } else { row.push(cur); cur=''; if(ch==='\r' && text[i+1]==='\n'){ i++; } if(row.length>0){ rows.push(row); row = []; } } } else if((ch===','||ch===';'||ch==='\t') && !inQuotes){ row.push(cur); cur=''; } else { cur += ch; } } if(cur!=='' || row.length){ row.push(cur); rows.push(row); } return rows.map(function(r){ return r.map(function(c){ return (''+(c||'')).trim(); }); }).filter(function(r){ return r.length>0 && r.some(function(c){ return c !== ''; }); }); }

