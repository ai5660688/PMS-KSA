@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model System.Data.DataTable
@{
 Layout = "_LayoutDashboard";
 ViewData["Title"] = "Painting Log";

 string FormatForDisplay(string? raw)
 {
 if (string.IsNullOrWhiteSpace(raw)) return string.Empty;
 var v = raw.Trim();
 if (DateTime.TryParse(v, out var dtv)) return dtv.ToString("yyyy-MM-dd");
 if (int.TryParse(v, out _)) return v;
 if (double.TryParse(v, out _)) return v;
 return v;
 }
}

@section Head {
 <link rel="stylesheet" href="/css/spoolReleaseLog.css" />
 <style>
 /* Consolidated header style with suitable bottom spacing */
 h1 {
 color: #176d8a;
 font-size:1.4rem; /* increased for better visibility */
 line-height:1.2;
 margin:0 0 24px 0; /* top and bottom margins equal */
 font-weight:700;
 letter-spacing:0.2px;
 }

 .toolbar {
 margin-bottom:12px;
 display: flex;
 gap:10px;
 align-items: center;
 flex-wrap: wrap;
 }

 .spool-layout {
 width:98%;
 margin:14px auto 0;
 padding:14px 14px 0;
 box-sizing: border-box;
 max-width:1500px;
 }

 .table-wrap {
 overflow: auto;
 -webkit-overflow-scrolling: touch;
 max-width:100%;
 max-height:495px;
 margin:0;
 padding:0;
 background: #fff;
 }

 .table-wrap::-webkit-scrollbar { height:18px; width:18px; }
 .table-wrap::-webkit-scrollbar-track { background: #f0fbff; }
 .table-wrap::-webkit-scrollbar-thumb { background: #176d8a; border-radius:10px; border:4px solid #fff; }
 .table-wrap::-webkit-scrollbar-thumb:hover { background: #125a6e; }
 .table-wrap { scrollbar-width: auto; scrollbar-color: #176d8a #f0fbff; }

 .search, .searchable-select {
 font-family: inherit;
 font-size: .95rem;
 color: #176d8a;
 background: #fff;
 border:1px solid #e6f6fa;
 padding:4px 8px;
 line-height:1.4;
 -webkit-appearance: none;
 appearance: none;
 border-radius:4px;
 box-sizing: border-box;
 display: inline-block;
 }
 select.searchable-select option { font-family: inherit; font-size: .86rem; color: #176d8a; white-space: nowrap; }
 .searchable-select:focus, .searchable-select:active { border-color: #000 !important; box-shadow:02px rgba(0,0,0,0.06); outline: none; }
 select.searchable-select::-webkit-scrollbar { width:12px; height:12px; }
 select.searchable-select::-webkit-scrollbar-thumb { background: #176d8a; border-radius:8px; border:3px solid #fff; }
 select.searchable-select::-webkit-scrollbar-thumb:hover { background: #125a6e; }
 select.searchable-select { scrollbar-width: thin; scrollbar-color: #176d8a #f0fbff; }

 table { width: auto; max-width:100%; border-collapse: collapse; background: #fff; box-shadow: none; table-layout: auto; margin:0; border-bottom: none; border-spacing:0; }
 thead, tbody, tr, th, td { margin:0; }
 th, td { padding:6px 8px; border:1px solid #e6f6fa; font-size: .86rem; box-sizing: border-box; white-space: nowrap; }
 tbody tr:last-child td { padding-bottom:0; }
 td.wrap { white-space: normal; }
 th { background: #f0fbff; text-align: left; position: sticky; top:0; z-index:3; }
 tr:hover { background: #f8fcff; }
 .btn { padding:6px 12px; border: none; border-radius:4px; cursor: pointer; font-weight:600; text-decoration: none; }
 .btn-outline { background: #fff; color: #176d8a; border:1px solid #1f99be; }
 .btn-outline:hover { background:#1f99be; color:#fff; }
 a.btn, a.btn:link, a.btn:visited, a.btn:hover, a.btn:focus, a.btn:active { text-decoration:none; }
 .search { padding:4px 8px; border:1px solid #cce7ef; border-radius:4px; font-size: .9rem; }
 .mono { font-family: Consolas, Monaco, monospace; font-size: .8rem; }
 .col-serial { width:55px; text-align: center; font-weight:600; }
 .header-fixed { vertical-align: middle; }
 .w110 { width:110px; } .w130 { width:130px; } .w90 { width:90px; } .w350 { width:350px; }
 .searchable-select { -webkit-appearance: auto; appearance: auto; }
 .nowrap { white-space: nowrap; }
 .filters { display: flex; gap:8px; align-items: center; flex-wrap: wrap; }
 .filters .field { display: flex; gap:6px; align-items: center; }
 .filters label { font-size: .78rem; color: #176d8a; font-weight:600; margin-right:6px; }
 .right-controls { margin-left: auto; }
.status-dropdown {
 display: none;
 position: absolute;
 left:0;
 top:34px;
 background: #fff;
 border:1px solid #e6f6fa;
 padding:0;
 max-height:260px;
 overflow: auto;
 min-width:260px;
 z-index:1200;
 box-sizing: border-box;
 }
 .status-dropdown .status-item {
 padding:6px 8px;
 border-bottom:1px solid #e6f6fa;
 display: flex;
 align-items: center;
 gap:8px;
 font-size: .86rem;
 color: #176d8a;
 background: #fff;
 }
 .status-dropdown .status-item:last-child { border-bottom: none; }
 .status-dropdown label { cursor: pointer; width:100%; }
 .status-checkbox { width:16px; height:16px; accent-color: #176d8a; margin-right:8px; }
 .status-dropdown::-webkit-scrollbar { width:12px; height:12px; }
 .status-dropdown::-webkit-scrollbar-track { background: #f0fbff; }
 .status-dropdown::-webkit-scrollbar-thumb { background: #176d8a; border-radius:8px; border:3px solid #fff; }
 .status-dropdown::-webkit-scrollbar-thumb:hover { background: #125a6e; }
 .status-dropdown { scrollbar-width: thin; scrollbar-color: #176d8a #f0fbff; }
 @@media (max-width:1200px) { .status-layout { grid-template-columns:1fr; } .right-col .chart-grid { grid-template-columns:1fr; } .chart-box { height:220px; } .chart-box.sm { height:220px; } .chart-card.full-width .chart-box { height:320px; } }
 @@media (max-width:900px) { .filters { flex-direction: column; align-items: flex-start; gap:6px; } .right-controls { margin-left:0; width:100%; } .button-wrapper { display: flex; flex-direction: row; flex-wrap: wrap; gap:10px; margin-top:10px; } .w350 { width:100%; } .w110, .w130, .w90 { width: auto; } table { min-width:0; } th, td { font-size: .95rem; white-space: normal; } }
 </style>
}

<div class="spool-layout">
 <h1>Painting Log</h1>
 <div class="toolbar">
 <div class="filters">
 <div class="field"><label for="statusBox">Status</label>
 <div style="position:relative; display:inline-block">
 <button type="button" id="statusToggle" class="search header-fixed w110 searchable-select" aria-expanded="false">Status <span id="statusCount" style="font-weight:600; margin-left:6px;">(0)</span></button>
 <div id="statusDropdown" class="status-dropdown">
 @{ 
 var statusOpts = ViewBag.StatusOptions as IEnumerable<string> ?? Enumerable.Empty<string>();
 var prefixes = ViewBag.StatusPrefixes as System.Collections.Generic.IDictionary<string,string> ?? new System.Collections.Generic.Dictionary<string,string>(System.StringComparer.OrdinalIgnoreCase);
 var orderedStatuses = statusOpts
 .Select(s => new { Status = s, Prefix = prefixes.TryGetValue(s, out var p) ? (p ?? string.Empty) : string.Empty })
 .OrderBy(x => string.IsNullOrWhiteSpace(x.Prefix) ? char.MaxValue : char.ToUpperInvariant(x.Prefix[0]))
 .ThenBy(x => x.Status, StringComparer.OrdinalIgnoreCase)
 .ToList();
 }
 @foreach(var item in orderedStatuses)
 {
 var s = item.Status; var tv = FormatForDisplay(s); var pref = !string.IsNullOrWhiteSpace(item.Prefix) ? item.Prefix + " " : string.Empty;
 <div class="status-item"><label><input type="checkbox" class="status-checkbox" data-val="@Html.Encode((s ?? string.Empty).Trim())" />@Html.Encode(pref + tv)</label></div>
 }
 </div>
 </div>
 <input type="hidden" id="statusBox" value="" />
 </div>
 <div class="field"><label for="dwgBox">DWG</label>
 <select id="dwgBox" class="search header-fixed w130 searchable-select">
 <option value=""></option>
 @{ var dwgOpts = ViewBag.DwgOptions as IEnumerable<string> ?? Enumerable.Empty<string>(); }
 @foreach(var d in dwgOpts) { var dv = FormatForDisplay(d); <option value="@Html.Encode((d ?? string.Empty).Trim())">@Html.Encode(dv)</option> }
 </select>
 </div>

 <div class="field"><label for="sheetBox">Sheet</label>
 <select id="sheetBox" class="search header-fixed w90 searchable-select" disabled>
 <option value=""></option>
 @{ var sheetOpts = ViewBag.SheetOptions as IEnumerable<string> ?? Enumerable.Empty<string>(); }
 @foreach(var s in sheetOpts) { var sh = FormatForDisplay(s); <option value="@Html.Encode((s ?? string.Empty).Trim())">@Html.Encode(sh)</option> }
 </select>
 </div>

 <div class="field"><label for="spoolBox">Spool</label>
 <select id="spoolBox" class="search header-fixed w110 searchable-select" disabled>
 <option value=""></option>
 @{ var spoolOpts = ViewBag.SpoolOptions as IEnumerable<string> ?? Enumerable.Empty<string>(); }
 @foreach(var sp in spoolOpts) { var spv = FormatForDisplay(sp); <option value="@Html.Encode((sp ?? string.Empty).Trim())">@Html.Encode(spv)</option> }
 </select>
 </div>

 <div class="button-wrapper">
 <button type="button" id="btnExport" class="btn btn-outline">Download</button>
 <button type="button" id="btnUpload" class="btn btn-outline">Upload</button>
 <button type="button" id="btnDownloadTemplate" class="btn btn-outline">Template</button>
 <button type="button" id="btnClear" class="btn btn-outline">Clear</button>
 </div>

 <input type="file" id="uploadExcel" accept=".xlsx,.xls,.csv" style="display:none" />
 </div>

 <div class="right-controls">
 <div class="field"><label for="projectBox">Project</label>
 <select id="projectBox" class="search header-fixed w350 searchable-select col-project-input">
 @{ var projects = ViewBag.ProjectsSelect as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>(); var defaultPid = ViewBag.DefaultProjectId as int?; }
 @foreach(var p in projects) { var label = (p.Label ?? string.Empty).ToString(); var val = p.Id.ToString(); if(defaultPid.HasValue && p.Id == defaultPid.Value) { <option value="@Html.Encode(val)" selected>@Html.Encode(FormatForDisplay(label))</option> } else { <option value="@Html.Encode(val)">@Html.Encode(FormatForDisplay(label))</option> } }
 </select>
 </div>
 </div>
 </div>

 <div class="table-wrap">
 <table id="logTable">
 <thead>
 <tr>
 <th class="col-serial">S/N</th>
 @foreach (System.Data.DataColumn c in Model.Columns)
 {
 <th>@c.ColumnName</th>
 }
 </tr>
 </thead>
 <tbody>
 @{ var i =0; }
 @foreach (System.Data.DataRow r in Model.Rows)
 {
 i++;
 <tr>
 <td class="col-serial">@i</td>
 @foreach (System.Data.DataColumn c in Model.Columns)
 {
 var val = r[c];
 if (val == null || val == System.DBNull.Value)
 {
 <td></td>
 }
 else if (val is DateTime dt)
 {
 <td class="nowrap">@dt.ToString("yyyy-MM-dd")</td>
 }
 else
 {
 <td>@val</td>
 }
 }
 </tr>
 }
 </tbody>
 </table>
 </div>
</div>

@section Scripts {
 <script type="application/json" id="serverSpoolMap_json">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.SpoolMap ?? new object()))</script>
 <script type="application/json" id="serverSpoolOptions_json">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.SpoolOptions ?? new string[0]))</script>
 <script src="https://cdn.jsdelivr.net/npm/xlsx/dist/xlsx.full.min.js"></script>
 <script>
 (function(){
 // read server json safely
 function readServerJson(id,fallback){ var el=document.getElementById(id); if(!el) return fallback; try{ var t = el.textContent||el.innerText||''; return t? JSON.parse(t): fallback; }catch(e){ console.error('Invalid server JSON',id,e); return fallback; } }
 var serverSpoolMap = readServerJson('serverSpoolMap_json',{});
 var serverSpoolOptions = readServerJson('serverSpoolOptions_json',[]);

 // keyboard incremental search helper for selects
 function makeSearchableSelect(sel){ if(!sel) return; try{ if(sel._searchHandler) sel.removeEventListener('keydown', sel._searchHandler); }catch(e){}
 var buffer=''; var last=0; var handler = function(e){ var now=Date.now(); if(now-last>800) buffer=''; last=now; if(e.key==='Backspace'){ buffer=buffer.slice(0,-1); e.preventDefault(); } else if(e.key && e.key.length===1 && !e.ctrlKey && !e.metaKey && !e.altKey){ buffer += e.key.toLowerCase(); } else return; var opts = Array.from(sel.options||[]); if(opts.length===0) return; var start = sel.selectedIndex>=0? sel.selectedIndex : -1; var findIdx = function(from){ for(var i=from+1;i<opts.length;i++){ if((opts[i].text||'').toLowerCase().includes(buffer)) return i; } for(var i=0;i<=from;i++){ if((opts[i].text||'').toLowerCase().includes(buffer)) return i; } return -1; };
 var idx = findIdx(start); if(idx>=0){ sel.selectedIndex = idx; sel.dispatchEvent(new Event('change',{bubbles:true})); }
 };
 sel.addEventListener('keydown', handler); sel._searchHandler = handler; sel.dataset.searchable='1'; }
 ['dwgBox','sheetBox','spoolBox','projectBox'].forEach(function(id){ var el=document.getElementById(id); if(el) makeSearchableSelect(el); });

 // normalization helpers
 function normalizeSheetValue(v){ if(!v && v!==0) return ''; var s=(''+v).toString().trim(); if(!s) return ''; var m=s.match(/^([0-9]+)([A-Za-z])?$/); if(m){ var num=m[1], letter=m[2]||''; return num.toString().padStart(3,'0')+letter; } return s.toLowerCase().trim(); }
 function normalizeSpoolValue(v){ if(!v && v!==0) return ''; var s=(''+v).toString().trim(); if(!s) return ''; var m=s.match(/^([0-9]+)([A-Za-z])?$/); if(m){ var num=m[1], letter=m[2]||''; return num.toString().padStart(2,'0')+letter; } return s.toLowerCase().trim(); }
 function normalizeDwgValue(v){ if(!v && v!==0) return ''; return (''+v).toString().trim().replace(/%/g,''); }

 // Reload page with selected project id to fetch server data
 function reloadForProject(sel){
 if(!sel) return;
 var val = (sel.value||'').trim();
 var url = new URL(window.location.href);
 if(val) url.searchParams.set('projectId', val); else url.searchParams.delete('projectId');
 window.location.href = url.toString();
 }
 
// table helpers
function buildColumnMap(){ var map={}; var ths = Array.from(document.querySelectorAll('#logTable thead th')); ths.forEach(function(th, idx){ var key = (th.textContent||'').trim().toLowerCase(); if(key.includes('status')) map.status=idx; if(key.includes('layout')||key.includes('dwg')) map.dwg=idx; if(key.includes('sheet')) map.sheet=idx; if(key.includes('spool') && !key.includes('completion') && !key.includes('complete') && !key.includes('date')) map.spool=idx; if(key.includes('project')) map.project=idx; }); return map; }
 function getSpoolsFromTable(){ var map=buildColumnMap(); var spoolIdx = map.spool; if(spoolIdx===undefined){ var ths = Array.from(document.querySelectorAll('#logTable thead th')); for(var i=0;i<ths.length;i++){ var key=(ths[i].textContent||'').trim().toLowerCase(); if(key.includes('spool') && !key.includes('completion') && !key.includes('complete') && !key.includes('date')) { spoolIdx=i; break; } } }
 if(spoolIdx===undefined) return [];
 var set = new Set(); Array.from(document.querySelectorAll('#logTable tbody tr')).forEach(function(r){ var cells = r.querySelectorAll('td'); var td = cells[spoolIdx]; var spool = (td && (td.textContent||'').trim())||''; if(spool) set.add(spool); }); return Array.from(set).sort(function(a,b){ return a.localeCompare(b); }); }
 function buildHierarchyFromTable(){ var map = buildColumnMap(); var dwgIdx=map.dwg, sheetIdx=map.sheet, spoolIdx=map.spool; var rows = Array.from(document.querySelectorAll('#logTable tbody tr')); var hierarchy = {}; rows.forEach(function(r){ var cells = r.querySelectorAll('td'); var dwg = (dwgIdx!==undefined && cells[dwgIdx]) ? (cells[dwgIdx].textContent||'').trim() : ''; var sheet = (sheetIdx!==undefined && cells[sheetIdx]) ? (cells[sheetIdx].textContent||'').trim() : ''; var spool = (spoolIdx!==undefined && cells[spoolIdx]) ? (cells[spoolIdx].textContent||'').trim() : ''; if(!dwg && !spool) return; var key = dwg||'__NO_DWG__'; if(!hierarchy[key]) hierarchy[key] = { sheets: {}, spools: new Set() }; if(sheet){ hierarchy[key].sheets[sheet] = hierarchy[key].sheets[sheet] || new Set(); if(spool) hierarchy[key].sheets[sheet].add(spool); } if(spool) hierarchy[key].spools.add(spool); }); Object.keys(hierarchy).forEach(function(d){ var s = hierarchy[d]; s.spools = Array.from(s.spools).sort(function(a,b){ return a.localeCompare(b); }); Object.keys(s.sheets).forEach(function(sh){ s.sheets[sh] = Array.from(s.sheets[sh]).sort(function(a,b){ return a.localeCompare(b); }); }); s.sheetList = Object.keys(s.sheets).sort(function(a,b){ return a.localeCompare(b); }); }); return hierarchy; }

 function populateSelectWithItems(sel, items, keepEmpty){ if(!sel) return; var cur = sel.value; sel.innerHTML=''; var empty = document.createElement('option'); empty.value=''; empty.textContent=''; if(keepEmpty) sel.appendChild(empty); if(items && items.length){ items.forEach(function(it){ var o=document.createElement('option'); o.value=it; o.textContent=it; sel.appendChild(o); }); } makeSearchableSelect(sel); resizeSelectToContent(sel); try{ if(cur) sel.value = cur; }catch(e){} }

 var _hier = null;
 function updateDependentSelects(){ if(!_hier) _hier = buildHierarchyFromTable(); var dwgSel=document.getElementById('dwgBox'); var sheetSel=document.getElementById('sheetBox'); var spoolSel=document.getElementById('spoolBox'); if(!dwgSel||!sheetSel||!spoolSel) return; var dwgText = (dwgSel.selectedOptions && dwgSel.selectedOptions[0] && (dwgSel.selectedOptions[0].text||'').trim()) || (dwgSel.value||'').trim(); var dwgValue = (dwgSel.value||'').toString().trim(); var sheetText = (sheetSel.selectedOptions && sheetSel.selectedOptions[0] && (sheetSel.selectedOptions[0].text||'').trim()) || sheetSel.value || '';
 if(!dwgText){ sheetSel.disabled = true; var tableSpools = (Array.isArray(serverSpoolOptions) && serverSpoolOptions.length) ? serverSpoolOptions.slice() : getSpoolsFromTable(); populateSelectWithItems(spoolSel, tableSpools, true); spoolSel.disabled = !(tableSpools && tableSpools.length); return; }
 // try server mapping
 var serverEntry = null; try{ if(Array.isArray(serverSpoolMap) && serverSpoolMap.length){ serverEntry = serverSpoolMap.find(function(e){ var key = ((e.Dwg||e.dwg||'')+'').toString().trim(); return key && (key===dwgText || key===dwgValue || key.toLowerCase()===dwgText.toLowerCase() || key.toLowerCase()===dwgValue.toLowerCase()); }); } }catch(e){ serverEntry = null; }
 if(serverEntry){ var sheets = (serverEntry.Sheets || serverEntry.sheets || []).map(function(s){ return (s.Sheet||s.sheet||'').trim(); }).filter(function(s){ return s; }); if(sheets.length){ populateSelectWithItems(sheetSel, sheets.sort(function(a,b){ return a.localeCompare(b); }), true); sheetSel.disabled=false; var sheetObj = (serverEntry.Sheets||serverEntry.sheets||[]).find(function(s){ return ((s.Sheet||s.sheet||'')+'').trim()===sheetText || ((s.Sheet||s.sheet||'')+'').trim()===sheetSel.value; }); var spForSheet = sheetObj ? (sheetObj.Spools||sheetObj.spools||[]).slice() : []; var dwgSpools = (serverEntry.Spools||serverEntry.spools||[]).slice(); if(sheetText && spForSheet.length){ populateSelectWithItems(spoolSel, spForSheet.sort(function(a,b){ return a.localeCompare(b); }), true); spoolSel.disabled=false; } else { populateSelectWithItems(spoolSel, dwgSpools.sort(function(a,b){ return a.localeCompare(b); }), true); spoolSel.disabled = !(dwgSpools && dwgSpools.length); } return; } else { var dwgSpools = (serverEntry.Spools||serverEntry.spools||[]).slice(); populateSelectWithItems(sheetSel, [], true); sheetSel.disabled=true; populateSelectWithItems(spoolSel, dwgSpools.sort(function(a,b){ return a.localeCompare(b); }), true); spoolSel.disabled = !(dwgSpools && dwgSpools.length); return; } }
 // fallback to table-derived
 function findEntryKey(key){ if(!key) return null; var candidates = Object.keys(_hier||{}); var want = key.toString().trim(); var wantLower = want.toLowerCase(); for(var i=0;i<candidates.length;i++){ var k=candidates[i]; if(k===want) return k; if((k||'').toString().trim()===want) return k; if((k||'').toString().trim().toLowerCase()===wantLower) return k; if((k||'').toString().trim().replace(/%/g,'').toLowerCase()===wantLower.replace(/%/g,'')) return k; } return null; }
 var entryKey = findEntryKey(dwgText) || findEntryKey(dwgValue);
 if(!entryKey){ populateSelectWithItems(sheetSel, [], true); sheetSel.disabled=true; populateSelectWithItems(spoolSel, [], true); spoolSel.disabled=true; return; }
 var entry = _hier[entryKey]; if(!entry){ populateSelectWithItems(sheetSel, [], true); sheetSel.disabled=true; populateSelectWithItems(spoolSel, [], true); spoolSel.disabled=true; return; }
 var sheets = entry.sheetList || [];
 if(sheets.length){ populateSelectWithItems(sheetSel, sheets, true); sheetSel.disabled=false; if(sheetText && sheets.indexOf(sheetText)!==-1){ var spForSheet = entry.sheets[sheetText] || []; populateSelectWithItems(spoolSel, (spForSheet && spForSheet.length) ? spForSheet : entry.spools, true); spoolSel.disabled = !((spForSheet && spForSheet.length) || (entry.spools && entry.spools.length)); } else { populateSelectWithItems(spoolSel, entry.spools || [], true); spoolSel.disabled = !(entry.spools && entry.spools.length); } } else { populateSelectWithItems(sheetSel, [], true); sheetSel.disabled=true; populateSelectWithItems(spoolSel, entry.spools || [], true); spoolSel.disabled = !(entry.spools && entry.spools.length); }
 }

 // selected value or displayed text helper
 function getSelectedValueOrText(id){ if(id==='statusBox'){ var checks = Array.from(document.querySelectorAll('#statusDropdown .status-checkbox:checked')); if(!checks.length) return ''; return checks.map(function(cb){ return (cb.dataset.val || cb.value || '').trim(); }).join(','); }
 var el=document.getElementById(id); if(!el) return ''; if(id==='projectBox') return el.value||''; var opt = el.selectedOptions && el.selectedOptions[0]; if(opt){ var t=(opt.text||'').trim(); if(t) return t; } return el.value||''; }
 // filter table rows
 function filterTable(){ var map = buildColumnMap(); var statusRaw = getSelectedValueOrText('statusBox'); var statusVals = statusRaw? statusRaw.split(',').map(function(s){ return s.trim().toLowerCase(); }).filter(function(s){ return s; }) : []; var dwgVal = getSelectedValueOrText('dwgBox').toLowerCase(); var sheetVal = getSelectedValueOrText('sheetBox').toLowerCase(); var spoolVal = getSelectedValueOrText('spoolBox').toLowerCase(); var projVal = getSelectedValueOrText('projectBox').toLowerCase(); var rows = Array.from(document.querySelectorAll('#logTable tbody tr')); if(statusVals.length===0 && !dwgVal && !sheetVal && !spoolVal && !projVal){ rows.forEach(function(r){ r.style.display=''; }); return; } rows.forEach(function(row){ var show=true; var cells = row.querySelectorAll('td'); function match(idx,val){ if(!val) return true; if(idx===undefined) return true; var c = cells[idx]; if(!c) return false; return (c.textContent||'').trim().toLowerCase().indexOf(val) >=0; }
 if(statusVals.length){ var sidx = map.status; if(sidx===undefined){ show=false; } else { var c = (cells[sidx] && (cells[sidx].textContent||'').trim().toLowerCase()) || ''; if(!statusVals.some(function(sv){ return c.includes(sv); })) show=false; } }
 if(!match(map.dwg,dwgVal)) show=false; if(!match(map.sheet,sheetVal)) show=false; if(!match(map.spool,spoolVal)) show=false; if(!match(map.project,projVal)) show=false; row.style.display = show ? '' : 'none'; }); }

