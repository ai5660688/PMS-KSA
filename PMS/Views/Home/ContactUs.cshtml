<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PMS - Contact Us</title>
    <link rel="icon" type="image/png" href="~/img/title_logo.png">
    <link rel="stylesheet" href="~/css/ContactUsStyle.css">
</head>
<body>
    <h1>
        <img src="~/img/PMS_logo.png" alt="Logo" class="main-logo">
    </h1>

    <div class="container-wrapper">
        <div class="contact-container">
            <h2>Contact Us</h2>
            @{
                var flash = TempData["Message"] as string;
            }
            @if (!string.IsNullOrEmpty(flash))
            {
                <div class="alert-success">@flash</div>
            }
            <form method="post" action="@Url.Action("ContactUs","Home")">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label for="title">Title</label>
                    <input type="text" id="title" name="title" required>
                </div>
                <div class="form-group">
                    <label for="company">Company</label>
                    <input type="text" id="company" name="company" required>
                </div>
                <div class="form-group">
                    <label for="name">Name</label>
                    <input type="text" id="name" name="name" required>
                </div>
                <div class="form-group">
                    <label for="email">Email</label>
                    <input type="email" id="email" name="email" required>
                </div>
                <div class="form-group contents-group">
                    <div class="toolbar-container">
                        <label class="toolbar-label" for="contents">Contents</label>
                        <div class="format-toolbar">
                            <button type="button" title="Bold" data-command="bold"><b>B</b></button>
                            <button type="button" title="Italic" data-command="italic"><i>I</i></button>
                            <button type="button" title="Underline" data-command="underline"><u>U</u></button>
                            <select title="Font Family" id="fontFamily">
                                <option value="Calibri">Calibri</option>
                                <option value="Arial">Arial</option>
                                <option value="Times New Roman">Times New Roman</option>
                                <option value="Courier New">Courier New</option>
                                <option value="Georgia">Georgia</option>
                            </select>
                            <select title="Font Size" id="fontSize">
                                <option value="1">8pt</option>
                                <option value="2">10pt</option>
                                <option value="3" selected>12pt</option>
                                <option value="4">14pt</option>
                                <option value="5">18pt</option>
                                <option value="6">24pt</option>
                                <option value="7">36pt</option>
                            </select>
                            <input type="color" title="Font Color" class="color-picker" id="fontColor">
                            <button type="button" title="Align Left" data-command="justifyLeft">&#8676;</button>
                            <button type="button" title="Align Center" data-command="justifyCenter">&#8596;</button>
                            <button type="button" title="Align Right" data-command="justifyRight">&#8677;</button>
                            <button type="button" title="Bullet List" data-command="insertUnorderedList">&#8226; List</button>
                            <button type="button" title="Numbered List" data-command="insertOrderedList">1. List</button>
                        </div>
                    </div>
                    <div id="contents" contenteditable="true" tabindex="0"></div>
                    <input type="hidden" id="contentsHtml" name="contentsHtml">
                </div>
                <input type="hidden" id="SubjectHidden" name="Subject" />
                <input type="hidden" id="MessageHidden" name="Message" />

                <div class="button-container">
                    <button type="submit">Send Message</button>
                </div>
            </form>

            <div class="back-to-login-container">
                <a href="@Url.Action("Login", "Home")" class="back-to-login-link">Back to Login</a>
            </div>
        </div>
    </div>

    <div class="footer">
        <div class="footer-center">
            This system is strictly restricted to authorized users only.<br>
            © 2025 Piping Management System. All rights reserved.
        </div>
        <div class="footer-right">
            <img src="~/img/work-smarter-not-harder.jpg?v=3" alt="Logo" class="footer-logo" />
        </div>
    </div>
    <script src="@Url.Content("~/js/site.js")"></script>
    <script>
        (function () {
            const form = document.querySelector('form[action$="ContactUs"]');
            if (!form) return;
            form.addEventListener('submit', function () {
                const title = document.getElementById('title');
                const contentsDiv = document.getElementById('contents');
                document.getElementById('SubjectHidden').value = title ? title.value : '';
                document.getElementById('MessageHidden').value = contentsDiv ? contentsDiv.innerHTML : '';
            });
        })();
    </script>
</body>
</html>