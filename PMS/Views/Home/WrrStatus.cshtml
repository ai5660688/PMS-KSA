@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model PMS.Models.WrrStatusPageViewModel
@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "WRR Status";
    var selectedSet = new HashSet<int>(Model.SelectedProjectIds);
}

@section Head {
    <style>
        .wrr-container { padding: 12px 12px 32px; background: #fff8eb; min-height: calc(100vh - 120px); }
        .wrr-card { background: #fff8eb; border: 1px solid #e6f6fa; border-radius: 10px; box-shadow: 0 4px 12px rgba(31,153,190,0.12); padding: 14px 16px; position: relative; }
        .wrr-card-header { font-size: 1.3em; font-weight: 700; color: #176d8a; margin-bottom: 12px; }
        .wrr-filters { display: flex; flex-wrap: wrap; gap: 12px; margin-bottom: 12px; align-items: flex-end; }
        .wrr-filter { display: flex; flex-direction: column; gap: 6px; min-width: 140px; }
        .wrr-filter label { color: #176d8a; font-weight: 600; font-size: .9rem; }
        .wrr-input { padding: 8px 10px; border: 1px solid #cce7ef; border-radius: 6px; color: #176d8a; background: #fff; min-width: 260px; font-size: .9rem; }
        .wrr-input:focus { border-color: #176d8a; outline: none; }
        .wrr-actions { display: flex; align-items: flex-end; gap: 8px; }
        /* Multi-select dropdown */
        .ms-wrap { position: relative; display: inline-block; vertical-align: middle; min-width: 370px; }
        .ms-toggle { width: 100%; box-sizing: border-box; cursor: pointer; font-family: inherit; font-weight: 600; display: flex; align-items: center; justify-content: space-between; gap: 6px; }
        .ms-toggle::after { content: '\25BC'; font-size: .65rem; color: #176d8a; flex-shrink: 0; }
        .ms-open .ms-toggle::after { content: '\25B2'; }
        .ms-open .ms-toggle { border-radius: 6px 6px 0 0; border-color: #176d8a; }
        .ms-panel { display: none; position: absolute; left: 0; right: 0; top: 100%; z-index: 1200; background: #fff; border: 1px solid #176d8a; border-top: none; border-radius: 0 0 6px 6px; max-height: 260px; overflow-y: auto; box-shadow: 0 4px 10px rgba(0,0,0,.12); scrollbar-width: thin; scrollbar-color: #0d9b8c #e6f6fa; }
        .ms-panel::-webkit-scrollbar { width: 10px; }
        .ms-panel::-webkit-scrollbar-track { background: #e6f6fa; border-radius: 8px; }
        .ms-panel::-webkit-scrollbar-thumb { background: #0d9b8c; border-radius: 8px; }
        .ms-panel::-webkit-scrollbar-thumb:hover { background: #0b877a; }
        .ms-search { width: 100%; box-sizing: border-box; padding: 6px 10px; border: none; border-bottom: 1px solid #e6f6fa; font-size: .85rem; color: #176d8a; outline: none; font-family: inherit; }
        .ms-actions { display: flex; gap: 4px; padding: 4px 8px; border-bottom: 1px solid #e6f6fa; }
        .ms-actions button { font-size: .75rem; padding: 2px 8px; border-radius: 4px; border: 1px solid #cce7ef; background: #f0fbff; color: #176d8a; cursor: pointer; font-weight: 600; }
        .ms-actions button:hover { background: #1f99be; color: #fff; border-color: #1f99be; }
        .ms-option { display: flex; align-items: center; gap: 6px; padding: 5px 10px; cursor: pointer; font-size: .85rem; color: #176d8a; }
        .ms-option:hover { background: #e6f6fa; }
        .ms-option input[type="checkbox"] { accent-color: #1f99be; cursor: pointer; }
        .ms-option.ms-hidden { display: none; }
        .ms-no-match { padding: 6px 10px; font-size: .85rem; color: #999; font-style: italic; }
        .btn { padding: 8px 14px; border-radius: 6px; border: 1px solid transparent; font-weight: 700; cursor: pointer; line-height: 1.2; font-size: .9rem; }
        .btn-primary { background: #1f99be; color: #fff; border-color: #1f99be; }
        .btn-primary:hover { background: #176d8a; border-color: #176d8a; }
        .btn-outline { background: #fff; color: #176d8a; border: 1px solid #1f99be; }
        .btn-outline:hover { background: #1f99be; color: #fff; }
        .wrr-as-of { color: #176d8a; font-weight: 700; font-size: .95rem; margin-bottom: 10px; text-align: right; }
        .wrr-tables-row { display: flex; gap: 16px; margin-bottom: 18px; }
        .wrr-table-card { flex: 1; background: #fff; border: 1px solid #e6f6fa; border-radius: 8px; padding: 10px; box-shadow: 0 1px 4px rgba(31,153,190,0.08); min-width: 0; }
        .wrr-table-title { font-weight: 700; color: #176d8a; margin-bottom: 6px; font-size: .95rem; }
        .wrr-table-wrap { max-height: calc(100vh - 360px); overflow: auto; scrollbar-color: #0d9b8c #e6f6fa; scrollbar-width: thin; }
        .wrr-table-wrap::-webkit-scrollbar { width: 10px; height: 10px; }
        .wrr-table-wrap::-webkit-scrollbar-track { background: #e6f6fa; border-radius: 8px; }
        .wrr-table-wrap::-webkit-scrollbar-thumb { background: #0d9b8c; border-radius: 8px; }
        .wrr-table-wrap::-webkit-scrollbar-thumb:hover { background: #0b877a; }
        .wrr-table { width: 100%; border-collapse: collapse; background: #fff; }
        .wrr-table th, .wrr-table td { border: 1px solid #e6f6fa; padding: 6px 8px; color: #176d8a; font-size: .82rem; white-space: nowrap; text-align: center; }
        .wrr-table th { position: sticky; top: 0; background: #f0fbff; z-index: 1; font-weight: 700; }
        .wrr-table tr:hover td { background: #f8fcff; }
        .wrr-charts-row { display: flex; gap: 16px; }
        .wrr-chart-card { flex: 1; background: #fff; border: 1px solid #e6f6fa; border-radius: 8px; padding: 14px; box-shadow: 0 1px 4px rgba(31,153,190,0.08); min-width: 0; }
        .wrr-empty { color: #176d8a; font-size: .95rem; padding: 20px 0; }
        .wrr-error { color: #cc0000; font-size: .9rem; font-weight: 600; padding: 8px 12px; background: #fff0f0; border: 1px solid #ffcccc; border-radius: 6px; margin-bottom: 10px; }
        @@media (max-width: 1200px) { .wrr-tables-row, .wrr-charts-row { flex-direction: column; } }
        @@media (max-width: 1024px) { .wrr-filters { gap: 8px; } .ms-wrap { min-width: 260px; } }
        @@media (max-width: 640px) { .wrr-container { padding: 12px; } .wrr-filters { flex-direction: column; } .wrr-input { min-width: 100%; } .ms-wrap { min-width: 100%; } }
    </style>
}

<div class="wrr-container">
    <div class="wrr-card">
        <div class="wrr-card-header" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;">
            <span>WRR Status</span>
            <a asp-action="WelderStatus" asp-controller="Home" class="btn btn-outline" style="font-size:.85rem;padding:6px 14px;text-decoration:none;">Welders Status</a>
        </div>

        <form method="get" asp-action="WrrStatus" asp-controller="Home" class="wrr-filters">
            <div class="wrr-filter">
                <label>Project No.</label>
                <div class="ms-wrap" id="projectMultiSelect">
                    <div class="ms-toggle wrr-input" tabindex="0">
                        <span class="ms-label">Select projects...</span>
                    </div>
                    <div class="ms-panel">
                        <input type="text" class="ms-search" placeholder="Search projects..." />
                        <div class="ms-actions">
                            <button type="button" data-action="all">All</button>
                            <button type="button" data-action="none">None</button>
                        </div>
                        <div class="ms-options">
                            @foreach (var p in Model.Projects)
                            {
                                var isChecked = selectedSet.Contains(p.Id);
                                <label class="ms-option">
                                    <input type="checkbox" name="projectId" value="@p.Id" @(isChecked ? "checked" : "") />
                                    @p.Id - @p.Name
                                </label>
                            }
                        </div>
                    </div>
                </div>
            </div>
            <div class="wrr-actions">
                <button type="submit" class="btn btn-primary">Load</button>
                @if (Model.JointRows.Count > 0 || Model.LinearRows.Count > 0)
                {
                    <button type="button" id="wrrExportBtn" class="btn btn-outline" style="font-size:.85rem;padding:8px 14px;display:inline-flex;align-items:center;gap:6px;">
                        &#128196; Download Excel
                    </button>
                }
            </div>
        </form>

        @if (ViewBag.ErrorMessage is string err && !string.IsNullOrWhiteSpace(err))
        {
            <div class="wrr-error">@err</div>
        }

        @if (Model.JointRows.Count == 0 && Model.LinearRows.Count == 0)
        {
            <div class="wrr-empty">Select a project and click Load to view WRR status.</div>
        }
        else
        {
            <div class="wrr-as-of">AS OF @Model.AsOfDate.ToUpper()</div>

            <div class="wrr-tables-row">
                <!-- Joint Basis -->
                <div class="wrr-table-card">
                    <div class="wrr-table-title">WRR STATUS - Joint Basis (Weekly)</div>
                    <div class="wrr-table-wrap">
                        <table class="wrr-table">
                            <thead>
                                <tr>
                                    <th>WEEK</th>
                                    <th>From</th>
                                    <th>To</th>
                                    <th>RT DONE</th>
                                    <th>RT REJECT</th>
                                    <th>WEEKLY WRR%<br />JOINT METHOD</th>
                                    <th>CUMM WRR%<br />JOINT METHOD</th>
                                    <th>Project<br />Acceptable Rate</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in Model.JointRows)
                                {
                                    <tr>
                                        <td>@row.Week</td>
                                        <td>@row.From</td>
                                        <td>@row.To</td>
                                        <td>@row.RtDone</td>
                                        <td>@row.RtReject</td>
                                        <td>@row.WeeklyWrr.ToString("0.00")</td>
                                        <td>@row.CummWrr.ToString("0.00")</td>
                                        <td>@row.AcceptableRate</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Linear Basis -->
                <div class="wrr-table-card">
                    <div class="wrr-table-title">WRR STATUS - Linear Basis (Weekly)</div>
                    <div class="wrr-table-wrap">
                        <table class="wrr-table">
                            <thead>
                                <tr>
                                    <th>WEEK</th>
                                    <th>From</th>
                                    <th>To</th>
                                    <th>WELD LENGTH<br />RT'd (Inches)</th>
                                    <th>Length Weld<br />Defect (Inches)</th>
                                    <th>WEEKLY WRR%<br />LINEAR METHOD</th>
                                    <th>CUMM WRR%<br />LINEAR METHOD</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in Model.LinearRows)
                                {
                                    <tr>
                                        <td>@row.Week</td>
                                        <td>@row.From</td>
                                        <td>@row.To</td>
                                        <td>@row.WeldLengthRtd.ToString("0.00")</td>
                                        <td>@row.LengthWeldDefect.ToString("0.000")</td>
                                        <td>@row.WeeklyWrr.ToString("0.000")</td>
                                        <td>@row.CummWrr.ToString("0.000")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Charts -->
            <div class="wrr-charts-row">
                <div class="wrr-chart-card">
                    <canvas id="jointChart" height="280"></canvas>
                </div>
                <div class="wrr-chart-card">
                    <canvas id="linearChart" height="280"></canvas>
                </div>
            </div>
        }
    </div>
</div>

@if (Model.JointRows.Count > 0 || Model.LinearRows.Count > 0)
{
    <form id="wrrExportForm" method="post" asp-action="ExportWrrStatusExcel" asp-controller="Home" style="display:none;">
        @foreach (var id in Model.SelectedProjectIds)
        {
            <input type="hidden" name="projectId" value="@id" />
        }
        <input type="hidden" name="jointChartImage" id="jointChartImageInput" />
        <input type="hidden" name="linearChartImage" id="linearChartImageInput" />
    </form>
}

@section Scripts {
    <script src="~/lib/chart.js/chart.umd.min.js"></script>
    <script id="wrrChartData" type="application/json">
        @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new {
            jointLabels = Model.JointRows.Select(r => r.Week),
            jointWeekly = Model.JointRows.Select(r => r.WeeklyWrr),
            jointCumm = Model.JointRows.Select(r => r.CummWrr),
            jointRate = Model.JointRows.Select(r => r.AcceptableRate),
            linearLabels = Model.LinearRows.Select(r => r.Week),
            linearWeekly = Model.LinearRows.Select(r => r.WeeklyWrr),
            linearCumm = Model.LinearRows.Select(r => r.CummWrr),
            linearRate = Model.LinearRows.Select(r => Model.LinearAcceptableRate)
        }))
    </script>
    <script>
    (function () {
        var _d = JSON.parse(document.getElementById('wrrChartData').textContent);
        var jointLabels = _d.jointLabels;
        var jointWeekly = _d.jointWeekly;
        var jointCumm   = _d.jointCumm;
        var jointRate   = _d.jointRate;
        var linearLabels = _d.linearLabels;
        var linearWeekly = _d.linearWeekly;
        var linearCumm   = _d.linearCumm;
        var linearRate   = _d.linearRate;

        if (jointLabels.length === 0) return;

        function buildChart(canvasId, title, labels, weeklyData, cummData, rateData, weeklyLabel, cummLabel, yOpts) {
            var ctx = document.getElementById(canvasId);
            if (!ctx) return;
            var yScale = { beginAtZero: true, ticks: { font: { size: 10 } } };
            if (yOpts) {
                if (yOpts.max != null) yScale.max = yOpts.max;
                if (yOpts.stepSize != null) yScale.ticks.stepSize = yOpts.stepSize;
            }
            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [
                        {
                            label: weeklyLabel,
                            data: weeklyData,
                            backgroundColor: 'rgba(31,153,190,0.65)',
                            borderColor: '#1f99be',
                            borderWidth: 1,
                            order: 2
                        },
                        {
                            label: cummLabel,
                            data: cummData,
                            type: 'line',
                            borderColor: '#e6a817',
                            backgroundColor: '#e6a817',
                            pointRadius: 3,
                            pointHoverRadius: 5,
                            borderWidth: 2,
                            fill: false,
                            tension: 0.2,
                            order: 1
                        },
                        {
                            label: 'Project Acceptable Rate',
                            data: rateData,
                            type: 'line',
                            borderColor: '#cc0000',
                            backgroundColor: 'transparent',
                            borderDash: [6, 4],
                            pointRadius: 0,
                            borderWidth: 2,
                            fill: false,
                            order: 0
                        }
                    ]
                },
                options: {
                    responsive: true,
                    plugins: {
                        title: { display: true, text: title, color: '#176d8a', font: { size: 14, weight: 'bold' } },
                        legend: { position: 'bottom', labels: { font: { size: 11 }, usePointStyle: true } }
                    },
                    scales: {
                        x: { ticks: { font: { size: 10 } } },
                        y: yScale
                    }
                }
            });
        }

        buildChart('jointChart', 'WRR% JOINT BASIS', jointLabels, jointWeekly, jointCumm, jointRate, 'WEEKLY WRR% JOINT METHOD', 'CUMM WRR% JOINT METHOD');
        buildChart('linearChart', 'WRR% Linear BASIS', linearLabels, linearWeekly, linearCumm, linearRate, 'WEEKLY WRR% LINEAR METHOD', 'CUMM WRR% LINEAR METHOD', { max: 0.9, stepSize: 0.1 });
    })();
    </script>
    <script>
    // Multi-select dropdown widget (for Project No.)
    (function () {
        var wrap = document.getElementById('projectMultiSelect');
        if (!wrap) return;
        var toggle = wrap.querySelector('.ms-toggle');
        var label = wrap.querySelector('.ms-label');
        var panel = wrap.querySelector('.ms-panel');
        var search = wrap.querySelector('.ms-search');
        var options = wrap.querySelectorAll('.ms-option');
        var checkboxes = wrap.querySelectorAll('.ms-option input[type="checkbox"]');
        var open = false;

        function updateLabel() {
            var checked = wrap.querySelectorAll('.ms-option input[type="checkbox"]:checked');
            if (checked.length === 0) { label.textContent = 'Select projects...'; }
            else if (checked.length === checkboxes.length) { label.textContent = 'All projects (' + checked.length + ')'; }
            else if (checked.length <= 2) {
                var names = [];
                checked.forEach(function (cb) { names.push(cb.parentElement.textContent.trim()); });
                label.textContent = names.join(', ');
            } else { label.textContent = checked.length + ' project(s) selected'; }
        }

        function showPanel() {
            if (open) return;
            open = true;
            panel.style.display = 'block';
            wrap.classList.add('ms-open');
            search.value = '';
            filterOptions('');
            search.focus();
        }

        function hidePanel() {
            if (!open) return;
            open = false;
            panel.style.display = 'none';
            wrap.classList.remove('ms-open');
        }

        function filterOptions(text) {
            var lc = text.toLowerCase();
            var visible = 0;
            options.forEach(function (opt) {
                var match = !lc || opt.textContent.toLowerCase().includes(lc);
                opt.classList.toggle('ms-hidden', !match);
                if (match) visible++;
            });
            var noMatch = panel.querySelector('.ms-no-match');
            if (visible === 0) {
                if (!noMatch) { noMatch = document.createElement('div'); noMatch.className = 'ms-no-match'; noMatch.textContent = 'No match'; panel.querySelector('.ms-options').appendChild(noMatch); }
            } else if (noMatch) { noMatch.remove(); }
        }

        toggle.addEventListener('click', function () { open ? hidePanel() : showPanel(); });
        toggle.addEventListener('keydown', function (e) { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); open ? hidePanel() : showPanel(); } });

        search.addEventListener('input', function () { filterOptions(search.value); });

        checkboxes.forEach(function (cb) { cb.addEventListener('change', updateLabel); });

        wrap.querySelectorAll('.ms-actions button').forEach(function (btn) {
            btn.addEventListener('click', function (e) {
                e.preventDefault();
                var action = btn.dataset.action;
                checkboxes.forEach(function (cb) {
                    if (!cb.closest('.ms-option').classList.contains('ms-hidden')) {
                        cb.checked = (action === 'all');
                    }
                });
                updateLabel();
            });
        });

        document.addEventListener('mousedown', function (e) { if (open && !wrap.contains(e.target)) hidePanel(); });

        updateLabel();
    })();
    </script>
    <script>
    (function () {
        var btn = document.getElementById('wrrExportBtn');
        if (!btn) return;
        btn.addEventListener('click', function () {
            var jointCanvas = document.getElementById('jointChart');
            var linearCanvas = document.getElementById('linearChart');
            var jointInput = document.getElementById('jointChartImageInput');
            var linearInput = document.getElementById('linearChartImageInput');
            if (jointCanvas) { try { jointInput.value = jointCanvas.toDataURL('image/png'); } catch (e) { } }
            if (linearCanvas) { try { linearInput.value = linearCanvas.toDataURL('image/png'); } catch (e) { } }
            document.getElementById('wrrExportForm').submit();
        });
    })();
    </script>
}
