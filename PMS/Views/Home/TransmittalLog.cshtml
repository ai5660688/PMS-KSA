@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model IEnumerable<PMS.Models.TransmittalLog>
@{
    Layout = null;
    ViewData["Title"] = "Transmittal Log";
    var projectMap = (ViewBag.ProjectMap as Dictionary<int, string>) ?? new Dictionary<int, string>();
    var defaultProjectId = ViewBag.DefaultProjectId as int?;
    var defaultDiscipline = (ViewBag.DefaultDiscipline as string) ?? "";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - PMS</title>
    <link rel="icon" type="image/png" href="~/img/title_logo.png">
    <link rel="stylesheet" href="~/css/DashboardStyle.css" asp-append-version="true">
    <style>
        .page { width:95%; margin:20px auto; background:#fff; border-radius:8px; box-shadow:0 4px 12px rgba(0,0,0,.1); padding:20px; }
        .page-title { color:#176d8a; margin:0 0 16px 0; padding-bottom:10px; border-bottom:2px solid #e6f6fa; font-size:2em; }
        label { font-weight:600; color:#176d8a; font-size:.9rem; }
        .form-control { padding:8px 12px; border:1px solid #cce7ef; border-radius:4px; background:#fff; color:#176d8a; font-size:.9rem; width:100%; box-sizing:border-box; }
        .form-control:focus { outline:none; border-color:#1f99be; box-shadow:0 0 0 2px rgba(31,153,190,.2); }
        .grid { display:grid; grid-template-columns: repeat(auto-fill,minmax(220px,1fr)); gap:12px; }
        .form-group { display:flex; flex-direction:column; gap:6px; }
        .actions { display:flex; gap:8px; justify-content:flex-end; margin-top:12px; }
        .btn { padding:8px 14px; border:none; border-radius:4px; cursor:pointer; font-weight:600; transition:.2s; }
        .btn-primary { background:#1f99be; color:#fff; } .btn-primary:hover{ background:#176d8a; }
        .btn-danger { background:#cc0000; color:#fff; } .btn-danger:hover{ background:#a30000; }
        .btn-secondary { background:#7a9aa8; color:#fff; }
        .btn-outline { background:#fff; color:#176d8a; border:1px solid #1f99be; }
        .btn-outline:hover { background:#1f99be; color:#fff; }
        .btn-success { background:#27ae60; color:#fff; } .btn-success:hover { background:#1e8c4c; }
        .user-table { width:100%; border-collapse:collapse; margin-top:10px; }
        .user-table th { background-color:#e6f6fa; color:#176d8a; padding:10px 12px; text-align:left; position:sticky; top:0; z-index:2; white-space:nowrap; }
        .user-table td { padding:10px 12px; border-bottom:1px solid #e6f6fa; color:#1a6d86; white-space:nowrap; }
        .msg { margin:0 0 12px 0; font-weight:400; font-size:0.875rem; display:block; border:none; outline:none; box-shadow:none; background:transparent; }
        .msg.text-danger { color:#cc0000; }
        .msg-success { margin:0 0 12px 0; color:#27ae60; font-weight:400; font-size:0.875rem; display:block; border:none; outline:none; box-shadow:none; background:transparent; }
        .row-actions { display:flex; gap:8px; }
        .filter-bar { display:flex; gap:10px; flex-wrap:wrap; align-items:center; margin-top:25px; }
        .filter-bar input[type="text"] { flex:1 1 260px; }
        .count { font-size:.8rem; color:#176d8a; }
        .filter-actions { display:flex; gap:8px; align-items:center; }
        .col-actions, td.row-actions { width:90px; max-width:90px; }
        .pdf-btns { display:inline-flex; gap:0; border-radius:4px; overflow:hidden; border:1px solid #1f99be; }
        .pdf-btns .pbtn { padding:4px 7px; font-size:.75rem; font-weight:600; border:none; cursor:pointer; white-space:nowrap; transition:.15s; text-decoration:none; display:inline-flex; align-items:center; gap:3px; line-height:1; }
        .pdf-btns .pbtn + .pbtn { border-left:1px solid rgba(31,153,190,.3); }
        .pdf-btns .pbtn-open  { background:#1f99be; color:#fff; }
        .pdf-btns .pbtn-open:hover { background:#176d8a; }
        .pdf-btns .pbtn-save  { background:#fff; color:#176d8a; }
        .pdf-btns .pbtn-save:hover { background:#e6f6fa; }
        .pdf-btns .pbtn-upload { background:#fff; color:#176d8a; }
        .pdf-btns .pbtn-upload:hover { background:#e6f6fa; }
        .pdf-btns .pbtn.disabled { opacity:.4; pointer-events:none; cursor:default; background:#eee; color:#aaa; }
        .table-scroll { overflow:auto; max-height:65vh; }
        .table-scroll::-webkit-scrollbar { width:10px; height:10px; }
        .table-scroll::-webkit-scrollbar-track { background:#f0fbff; border-radius:8px; }
        .table-scroll::-webkit-scrollbar-thumb { background:#1f99be; border-radius:8px; border:2px solid #f0fbff; }
        .table-scroll::-webkit-scrollbar-thumb:hover { background:#176d8a; }
        .table-scroll::-webkit-scrollbar-corner { background:transparent; }
        .modal-content::-webkit-scrollbar { width:10px; }
        .modal-content::-webkit-scrollbar-track { background:#f0fbff; border-radius:8px; }
        .modal-content::-webkit-scrollbar-thumb { background:#1f99be; border-radius:8px; border:2px solid #f0fbff; }
        .modal-content::-webkit-scrollbar-thumb:hover { background:#176d8a; }
        .table-scroll { scrollbar-width:thin; scrollbar-color:#1f99be #f0fbff; }
        .modal-content { scrollbar-width:thin; scrollbar-color:#1f99be #f0fbff; }
        .import-section { margin-top:20px; padding:16px; border:1px dashed #cce7ef; border-radius:8px; background:#f9fdfe; }
        .import-section label { display:block; margin-bottom:8px; }
        .import-row { display:flex; gap:10px; align-items:center; flex-wrap:wrap; }
        .modal { display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:10000; justify-content:center; align-items:center; }
        .modal-content { background:#fff; padding:25px; border-radius:8px; width:90%; max-width:780px; max-height:85vh; overflow-y:auto; box-shadow:0 4px 20px rgba(0,0,0,0.15); }
        .modal-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:16px; padding-bottom:10px; border-bottom:1px solid #e6f6fa; }
        .modal-title { color:#176d8a; font-size:1.3rem; margin:0; }
        .close-modal { background:none; border:none; font-size:1.5rem; cursor:pointer; color:#176d8a; }
        .modal-actions { display:flex; justify-content:flex-end; gap:10px; margin-top:18px; padding-top:12px; border-top:1px solid #e6f6fa; }
        .fitup-header { display:flex; gap:12px; flex-wrap:wrap; align-items:center; padding:10px 0; }
        .fitup-header label { margin-right:4px; }
        .header-fixed { width:auto; display:inline-block; }
        .w350 { width:350px; min-width:350px; }
    </style>
</head>
<body>
    @await Html.PartialAsync("_DashboardHeader")

    <div class="page">
        <h1 class="page-title">Transmittal Log</h1>

        @if (TempData["Msg"] is string m && !string.IsNullOrWhiteSpace(m))
        {
            var isSuccessMsg = System.Text.RegularExpressions.Regex.IsMatch(m, "(successfully|saved|uploaded|updated|added|complete|deleted|removed)", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            var flashClass = isSuccessMsg ? "msg msg-success" : "msg text-danger";
            <div id="topFlashMsg" class="@flashClass" role="status" aria-live="polite">@m</div>
        }

        <!-- Project filter -->
        <div class="fitup-header">
            <form method="get" asp-action="TransmittalLog" asp-controller="Home" id="trFilterForm">
                <label for="projectSelect">Project</label>
                <select id="projectSelect" name="projectId" class="form-control header-fixed w350">
                    @foreach (var p in (IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)ViewBag.FilterProjects)
                    {
                        <option value="@p.Value" selected="@p.Selected">@p.Text</option>
                    }
                </select>
            </form>
            <button type="button" class="btn btn-primary" onclick="openAddModal()">+ Add Transmittal</button>
        </div>

        <!-- Import / Append by Excel -->
        <div class="import-section">
            <label>Import / Append from Excel</label>
            <form asp-action="ImportTransmittal" asp-controller="Home" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="projectId" value="@(defaultProjectId)" />
                <div class="import-row">
                    <input type="file" name="excelFile" accept=".xlsx,.xls" class="form-control" style="flex:1 1 300px;" required />
                    <button type="submit" class="btn btn-success">Upload &amp; Import</button>
                    <a asp-action="DownloadTransmittalTemplate" asp-controller="Home" class="btn btn-outline" style="margin-left:4px;">Download Template</a>
                </div>
                <small style="color:#7a9aa8; margin-top:6px; display:block;">
                    Expected columns: Transmittal, Date, Doc No, Documents Title, Discipline, etc.
                    Rows with an existing ID will be updated; new rows will be appended.
                </small>
            </form>
        </div>

        <!-- Bulk PDF Upload / Download -->
        <div class="import-section" style="margin-top:12px;">
            <label>Bulk PDF Upload &amp; Download</label>
            <form asp-action="BulkUploadTransmittalPdfs" asp-controller="Home" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="projectId" value="@(defaultProjectId)" />
                <div class="import-row">
                    <input type="file" name="pdfFiles" accept=".pdf" multiple class="form-control" style="flex:1 1 300px;" required />
                    <button type="submit" class="btn btn-success">Bulk Upload PDFs</button>
                    <a href="/Home/BulkDownloadTransmittalPdfs?projectId=@(defaultProjectId)" class="btn btn-outline" id="bulkDownloadPdfBtn" style="margin-left:4px;">⬇ Download All PDFs</a>
                </div>
                <small style="color:#7a9aa8; margin-top:6px; display:block;">
                    Select multiple PDF files. Each file is matched to a Transmittal row if its filename contains the <strong>Doc No</strong> value.
                    Bulk download exports all attached PDFs for the current project as a ZIP.
                </small>
            </form>
        </div>

        <div class="filter-bar">
            <input id="searchBox" class="form-control" type="text" placeholder="Search all columns..." autocomplete="off" />
            <div class="filter-actions">
                <button id="downloadBtn" type="button" class="btn btn-outline">Download Excel</button>
                <span id="rowCount" class="count"></span>
            </div>
        </div>

        <div class="table-scroll">
            <table class="user-table" id="trTable">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Transmittal</th>
                        <th>Date</th>
                        <th>Doc No</th>
                        <th>eGesDoc No</th>
                        <th>Documents Title</th>
                        <th>REV</th>
                        <th>Remarks</th>
                        <th>Transmittal No</th>
                        <th>TR Comment</th>
                        <th>Date TR</th>
                        <th>TR REV</th>
                        <th>SAPMT Comment</th>
                        <th>Date SAPMT</th>
                        <th>SAPMT REV</th>
                        <th>Categorize</th>
                        <th>Discipline</th>
                        <th>Attached</th>
                        <th class="col-actions">Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var t in Model)
                {
                    <tr data-id="@t.ID"
                        data-transmittal="@t.Transmittal"
                        data-date="@(t.Date.HasValue ? t.Date.Value.ToString("yyyy-MM-dd") : "")"
                        data-doc-no="@t.Doc_No"
                        data-egesdoc-no="@t.eGesDoc_No"
                        data-documents-title="@t.Documents_Title"
                        data-rev="@t.REV"
                        data-remarks="@t.Remarks"
                        data-transmittal-no="@t.Transmittal_No"
                        data-tr-comment="@t.TR_Comment"
                        data-date-tr="@(t.Date_TR.HasValue ? t.Date_TR.Value.ToString("yyyy-MM-dd") : "")"
                        data-tr-rev="@t.TR_REV"
                        data-sapmt-comment="@t.SAPMT_Comment"
                        data-date-sapmt="@(t.Date_SAPMT.HasValue ? t.Date_SAPMT.Value.ToString("yyyy-MM-dd") : "")"
                        data-sapmt-rev="@t.SAPMT_REV"
                        data-categorize="@t.Categorize"
                        data-discipline="@t.Discipline"
                        data-project-id="@t.TR_Project_No"
                        data-file-name="@t.TR_FileName"
                        data-blob-name="@t.TR_BlobName">
                        <td>@t.ID</td>
                        <td>@t.Transmittal</td>
                        <td>@(t.Date.HasValue ? t.Date.Value.ToString("dd-MMM-yyyy") : "")</td>
                        <td>@t.Doc_No</td>
                        <td>@t.eGesDoc_No</td>
                        <td title="@t.Documents_Title">@(t.Documents_Title != null && t.Documents_Title.Length > 50 ? t.Documents_Title[..50] + "…" : t.Documents_Title)</td>
                        <td>@t.REV</td>
                        <td>@t.Remarks</td>
                        <td>@t.Transmittal_No</td>
                        <td>@t.TR_Comment</td>
                        <td>@(t.Date_TR.HasValue ? t.Date_TR.Value.ToString("dd-MMM-yyyy") : "")</td>
                        <td>@t.TR_REV</td>
                        <td>@t.SAPMT_Comment</td>
                        <td>@(t.Date_SAPMT.HasValue ? t.Date_SAPMT.Value.ToString("dd-MMM-yyyy") : "")</td>
                        <td>@t.SAPMT_REV</td>
                        <td>@t.Categorize</td>
                        <td>@t.Discipline</td>
                        <td>
                            @{ var hasPdf = !string.IsNullOrWhiteSpace(t.TR_BlobName); }
                            <div class="pdf-btns">
                                @if (hasPdf)
                                {
                                    <a href="/Home/OpenTransmittalFile?id=@t.ID" target="_blank" title="Open @t.TR_FileName" class="pbtn pbtn-open">&#128196; Open</a>
                                    <a href="/Home/DownloadTransmittalFile?id=@t.ID" title="Download @t.TR_FileName" class="pbtn pbtn-save">⬇ Save</a>
                                }
                                else
                                {
                                    <span class="pbtn disabled">&#128196; Open</span>
                                    <span class="pbtn disabled">⬇ Save</span>
                                }
                                <button type="button" class="pbtn pbtn-upload btn-upload-pdf" data-tr-id="@t.ID" title="@(hasPdf ? "Replace PDF" : "Upload PDF")">&#128228;</button>
                            </div>
                        </td>
                        <td class="row-actions">
                            <button type="button" class="btn btn-primary" onclick="editTr(this)">Edit</button>
                            <button type="button" class="btn btn-danger delete-tr" data-id="@t.ID">Del</button>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>

    @await Html.PartialAsync("_DashboardFooter")

    <!-- Hidden delete form -->
    <form id="deleteTrForm" method="post" asp-action="DeleteTransmittal" asp-controller="Home" style="display:none;">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" id="deleteTrId" />
    </form>

    <!-- Hidden inline PDF upload form -->
    <form id="inlinePdfUploadForm" method="post" asp-action="UploadTransmittalFile" asp-controller="Home" enctype="multipart/form-data" style="display:none;">
        @Html.AntiForgeryToken()
        <input type="hidden" name="trId" id="inlinePdfTrId" />
        <input type="file" name="pdfFile" id="inlinePdfFileInput" accept=".pdf" />
    </form>

    <!-- Confirm delete modal -->
    <div class="modal" id="confirmDeleteTrModal" role="dialog" aria-modal="true" aria-labelledby="trDeleteTitle" aria-hidden="true">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title" id="trDeleteTitle">Confirm Delete</h2>
                <button class="close-modal" type="button" aria-label="Close" onclick="closeDeleteModal()">&times;</button>
            </div>
            <p id="confirmDeleteTrMessage" style="color:#176d8a; margin:0 0 16px 0;"></p>
            <div class="modal-actions">
                <button type="button" class="btn" onclick="closeDeleteModal()">Cancel</button>
                <button type="button" class="btn btn-danger" onclick="confirmTrDelete()">Delete</button>
            </div>
        </div>
    </div>

    <!-- Add / Edit modal -->
    <div class="modal" id="trEditModal" role="dialog" aria-modal="true" aria-labelledby="trEditTitle" aria-hidden="true">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title" id="trEditTitle">Add Transmittal</h2>
                <button class="close-modal" type="button" aria-label="Close" onclick="closeEditModal()">&times;</button>
            </div>
            <form asp-action="SaveTransmittal" asp-controller="Home" method="post" id="trForm">
                @Html.AntiForgeryToken()
                <input type="hidden" id="fID" name="ID" value="0" />
                <input type="hidden" id="fTR_Project_No" name="TR_Project_No" value="@(defaultProjectId)" />
                <div class="grid">
                    <div class="form-group">
                        <label for="fTransmittal">Transmittal</label>
                        <input class="form-control" id="fTransmittal" name="Transmittal" maxlength="30" />
                    </div>
                    <div class="form-group">
                        <label for="fDate">Date</label>
                        <input class="form-control" id="fDate" name="Date" type="date" />
                    </div>
                    <div class="form-group">
                        <label for="fDoc_No">Doc No</label>
                        <input class="form-control" id="fDoc_No" name="Doc_No" maxlength="30" />
                    </div>
                    <div class="form-group">
                        <label for="feGesDoc_No">eGesDoc No</label>
                        <input class="form-control" id="feGesDoc_No" name="eGesDoc_No" maxlength="20" />
                    </div>
                    <div class="form-group" style="grid-column:1/-1;">
                        <label for="fDocuments_Title">Documents Title</label>
                        <input class="form-control" id="fDocuments_Title" name="Documents_Title" maxlength="150" />
                    </div>
                    <div class="form-group">
                        <label for="fREV">REV</label>
                        <input class="form-control" id="fREV" name="REV" maxlength="3" />
                    </div>
                    <div class="form-group">
                        <label for="fRemarks">Remarks</label>
                        <input class="form-control" id="fRemarks" name="Remarks" maxlength="50" />
                    </div>
                    <div class="form-group">
                        <label for="fTransmittal_No">Transmittal No</label>
                        <input class="form-control" id="fTransmittal_No" name="Transmittal_No" maxlength="30" />
                    </div>
                    <div class="form-group">
                        <label for="fTR_Comment">TR Comment</label>
                        <select class="form-control" id="fTR_Comment" name="TR_Comment">
                            <option value="">-- Select --</option>
                            <option value="REVIEWED WITHOUT COMMENTS">REVIEWED WITHOUT COMMENTS</option>
                            <option value="REVIEWED WITH COMMENTS">REVIEWED WITH COMMENTS</option>
                            <option value="COMMENTS AS NOTED">COMMENTS AS NOTED</option>
                            <option value="FOR INFORMATION">FOR INFORMATION</option>
                            <option value="RECEIVED">RECEIVED</option>
                            <option value="REJECTED">REJECTED</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="fDate_TR">Date TR</label>
                        <input class="form-control" id="fDate_TR" name="Date_TR" type="date" />
                    </div>
                    <div class="form-group">
                        <label for="fTR_REV">TR REV</label>
                        <input class="form-control" id="fTR_REV" name="TR_REV" maxlength="3" />
                    </div>
                    <div class="form-group">
                        <label for="fSAPMT_Comment">SAPMT Comment</label>
                        <select class="form-control" id="fSAPMT_Comment" name="SAPMT_Comment">
                            <option value="">-- Select --</option>
                            <option value="REVIEWED WITHOUT COMMENTS">REVIEWED WITHOUT COMMENTS</option>
                            <option value="REVIEWED WITH COMMENTS">REVIEWED WITH COMMENTS</option>
                            <option value="COMMENTS AS NOTED">COMMENTS AS NOTED</option>
                            <option value="FOR INFORMATION">FOR INFORMATION</option>
                            <option value="RECEIVED">RECEIVED</option>
                            <option value="REJECTED">REJECTED</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="fDate_SAPMT">Date SAPMT</label>
                        <input class="form-control" id="fDate_SAPMT" name="Date_SAPMT" type="date" />
                    </div>
                    <div class="form-group">
                        <label for="fSAPMT_REV">SAPMT REV</label>
                        <input class="form-control" id="fSAPMT_REV" name="SAPMT_REV" maxlength="3" />
                    </div>
                    <div class="form-group">
                        <label for="fCategorize">Categorize</label>
                        <select class="form-control" id="fCategorize" name="Categorize">
                            <option value="">-- Select --</option>
                            <option value="PROCEDURES">PROCEDURES</option>
                            <option value="MANPOWER">MANPOWER</option>
                            <option value="OTHER">OTHER</option>
                            <option value="FMAR">FMAR</option>
                            <option value="STQ">STQ</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="fDiscipline">Discipline</label>
                        <select class="form-control" id="fDiscipline" name="Discipline">
                            <option value="">-- Select --</option>
                            <option value="QC">QC</option>
                            <option value="Project">Project</option>
                            <option value="Engineering">Engineering</option>
                            <option value="Construction">Construction</option>
                        </select>
                    </div>
                </div>
                <div class="modal-actions">
                    <button type="button" class="btn" onclick="closeEditModal()">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        // ---------- Project filter auto-submit ----------
        document.getElementById('projectSelect').addEventListener('change', function () {
            document.getElementById('trFilterForm').submit();
        });

        // ---------- Search / filter ----------
        const searchBox = document.getElementById('searchBox');
        const trTable = document.getElementById('trTable');
        const rowCountEl = document.getElementById('rowCount');

        function filterRows() {
            const term = searchBox.value.trim().toLowerCase();
            const rows = trTable.querySelectorAll('tbody tr');
            let visible = 0;
            rows.forEach(row => {
                const text = row.textContent.toLowerCase();
                const show = !term || text.includes(term);
                row.style.display = show ? '' : 'none';
                if (show) visible++;
            });
            rowCountEl.textContent = visible + ' row(s)';
        }
        searchBox.addEventListener('input', filterRows);
        filterRows();

        // ---------- Download Excel ----------
        document.getElementById('downloadBtn').addEventListener('click', function () {
            const pid = document.getElementById('projectSelect').value;
            const q = searchBox.value.trim();
            let url = '/Home/ExportTransmittal?projectId=' + encodeURIComponent(pid);
            if (q) url += '&q=' + encodeURIComponent(q);
            window.location.href = url;
        });

        // ---------- Add / Edit modal ----------
        const defaultDiscipline = '@Html.Raw(defaultDiscipline)';

        function openAddModal() {
            document.getElementById('trEditTitle').textContent = 'Add Transmittal';
            document.getElementById('fID').value = '0';
            document.getElementById('fTR_Project_No').value = document.getElementById('projectSelect').value;
            document.getElementById('fTransmittal').value = '';
            document.getElementById('fDate').value = '';
            document.getElementById('fDoc_No').value = '';
            document.getElementById('feGesDoc_No').value = '';
            document.getElementById('fDocuments_Title').value = '';
            document.getElementById('fREV').value = '';
            document.getElementById('fRemarks').value = '';
            document.getElementById('fTransmittal_No').value = '';
            document.getElementById('fTR_Comment').value = '';
            document.getElementById('fDate_TR').value = '';
            document.getElementById('fTR_REV').value = '';
            document.getElementById('fSAPMT_Comment').value = '';
            document.getElementById('fDate_SAPMT').value = '';
            document.getElementById('fSAPMT_REV').value = '';
            document.getElementById('fCategorize').value = '';
            document.getElementById('fDiscipline').value = defaultDiscipline;
            document.getElementById('trEditModal').style.display = 'flex';
        }

        function editTr(btn) {
            const row = btn.closest('tr');
            const d = row.dataset;
            document.getElementById('trEditTitle').textContent = 'Edit Transmittal #' + d.id;
            document.getElementById('fID').value = d.id;
            document.getElementById('fTR_Project_No').value = d.projectId || document.getElementById('projectSelect').value;
            document.getElementById('fTransmittal').value = d.transmittal || '';
            document.getElementById('fDate').value = d.date || '';
            document.getElementById('fDoc_No').value = d.docNo || '';
            document.getElementById('feGesDoc_No').value = d.egesdocNo || '';
            document.getElementById('fDocuments_Title').value = d.documentsTitle || '';
            document.getElementById('fREV').value = d.rev || '';
            document.getElementById('fRemarks').value = d.remarks || '';
            document.getElementById('fTransmittal_No').value = d.transmittalNo || '';
            document.getElementById('fTR_Comment').value = d.trComment || '';
            document.getElementById('fDate_TR').value = d.dateTr || '';
            document.getElementById('fTR_REV').value = d.trRev || '';
            document.getElementById('fSAPMT_Comment').value = d.sapmtComment || '';
            document.getElementById('fDate_SAPMT').value = d.dateSapmt || '';
            document.getElementById('fSAPMT_REV').value = d.sapmtRev || '';
            document.getElementById('fCategorize').value = d.categorize || '';
            document.getElementById('fDiscipline').value = d.discipline || '';
            document.getElementById('trEditModal').style.display = 'flex';
        }

        function closeEditModal() {
            document.getElementById('trEditModal').style.display = 'none';
        }

        // ---------- Delete ----------
        let pendingDeleteId = null;
        document.querySelectorAll('.delete-tr').forEach(btn => {
            btn.addEventListener('click', function () {
                pendingDeleteId = this.dataset.id;
                document.getElementById('confirmDeleteTrMessage').textContent = 'Are you sure you want to delete Transmittal record #' + pendingDeleteId + '?';
                document.getElementById('confirmDeleteTrModal').style.display = 'flex';
            });
        });
        function closeDeleteModal() {
            document.getElementById('confirmDeleteTrModal').style.display = 'none';
            pendingDeleteId = null;
        }
        function confirmTrDelete() {
            if (!pendingDeleteId) return;
            document.getElementById('deleteTrId').value = pendingDeleteId;
            document.getElementById('deleteTrForm').submit();
        }

        // ---------- Inline PDF upload ----------
        document.querySelectorAll('.btn-upload-pdf').forEach(btn => {
            btn.addEventListener('click', function () {
                const trId = this.dataset.trId;
                document.getElementById('inlinePdfTrId').value = trId;
                document.getElementById('inlinePdfFileInput').value = '';
                document.getElementById('inlinePdfFileInput').click();
            });
        });
        document.getElementById('inlinePdfFileInput').addEventListener('change', function () {
            if (this.files.length > 0) {
                document.getElementById('inlinePdfUploadForm').submit();
            }
        });

        // ---------- Close modals on backdrop click ----------
        document.querySelectorAll('.modal').forEach(modal => {
            modal.addEventListener('click', function (e) {
                if (e.target === this) {
                    this.style.display = 'none';
                    pendingDeleteId = null;
                }
            });
        });

        // ---------- Auto-dismiss flash message ----------
        const flash = document.getElementById('topFlashMsg');
        if (flash) setTimeout(() => { flash.style.transition = 'opacity .5s'; flash.style.opacity = '0'; setTimeout(() => flash.remove(), 600); }, 6000);
    </script>
</body>
</html>
