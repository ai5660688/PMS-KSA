<!DOCTYPE html>
<html lang="en">
<head>
 <title>PMS - Dashboard</title>
 <link rel="icon" type="image/png" href="~/img/title_logo.png">
 <link rel="stylesheet" href="~/css/DashboardStyle.css" asp-append-version="true">
 <meta name="viewport" content="width=device-width, initial-scale=1.0">
 <style>
 /* Spool Status Summary styles (match dashboard palette) */
 .content { box-sizing: border-box; padding:12px 12px 56px 12px; }
 /* ensure status-summary can be the positioning context for the overlay if needed */
 #status-summary { position: relative; }
 .card { background: #faf2e3; border:1px solid #e6f6fa; border-radius:8px; box-shadow:02px 6px rgba(31,153,190,0.12); margin:12px 0; }
 .card-header { padding:10px 14px; border-bottom:1px solid #e6f6fa; color: #176d8a; font-weight:700; font-size:1.1em; display: flex; align-items: center; gap:8px; justify-content: space-between; }
 .card-body { padding:10px 12px 14px 12px; }
 .muted { color: #1f99be; font-weight:600; }
 .summary-grid { display: grid; grid-template-columns:1fr; gap:12px; }
 .table-wrap { overflow: auto; max-height:58vh; }
 table.ss { width:100%; border-collapse: collapse; background: #fff8eb; }
 table.ss th, table.ss td { border:1px solid #e6f6fa; padding:6px 8px; color: #176d8a; font-size: .95em; }
 table.ss th { background: #f0fbff; text-align: left; position: sticky; top:0; z-index:1; }
 .col-name { width:70%; }
 .col-count { width:15%; text-align: right; }
 .col-pct { width:15%; text-align: right; }
 .lvl-0 { font-weight:700; }
 .lvl-1 { padding-left:16px; }
 .lvl-2 { padding-left:28px; font-style: italic; }
 .lvl-3 { padding-left:42px; }
 .badge { display: inline-block; padding:2px 6px; border-radius:12px; font-size: .75em; font-weight:700; margin-left:8px; background: #e6f6fa; color: #176d8a; }
 .split { display: flex; gap:14px; align-items: center; flex-wrap: wrap; }
 /* Make progress bar adapt to column width but not full width */
 .bar-wrap { display: flex; height:18px; background: #fff; border:1px solid #e6f6fa; border-radius:9px; overflow: hidden; flex: 0 1 520px; min-width:200px; max-width:930px; width:100%; }
 .bar-shop { height:100%; background: #0072B2; }
 .bar-site { height:100%; background: #E69F00; }
 .hl { font-weight:700; color: #176d8a; }
 .overall-stats { white-space: nowrap; }
 /* Two-column layout: pivot tables left (narrower), charts right (wider) */
 .status-layout { display: grid; grid-template-columns: minmax(0,1fr) minmax(0,1.2fr); gap:12px; align-items: start; }
 .right-col .chart-grid { display: grid; grid-template-columns: repeat(auto-fit,minmax(260px,1fr)); gap:12px; }
 .chart-card { background: #fff8eb; border:1px solid #e6f6fa; border-radius:8px; padding:8px; display: flex; flex-direction: column; margin:12px 0; }
 .chart-title { color: #176d8a; font-weight:700; margin:2px 6px 4px; font-size: .95em; }
 .chart-box { position: relative; width:100%; height:240px; }
 .chart-box.sm { height:280px; }
 .chart-card.full-width { grid-column:1 / -1; }
 /* Taller Shop Spool Status chart */
 .chart-card.full-width .chart-box { height:420px; }
 /* Searchable select dropdown widget */
   .ss-wrap { position:relative; display:inline-block; vertical-align:middle; min-width:350px; }
   .ss-input { width:100%; box-sizing:border-box; cursor:pointer; padding:4px 6px; border:1px solid #cce7ef; border-radius:4px; color:#176d8a; font-size:.95rem; font-weight:normal; font-family:inherit; background:#fff; }
   .ss-input:focus { cursor:text; border-color:#176d8a; outline:none; }
   .ss-list { display:none; position:absolute; left:0; right:0; top:100%; z-index:1200; background:#fff; border:1px solid #176d8a; border-top:none; border-radius:0 0 6px 6px; max-height:220px; overflow-y:auto; box-shadow:0 4px 10px rgba(0,0,0,.12); }
   .ss-item { padding:6px 10px; cursor:pointer; font-size:.9rem; color:#176d8a; font-weight:normal; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
   .ss-item:hover, .ss-item.ss-highlight { background:#e6f6fa; }
   .ss-item.ss-active { font-weight:700; }
   .ss-empty { padding:6px 10px; font-size:.85rem; color:#999; font-style:italic; }
   .ss-open .ss-input { border-radius:4px 4px 0 0; border-color:#176d8a; }
   .ss-list::-webkit-scrollbar { width:10px; }
   .ss-list::-webkit-scrollbar-track { background:#f0fbff; border-radius:8px; }
   .ss-list::-webkit-scrollbar-thumb { background:#176d8a; border-radius:8px; border:2px solid #f0fbff; }
   .ss-list::-webkit-scrollbar-thumb:hover { background:#125a6e; }
   .ss-list { scrollbar-width:thin; scrollbar-color:#176d8a #f0fbff; }

   /* Responsive */
   @@media (max-width:1200px) {
 .status-layout { grid-template-columns:1fr; }
 .right-col .chart-grid { grid-template-columns:1fr; }
 .chart-box { height:220px; }
 .chart-box.sm { height:220px; }
 .chart-card.full-width .chart-box { height:320px; }
 }
 @@media (max-width:860px) {
 .bar-wrap { width:100%; }
 .right-col .chart-grid { grid-template-columns:1fr; }
 }
 @@media (max-width:600px) {
 .card { margin:8px 0; }
 .card-header { flex-direction: column; align-items: flex-start; gap:4px; }
 .status-layout { grid-template-columns:1fr; }
 #projectSelect, .ss-wrap { width:100%; }
 .overall-stats { width:100%; }
 .chart-box { height:200px; }
 .chart-box.sm { height:200px; }
 .chart-card.full-width .chart-box { height:260px; }
 .table-wrap { max-height:50vh; }
 .bar-wrap { min-width:0; flex:1 1 auto; }
 }

/* Center align Count and % columns */
table.ss th.col-count,
table.ss td.col-count,
table.ss th.col-pct,
table.ss td.col-pct { text-align: center; }

/* Match chart containers spacing with pivot cards */
.left-col .summary-grid > .card { margin:12px 0 !important; }
.right-col .chart-grid > .chart-card { margin:12px 0 !important; }

/* Custom scrollbar for Shop Spool Status pivot table */
#shopTableWrap::-webkit-scrollbar { width:10px; height:10px; }
#shopTableWrap::-webkit-scrollbar-track { background: #f0f4f8; border-radius:8px; }
#shopTableWrap::-webkit-scrollbar-thumb { background: #0072B2; border-radius:8px; border:2px solid #f0f4f8; }
#shopTableWrap::-webkit-scrollbar-thumb:hover { background: #005a8f; }
#shopTableWrap::-webkit-scrollbar-thumb:active { background: #00486b; }
#shopTableWrap::-webkit-scrollbar-corner { background: transparent; }
@@supports (scrollbar-color: #000 #fff) {
#shopTableWrap { scrollbar-color: #0072B2 #f0f4f8; }
}
@@supports (scrollbar-width: thin) {
#shopTableWrap { scrollbar-width: thin; }
}

/* Right-aligned actions inside card body */
.card-actions { display: flex; justify-content: flex-end; margin-top:10px; }

/* Button styles to match Line List/Download */
.btn { padding:6px 12px; border:none; border-radius:4px; cursor:pointer; font-weight:600; text-decoration:none; display:inline-block; line-height:1; }
 a.btn, a.btn:link, a.btn:visited, a.btn:hover, a.btn:focus, a.btn:active { text-decoration:none; }
 .btn-outline { background:#fff; color:#176d8a; border:1px solid #1f99be; }
 .btn-outline:hover { background:#1f99be; color:#fff; border-color:#176d8a; }

 /* Loading overlay - centered in the middle of the body */
 .hidden { display: none !important; }
 .loader-overlay { position: fixed; top:50%; left:50%; transform: translate(-50%, -50%); background: transparent; display:flex; align-items:center; justify-content:center; z-index:10000; flex-direction:column; gap:12px; color:#176d8a; font-weight:700; border-radius:0; padding:0; box-shadow:none; width: auto; max-width:780px; }
 .loader-box { display:flex; align-items:center; gap:12px; background:transparent; border:0; padding:0; border-radius:0; }
 .spinner { width:36px; height:36px; display:inline-block; animation: spin 1s linear infinite; transform-origin: 50% 50%; transform-box: fill-box; }
 @@-webkit-keyframes spin {
 from { -webkit-transform: rotate(0deg); }
 to { -webkit-transform: rotate(360deg); }
 }
 @@keyframes spin {
 from { transform: rotate(0deg); }
 to { transform: rotate(360deg); }
 }
@@media (max-width:420px) { .loader-overlay { width:92%; } .loader-box { padding:12px 14px; } }
 </style>
</head>
<body>
@{
 var projects = ViewBag.Projects as IEnumerable<dynamic>;
 var defaultProjectId = ViewBag.DefaultProjectId as int?;
}
 @await Html.PartialAsync("_DashboardHeader")

 <!-- Centered loader (fixed) placed in body so it sits in the middle of the viewport) -->
 <div id="dashboardLoader" class="loader-overlay" aria-hidden="false" style="display:flex;">
 <div class="loader-box">
 <!-- Keep only the rotating arc circle (remove duplicate static track to avoid two rings) -->
 <svg class="spinner" role="img" aria-label="Loading" width="36" height="36" viewBox="0 0 50 50" xmlns="http://www.w3.org/2000/svg">
 <circle cx="25" cy="25" r="20" fill="none" stroke="#176d8a" stroke-width="4" stroke-linecap="round" stroke-dasharray="90 125"></circle>
 </svg>
 <div style="font-weight:700; color:#176d8a;">Loading Spool Status Summary...</div>
 </div>
 </div>

 <div class="content" id="status-summary">
 <div class="card">
 <div class="card-header">
 <span>Spool Status Summary</span>
 <span>
 <label for="projectSelect" style="font-weight:600;color:#176d8a;">Project: </label>
 <select id="projectSelect" style="padding:4px 6px; border:1px solid #cce7ef; border-radius:4px; color: #176d8a;">
 @if (projects != null)
 {
 foreach (var p in projects)
 {
 if (defaultProjectId.HasValue && p.Project_ID == defaultProjectId.Value)
 {
 <option value="@p.Project_ID" selected>@p.Project_ID - @p.Project_Name</option>
 }
 else
 {
 <option value="@p.Project_ID">@p.Project_ID - @p.Project_Name</option>
 }
 }
 }
 </select>
 </span>
 </div>
 <div class="card-body">
 <div class="split" id="overallSplit">
 <div class="muted">Overall</div>
 <div class="bar-wrap">
 <div class="bar-shop" id="barShop" style="width:0%"></div>
 <div class="bar-site" id="barSite" style="width:0%"></div>
 </div>
 <div class="muted overall-stats"><span class="hl" id="lblShop">Shop0.00% (0)</span> | <span class="hl" id="lblSite">Site0.00% (0)</span> | <span class="hl" id="lblTotal">Total0</span></div>
 </div>

 <div class="status-layout">
 <div class="left-col">
 <div class="summary-grid">
 <div class="card">
 <div class="card-header">Site Spool Status</div>
 <div class="card-body table-wrap">
 <table class="ss" id="tblSite">
 <thead>
 <tr><th class="col-name">Status</th><th class="col-count">Count</th><th class="col-pct">%</th></tr>
 </thead>
 <tbody></tbody>
 </table>
 </div>
 </div>
 <div class="card">
 <div class="card-header">Shop Spool Status</div>
 <div class="card-body table-wrap" id="shopTableWrap">
 <table class="ss" id="tblShop">
 <thead>
 <tr><th class="col-name">Status</th><th class="col-count">Count</th><th class="col-pct">%</th></tr>
 </thead>
 <tbody></tbody>
 </table>
 </div>
 </div>
 </div>
 </div>

 <div class="right-col">
 <div class="chart-grid">
 <div class="chart-card">
 <div class="chart-title">Shop Breakdown</div>
 <div class="chart-box sm"><canvas id="chartShop"></canvas></div>
 </div>
 <div class="chart-card">
 <div class="chart-title">Site (Erection) Breakdown</div>
 <div class="chart-box sm"><canvas id="chartSite"></canvas></div>
 </div>
 <!-- Full width Shop Spool Status (VB style) bar chart -->
 <div class="chart-card full-width">
 <div class="chart-title">Shop Spool In Progress</div>
 <div class="chart-box"><canvas id="chartShopBar"></canvas></div>
 </div>
 </div> <!-- close .chart-grid -->
 </div> <!-- close .right-col -->
 </div> <!-- close .status-layout -->

 <!-- Actions: bottom-right download inside Spool Status Summary container -->
 <div class="card-actions">
 </div>
 </div> <!-- close .card-body -->
 </div> <!-- close .card -->
 </div> <!-- close .content -->

 @await Html.PartialAsync("_DashboardFooter")

 <script src="~/lib/chart.js/chart.umd.min.js" asp-append-version="true"></script>
 <script>
 // Simple color shading util (-100..100)
 function shadeColor(color, percent) {
 try {
 if (!color) return '#999';
 const p = Math.max(-100, Math.min(100, percent)) /100;
 // hex
 if (color[0] === '#') {
 let c = color.substring(1);
 if (c.length ===3) c = c.split('').map(x => x + x).join(''); // convert 3-digit hex to 6-digit
 const num = parseInt(c,16);
 let r = (num >>16) &0xff, g = (num >>8) &0xff, b = num &0xff;
 r = Math.round(r + (p <0 ? r * p : (255 - r) * p));
 g = Math.round(g + (p <0 ? g * p : (255 - g) * p));
 b = Math.round(b + (p <0 ? b * p : (255 - b) * p));
 return '#' + ((1 <<24) + (r <<16) + (g <<8) + b).toString(16).slice(1);
 }
 // rgb(a)
 const m = color.match(/rgba?\((\d+),\s*(\d+),\s*(\d+)(?:,\s*(\d+(?:\.\d+)?))?\)/i);
 if (m) {
 let r = parseInt(m[1]), g = parseInt(m[2]), b = parseInt(m[3]);
 const a = m[4] !== undefined ? parseFloat(m[4]) :1;
 r = Math.round(r + (p <0 ? r * p : (255 - r) * p));
 g = Math.round(g + (p <0 ? g * p : (255 - g) * p));
 b = Math.round(b + (p <0 ? b * p : (255 - b) * p));
 return `rgba(${r}, ${g}, ${b}, ${a})`;
 }
 return color;
 } catch { return color; }
 }
 
 // Chart.js plugin to render "3D" extruded pie before top layer is drawn
 const ExtrudedPiePlugin = {
 id: 'extrudedPie',
 beforeDatasetDraw(chart, args, pluginOptions) {
 if (!pluginOptions || !pluginOptions.enabled) return;
 if (chart.canvas.id !== 'chartShop') return;
 const depth = Math.max(2, Math.min(40, pluginOptions.depth ||12));
 const ctx = chart.ctx;
 const meta = chart.getDatasetMeta(args.index);
 if (!meta || meta.type !== 'doughnut') return;
 const elements = meta.data || [];
 for (let z = depth, zEnd =0; z > zEnd; z--) {
 elements.forEach(el => {
 const p = el.getProps(['x', 'y', 'startAngle', 'endAngle', 'innerRadius', 'outerRadius'], true);
 ctx.save();
 ctx.translate(0, z); // shift down to create thickness
 ctx.beginPath();
 const base = el.options && el.options.backgroundColor ? el.options.backgroundColor : '#1f99be';
 ctx.fillStyle = shadeColor(base, -25);
 ctx.moveTo(p.x, p.y);
 ctx.arc(p.x, p.y, p.outerRadius, p.startAngle, p.endAngle);
 ctx.arc(p.x, p.y, p.innerRadius, p.endAngle, p.startAngle, true);
 ctx.closePath();
 ctx.fill();
 ctx.restore();
 });
 }
 }
 };
 if (window.Chart) { Chart.register(ExtrudedPiePlugin); }
 
 function qs(obj) { const usp = new URLSearchParams(); Object.entries(obj).forEach(([k, v]) => { if (v !== undefined && v !== null && v !== '') usp.append(k, v); }); return usp.toString(); }
 let chartSite, chartShop, chartShopBar;
 
 // Show/hide loading overlay and content
 function showLoading() {
 const overlay = document.getElementById('dashboardLoader');
 // hide only the main card inside the status-summary so the centered overlay remains visible
 const card = document.querySelector('#status-summary > .card');
 if (overlay) overlay.style.display = 'flex';
 if (card) card.classList.add('hidden');
 }
 function hideLoading() {
 const overlay = document.getElementById('dashboardLoader');
 const card = document.querySelector('#status-summary > .card');
 if (overlay) { overlay.style.display = 'none'; overlay.setAttribute('aria-hidden','true'); }
 if (card) card.classList.remove('hidden');
 }
 
 function renderEmpty() {
 renderOverall({ totalOverall:0, totalSite:0, totalShop:0 });
 renderSite([]);
 renderShop([]);
 renderCharts([], [], { totalOverall:0, totalSite:0, totalShop:0 });
 }
 async function loadSpoolStatusSummary(projectId) {
 try {
 showLoading();
 const res = await fetch('/Home/GetSpoolStatusSummary' + (projectId ? ('?' + qs({ projectId })) : ''));
 if (!res.ok) { renderEmpty(); return; }
 const data = await res.json();
 renderOverall(data?.totals);
 renderSite(data?.site || []);
 renderShop(data?.shop || []);
 renderCharts(data?.site || [], data?.shop || [], data?.totals || {});
 } catch {
 renderEmpty();
 } finally {
 hideLoading();
 }
 }
 function fmtPct(x) { if (!isFinite(x) || x <=0) return '0%'; return (x *100).toFixed(2) + '%'; }
 function renderOverall(t) {
 const total = (t?.totalOverall) ||0, site = (t?.totalSite) ||0, shop = (t?.totalShop) ||0;
 const shopPct = total >0 ? (shop / total *100) :0; const sitePct = total >0 ? (site / total *100) :0;
 document.getElementById('barShop').style.width = shopPct.toFixed(2) + '%';
 document.getElementById('barSite').style.width = sitePct.toFixed(2) + '%';
 const lblShop = document.getElementById('lblShop');
 const lblSite = document.getElementById('lblSite');
 const lblTotal = document.getElementById('lblTotal');
 if (lblShop) lblShop.textContent = `Shop ${shopPct.toFixed(2)}% (${shop})`;
 if (lblSite) lblSite.textContent = `Site ${sitePct.toFixed(2)}% (${site})`;
 if (lblTotal) lblTotal.textContent = `Total ${total}`;
 }
 function addRow(tbody, name, count, pct, level) {
 const tr = document.createElement('tr');
 const td1 = document.createElement('td');
 td1.textContent = name; td1.className = 'lvl-' + (level ||0);
 const td2 = document.createElement('td');
 td2.className = 'col-count'; td2.textContent = count ??0;
 const td3 = document.createElement('td');
 td3.className = 'col-pct'; td3.textContent = fmtPct(pct ??0);
 tr.appendChild(td1); tr.appendChild(td2); tr.appendChild(td3); tbody.appendChild(tr);
 }
 function renderSite(site) {
 const tbody = document.querySelector('#tblSite tbody'); tbody.innerHTML = '';
 let wroteHeader = false;
 site.forEach(g => {
 addRow(tbody, g.name, g.count, g.percent,0);
 (g.children || []).forEach(it => addRow(tbody, ' ' + it.name, it.count, it.percent,1));
 wroteHeader = true;
 });
 if (!wroteHeader) addRow(tbody, 'No data',0,0,0);
 }
 function renderShop(shop) {
 const tbody = document.querySelector('#tblShop tbody'); tbody.innerHTML = '';
 if (!shop || shop.length ===0) { addRow(tbody, 'No data',0,0,0); return; }
 shop.forEach(g => {
 addRow(tbody, g.name, g.count, g.percent,0);
 (g.children || []).forEach(sg => {
 addRow(tbody, ' ' + sg.name, sg.count, sg.percent,1);
 (sg.children || []).forEach(it => addRow(tbody, ' ' + it.name, it.count, it.percent,2));
 });
 });
 }
 function destroyCharts() {
 if (chartSite) { chartSite.destroy(); chartSite = null; }
 if (chartShop) { chartShop.destroy(); chartShop = null; }
 if (chartShopBar) { chartShopBar.destroy(); chartShopBar = null; }
 }

 // Compute dynamic height and bar thickness for Shop Spool Status bar chart
 function calcBarChartLayout(datasetCount, rowCount) {
 const dsCount = Math.max(1, datasetCount |0);
 const rows = Math.max(1, rowCount |0);
 const minH =280, maxH =1000; // px - allow a bit more space
 const basePerRow =36; // base height per category row (thicker)
 const extraPerRow = Math.min(30, Math.max(0, dsCount -1) *5); // add more space if many datasets per row
 const perRow = basePerRow + extraPerRow; // px per row
 const height = Math.max(minH, Math.min(maxH, Math.round(rows * perRow +80))); // +legend/axes padding
 const availablePerCat = (height -80) / rows; // space per category in px
 const barThickness = Math.max(16, Math.min(48, Math.floor((availablePerCat *0.9) / dsCount))); // thicker bars
 const categoryPercentage =0.95; // use more of the category slot
 return { height, barThickness, categoryPercentage };
 }

 function renderCharts(site, shop, totals) {
 if (typeof Chart === 'undefined') return; // skip if CDN blocked
 destroyCharts();
 // Site donut
 const separatorColor = '#F5F7FA';
 // Site donut (warm/calm Tableau-inspired palette)
 const gErection = (site || []).find(x => (x.name||'').toLowerCase().includes('erection'));
 const siteChildren = (gErection && Array.isArray(gErection.children)) ? gErection.children : [];
 const siteLabels = siteChildren.length ? siteChildren.map(x => x.name) : ['No data'];
 const siteData = siteChildren.length ? siteChildren.map(x => x.count||0) : [1];
 const siteColors = ['#F28E2B','#E15759','#EDC948','#B07AA1','#59A14F','#4E79A7','#76B7B2','#9C755F'];
 const siteCtx = document.getElementById('chartSite').getContext('2d');
 chartSite = new Chart(siteCtx, { type: 'doughnut', data: { labels: siteLabels, datasets: [{ data: siteData, backgroundColor: siteLabels.map((_,i)=> siteColors[i % siteColors.length]), borderWidth:2, borderColor: separatorColor, hoverOffset:6 }] }, options: { responsive:true, maintainAspectRatio:false, plugins: { legend: { position: 'bottom', labels:{ boxWidth:12, color:'#176d8a' } } }, cutout: '55%' } });
 // Shop pie with3D extrusion
 const flattened = [];
 (shop || []).forEach(g => { if ((g.name||'').toLowerCase().includes('iii. fabrication')) { (g.children || []).forEach(sg => flattened.push({ name: sg.name, count: sg.count })); } else { flattened.push({ name: g.name, count: g.count }); } });
 const shopLabels = flattened.length ? flattened.map(x => x.name) : ['No data'];
 const shopData = flattened.length ? flattened.map(x => x.count||0) : [1];
 const shopColors = ['#4E79A7','#76B7B2','#59A14F','#E15759','#F28E2B','#B07AA1','#EDC948','#9C755F','#BAB0AC','#2E4057'];
 const shopCtx = document.getElementById('chartShop')?.getContext('2d');
 if (shopCtx) {
 chartShop = new Chart(shopCtx, { type: 'doughnut', data: { labels: shopLabels, datasets: [{ data: shopData, backgroundColor: shopLabels.map((_,i)=> shopColors[i % shopColors.length]), borderWidth:2, borderColor: separatorColor, hoverOffset:6 }] }, options: { responsive:true, maintainAspectRatio:false, layout: { padding: { top:0, bottom:12 } }, plugins: { legend: { position: 'bottom', labels:{ boxWidth:12, color:'#176d8a', padding:16 } }, extrudedPie: { enabled: true, depth:12 } }, cutout: '0%' } });
 }
 // Shop Spool In Progress stacked bar
 const fabGroup = (shop.find(x => (x.name||'').toLowerCase().includes('iii. fabrication')) || { children: [] });
 const groups = Array.isArray(fabGroup.children) ? fabGroup.children : [];
 const groupLabels = groups.map(g => g.name);
 const groupLetter = (name) => { const m = (name || '').match(/^\s*([A-Za-z])/); return (m && m[1]) ? m[1].toUpperCase() : ''; };
 const palette = ['#4E79A7','#F28E2B','#E15759','#76B7B2','#59A14F','#EDC948','#B07AA1','#9C755F','#BAB0AC','#2E4057','#8CD17D','#FFBE7D'];
 let datasets = []; let maxChildren =0; let dsIdx =0;
 groups.forEach((g, gi) => {
 const kids = Array.isArray(g.children) ? g.children : [];
 maxChildren = Math.max(maxChildren, kids.length);
 kids.forEach((it) => {
 const data = new Array(groupLabels.length).fill(0);
 data[gi] = Number(it?.count) ||0;
 datasets.push({ label: `${groupLetter(g.name)}-${it?.name ?? ''}`.trim(), data, backgroundColor: palette[dsIdx % palette.length], barPercentage:0.85, categoryPercentage:0.9, stack: 'total', borderWidth:1, borderColor: separatorColor, borderSkipped: false, borderRadius:4 });
 dsIdx++;
 });
 });

 // fallback to4 broad phases if no children present
 let labelsForBar = groupLabels;
 if (datasets.length ===0) {
 const cA = groups.find(x => (x.name||'').toLowerCase() === 'a. production')?.count ||0;
 const cB = groups.find(x => (x.name||'').toLowerCase() === 'b. dispatch')?.count ||0;
 const cC = groups.find(x => (x.name||'').toLowerCase() === 'c. painting')?.count ||0;
 const cD = groups.find(x => (x.name||'').toLowerCase() === 'd. qc')?.count ||0;
 labelsForBar = ['A. PRODUCTION','B. DISPATCH','C. PAINTING','D. QC'];
 datasets = [{ label: 'Count', data: [cA, cB, cC, cD], backgroundColor: '#4E79A7', barPercentage:0.85, categoryPercentage:0.9, stack: 'total', borderWidth:1, borderColor: separatorColor, borderSkipped:false, borderRadius:4 }];
 }

 // compute layout based on max children per group (for bar thickness scaling)
 const rows = datasets.length >0 ? (labelsForBar.length ||4) :4;
 const dsCount = datasets.length >0 ? (maxChildren ||1) :1;
 const dims = calcBarChartLayout(dsCount, rows);
 const shbarBox = document.getElementById('chartShopBar')?.closest('.chart-box');
 if (shbarBox) { shbarBox.style.height = dims.height + 'px'; }
 datasets.forEach(ds => { ds.barThickness = dims.barThickness; ds.maxBarThickness = dims.barThickness; ds.categoryPercentage = dims.categoryPercentage; });
 const shbarCtx = document.getElementById('chartShopBar').getContext('2d');
 chartShopBar = new Chart(shbarCtx, { type: 'bar', data: { labels: labelsForBar, datasets }, options: { responsive: true, maintainAspectRatio: false, indexAxis: 'y', layout: { padding: { right:36 } }, plugins: { legend: { display: true, position: 'right', align: 'start', labels: { color: '#176d8a', boxWidth:18, boxHeight:12, padding:6 } }, tooltip: { enabled: true, callbacks: { label: c => { const total = (c.chart.data.datasets || []).reduce((sum, ds) => sum + (Number(ds.data?.[c.dataIndex]) ||0),0); const pct = total >0 ? ((Number(c.parsed?.x) ||0) / total *100).toFixed(1) + '%' : '0%'; return `${c.dataset.label}: ${c.parsed.x} (${pct})`; } } } }, scales: { x: { stacked: true, beginAtZero: true, grid: { color: '#e6f6fa' }, ticks: { color: '#176d8a' } }, y: { stacked: true, grid: { color: '#f0fbff' }, ticks: { color: '#176d8a' } } } } });
 // Increase container height when legend is tall so legend doesn't get clipped. Estimate legend height from dataset count and legend label sizing.
 try {
 const legendCfg = (chartShopBar?.options?.plugins?.legend?.labels) || {};
 const itemBoxH = legendCfg.boxHeight ||12;
 const itemPadding = legendCfg.padding ||6;
 const legendItems = (chartShopBar?.data?.datasets || []).length;
 const legendHeightApprox = legendItems * (itemBoxH + itemPadding);
 if (shbarBox) {
 // Add some padding for axes/title area
 const needed = Math.max(dims.height, Math.round(legendHeightApprox +60));
 shbarBox.style.height = needed + 'px';
 }
 
 // --- New: ensure legend text does not wrap/truncate by expanding legend area width when needed ---
 try {
 const itemBoxW = legendCfg.boxWidth ||18;
 const fontSize = (legendCfg.font && legendCfg.font.size) ||12;
 const fontFamily = (legendCfg.font && legendCfg.font.family) || getComputedStyle(document.body).fontFamily || 'sans-serif';
 const tmpCtx = document.createElement('canvas').getContext('2d');
 tmpCtx.font = `${fontSize}px ${fontFamily}`;
 const labels = (chartShopBar?.data?.datasets || []).map(ds => ds.label || '');
 let maxLabelW =0;
 labels.forEach(l => { const w = tmpCtx.measureText(l).width; if (w > maxLabelW) maxLabelW = w; });
 // compute needed legend width (label + symbol + padding buffer)
 const neededLegendW = Math.ceil(maxLabelW + itemBoxW + itemPadding *4);
 // current container width and a safe cap to avoid overflowing small screens
 const currentContainerW = shbarBox.clientWidth || shbarBox.offsetWidth ||1000;
 // allow larger expansion (up from90% to98% of window width)
 const maxAllowed = Math.round(window.innerWidth *0.98);
 // ensure more room for the chart area (further increased padding)
 const minExtraForChart =300;
 const finalW = Math.min(maxAllowed, Math.max(currentContainerW, neededLegendW + minExtraForChart));
 // apply only if it's larger than current so we don't shrink existing layout
 if (shbarBox) {
 // If the final desired width is reasonable relative to viewport, expand; otherwise put legend at bottom to avoid horizontal clipping on small screens
 const cardEl = shbarBox.closest('.chart-card') || shbarBox.parentElement;
 if (finalW > currentContainerW && finalW <= maxAllowed -10) {
 // expand width so legend fits
 shbarBox.style.boxSizing = 'border-box';
 shbarBox.style.width = finalW + 'px';
 shbarBox.style.minWidth = finalW + 'px';
 shbarBox.style.maxWidth = 'none';
 if (cardEl) { cardEl.style.overflowX = 'auto'; }
 } else {
 // viewport too small to expand: move legend below chart so it doesn't clip
 try {
 if (chartShopBar) {
 chartShopBar.options.plugins.legend.position = 'bottom';
 chartShopBar.options.plugins.legend.align = 'center';
 chartShopBar.update();
 }
 } catch (e) { /* ignore chart update errors */ }
 // make chart box adapt to available width
 shbarBox.style.width = '100%';
 shbarBox.style.minWidth = '0';
 shbarBox.style.maxWidth = '100%';
 if (cardEl) { cardEl.style.overflowX = 'visible'; }
 }
 }
 } catch (e) {
 // safe-fail: do nothing if measurement/DOM not available
 }
 } catch (e) { /* ignore */ }
 }
 // Searchable dropdown widget for Project select
 function makeSearchableSelect(sel){
 if(!sel || sel._ssWidget) return;
 sel.style.display='none';
 var wrap=document.createElement('div'); wrap.className='ss-wrap'; wrap.style.display='inline-block';
 sel.parentNode.insertBefore(wrap,sel); wrap.appendChild(sel);
 var input=document.createElement('input'); input.type='text'; input.className='ss-input'; input.setAttribute('autocomplete','off'); input.setAttribute('spellcheck','false'); input.placeholder='';
 wrap.appendChild(input);
 var list=document.createElement('div'); list.className='ss-list'; wrap.appendChild(list);
 var items=[],highlighted=-1,open=false;
 function buildItems(){items=[];Array.from(sel.options).forEach(function(opt){items.push({value:opt.value,text:opt.text||opt.value});});}
 function syncInputText(){var idx=sel.selectedIndex;input.value=idx>=0&&sel.options[idx]?(sel.options[idx].text||sel.options[idx].value):'';}
 function render(filter){list.innerHTML='';highlighted=-1;var lc=(filter||'').toLowerCase();var count=0;
 items.forEach(function(item,i){if(lc&&!(item.text||'').toLowerCase().includes(lc))return;
 var div=document.createElement('div');div.className='ss-item';div.textContent=item.text;div.dataset.idx=String(i);
 if(item.value===sel.value)div.classList.add('ss-active');
 div.addEventListener('mousedown',function(e){e.preventDefault();pick(i);});list.appendChild(div);count++;});
 if(count===0){var em=document.createElement('div');em.className='ss-empty';em.textContent='No match';list.appendChild(em);}}
 function pick(idx){if(idx<0||idx>=items.length)return;sel.value=items[idx].value;syncInputText();close();sel.dispatchEvent(new Event('change',{bubbles:true}));}
 function show(){if(open)return;open=true;render(input.value!==(items[sel.selectedIndex]?items[sel.selectedIndex].text:'')?input.value:'');list.style.display='block';wrap.classList.add('ss-open');}
 function close(){open=false;list.style.display='none';wrap.classList.remove('ss-open');highlighted=-1;}
 function highlightItem(dir){var visible=list.querySelectorAll('.ss-item');if(!visible.length)return;
 if(dir==='down')highlighted=highlighted<visible.length-1?highlighted+1:0;else highlighted=highlighted>0?highlighted-1:visible.length-1;
 visible.forEach(function(el,i){el.classList.toggle('ss-highlight',i===highlighted);});if(visible[highlighted])visible[highlighted].scrollIntoView({block:'nearest'});}
 input.addEventListener('focus',function(){buildItems();input.select();show();});
 input.addEventListener('input',function(){buildItems();show();render(input.value);});
 input.addEventListener('keydown',function(e){
 if(e.key==='ArrowDown'){e.preventDefault();if(!open){show();render('');}highlightItem('down');}
 else if(e.key==='ArrowUp'){e.preventDefault();highlightItem('up');}
 else if(e.key==='Enter'){e.preventDefault();if(open&&highlighted>=0){var vis=list.querySelectorAll('.ss-item');if(vis[highlighted]){var idx=parseInt(vis[highlighted].dataset.idx,10);pick(idx);}}}
 else if(e.key==='Escape'){syncInputText();close();input.blur();}
 else if(e.key==='Tab'){syncInputText();close();}});
 input.addEventListener('blur',function(){setTimeout(function(){if(!wrap.contains(document.activeElement)){syncInputText();close();}},150);});
 var mo=new MutationObserver(function(){buildItems();syncInputText();if(open)render(input.value);});
 mo.observe(sel,{childList:true,subtree:true});
 buildItems();syncInputText();
 sel._ssWidget={rebuild:function(){buildItems();syncInputText();if(open)render(input.value);}};
 sel.dataset.searchable='1';
 }
 document.addEventListener('DOMContentLoaded', () => {
 const sel = document.getElementById('projectSelect');
 makeSearchableSelect(sel);
 const pid = sel?.value;
 loadSpoolStatusSummary(pid);
 // Ensure fabrication link includes selected project on initial load
 const fab = document.getElementById('lnkFabricationLog');
 if (fab) { fab.setAttribute('href', '/Home/SpoolReleaseLog' + (pid ? ('?projectId=' + encodeURIComponent(pid)) : '')); }
 const ere = document.getElementById('lnkErectionLog');
 if (ere) { ere.setAttribute('href', '/Home/SpoolErectionLog' + (pid ? ('?projectId=' + encodeURIComponent(pid)) : '')); }
 const jp = document.getElementById('lnkJointProgress');
 if (jp) { jp.setAttribute('href', '/Home/JointProgress' + (pid ? ('?projectId=' + encodeURIComponent(pid)) : '')); }
 sel?.addEventListener('change', () => {
 const v = sel.value; loadSpoolStatusSummary(v);
 // update Fabrication link to carry project
 const fab = document.getElementById('lnkFabricationLog');
 if (fab) { fab.setAttribute('href', '/Home/SpoolReleaseLog' + (v ? ('?projectId=' + encodeURIComponent(v)) : '')); }
 const ere = document.getElementById('lnkErectionLog');
 if (ere) { ere.setAttribute('href', '/Home/SpoolErectionLog' + (v ? ('?projectId=' + encodeURIComponent(v)) : '')); }
 const jp = document.getElementById('lnkJointProgress');
 if (jp) { jp.setAttribute('href', '/Home/JointProgress' + (v ? ('?projectId=' + encodeURIComponent(v)) : '')); }
 });
 });
 </script>
