@model PMS.Models.JointProgressViewModel
@using System.Text.Json
@{
    Layout = null;
    var selectedWeldTypes = (Model.SelectedWeldTypes != null && Model.SelectedWeldTypes.Count > 0)
        ? Model.SelectedWeldTypes
        : Model.WeldTypeOptions;
    var selectedWeldTypesJson = JsonSerializer.Serialize(selectedWeldTypes ?? new List<string>());
    string startDateVal = Model.StartDate.HasValue ? Model.StartDate.Value.ToString("yyyy-MM-dd") : string.Empty;
    string endDateVal = Model.EndDate.HasValue ? Model.EndDate.Value.ToString("yyyy-MM-dd") : string.Empty;
    string groupingVal = string.IsNullOrWhiteSpace(Model.Grouping) ? "Monthly" : Model.Grouping;
    var groupingJson = JsonSerializer.Serialize(groupingVal);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <title>PMS - Joint Progress</title>
    <link rel="icon" type="image/png" href="~/img/title_logo.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="~/css/DashboardStyle.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/JointProgress.css" asp-append-version="true" />
    <script src="~/lib/chart.js/chart.umd.min.js" asp-append-version="true"></script>
</head>
<body>
    @await Html.PartialAsync("~/Views/Shared/_DashboardHeader.cshtml")

    <div class="jp-container">
        <div class="jp-card">
            <div class="jp-card-header">Joint Progress</div>
            <div class="jp-filters">
                <div class="jp-filter">
                    <label>Project No</label>
                    <div class="ms-wrap ms-wrap-wide" id="jpProjectMs" data-ms-placeholder="Select projects...">
                        <div class="ms-toggle" tabindex="0">
                            <span class="ms-label">Select projects...</span>
                        </div>
                        <div class="ms-panel">
                            <input type="text" class="ms-search" placeholder="Search projects..." />
                            <div class="ms-actions">
                                <button type="button" data-action="all">All</button>
                                <button type="button" data-action="none">None</button>
                            </div>
                            <div class="ms-options">
                                @foreach (var p in Model.Projects)
                                {
                                    var isChecked = Model.SelectedProjectIds.Contains(p.Id);
                                    <label class="ms-option">
                                        <input type="checkbox" name="jpProject" value="@p.Id" @(isChecked ? "checked" : "") />
                                        @p.Id - @p.Name
                                    </label>
                                }
                            </div>
                        </div>
                    </div>
                </div>
                <div class="jp-filter">
                    <label for="startDate">Actual Date (From)</label>
                    <input id="startDate" class="jp-input" type="date" value="@startDateVal" />
                </div>
                <div class="jp-filter">
                    <label for="endDate">Actual Date (To)</label>
                    <input id="endDate" class="jp-input" type="date" value="@endDateVal" />
                </div>
                <div class="jp-filter">
                    <label>Location</label>
                    <div class="jp-radio-group">
                        <label><input type="radio" name="locOption" value="All" @(Model.Location.Equals("All", StringComparison.OrdinalIgnoreCase) ? "checked" : string.Empty) /> All</label>
                        <label><input type="radio" name="locOption" value="Shop" @(Model.Location.Equals("Shop", StringComparison.OrdinalIgnoreCase) ? "checked" : string.Empty) /> Shop</label>
                        <label><input type="radio" name="locOption" value="Field" @(Model.Location.Equals("Field", StringComparison.OrdinalIgnoreCase) ? "checked" : string.Empty) /> Field</label>
                    </div>
                </div>
                <div class="jp-filter">
                    <label>Progress Category</label>
                    <div class="jp-radio-group">
                        <label><input type="radio" name="dateBasis" value="Welding" @(Model.DateBasis.Equals("Welding", StringComparison.OrdinalIgnoreCase) ? "checked" : string.Empty) /> Welding</label>
                        <label><input type="radio" name="dateBasis" value="Fit-up" @(Model.DateBasis.Equals("Fit-up", StringComparison.OrdinalIgnoreCase) ? "checked" : string.Empty) /> Fit-up</label>
                    </div>
                </div>
                <div class="jp-filter">
                    <label>Group By</label>
                    <div class="jp-radio-group">
                        <label><input type="radio" name="grouping" value="Monthly" @(string.Equals(Model.Grouping, "Monthly", StringComparison.OrdinalIgnoreCase) ? "checked" : string.Empty) /> Monthly</label>
                        <label><input type="radio" name="grouping" value="Daily" @(string.Equals(Model.Grouping, "Daily", StringComparison.OrdinalIgnoreCase) ? "checked" : string.Empty) /> Daily</label>
                    </div>
                </div>
            </div>
            <div class="jp-wt-row">
                <div class="jp-weld-types">
                    <div class="jp-wt-header">Weld Type</div>
                    <div class="jp-wt-list">
                        @{
                            var selectedSet = new HashSet<string>(selectedWeldTypes ?? new List<string>(), StringComparer.OrdinalIgnoreCase);
                            foreach (var wt in Model.WeldTypeOptions)
                            {
                                var isChecked = selectedSet.Contains(wt);
                                <label><input type="checkbox" class="wt" value="@wt" @(isChecked ? "checked" : string.Empty) /> @wt</label>
                            }
                        }
                    </div>
                    <div class="jp-wt-actions">
                        <button type="button" id="wtAll" class="btn btn-outline">All</button>
                        <button type="button" id="wtNone" class="btn btn-outline">None</button>
                        <button type="button" id="wtDefault" class="btn btn-outline">Default</button>
                    </div>
                </div>
                <div class="jp-actions-inline">
                    <button id="applyBtn" type="button" class="btn btn-primary">Apply</button>
                    <button id="resetBtn" type="button" class="btn btn-outline">Reset</button>
                    <button id="downloadExcelBtn" type="button" class="btn btn-outline">Fit-up / Welding Excel</button>
                    <button id="downloadJointsRecordBtn" type="button" class="btn btn-outline">Joints Record Excel</button>
                </div>
            </div>
            <div class="jp-grid">
                <div class="jp-chart-card">
                    <div class="jp-card-title">Progress Curve</div>
                    <div class="jp-chart-box">
                        <canvas id="jpChart"></canvas>
                    </div>
                </div>
                <div class="jp-table-card">
                    <div class="jp-card-title">Progress Dia. In.</div>
                    <div class="jp-table-wrap">
                        <table class="jp-table" id="jpTable">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Location</th>
                                    <th>Total Dia In</th>
                                    <th>Planning Dia In</th>
                                    <th>Dia In Deviation</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr class="empty"><td colspan="5">No data</td></tr>
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="2">Total</td>
                                    <td class="num" id="jpTotalDiaIn">0.00</td>
                                    <td class="num" id="jpPlanningDiaIn">0.00</td>
                                    <td class="num" id="jpDeviationDiaIn">0.00</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
            <div class="jp-loader hidden" id="jpLoader">Loading...</div>
        </div>
    </div>

    <script>
        // Multi-select dropdown behaviour
        function initMs(wrap) {
            var toggle = wrap.querySelector('.ms-toggle');
            var panel = wrap.querySelector('.ms-panel');
            var search = wrap.querySelector('.ms-search');
            var placeholder = wrap.dataset.msPlaceholder || 'Select...';
            var labelSpan = toggle.querySelector('.ms-label');
            function updateLabel() {
                var checked = wrap.querySelectorAll('.ms-option input:checked');
                if (checked.length === 0) { labelSpan.textContent = placeholder; }
                else if (checked.length === 1) { labelSpan.textContent = checked[0].parentElement.textContent.trim(); }
                else { labelSpan.textContent = checked.length + ' selected'; }
            }
            if (!wrap.dataset.msInit) {
                wrap.dataset.msInit = '1';
                toggle.addEventListener('click', function (e) {
                    e.stopPropagation();
                    var wasOpen = wrap.classList.contains('ms-open');
                    closeAllMs();
                    if (!wasOpen) { wrap.classList.add('ms-open'); panel.style.display = 'block'; if (search) search.focus(); }
                });
                if (search) {
                    search.addEventListener('input', function () {
                        var q = search.value.toLowerCase();
                        wrap.querySelectorAll('.ms-option').forEach(function (opt) {
                            var match = opt.textContent.toLowerCase().indexOf(q) >= 0;
                            opt.classList.toggle('ms-hidden', !match);
                        });
                    });
                }
                wrap.querySelectorAll('.ms-actions button').forEach(function (b) {
                    b.addEventListener('click', function (e) {
                        e.preventDefault();
                        var action = b.dataset.action;
                        wrap.querySelectorAll('.ms-option').forEach(function (opt) {
                            if (!opt.classList.contains('ms-hidden')) {
                                opt.querySelector('input').checked = (action === 'all');
                            }
                        });
                        updateLabel();
                    });
                });
                var optionsContainer = wrap.querySelector('.ms-options');
                if (optionsContainer) {
                    optionsContainer.addEventListener('change', function () { updateLabel(); });
                }
            }
            updateLabel();
        }
        function closeAllMs() {
            document.querySelectorAll('.ms-wrap').forEach(function (w) {
                w.classList.remove('ms-open');
                var p = w.querySelector('.ms-panel');
                if (p) p.style.display = 'none';
            });
        }
        document.addEventListener('click', closeAllMs);
        (function(){
            var projectMsWrap = document.getElementById('jpProjectMs');
            initMs(projectMsWrap);
            function getSelectedProjectIds() {
                return Array.from((projectMsWrap || document).querySelectorAll('input[name="jpProject"]:checked')).map(cb => Number(cb.value)).filter(v => v > 0);
            }
            function getFirstProjectId() {
                var ids = getSelectedProjectIds(); return ids.length > 0 ? ids[0] : 0;
            }
            let defaultWeldTypes = JSON.parse('@Html.Raw(selectedWeldTypesJson ?? "[]")');
            const defaultGrouping = JSON.parse('@Html.Raw(groupingJson ?? "\"Monthly\"")');
            const startDate = document.getElementById('startDate');
            const endDate = document.getElementById('endDate');
            const applyBtn = document.getElementById('applyBtn');
            const resetBtn = document.getElementById('resetBtn');
            const downloadBtn = document.getElementById('downloadExcelBtn');
            const downloadRecordBtn = document.getElementById('downloadJointsRecordBtn');
            const loader = document.getElementById('jpLoader');
            const dateBasisInputs = document.querySelectorAll('input[name="dateBasis"]');
            const groupingInputs = document.querySelectorAll('input[name="grouping"]');
            const totalDiaInEl = document.getElementById('jpTotalDiaIn');
            const planningDiaInEl = document.getElementById('jpPlanningDiaIn');
            const deviationDiaInEl = document.getElementById('jpDeviationDiaIn');
            let chartInstance = null;

            function selectedLocation(){
                return document.querySelector('input[name="locOption"]:checked')?.value || 'All';
            }
            function getSelectedWeldTypes(){
                return Array.from(document.querySelectorAll('.jp-wt-list input.wt:checked')).map(cb => cb.value);
            }
            function renderWeldTypes(options, defaults){
                const list = document.querySelector('.jp-wt-list');
                if(!list) return;
                const opts = Array.isArray(options) ? options : [];
                const defSet = new Set((Array.isArray(defaults) ? defaults : []).map(x => (x || '').toString().trim().toUpperCase()));
                list.innerHTML = opts.map(wt => {
                    const val = (wt || '').toString();
                    const isChecked = defSet.size === 0 || defSet.has(val.trim().toUpperCase());
                    const checkedAttr = isChecked ? ' checked' : '';
                    return `<label><input type="checkbox" class="wt" value="${val}"${checkedAttr} /> ${val}</label>`;
                }).join('');
            }
            function setAllWeldTypes(state){
                document.querySelectorAll('.jp-wt-list input.wt').forEach(cb => { cb.checked = state; });
            }
            function setDefaultWeldTypes(){
                if(!Array.isArray(defaultWeldTypes)) return;
                const set = new Set(defaultWeldTypes.map(x => (x || '').toString().trim().toUpperCase()));
                document.querySelectorAll('.jp-wt-list input.wt').forEach(cb => {
                    cb.checked = set.size === 0 || set.has((cb.value || '').toString().trim().toUpperCase());
                });
            }
            function setDefaultGrouping(){
                const def = (defaultGrouping || 'Monthly').toString();
                groupingInputs.forEach(r => { r.checked = r.value === def; });
            }

            function formatNumber(val){
                const n = Number(val || 0);
                return n.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            }
            function toMonthLabel(val){
                if(!val) return '';
                const d = val instanceof Date ? val : new Date(val);
                if(Number.isNaN(d.getTime())) return val;
                return d.toLocaleString(undefined, { month:'short', year:'numeric' });
            }
            function formatDate(val, grouping){
                if(!val) return '';
                const d = val instanceof Date ? val : new Date(val);
                if(Number.isNaN(d.getTime())) return val;
                if(grouping === 'Monthly') return toMonthLabel(d);
                return d.toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: '2-digit' });
            }

            function toggleLoading(show){
                if(!loader) return;
                if(show){ loader.classList.remove('hidden'); }
                else { loader.classList.add('hidden'); }
            }

            function selectedDateBasis(){
                return document.querySelector('input[name="dateBasis"]:checked')?.value || 'Welding';
            }
            function selectedGrouping(){
                return document.querySelector('input[name="grouping"]:checked')?.value || defaultGrouping || 'Monthly';
            }

            function buildQueryParams(){
                const params = new URLSearchParams();
                var ids = getSelectedProjectIds();
                ids.forEach(function(id){ params.append('projectIds', id); });
                var fid = ids.length > 0 ? ids[0] : 0;
                if(fid) params.append('projectId', fid);
                if(startDate?.value) params.append('startDate', startDate.value);
                if(endDate?.value) params.append('endDate', endDate.value);
                const loc = selectedLocation();
                if(loc) params.append('location', loc);
                const db = selectedDateBasis();
                if(db) params.append('dateBasis', db);
                const wt = getSelectedWeldTypes();
                wt.forEach(w => params.append('weldTypes', w));
                return params;
            }

            async function refreshWeldTypesForProject(projectId){
                if(!projectId) projectId = getFirstProjectId();
                if(!projectId) return;
                try{
                    const res = await fetch(`/Home/GetJointProgressWeldTypes?projectId=${encodeURIComponent(projectId)}`);
                    const data = await res.json();
                    const options = Array.isArray(data?.options) ? data.options : [];
                    const defaults = Array.isArray(data?.defaults) ? data.defaults : [];
                    defaultWeldTypes = defaults;
                    renderWeldTypes(options, defaultWeldTypes);
                    setDefaultWeldTypes();
                } catch(err) {
                    // leave existing weld type list as-is
                }
            }

            function groupRows(rows, grouping){
                const list = Array.isArray(rows) ? rows : [];
                if(grouping === 'Monthly'){
                    const map = new Map();
                    list.forEach(r => {
                        const d = r?.weldDate instanceof Date ? r.weldDate : new Date(r?.weldDate);
                        if(Number.isNaN(d.getTime())) return;
                        const loc = r?.location || '';
                        const key = `${d.getFullYear()}-${d.getMonth()}-${loc}`;
                        const planned = Number(r?.plannedDiaIn || 0);
                        const total = Number(r?.totalDiaIn ?? (Number(r?.weldedDiaIn || 0) + Number(r?.threadedDiaIn || 0)));
                        const existing = map.get(key) || { weldDate: new Date(d.getFullYear(), d.getMonth(), 1), location: loc, plannedDiaIn: 0, totalDiaIn: 0 };
                        existing.plannedDiaIn += planned;
                        existing.totalDiaIn += total;
                        map.set(key, existing);
                    });
                    return Array.from(map.values()).sort((a, b) => {
                        const ad = a.weldDate instanceof Date ? a.weldDate.getTime() : new Date(a.weldDate).getTime();
                        const bd = b.weldDate instanceof Date ? b.weldDate.getTime() : new Date(b.weldDate).getTime();
                        if(ad === bd) return (a.location || '').localeCompare(b.location || '');
                        return ad - bd;
                    });
                }
                return list;
            }

            function renderTable(rows, grouping){
                const tbody = document.querySelector('#jpTable tbody');
                if(!tbody) return;
                if(!rows || rows.length === 0){
                    tbody.innerHTML = '<tr class="empty"><td colspan="5">No data</td></tr>';
                    renderTotals({ total: 0, planned: 0 });
                    return;
                }
                const totals = { total: 0, planned: 0 };
                const html = rows.map(r => {
                    const planned = Number(r.plannedDiaIn || 0);
                    const total = Number(r.totalDiaIn ?? (Number(r.weldedDiaIn || 0) + Number(r.threadedDiaIn || 0)));
                    totals.planned += planned;
                    totals.total += total;
                    const variance = total - planned;
                    const varianceClass = variance < 0 ? 'neg' : '';
                    return `<tr>
                        <td>${formatDate(r.weldDate, grouping)}</td>
                        <td>${r.location || ''}</td>
                        <td class="num">${formatNumber(total)}</td>
                        <td class="num">${formatNumber(planned)}</td>
                        <td class="num ${varianceClass}">${formatNumber(variance)}</td>
                    </tr>`;
                }).join('');
                tbody.innerHTML = html;
                renderTotals(totals);
            }

            function renderTotals(totals){
                if(!totalDiaInEl || !planningDiaInEl || !deviationDiaInEl) return;
                const planned = Number(totals?.planned || 0);
                const total = Number(totals?.total || 0);
                const deviation = total - planned;
                totalDiaInEl.textContent = formatNumber(total);
                planningDiaInEl.textContent = formatNumber(planned);
                deviationDiaInEl.textContent = formatNumber(deviation);
                deviationDiaInEl.classList.toggle('neg', deviation < 0);
            }

            function buildChartSeries(points, grouping){
                const list = Array.isArray(points) ? points.slice() : [];
                const parsed = list
                    .map(p => ({ ...p, _date: new Date(p.date) }))
                    .filter(p => !Number.isNaN(p._date.getTime()))
                    .sort((a, b) => a._date - b._date);

                if(grouping === 'Monthly'){
                    const map = new Map();
                    parsed.forEach(p => {
                        const key = `${p._date.getFullYear()}-${p._date.getMonth()}`;
                        const entry = map.get(key) || { date: new Date(p._date.getFullYear(), p._date.getMonth(), 1), planned: 0, actual: 0 };
                        entry.actual += Number(p.dailyTotal || 0);
                        entry.planned += Number(p.plannedDailyTotal || 0);
                        map.set(key, entry);
                    });
                    const arr = Array.from(map.values()).sort((a, b) => a.date - b.date);
                    let running = 0;
                    arr.forEach(x => { running += x.actual; x.cumulative = running; x.label = toMonthLabel(x.date); });
                    return arr;
                }

                let running = 0;
                return parsed.map(p => {
                    const actual = Number(p.dailyTotal || 0);
                    const planned = Number(p.plannedDailyTotal || 0);
                    running += actual;
                    return { label: formatDate(p._date), planned, actual, cumulative: running };
                });
            }

            function renderChart(points, grouping){
                const ctx = document.getElementById('jpChart');
                if(!ctx || typeof Chart === 'undefined') return;
                if(chartInstance){ chartInstance.destroy(); chartInstance = null; }

                const series = buildChartSeries(points, grouping);
                if(!series || series.length === 0){ return; }

                const labels = series.map(s => s.label);
                const daily = series.map(s => Number(s.actual || 0));
                const planned = series.map(s => Number(s.planned || 0));
                const total = series.map(s => Number(s.cumulative || 0));

                chartInstance = new Chart(ctx, {
                    data: {
                        labels,
                        datasets: [
                            { type:'bar', label: 'Actual Dia In', data: daily, backgroundColor: 'rgba(78,121,167,0.6)', borderColor:'#4E79A7', borderWidth:1, maxBarThickness:28 },
                            { type:'bar', label: 'Planning Dia In', data: planned, backgroundColor: 'rgba(242,142,43,0.55)', borderColor:'#f28e2b', borderWidth:1, maxBarThickness:28 },
                            { type:'line', label: 'Cumulative', data: total, borderColor: '#1f9b85', backgroundColor: 'rgba(31,155,133,0.2)', tension: 0.3, fill: false, pointRadius: 2.5, pointHoverRadius:4, borderWidth:3 }
                        ]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        interaction: { mode: 'index', intersect: false },
                        plugins: {
                            legend: { position: 'bottom', labels: { color: '#176d8a' } }
                        },
                        scales: {
                            x: { ticks: { color: '#176d8a', maxRotation: 75, minRotation: 45 }, grid: { color: '#e6f6fa' } },
                            y: { beginAtZero: true, ticks: { color: '#176d8a' }, grid: { color: '#f0fbff' } }
                        }
                    }
                });
            }

            async function loadData(){
                const grouping = selectedGrouping();
                try{
                    toggleLoading(true);
                    const params = buildQueryParams();
                    const res = await fetch('/Home/GetJointProgressData?' + params.toString());
                    const data = await res.json();
                    const groupedRows = groupRows(data?.rows || [], grouping);
                    renderTable(groupedRows, grouping);
                    renderChart(data?.chart || [], grouping);
                } catch(err){
                    renderTable([], grouping);
                    renderChart([], grouping);
                } finally {
                    toggleLoading(false);
                }
            }

            document.getElementById('wtAll')?.addEventListener('click', () => setAllWeldTypes(true));
            document.getElementById('wtNone')?.addEventListener('click', () => setAllWeldTypes(false));
            document.getElementById('wtDefault')?.addEventListener('click', setDefaultWeldTypes);

            applyBtn?.addEventListener('click', loadData);
            if (projectMsWrap) {
                var optsCont = projectMsWrap.querySelector('.ms-options');
                if (optsCont) optsCont.addEventListener('change', async () => {
                    var pid = getFirstProjectId();
                    await refreshWeldTypesForProject(pid);
                    await loadData();
                });
                projectMsWrap.querySelectorAll('.ms-actions button').forEach(function(b){
                    b.addEventListener('click', async function(){
                        await new Promise(r => setTimeout(r, 0));
                        var pid = getFirstProjectId();
                        await refreshWeldTypesForProject(pid);
                        await loadData();
                    });
                });
            }
            document.querySelectorAll('input[name="locOption"]').forEach(r => r.addEventListener('change', loadData));
            dateBasisInputs.forEach(r => r.addEventListener('change', loadData));
            groupingInputs.forEach(r => r.addEventListener('change', loadData));
            downloadBtn?.addEventListener('click', () => {
                const params = buildQueryParams();
                const qs = params.toString();
                window.location = '/Home/ExportJointProgressExcel' + (qs ? ('?' + qs) : '');
            });
            downloadRecordBtn?.addEventListener('click', () => {
                const params = buildQueryParams();
                const qs = params.toString();
                window.location = '/Home/ExportJointsRecordExcel' + (qs ? ('?' + qs) : '');
            });
             resetBtn?.addEventListener('click', () => {
                 startDate.value = '';
                 endDate.value = '';
                 setDefaultWeldTypes();
                 setDefaultGrouping();
                 const all = document.querySelector('input[name="locOption"][value="All"]');
                 if(all) all.checked = true;
                 const welding = document.querySelector('input[name="dateBasis"][value="Welding"]');
                 if(welding) welding.checked = true;
                 loadData();
             });

            // Initial load
            setDefaultWeldTypes();
            setDefaultGrouping();
            loadData();
        })();
    </script>
</body>
</html>
