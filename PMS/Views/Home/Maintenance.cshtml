@{
    Layout = null;
    var message = ViewBag.MaintenanceMessage as string
        ?? "The system is currently undergoing scheduled maintenance. Please try again later.";
    var estimatedEnd = ViewBag.EstimatedEndUtc as DateTime?;
    var estimatedEndIso = estimatedEnd?.ToString("o") ?? "";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>PMS - Maintenance</title>
    <link rel="icon" type="image/png" href="~/img/title_logo.png" />
    <link rel="stylesheet" href="~/css/LoginStyle.css" />
    <style>
        .container-wrapper {
            display: flex;
            justify-content: center;
            align-items: center;
            flex: 1;
            width: 100%;
            padding: 20px 0 85px;
        }

        .maintenance-container {
            max-width: 520px;
            width: 92%;
            box-sizing: border-box;
            background: #faf2e3;
            padding: 38px 32px 32px;
            border-radius: 8px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.10);
            margin: 0 auto;
            text-align: center;
            border-top: 4px solid #1f99be;
        }

        /* ── Animated gear icon ── */
        .maint-gear-wrap {
            display: flex;
            justify-content: center;
            margin-bottom: 12px;
        }
        .maint-gear {
            animation: spin 4s linear infinite;
        }
        @@keyframes spin { to { transform: rotate(360deg); } }

        .maintenance-container h2 {
            color: #176d8a;
            font-size: 1.7em;
            font-weight: bold;
            margin: 0 0 6px;
            letter-spacing: 0.3px;
        }
        .maint-subtitle {
            color: #1f99be;
            font-size: 0.95em;
            margin-bottom: 18px;
        }

        /* ── Message box ── */
        .maintenance-message {
            background: #fff8eb;
            border-left: 4px solid #1f99be;
            padding: 14px 18px;
            border-radius: 4px;
            text-align: left;
            color: rgb(26, 109, 134);
            margin: 0 0 18px;
            font-size: 1.02em;
            line-height: 1.55;
        }

        /* ── Countdown section ── */
        .countdown-section {
            margin-bottom: 20px;
        }
        .countdown-label {
            font-size: 0.88em;
            color: #888;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            margin-bottom: 8px;
        }
        .countdown-boxes {
            display: flex;
            justify-content: center;
            gap: 10px;
        }
        .countdown-box {
            background: #fff;
            border: 1.5px solid #1f99be;
            border-radius: 6px;
            min-width: 58px;
            padding: 8px 6px 6px;
            text-align: center;
        }
        .countdown-box .cd-value {
            font-size: 1.5em;
            font-weight: 700;
            color: #176d8a;
            line-height: 1.2;
        }
        .countdown-box .cd-unit {
            font-size: 0.7em;
            color: #999;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* ── Progress bar ── */
        .maint-progress-track {
            height: 6px;
            background: #e6dbc8;
            border-radius: 3px;
            overflow: hidden;
            margin-bottom: 20px;
        }
        .maint-progress-bar {
            height: 100%;
            background: linear-gradient(90deg, #1f99be 0%, #176d8a 100%);
            border-radius: 3px;
            animation: maint-progress 2.5s ease-in-out infinite;
            width: 40%;
        }
        @@keyframes maint-progress {
            0%   { margin-left: -40%; }
            100% { margin-left: 100%; }
        }

        .maintenance-container p {
            color: rgb(26, 109, 134);
            font-size: 0.95em;
            line-height: 1.55;
            margin-bottom: 22px;
        }
        .maintenance-btn {
            display: inline-block;
            padding: 10px 32px;
            background-color: #1f99be;
            color: #fff;
            border: none;
            border-radius: 4px;
            text-decoration: none;
            font-weight: bold;
            font-size: 1.05em;
            cursor: pointer;
            box-shadow: 0 2px 6px rgba(31,153,190,0.15);
            transition: background 0.2s;
        }
        .maintenance-btn:hover {
            background-color: #176d8a;
        }

        /* ── Responsive ── */
        @@media (max-width: 600px) {
            .maintenance-container { padding: 28px 18px 24px; }
            .maintenance-container h2 { font-size: 1.35em; }
            .countdown-box { min-width: 48px; padding: 6px 4px 5px; }
            .countdown-box .cd-value { font-size: 1.25em; }
        }
    </style>
</head>
<body>
    <h1>
        <img src="~/img/PMS_logo.png" alt="PMS logo" class="main-logo">
    </h1>

    <div class="container-wrapper">
        <div class="maintenance-container">
            <!-- Animated gear SVG -->
            <div class="maint-gear-wrap">
                <svg class="maint-gear" width="56" height="56" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" stroke="#1f99be" stroke-width="1.8"/>
                    <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33
                            1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06
                            a2 2 0 1 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09
                            A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9
                            4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06
                            a2 2 0 1 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 1 1 0 4h-.09
                            a1.65 1.65 0 0 0-1.51 1Z" stroke="#176d8a" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>

            <h2>Under Maintenance</h2>
            <p class="maint-subtitle">We'll be back shortly</p>

            <!-- Animated progress bar -->
            <div class="maint-progress-track">
                <div class="maint-progress-bar"></div>
            </div>

            <div class="maintenance-message">@message</div>

            @if (!string.IsNullOrEmpty(estimatedEndIso))
            {
                <div class="countdown-section" id="countdownSection">
                    <div class="countdown-label">Estimated time remaining</div>
                    <div class="countdown-boxes" id="countdownBoxes">
                        <div class="countdown-box">
                            <div class="cd-value" id="cdHours">--</div>
                            <div class="cd-unit">Hours</div>
                        </div>
                        <div class="countdown-box">
                            <div class="cd-value" id="cdMinutes">--</div>
                            <div class="cd-unit">Minutes</div>
                        </div>
                        <div class="countdown-box">
                            <div class="cd-value" id="cdSeconds">--</div>
                            <div class="cd-unit">Seconds</div>
                        </div>
                    </div>
                </div>
            }

            <p>We apologize for the inconvenience. Our team is working to get the system back online as quickly as possible.</p>
            <a href="/Home/Login" class="maintenance-btn">Back to Login</a>
        </div>
    </div>

    <div class="footer">
        <div class="footer-left">
            <a href="@Url.Action("ContactUs", "Home")">Contact us</a>
            <span class="footer-separator">|</span>
            <a href="@Url.Action("AboutUs", "Home")">About us</a>
        </div>
        <div class="footer-center">
            This system is strictly restricted to authorized users only.<br>
            &copy; 2025 Piping Management System. All rights reserved.
        </div>
        <div class="footer-right">
            <img src="~/img/work-smarter-not-harder.jpg?v=3" alt="Footer logo" class="footer-logo" />
        </div>
    </div>

    @if (!string.IsNullOrEmpty(estimatedEndIso))
    {
        <script>
        (function () {
            var endUtc = new Date('@estimatedEndIso');
            var hEl = document.getElementById('cdHours');
            var mEl = document.getElementById('cdMinutes');
            var sEl = document.getElementById('cdSeconds');
            var section = document.getElementById('countdownSection');

            function pad(n) { return n < 10 ? '0' + n : '' + n; }

            function tick() {
                var now = new Date();
                var diff = endUtc - now;
                if (diff <= 0) {
                    hEl.textContent = '00';
                    mEl.textContent = '00';
                    sEl.textContent = '00';
                    section.querySelector('.countdown-label').textContent = 'Maintenance should be complete — try refreshing';
                    return;
                }
                var totalSec = Math.floor(diff / 1000);
                var h = Math.floor(totalSec / 3600);
                var m = Math.floor((totalSec % 3600) / 60);
                var s = totalSec % 60;
                hEl.textContent = pad(h);
                mEl.textContent = pad(m);
                sEl.textContent = pad(s);
            }

            tick();
            setInterval(tick, 1000);
        })();
        </script>
    }
</body>
</html>
