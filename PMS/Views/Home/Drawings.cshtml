@model PMS.Models.DrawingsViewModel
@{
    Layout = null;
    ViewData["Title"] = "Drawings";
}

@functions {
    private static string StripOuterParens(string? s)
    {
        if (string.IsNullOrWhiteSpace(s)) return string.Empty;
        s = s.Trim();
        if (s.Length >= 2 && s.StartsWith("(") && s.EndsWith(")"))
            s = s.Substring(1, s.Length - 2);
        return s.Replace('-', '_');
    }
}

<!DOCTYPE html>
<html>
<head>
    <title>PMS - Drawings</title>
    <link rel="icon" type="image/png" href="~/img/title_logo.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="~/css/DashboardStyle.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/DailyFitup.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Drawings.css" asp-append-version="true" />
</head>
<body>
    @await Html.PartialAsync("_DashboardHeader")

    <div class="page">
        <h1 class="page-title">Drawings</h1>

        @if (TempData["Msg"] != null)
        {
            <div class="inline-msg">@TempData["Msg"]</div>
        }

        <div class="fitup-header no-frame">
            <form method="get" asp-action="Drawings" asp-controller="Home" id="drawingsFilterForm">
                <div class="row">
                    <label for="projectSelect">Project</label>
                    <select id="projectSelect" name="projectId" class="form-control header-fixed w350 searchable-select">
                        @foreach (var p in (IEnumerable<SelectListItem>)ViewBag.Projects)
                        {
                            <option value="@p.Value" selected="@p.Selected">@p.Text</option>
                        }
                    </select>

                    @* Separate Layout and Sheet selectors similar to DailyFitup (DWG view) *@
                    @{
                        // Build distinct layout list from Keys
                        var layoutList = (Model.Keys ?? new List<PMS.Models.DrawingKeyOption>())
                            .Select(k => (k.Key ?? string.Empty).Split('|')[0])
                            .Where(s => !string.IsNullOrWhiteSpace(s))
                            .Distinct(StringComparer.OrdinalIgnoreCase)
                            .OrderBy(s => s)
                            .ToList();
                        var selectedLayout = Model.Layout ?? (layoutList.Count > 0 ? layoutList[0] : string.Empty);
                        // For Sheet mode, build sheet list for current layout
                        var sheetList = string.Equals(Model.Mode, "Sheet", StringComparison.OrdinalIgnoreCase)
                            ? (Model.Keys ?? new List<PMS.Models.DrawingKeyOption>())
                                .Select(k => (k.Key ?? string.Empty))
                                .Where(key => key.StartsWith((selectedLayout ?? string.Empty) + "|", StringComparison.OrdinalIgnoreCase))
                                .Select(key =>
                                {
                                    var parts = key.Split('|');
                                    return parts.Length > 1 ? parts[1] : string.Empty;
                                })
                                .Where(s => !string.IsNullOrWhiteSpace(s))
                                .Distinct(StringComparer.OrdinalIgnoreCase)
                                .OrderBy(s => s)
                                .ToList()
                            : new List<string>();
                    }

                    <label for="layoutSelect" style="margin-left:20px">Layout</label>
                    @if (string.Equals(Model.Mode, "Sheet", StringComparison.OrdinalIgnoreCase))
                    {
                        <select id="layoutSelect" name="layout" class="form-control header-fixed w130 searchable-select">
                            @foreach (var l in layoutList)
                            {
                                if (string.Equals(l, selectedLayout, StringComparison.OrdinalIgnoreCase))
                                {
                                    <option value="@l" selected="selected">@l</option>
                                }
                                else
                                {
                                    <option value="@l">@l</option>
                                }
                            }
                        </select>
                    }
                    else
                    {
                        <select id="layoutSelect" name="layout" class="form-control header-fixed w130 searchable-select">
                            @foreach (var l in layoutList)
                            {
                                if (string.Equals(l, selectedLayout, StringComparison.OrdinalIgnoreCase))
                                {
                                    <option value="@l" selected="selected">@l</option>
                                }
                                else
                                {
                                    <option value="@l">@l</option>
                                }
                            }
                        </select>
                    }

                    @if (string.Equals(Model.Mode, "Sheet", StringComparison.OrdinalIgnoreCase))
                    {
                        <label for="sheetSelect">Sheet</label>
                        <select id="sheetSelect" name="sheet" class="form-control header-fixed w90 searchable-select">
                            @{
                                var selectedSheet = Model.Sheet ?? (sheetList.Count > 0 ? sheetList[0] : string.Empty);
                            }
                            @foreach (var s in sheetList)
                            {
                                if (string.Equals(s, selectedSheet, StringComparison.OrdinalIgnoreCase))
                                {
                                    <option value="@s" selected="selected">@s</option>
                                }
                                else
                                {
                                    <option value="@s">@s</option>
                                }

                            }
                        </select>
                        <label for="lsRevInput" style="margin-left:10px">Rev:</label>
                        <input id="lsRevInput" class="form-control rev-inline" type="text" value="@StripOuterParens(Convert.ToString(ViewBag.LatestDesignRev))" placeholder="Rev" />
                        <button id="lsRevSaveBtn" type="button" class="btn btn-outline btn-action" style="margin-left:6px; min-width:auto; padding:4px 10px;">Save</button>
                        <span id="lsRevStatus" class="inline-msg" aria-live="polite"></span>
                    }
                </div>
            </form>
        </div>

        <div>
            <h3 style="color:#176d8a;">Upload new revision</h3>
            <form id="singleUploadForm" method="post" enctype="multipart/form-data" asp-action="UploadDrawing" asp-controller="Home">
                @Html.AntiForgeryToken()
                <input type="hidden" name="projectId" value="@Model.SelectedProjectId" />
                <input type="hidden" name="mode" value="@Model.Mode" />
                <input type="hidden" name="layout" value="@Model.Layout" />
                <input type="hidden" name="sheet" value="@Model.Sheet" />
                <label class="btn btn-outline btn-action">Choose File<input type="file" id="singleFileInput" name="file" accept="application/pdf" required aria-describedby="singleUploadStatus" onchange="document.getElementById('selectedFileName').textContent=this.files?.[0]?.name||''; resetSingleUploadStatus();" /></label>
                <span id="selectedFileName" class="file-name"></span>
                <label class="revtag-label" style="margin-left:10px" for="revisionTagInput">Revision Tag</label>
                <input id="revisionTagInput" class="form-control revtag-input" style="display:inline-block; width:auto;" type="text" name="revisionTag" maxlength="20" />
                <input id="singleUploadBtn" type="submit" class="btn btn-primary btn-action" value="Upload" />
                <div id="singleUploadStatus" class="upload-status" aria-live="polite"></div>
                <div class="progress-bar-wrap" id="singleProgressWrap" style="display:none;"><div class="progress-bar-inner" id="singleProgressBar"></div></div>
            </form>

            <div style="margin-top:14px;">
                <h3 style="color:#176d8a;">Bulk Upload</h3>
                <form id="bulkUploadForm" method="post" enctype="multipart/form-data" asp-action="BulkUploadDrawings" asp-controller="Home">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="projectId" value="@Model.SelectedProjectId" />
                    <label id="bulkChooseBtn" class="btn btn-outline btn-action">Choose Files<input type="file" id="bulkFilesInput" name="files" accept="application/pdf" multiple aria-describedby="bulkUploadStatus" onchange="prepareBulkList();" /></label>
                    <span id="bulkChooseInfo" class="bulk-note"></span>
                    <button id="bulkUploadBtn" type="submit" class="btn btn-primary btn-action" style="margin-left:8px;" disabled>Upload All</button>
                    <button id="bulkUploadCloseBtn" type="button" class="btn btn-outline btn-action" style="margin-left:6px; display:none;">Close</button>
                    <div id="bulkUploadStatus" class="upload-status" aria-live="polite"></div>
                    <div class="progress-bar-wrap" id="bulkProgressWrap" style="display:none;"><div class="progress-bar-inner" id="bulkProgressBar"></div></div>
                    <ul id="bulkUploadList" class="upload-list" aria-live="polite" style="display:none;"></ul>
                </form>
            </div>

            <div id="revisionsPlaceholder" style="display:none;">
                <hr />
                <h3 style="color:#176d8a;">Revisions</h3>
                <div>No revisions uploaded.</div>
            </div>

            <div id="revisionsBlock">
                <hr />
                <h3 style="color:#176d8a;">Revisions</h3>
                @if (Model.Revisions.Count == 0)
                {
                    <div>No revisions uploaded.</div>
                }
                else
                {
                    var maxRev = Model.Revisions.Max(x => x.RevisionOrder);
                    <div class="table-responsive">
                        <table class="user-table">
                            <thead>
                                <tr>
                                    <th style="width:70px">Order</th>
                                    <th style="width:180px">Revision</th>
                                    <th>File</th>
                                    <th style="width:80px">Size (KB)</th>
                                    <th style="width:150px">Upload Date</th>
                                    <th style="width:200px">Uploaded By</th>
                                    <th style="width:300px">Actions</th>
                                </tr>
                            </thead>
                            <tbody id="rev-tbody">
                                @* Change listing to descending order *@
                                @foreach (var r in Model.Revisions.OrderByDescending(x => x.RevisionOrder))
                                {
                                    <tr data-id="@r.Id" data-file="@r.FileName" data-rev="@r.RawRevisionTag">
                                        <td>
                                            <button type="button" class="btn btn-primary btn-move" onclick="moveUp(this)" aria-label="Move revision up">▲</button>
                                            <button type="button" class="btn btn-primary btn-move" onclick="moveDown(this)" aria-label="Move revision down">▼</button>
                                        </td>
                                        <td class="col-rev" title="@r.RevisionTag">Rev: @r.RevisionOrder @if (!string.IsNullOrWhiteSpace(r.RevisionTag)) { <text>(@StripOuterParens(r.RevisionTag))</text> } @if (r.RevisionOrder == maxRev) { <span class="rev-latest" aria-label="Latest revision">Latest</span> }</td>
                                        <td class="col-file">@r.FileName</td>
                                        <td>@(Math.Round(r.FileSize/1024.0,1))</td>
                                        <td>@r.UploadDate</td>
                                        <td class="uploaded-by">@((string.IsNullOrWhiteSpace(r.UploadedBy) ? "" : r.UploadedBy))</td>
                                        <td>
                                            <div class="rev-actions">
                                                <form method="get" action="@Url.Action("OpenDrawing","Home", new { id = r.Id })">
                                                    <button type="submit" class="btn btn-primary btn-action" formtarget="_blank">Open</button>
                                                </form>
                                                <a class="btn btn-outline btn-action" asp-action="DownloadDrawing" asp-controller="Home" asp-route-id="@r.Id">Download</a>
                                                <button type="button" class="btn btn-primary btn-action" onclick="openEditDrawingModal(this)">Edit</button>
                                                <form method="post" asp-action="DeleteDrawing" asp-controller="Home" class="delete-form">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@r.Id" />
                                                    <input type="hidden" name="projectId" value="@Model.SelectedProjectId" />
                                                    <input type="hidden" name="mode" value="@Model.Mode" />
                                                    <input type="hidden" name="layout" value="@Model.Layout" />
                                                    <input type="hidden" name="sheet" value="@Model.Sheet" />
                                                    <button type="submit" class="btn btn-danger btn-action btn-del">Del</button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }

                                @* Keep top-to-bottom order when submitting (no reverse) *@
                            </tbody>
                        </table>
                    </div>
                    <form id="reorderForm" method="post" asp-action="ReorderDrawings" asp-controller="Home" onsubmit="collectOrder()">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="projectId" value="@Model.SelectedProjectId" />
                        <input type="hidden" name="mode" value="@Model.Mode" />
                        <input type="hidden" name="layout" value="@Model.Layout" />
                        <input type="hidden" name="sheet" value="@Model.Sheet" />
                        <input type="hidden" id="orderedIds" name="orderedIds" />
                        <button type="submit" class="btn btn-primary">Save Order</button>
                    </form>
                }
            </div>
        </div>
    </div>

    @await Html.PartialAsync("_EditDrawingModal")
    @await Html.PartialAsync("_ConfirmDeleteModal")

    @await Html.PartialAsync("_DashboardFooter")

    <div id="drawingsData"
         data-mode="@Model.Mode"
         data-selected-project-id="@Model.SelectedProjectId"
         data-drawings-url="@Url.Action("Drawings","Home")"
         data-get-sheet-revision-url="@Url.Action("GetSheetRevision","Home")"
         data-update-sheet-revision-url="@Url.Action("UpdateSheetRevision","Home")"
         data-suggest-revision-tag-url="@Url.Action("SuggestRevisionTagFromName","Home")"
         hidden></div>
    <script id="drawingKeysJson" type="application/json">@Html.Raw(System.Text.Json.JsonSerializer.Serialize((Model.Keys ?? new List<PMS.Models.DrawingKeyOption>()).Select(k => k.Key)))</script>
    <script src="~/js/drawings.js" asp-append-version="true"></script>
</body>
</html>