@model PMS.Models.HtSelectionViewModel
@using System.Text.Json
@{
    Layout = null;
    var selectedWeldTypes = Model.SelectedWeldTypes ?? new List<string>();
    var lotOptions = Model.LotOptions ?? new List<PMS.Models.LotOption>();
    var weldTypeOptionsJson = JsonSerializer.Serialize(Model.WeldTypeOptions ?? new List<string>());
    var selectedWeldTypesJson = JsonSerializer.Serialize(selectedWeldTypes);
    var lotOptionsJson = JsonSerializer.Serialize(lotOptions);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>PMS - HT Selection</title>
    <link rel="icon" type="image/png" href="~/img/title_logo.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="~/css/DashboardStyle.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/RtSelection.css" asp-append-version="true" />
</head>
<body>
    @await Html.PartialAsync("~/Views/Shared/_DashboardHeader.cshtml")
    <div class="rt-container">
        <div class="rt-card">
            <header class="rt-page-header">
                <div class="rt-heading">
                    <p class="rt-eyebrow">Hardness Test</p>
                    <h1>HT Selection</h1>
                    <p class="rt-subtitle">Refine lots, welders, and joint attributes before updating HT selections.</p>
                </div>
                <div class="rt-primary-actions">
                    <button id="rtSave" type="button" class="btn btn-primary">Save HT Selection</button>
                    <button id="rtAutoSelect" type="button" class="btn btn-outline">Auto Select</button>
                    <button id="rtApply" type="button" class="btn btn-primary">Apply Filters</button>
                    <button id="rtReset" type="button" class="btn btn-outline">Reset</button>
                </div>
            </header>
            <div class="rt-layout">
                 <section class="rt-main-panel">
                    <div class="rt-alert hidden" id="rtMessage" role="status" aria-live="polite"></div>
                    <div class="rt-alert rt-alert-info hidden" id="rtTruncatedNotice">Showing the first 4000 results. Refine filters to see more.</div>
                    <div class="rt-pretable">
                        <div class="rt-panel-card rt-panel-inline">
                            <div class="rt-panel-header">
                                <div>
                                    <p class="rt-panel-eyebrow">Filters</p>
                                        <h2>Selection Criteria</h2>
                                        <p class="rt-panel-hint">Project and lot changes instantly refresh the available weld types.</p>
                                </div>
                                <div class="rt-bulk-date">
                                        <label for="rtBulkSelectionDate">HT Selection Date</label>
                                    <div class="rt-bulk-date-controls">
                                        <input type="date" id="rtBulkSelectionDate" class="rt-input" />
                                        <button id="rtBulkFillSelectionDate" type="button" class="btn btn-outline">Fill Selection Date</button>
                                    </div>
                                        <p class="rt-inline-hint">Fills selection date for checked HT rows (unsaved until you Save).</p>
                                </div>
                                <div class="rt-panel-actions">
                                    <div class="rt-upload-group">
                                        <button id="rtUpload" type="button" class="btn btn-outline">Upload Joint List</button>
                                        <button id="rtClearUpload" type="button" class="btn btn-outline hidden">Clear Upload</button>
                                        <button id="rtTemplate" type="button" class="btn btn-outline">Download Template</button>
                                        <input type="file" id="rtUploadFile" accept=".xlsx,.xls,.csv" style="display:none" />
                                    </div>
                                    <p class="rt-inline-hint">Upload a spreadsheet to spotlight matching joints in the results.</p>
                                </div>
                            </div>
                            <div class="rt-filters">
                                <div class="rt-filters-row rt-filters-row-top">
                                    <div class="rt-field-group">
                                        <div class="rt-field-cluster rt-field-cluster-stacked">
                                            <div class="rt-field-stack">
                                                <div class="rt-field-slim">
                                                     <label>Project No</label>
                                                    <div class="ms-wrap ms-wrap-wide" id="rtProjectMs" data-ms-placeholder="Select projects...">
                                                        <div class="ms-toggle" tabindex="0">
                                                            <span class="ms-label">Select projects...</span>
                                                        </div>
                                                        <div class="ms-panel">
                                                            <input type="text" class="ms-search" placeholder="Search projects..." />
                                                            <div class="ms-actions">
                                                                <button type="button" data-action="all">All</button>
                                                                <button type="button" data-action="none">None</button>
                                                            </div>
                                                            <div class="ms-options">
                                                                @foreach (var p in Model.Projects)
                                                                {
                                                                    var isChecked = Model.SelectedProjectIds.Contains(p.Id);
                                                                    <label class="ms-option">
                                                                        <input type="checkbox" name="rtProject" value="@p.Id" @(isChecked ? "checked" : "") />
                                                                        @p.Id - @p.Name
                                                                    </label>
                                                                }
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="rt-field-slim rt-field-radio">
                                                    <span class="rt-chip-title">Location</span>
                                                    <div class="rt-radio-group rt-radio-inline">
                                                        <label><input type="radio" name="rtLocation" value="All" @(Model.Location.Equals("All", StringComparison.OrdinalIgnoreCase) ? "checked" : string.Empty) /> All</label>
                                                        <label><input type="radio" name="rtLocation" value="Shop" @(Model.Location.Equals("Shop", StringComparison.OrdinalIgnoreCase) ? "checked" : string.Empty) /> Shop</label>
                                                        <label><input type="radio" name="rtLocation" value="Field" @(Model.Location.Equals("Field", StringComparison.OrdinalIgnoreCase) ? "checked" : string.Empty) /> Field</label>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="rt-field-stack">
                                                <div class="rt-field-slim">
                                                    <label for="rtLot">Lot No.</label>
                                                    <select id="rtLot" class="rt-input">
                                                        <option value="">All</option>
                                                        @foreach (var lot in lotOptions.OrderBy(l => l.From).ThenBy(l => l.LotNo))
                                                        {
                                                            var fromTxt = lot.From?.ToString("dd-MM-yyyy") ?? string.Empty;
                                                            var toTxt = lot.To?.ToString("dd-MM-yyyy") ?? string.Empty;
                                                            var label = lot.LotNo + ((fromTxt != string.Empty || toTxt != string.Empty) ? $" ({fromTxt}{(toTxt != string.Empty ? " - " + toTxt : string.Empty)})" : string.Empty);
                                                            var isSelected = Model.SelectedLotId == lot.Id;
                                                            if (isSelected)
                                                            {
                                                                <option value="@lot.Id" selected>@label</option>
                                                            }
                                                            else
                                                            {
                                                                <option value="@lot.Id">@label</option>
                                                            }
                                                        }
                                                    </select>
                                                </div>
                                                <div class="rt-field-slim rt-field-radio">
                                                    <span class="rt-chip-title">Lot Category</span>
                                                    <div class="rt-radio-group rt-radio-inline">
                                                        <label><input type="radio" name="rtLotCategory" value="Welding" @(Model.LotCategory.Equals("Welding", StringComparison.OrdinalIgnoreCase) ? "checked" : string.Empty) /> Welding</label>
                                                        <label><input type="radio" name="rtLotCategory" value="Fit-up" @(!Model.LotCategory.Equals("Welding", StringComparison.OrdinalIgnoreCase) ? "checked" : string.Empty) /> Fit-up</label>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="rt-wt-column">
                                        <div class="rt-filter rt-wt-filter">
                                            <div class="rt-filter-header">
                                                <label>Weld Type</label>
                                                <div class="rt-wt-actions">
                                                    <button type="button" id="rtWtAll" class="btn btn-outline">All</button>
                                                    <button type="button" id="rtWtNone" class="btn btn-outline">None</button>
                                                    <button type="button" id="rtWtDefault" class="btn btn-outline">Default</button>
                                                </div>
                                            </div>
                                            <div class="rt-wt-list" id="rtWeldTypes"></div>
                                        </div>
                                        <div class="rt-field-slim rt-field-radio">
                                            <span class="rt-chip-title">HT Option</span>
                                            <div class="rt-radio-group rt-radio-inline">
                                                <label><input type="radio" name="rtHtMode" value="WithoutPWHT" @(string.Equals(Model.HtMode ?? "", "WithoutPWHT", StringComparison.OrdinalIgnoreCase) ? "checked" : string.Empty) /> HT Without PWHT</label>
                                                <label><input type="radio" name="rtHtMode" value="AfterPWHT" @(string.Equals(Model.HtMode ?? "", "AfterPWHT", StringComparison.OrdinalIgnoreCase) ? "checked" : string.Empty) /> HT After PWHT</label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="rt-filters-row rt-filters-row-bottom">
                                    <div class="rt-filter-grid-slim">
                                        <div class="rt-field-slim">
                                            <label for="rtPipeClass">Pipe Class</label>
                                            <input id="rtPipeClass" class="rt-input" type="text" placeholder="Search Line Class" />
                                        </div>
                                        <div class="rt-field-slim">
                                            <label for="rtWelder">Welder</label>
                                            <input id="rtWelder" class="rt-input" type="text" placeholder="Search Root / Fill / Cap" />
                                        </div>
                                        <div class="rt-field-slim">
                                            <label for="rtLayout">Layout</label>
                                            <input id="rtLayout" class="rt-input" type="text" placeholder="Search Layout" />
                                        </div>
                                        <div class="rt-field-slim">
                                            <label for="rtSheet">Sheet</label>
                                            <input id="rtSheet" class="rt-input" type="text" placeholder="Search Sheet" />
                                        </div>
                                        <div class="rt-field-slim">
                                            <label for="rtJoint">Joint No</label>
                                            <input id="rtJoint" class="rt-input" type="text" placeholder="Search Joint No" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                     </div>
                     <div class="rt-tables-grid">
                         <div class="rt-table-card">
                            <div class="rt-card-title">Joints Selection</div>
                            <div class="rt-table-wrap">
                                <table class="rt-table rt-table-selection" id="rtTable">
                                    <thead>
                                        <tr>
                                            <th>S/N.</th>
                                            <th class="rt-center">Line Class</th>
                                            <th>Layout</th>
                                            <th class="rt-center">Sheet</th>
                                            <th class="rt-center">Spool</th>
                                            <th class="rt-center">Joint No</th>
                                            <th class="rt-center rt-col-dia">Dia. In.</th>
                                            <th class="rt-center rt-col-thickness">Act. Thk.</th>
                                            <th class="rt-center">Root</th>
                                            <th class="rt-center">Fill / Cap</th>
                                            <th class="rt-center rt-col-pid">HT Sele.</th>
                                            <th class="rt-center rt-col-selection-date">HT Selection Date</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr class="empty"><td colspan="12">No data</td></tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <div class="rt-table-card rt-stats-card">
                            <div class="rt-card-title">Statistics</div>
                            <div class="rt-table-wrap">
                                <table class="rt-table rt-table-stats" id="rtStatsTable">
                                    <thead>
                                        <tr>
                                            <th colspan="3">Line Class / Root / Fill / Group Count</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr class="empty"><td colspan="3">No data</td></tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                    <div class="rt-loader hidden" id="rtLoader">Loading...</div>
                </section>
            </div>
        </div>
    </div>

    <div id="rtConfirmOverlay" class="rt-modal-overlay hidden">
        <div class="rt-modal">
            <h3 class="rt-modal-title" id="rtConfirmTitle">Confirm</h3>
            <div class="rt-modal-body" id="rtConfirmBody"></div>
            <div class="rt-modal-actions">
                <button type="button" class="btn btn-outline" id="rtConfirmCancel">Cancel</button>
                <button type="button" class="btn btn-primary" id="rtConfirmOk">OK</button>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/xlsx/dist/xlsx.full.min.js"></script>
    <script>
        (function(){
            function confirmModal(message, title){
                return new Promise(resolve => {
                    const overlay = document.getElementById('rtConfirmOverlay');
                    const titleEl = document.getElementById('rtConfirmTitle');
                    const bodyEl = document.getElementById('rtConfirmBody');
                    const okBtn = document.getElementById('rtConfirmOk');
                    const cancelBtn = document.getElementById('rtConfirmCancel');
                    titleEl.textContent = title || 'Confirm';
                    bodyEl.textContent = message || '';
                    overlay.classList.remove('hidden');
                    requestAnimationFrame(() => overlay.classList.add('rt-modal-visible'));
                    function close(result){
                        overlay.classList.remove('rt-modal-visible');
                        setTimeout(() => overlay.classList.add('hidden'), 200);
                        okBtn.removeEventListener('click', onOk);
                        cancelBtn.removeEventListener('click', onCancel);
                        overlay.removeEventListener('click', onOverlay);
                        resolve(result);
                    }
                    function onOk(){ close(true); }
                    function onCancel(){ close(false); }
                    function onOverlay(e){ if(e.target === overlay) close(false); }
                    okBtn.addEventListener('click', onOk);
                    cancelBtn.addEventListener('click', onCancel);
                    overlay.addEventListener('click', onOverlay);
                });
            }

            const weldTypeOptions = JSON.parse('@Html.Raw(weldTypeOptionsJson)');
            let defaultWeldTypes = JSON.parse('@Html.Raw(selectedWeldTypesJson)');
            let lotOptions = JSON.parse('@Html.Raw(lotOptionsJson)');

            const projectMsWrap = document.getElementById('rtProjectMs');
            function getSelectedProjectIds() {
                return Array.from((projectMsWrap || document).querySelectorAll('input[name="rtProject"]:checked')).map(cb => Number(cb.value)).filter(v => v > 0);
            }
            function getFirstProjectId() {
                var ids = getSelectedProjectIds(); return ids.length > 0 ? ids[0] : 0;
            }
            const lotSelect = document.getElementById('rtLot');
            const weldTypeContainer = document.getElementById('rtWeldTypes');
            const pipeInput = document.getElementById('rtPipeClass');
            const welderInput = document.getElementById('rtWelder');
            const layoutInput = document.getElementById('rtLayout');
            const sheetInput = document.getElementById('rtSheet');
            const jointInput = document.getElementById('rtJoint');
            const loader = document.getElementById('rtLoader');
            const truncatedNotice = document.getElementById('rtTruncatedNotice');
            const messageBox = document.getElementById('rtMessage');
            const uploadInput = document.getElementById('rtUploadFile');
            const bulkSelectionDateInput = document.getElementById('rtBulkSelectionDate');
            const bulkFillSelectionDateBtn = document.getElementById('rtBulkFillSelectionDate');
            const rowFilters = { upload: null, stats: null };
            let statsFilter = null;
            let activeStatsTrigger = null;
            let hasUserSelectedLot = false;
            let messageTimer = null;
            let loadAbort = null;
            let loadDebounceTimer = null;

            function showMessage(text, type){
                if(!messageBox){
                    alert(text || '');
                    return;
                }
                messageBox.textContent = text || '';
                messageBox.classList.remove('hidden','rt-alert-info','rt-alert-success','rt-alert-error');
                const cls = type === 'success' ? 'rt-alert-success' : (type === 'error' ? 'rt-alert-error' : 'rt-alert-info');
                messageBox.classList.add(cls);
                if(messageTimer){ clearTimeout(messageTimer); }
                messageTimer = setTimeout(() => messageBox.classList.add('hidden'), 4000);
            }

            function normalizeStatValue(value){
                return (value || '').toString().trim().toUpperCase();
            }

            function normalizeSheetValue(v){
                if(v === null || v === undefined) return '';
                const s = ('' + v).trim();
                if(!s) return '';
                const m = s.match(/^([0-9]+)([A-Za-z])?$/);
                if(m){
                    const num = m[1];
                    const letter = (m[2] || '').toUpperCase();
                    return num.toString().padStart(3,'0') + letter;
                }
                return s.toUpperCase();
            }

            function normalizeLayoutValue(v){
                if(v === null || v === undefined) return '';
                return ('' + v).trim().toUpperCase();
            }

            function normalizeJointValue(v){
                if(v === null || v === undefined) return '';
                return ('' + v).trim().toUpperCase();
            }

            function applyRowFilters(){
                const rows = document.querySelectorAll('#rtTable tbody tr');
                if(!rows.length) return;
                let index = 1;
                rows.forEach(tr => {
                    if(tr.classList.contains('empty')) return;
                    let visible = true;
                    if(rowFilters.upload){
                        const rowLayout = normalizeLayoutValue(tr.getAttribute('data-layout'));
                        const rowSheet = normalizeSheetValue(tr.getAttribute('data-sheet'));
                        const rowJoint = normalizeJointValue(tr.getAttribute('data-joint-no'));
                        const rowSpool = normalizeJointValue(tr.getAttribute('data-spool'));
                        visible = rowFilters.upload.some(f => {
                            let okLayout = true;
                            if(f.layout){
                                okLayout = rowLayout === f.layout;
                            }
                            let okSheet = true;
                            if(f.sheet){
                                okSheet = rowSheet === f.sheet;
                            }
                            let okJoint = true;
                            if(f.joint){
                                okJoint = rowJoint === f.joint || rowSpool === f.joint;
                            }
                            return okLayout && okSheet && okJoint;
                        });
                    }
                    if(visible && rowFilters.stats){
                        const { lineClass, root, fill } = rowFilters.stats;
                        const rowLine = tr.getAttribute('data-line-class') || '';
                        if(lineClass && rowLine !== lineClass){ visible = false; }
                        const rowRoot = tr.getAttribute('data-root') || '';
                        if(visible && root && rowRoot !== root){ visible = false; }
                        const rowFill = tr.getAttribute('data-fill') || '';
                        if(visible && fill && rowFill !== fill){ visible = false; }
                    }
                    tr.style.display = visible ? '' : 'none';
                    if(visible){
                        const serialCell = tr.querySelector('.rt-serial');
                        if(serialCell){ serialCell.textContent = index++; }
                    }
                });
            }

            function clearStatsFilter(){
                if(activeStatsTrigger){
                    activeStatsTrigger.classList.remove('rt-stats-active');
                }
                activeStatsTrigger = null;
                statsFilter = null;
                rowFilters.stats = null;
                applyRowFilters();
            }

            function applyStatsFilter(filter, trigger){
                const normalized = {
                    lineClass: normalizeStatValue(filter?.lineClass),
                    root: normalizeStatValue(filter?.root),
                    fill: normalizeStatValue(filter?.fill)
                };
                const hasFilter = normalized.lineClass || normalized.root || normalized.fill;
                if(activeStatsTrigger === trigger){
                    clearStatsFilter();
                    return;
                }
                if(!hasFilter){
                    clearStatsFilter();
                    return;
                }
                if(activeStatsTrigger){
                    activeStatsTrigger.classList.remove('rt-stats-active');
                }
                activeStatsTrigger = trigger;
                trigger?.classList.add('rt-stats-active');
                statsFilter = normalized;
                rowFilters.stats = normalized;
                applyRowFilters();
            }

            function hydrateActiveStatsTrigger(){
                if(!statsFilter) return;
                const { lineClass, root, fill } = statsFilter;
                const chips = Array.from(document.querySelectorAll('.rt-stats-chip[data-line-class]'));
                let match = chips.find(el => {
                    if(lineClass && el.getAttribute('data-line-class') !== lineClass) return false;
                    if(root && el.getAttribute('data-root') !== root) return false;
                    if(fill && el.getAttribute('data-fill') !== fill) return false;
                    return true;
                });
                if(!match && lineClass){
                    const lines = Array.from(document.querySelectorAll('.rt-line-class[data-line-class]'));
                    match = lines.find(el => el.getAttribute('data-line-class') === lineClass);
                }
                if(match){
                    activeStatsTrigger = match;
                    match.classList.add('rt-stats-active');
                }else{
                    clearStatsFilter();
                }
            }

            function attachStatsFilters(){
                document.querySelectorAll('.rt-line-class[data-line-class]').forEach(el => {
                    el.addEventListener('click', () => applyStatsFilter({ lineClass: el.getAttribute('data-line-class') }, el));
                    el.addEventListener('keydown', evt => {
                        if(evt.key === 'Enter' || evt.key === ' '){
                            evt.preventDefault();
                            el.click();
                        }
                    });
                });
                document.querySelectorAll('.rt-stats-chip[data-line-class]').forEach(el => {
                    el.addEventListener('click', () => applyStatsFilter({
                        lineClass: el.getAttribute('data-line-class'),
                        root: el.getAttribute('data-root'),
                        fill: el.getAttribute('data-fill')
                    }, el));
                    el.addEventListener('keydown', evt => {
                        if(evt.key === 'Enter' || evt.key === ' '){
                            evt.preventDefault();
                            el.click();
                        }
                    });
                });
                hydrateActiveStatsTrigger();
            }


            function escapeHtml(str){
                return (str || '').toString()
                    .replace(/&/g,'&amp;')
                    .replace(/</g,'&lt;')
                    .replace(/>/g,'&gt;')
                    .replace(/"/g,'&quot;')
                    .replace(/'/g,'&#39;');
            }

            function toggleLoading(show){
                if(!loader) return;
                if(show) loader.classList.remove('hidden'); else loader.classList.add('hidden');
            }

            function setTruncatedNotice(isTruncated){
                if(!truncatedNotice) return;
                if(isTruncated){
                    truncatedNotice.classList.remove('hidden');
                }else{
                    truncatedNotice.classList.add('hidden');
                }
            }

            function renderWeldTypes(options, defaults){
                const list = Array.isArray(options) ? options : [];
                const def = new Set((defaults || []).map(x => (x || '').toString().trim().toUpperCase()));
                weldTypeContainer.innerHTML = list.map(w => {
                    const val = (w || '').toString();
                    const checked = def.size === 0 || def.has(val.trim().toUpperCase());
                    const checkedAttr = checked ? ' checked' : '';
                    return `<label><input type="checkbox" class="rt-wt" value="${escapeHtml(val)}"${checkedAttr}/> ${escapeHtml(val)}</label>`;
                }).join('');
            }

            renderWeldTypes(weldTypeOptions, defaultWeldTypes);

            document.getElementById('rtWtAll')?.addEventListener('click', () => {
                document.querySelectorAll('.rt-wt').forEach(cb => cb.checked = true);
            });
            document.getElementById('rtWtNone')?.addEventListener('click', () => {
                document.querySelectorAll('.rt-wt').forEach(cb => cb.checked = false);
            });
            document.getElementById('rtWtDefault')?.addEventListener('click', () => {
                renderWeldTypes(weldTypeOptions, defaultWeldTypes);
            });

            function selectedLocation(){
                return document.querySelector('input[name="rtLocation"]:checked')?.value || 'All';
            }
            function selectedLotCategory(){
                return document.querySelector('input[name="rtLotCategory"]:checked')?.value || 'Welding';
            }
            function selectedHtMode(){
                return document.querySelector('input[name="rtHtMode"]:checked')?.value || 'WithoutPWHT';
            }
            function selectedWeldTypes(){
                return Array.from(document.querySelectorAll('.rt-wt:checked')).map(cb => cb.value);
            }

            function formatDateDMY(val){
                if(!val) return '';
                try{
                    const d = new Date(val);
                    if(isNaN(d.getTime())) return '';
                    const dd = String(d.getDate()).padStart(2,'0');
                    const mm = String(d.getMonth()+1).padStart(2,'0');
                    const yyyy = d.getFullYear();
                    return `${dd}-${mm}-${yyyy}`;
                }catch{ return ''; }
            }

            function formatDateInputValue(val){
                if(!val) return '';
                try{
                    const d = new Date(val);
                    if(isNaN(d.getTime())) return '';
                    const dd = String(d.getDate()).padStart(2,'0');
                    const mm = String(d.getMonth()+1).padStart(2,'0');
                    const yyyy = d.getFullYear();
                    return `${yyyy}-${mm}-${dd}`;
                }catch{ return ''; }
            }

            function getSelectionDateValue(input){
                if(!input) return null;
                const val = (input.value || '').trim();
                return val ? val : null;
            }

            function rebuildLotOptions(newOptions, defaultLotId){
                if(!lotSelect) return;
                const current = lotSelect.value;
                const opts = Array.isArray(newOptions) ? newOptions : [];
                lotSelect.innerHTML = '<option value="">All</option>' + opts.map(l => {
                    const id = l.lot_ID ?? l.Lot_ID ?? l.id ?? l.Id;
                    const name = l.lot_No ?? l.Lot_No ?? l.lotNo ?? l.LotNo ?? '';
                    const fromTxt = formatDateDMY(l.from_Date || l.From_Date || l.from || l.From);
                    const toTxt = formatDateDMY(l.to_Date || l.To_Date || l.to || l.To);
                    const label = `${escapeHtml(name)}${(fromTxt || toTxt) ? ` (${fromTxt}${toTxt ? ' - ' + toTxt : ''})` : ''}`;
                    return `<option value="${id}">${label}</option>`;
                }).join('');
                const hasCurrent = current && lotSelect.querySelector(`option[value="${current}"]`);
                if(hasCurrent){
                    lotSelect.value = current;
                }else if(!hasUserSelectedLot){
                    const defaultValue = (defaultLotId ?? '').toString();
                    if(defaultValue && lotSelect.querySelector(`option[value="${defaultValue}"]`)){
                        lotSelect.value = defaultValue;
                    }else{
                        lotSelect.value = '';
                    }
                }else{
                    lotSelect.value = '';
                }
                lotOptions = opts;
            }

            function buildRequestPayload(){
                var ids = getSelectedProjectIds();
                return {
                    projectId: ids.length > 0 ? ids[0] : 0,
                    projectIds: ids,
                    location: selectedLocation(),
                    lotCategory: selectedLotCategory(),
                    htMode: selectedHtMode(),
                    lotId: lotSelect && lotSelect.value ? Number(lotSelect.value) : null,
                    weldTypes: selectedWeldTypes(),
                    pipeClass: pipeInput?.value || '',
                    welder: welderInput?.value || '',
                    layout: layoutInput?.value || '',
                    sheet: sheetInput?.value || '',
                    jointNo: jointInput?.value || ''
                };
            }

            function buildParams(){
                const params = new URLSearchParams();
                const payload = buildRequestPayload();
                (payload.projectIds || []).forEach(id => params.append('projectIds', id));
                if(payload.projectId) params.append('projectId', payload.projectId);
                params.append('location', payload.location);
                params.append('lotCategory', payload.lotCategory);
                params.append('htMode', payload.htMode);
                if(payload.lotId) params.append('lotId', payload.lotId);
                (payload.weldTypes || []).forEach(w => params.append('weldTypes', w));
                if(payload.pipeClass) params.append('pipeClass', payload.pipeClass);
                if(payload.welder) params.append('welder', payload.welder);
                if(payload.layout) params.append('layout', payload.layout);
                if(payload.sheet) params.append('sheet', payload.sheet);
                if(payload.jointNo) params.append('jointNo', payload.jointNo);
                return params;
            }

            function renderRows(rows){
                const tbody = document.querySelector('#rtTable tbody');
                if(!tbody) return;
                if(!rows || rows.length === 0){
                    tbody.innerHTML = '<tr class="empty"><td colspan="12">No data</td></tr>';
                    return;
                }
                const frag = document.createDocumentFragment();
                rows.forEach((r, idx) => {
                    const dia = r.diameter ?? r.Diameter;
                    const thick = r.actualThick ?? r.ActualThick;
                    const ht = r.htSelection ?? r.HtSelection;
                    const jointId = r.jointId ?? r.JointId;
                    const lineClass = r.lineClass ?? r.LineClass ?? '';
                    const dataLineClass = normalizeStatValue(lineClass || 'Unspecified');
                    const layoutNumber = r.layoutNumber ?? r.LayoutNumber;
                    const sheet = r.sheet ?? r.Sheet;
                    const spool = r.spoolNumber ?? r.SpoolNumber;
                    const jointNo = r.jointNo ?? r.JointNo;
                    const rootVal = r.root ?? r.Root ?? '';
                    const fillVal = r.fillCap ?? r.FillCap ?? '';
                    const selectionDateVal = formatDateInputValue(r.htSelectionDate ?? r.HtSelectionDate);
                    const tr = document.createElement('tr');
                    tr.setAttribute('data-joint', jointId);
                    tr.setAttribute('data-joint-no', jointNo || '');
                    tr.setAttribute('data-layout', layoutNumber || '');
                    tr.setAttribute('data-sheet', sheet || '');
                    tr.setAttribute('data-spool', spool || '');
                    tr.setAttribute('data-line-class', dataLineClass);
                    tr.setAttribute('data-root', normalizeStatValue(rootVal));
                    tr.setAttribute('data-fill', normalizeStatValue(fillVal));
                    tr.innerHTML = `<td class="rt-center rt-serial">${idx + 1}</td>
                        <td class="rt-center">${escapeHtml(lineClass)}</td>
                        <td>${escapeHtml(layoutNumber)}</td>
                        <td class="rt-center">${escapeHtml(sheet)}</td>
                        <td class="rt-center">${escapeHtml(spool)}</td>
                        <td class="rt-center">${escapeHtml(jointNo)}</td>
                        <td class="rt-center rt-col-dia">${dia !== null && dia !== undefined ? Number(dia).toLocaleString() : ''}</td>
                        <td class="rt-center rt-col-thickness">${thick !== null && thick !== undefined ? Number(thick).toLocaleString() : ''}</td>
                        <td class="rt-center">${escapeHtml(rootVal)}</td>
                        <td class="rt-center">${escapeHtml(fillVal)}</td>
                        <td class="rt-center rt-col-pid"><input type="checkbox" class="ht-toggle" data-joint="${jointId}" ${ht ? 'checked' : ''}></td>
                        <td class="rt-center rt-col-selection-date"><input type="date" class="rt-input rt-selection-date" value="${selectionDateVal}" data-joint="${jointId}"></td>`;
                    frag.appendChild(tr);
                });
                tbody.innerHTML = '';
                tbody.appendChild(frag);
                attachHtHandlers();
                applyRowFilters();
            }

            function renderStats(stats){
                const tbody = document.querySelector('#rtStatsTable tbody');
                if(!tbody) return;
                if(!stats || stats.length === 0){
                    tbody.innerHTML = '<tr class="empty"><td colspan="3">No data</td></tr>';
                    clearStatsFilter();
                    return;
                }
                const groups = new Map();
                stats.forEach(item => {
                    const key = ((item.lineClass ?? item.LineClass) || 'Unspecified').toString();
                    if(!groups.has(key)){ groups.set(key, []); }
                    groups.get(key).push(item);
                });
                let total = 0;
                let selectedTotal = 0;
                const rows = [];
                groups.forEach((items, lineClass) => {
                    const subtotal = items.reduce((sum, entry) => sum + Number(entry.groupCount ?? entry.GroupCount ?? 0), 0);
                    const selectedSubtotal = items.reduce((sum, entry) => sum + Number(entry.selectedCount ?? entry.SelectedCount ?? 0), 0);
                    total += subtotal;
                    selectedTotal += selectedSubtotal;
                    const normalizedLine = normalizeStatValue(lineClass || 'Unspecified');
                    const displayLine = escapeHtml(lineClass || 'Unspecified');
                    const chips = items.map(entry => {
                        const rootRaw = entry.root ?? entry.Root ?? '';
                        const fillRaw = entry.fillCap ?? entry.FillCap ?? '';
                        const count = Number(entry.groupCount ?? entry.GroupCount ?? 0);
                        const rootDisplay = escapeHtml(rootRaw);
                        const fillDisplay = escapeHtml(fillRaw);
                        return `<span class="rt-stats-chip" role="button" tabindex="0" data-line-class="${escapeHtml(normalizedLine)}" data-root="${escapeHtml(normalizeStatValue(rootRaw))}" data-fill="${escapeHtml(normalizeStatValue(fillRaw))}"><span class="rt-chip-label">${rootDisplay || '—'} / ${fillDisplay || '—'}</span><span class="rt-chip-count">${count}</span></span>`;
                    }).join('');
                    rows.push(`<tr class="rt-stats-group-row"><td colspan="3"><div class="rt-stats-group-line"><span class="rt-line-class" role="button" tabindex="0" data-line-class="${escapeHtml(normalizedLine)}">${displayLine}</span><span class="rt-line-subtotal">Subtotal: ${subtotal}</span><span class="rt-line-selected">Selected: ${selectedSubtotal}</span></div><div class="rt-stats-chips">${chips || '<span class="rt-stats-chip rt-chip-empty">No breakdown</span>'}</div></td></tr>`);
                });
                rows.push(`<tr class="rt-stats-total-row"><td colspan="3"><div class="rt-stats-group-line"><span class="rt-line-subtotal">Total: ${total}</span><span class="rt-line-selected">Selected: ${selectedTotal}</span></div></td></tr>`);
                tbody.innerHTML = rows.join('');
                attachStatsFilters();
            }

            async function loadData(options = {}){
                const skipAutoLotReload = !!options.skipAutoLotReload;
                const projectOnly = !!options.projectOnly;
                const requestedLotValue = lotSelect ? lotSelect.value : '';
                let shouldAutoReload = false;
                if(loadAbort){ loadAbort.abort(); }
                loadAbort = new AbortController();

                try{
                    toggleLoading(true);
                    const params = projectOnly ? (function(){ var pp = new URLSearchParams(); getSelectedProjectIds().forEach(function(id){ pp.append('projectIds', id); }); var fid = getFirstProjectId(); if(fid) pp.append('projectId', fid); return pp; })() : buildParams();
                    const res = await fetch('/Home/GetHtSelectionData?' + params.toString(), { signal: loadAbort.signal });
                    const data = await res.json();
                    if(data?.lots){ rebuildLotOptions(data.lots, data?.defaultLotId); }
                    const autoLotApplied = !skipAutoLotReload && !requestedLotValue && lotSelect && lotSelect.value;
                    if(autoLotApplied){
                        shouldAutoReload = true;
                    }else{
                        renderRows(data?.rows || []);
                        renderStats(data?.stats || []);
                        setTruncatedNotice(!!data?.truncated);
                    }
                }catch(err){
                    if(err?.name === 'AbortError') return;
                    renderRows([]); renderStats([]);
                    setTruncatedNotice(false);
                } finally {
                    if(!shouldAutoReload){
                        toggleLoading(false);
                    }
                }

                if(shouldAutoReload){
                    await loadData({ skipAutoLotReload: true });
                }
            }

            async function updateWeldTypesForProject(pid){
                if(!pid) pid = getFirstProjectId();
                if(!pid) return;
                try{
                    const res = await fetch(`/Home/GetJointProgressWeldTypes?projectId=${encodeURIComponent(pid)}`);
                    const data = await res.json();
                    const options = Array.isArray(data?.options) ? data.options : [];
                    weldTypeOptions.length = 0; options.forEach(o => weldTypeOptions.push(o));
                    const defaultsFromServer = Array.isArray(data?.defaults) ? data.defaults : [];
                    const bw = options.find(o => (o || '').toString().trim().toUpperCase() === 'BW');
                    defaultWeldTypes = bw ? [bw] : (defaultsFromServer.length > 0 ? defaultsFromServer : options);
                    renderWeldTypes(weldTypeOptions, defaultWeldTypes);
                }catch(err){
                    // keep current weld types
                }
            }

            let isDirty = false;

            function markDirty(){
                isDirty = true;
                const saveBtn = document.getElementById('rtSave');
                if(saveBtn) saveBtn.textContent = 'Save HT Selection *';
            }

            function clearDirty(){
                isDirty = false;
                const saveBtn = document.getElementById('rtSave');
                if(saveBtn) saveBtn.textContent = 'Save HT Selection';
            }

            function attachHtHandlers(){
                const tbody = document.querySelector('#rtTable tbody');
                if(!tbody || tbody._htDelegated) return;
                tbody.addEventListener('change', e => {
                    if(e.target.classList.contains('ht-toggle') || e.target.classList.contains('rt-selection-date')){
                        markDirty();
                    }
                });
                tbody._htDelegated = true;
            }

            async function saveAllHtSelections(){
                const toggles = Array.from(document.querySelectorAll('.ht-toggle')).filter(cb => {
                    const tr = cb.closest('tr');
                    return tr && tr.style.display !== 'none';
                });
                if(toggles.length === 0){ showMessage('No HT selections to save.', 'info'); return; }
                if(!await confirmModal('Save all HT selections?', 'Save HT Selection')) return;
                const items = toggles
                    .map(cb => {
                        const jointId = Number(cb.getAttribute('data-joint'));
                        const dateInput = cb.closest('tr')?.querySelector('.rt-selection-date');
                        return { jointId, htSelection: !!cb.checked, htSelectionDate: getSelectionDateValue(dateInput) };
                    })
                    .filter(item => !!item.jointId);
                if(items.length === 0){ showMessage('No valid joints to save.', 'info'); return; }
                toggleLoading(true);
                try{
                    const res = await fetch('/Home/UpdateHtSelectionBulk', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ items: items })
                    });
                    const isJson = (res.headers.get('content-type') || '').includes('application/json');
                    if(!res.ok){
                        let message = 'Failed to save HT selections.';
                        if(isJson){
                            try{
                                const errorData = await res.json();
                                if(errorData?.missing && Array.isArray(errorData.missing) && errorData.missing.length){
                                    message = `Some joints were not found: ${errorData.missing.join(', ')}`;
                                }else if(errorData?.detail){
                                    message = errorData.message ? `${errorData.message}\n${errorData.detail}` : errorData.detail;
                                }else if(errorData?.message){
                                    message = errorData.message;
                                }
                            }catch{}
                        }else{
                            try{
                                const raw = await res.text();
                                if(raw) message = raw;
                            }catch{}
                        }
                        throw new Error(message);
                    }
                    const data = isJson ? await res.json() : {};
                    if(data?.missing && Array.isArray(data.missing) && data.missing.length){
                        showMessage(`Some joints were not found: ${data.missing.join(', ')}`, 'info');
                    }else{
                        showMessage('HT selections saved.', 'success');
                    }
                    clearDirty();
                    await loadData({ skipAutoLotReload: true });
                }catch(err){
                    showMessage(err?.message || 'Failed to save HT selections.', 'error');
                }finally{
                    toggleLoading(false);
                }
            }

            function applyAutoSelection(selectedIds){
                const set = new Set((selectedIds || []).map(id => Number(id)));
                let applied = 0;
                document.querySelectorAll('.ht-toggle').forEach(cb => {
                    const jid = Number(cb.getAttribute('data-joint'));
                    const shouldCheck = set.has(jid);
                    cb.checked = shouldCheck;
                    if(shouldCheck) applied++;
                });
                return applied;
            }

            async function autoSelectHt(){
                const payload = buildRequestPayload();
                if(!payload.projectIds || payload.projectIds.length === 0){
                    showMessage('Select a project before running Auto Select.', 'error');
                    return;
                }
                toggleLoading(true);
                try{
                    const res = await fetch('/Home/AutoSelectHtSelection', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });
                    const data = await res.json();
                    if(!res.ok){
                        throw new Error(data?.message || 'Auto Select failed.');
                    }
                    const selected = Array.isArray(data?.selectedIds) ? data.selectedIds : [];
                    const applied = applyAutoSelection(selected);
                    if(applied > 0) markDirty();
                    showMessage(`Auto-selected ${applied} joints. Save HT Selection to persist.`, 'success');
                }catch(err){
                    showMessage(err?.message || 'Auto Select failed.', 'error');
                }finally{
                    toggleLoading(false);
                }
            }

            if (projectMsWrap) {
                var optsCont = projectMsWrap.querySelector('.ms-options');
                if (optsCont) optsCont.addEventListener('change', async () => {
                    var pid = getFirstProjectId();
                    clearUploadFilter();
                    await updateWeldTypesForProject(pid);
                    hasUserSelectedLot = false;
                    if(lotSelect) lotSelect.value = '';
                    await loadData();
                });
                projectMsWrap.querySelectorAll('.ms-actions button').forEach(function(b){
                    b.addEventListener('click', async function(){
                        await new Promise(r => setTimeout(r, 0));
                        var pid = getFirstProjectId();
                        clearUploadFilter();
                        await updateWeldTypesForProject(pid);
                        hasUserSelectedLot = false;
                        if(lotSelect) lotSelect.value = '';
                        await loadData();
                    });
                });
            }

            function debouncedLoad(){
                if(loadDebounceTimer){ clearTimeout(loadDebounceTimer); }
                loadDebounceTimer = setTimeout(() => loadData(), 150);
            }
            document.querySelectorAll('input[name="rtLocation"]').forEach(r => r.addEventListener('change', debouncedLoad));
            document.querySelectorAll('input[name="rtLotCategory"]').forEach(r => r.addEventListener('change', debouncedLoad));
            document.querySelectorAll('input[name="rtHtMode"]').forEach(r => r.addEventListener('change', debouncedLoad));
            lotSelect?.addEventListener('change', () => {
                hasUserSelectedLot = true;
                debouncedLoad();
            });

            function applyUploadFilter(list){
                const normalized = (Array.isArray(list) ? list : []).map(item => ({
                    layout: normalizeLayoutValue(item?.layout),
                    sheet: normalizeSheetValue(item?.sheet),
                    joint: normalizeJointValue(item?.joint)
                })).filter(it => it.layout || it.sheet || it.joint);
                rowFilters.upload = normalized.length ? normalized : null;
                applyRowFilters();
                const uploadBtn = document.getElementById('rtUpload');
                const clearBtn = document.getElementById('rtClearUpload');
                if(rowFilters.upload){
                    uploadBtn?.classList.add('rt-upload-active');
                    clearBtn?.classList.remove('hidden');
                } else {
                    uploadBtn?.classList.remove('rt-upload-active');
                    clearBtn?.classList.add('hidden');
                }
            }

            function clearUploadFilter(){
                rowFilters.upload = null;
                applyRowFilters();
                if(uploadInput) uploadInput.value = '';
                document.getElementById('rtUpload')?.classList.remove('rt-upload-active');
                document.getElementById('rtClearUpload')?.classList.add('hidden');
            }

            document.getElementById('rtUpload')?.addEventListener('click', () => uploadInput?.click());
            document.getElementById('rtClearUpload')?.addEventListener('click', () => {
                clearUploadFilter();
                showMessage('Upload filter cleared.', 'info');
            });
            uploadInput?.addEventListener('change', async (e) => {
                const file = e.target.files && e.target.files[0];
                if(!file) return;
                const selectedIds = getSelectedProjectIds();
                const pid = selectedIds.length > 0 ? selectedIds[0] : 0;
                if(!pid){
                    showMessage('Select a Project No before uploading a joint list.', 'error');
                    try{ uploadInput.value = ''; }catch{}
                    return;
                }
                try{
                    toggleLoading(true);
                    document.getElementById('rtUpload')?.setAttribute('disabled','');
                    await new Promise(r => setTimeout(r, 0));
                    const data = await file.arrayBuffer();
                    const wb = XLSX.read(data, { type: 'array' });
                    const firstSheet = wb.SheetNames && wb.SheetNames[0];
                    if(!firstSheet){ alert('No sheet found in the uploaded file.'); return; }
                    const ws = wb.Sheets[firstSheet];
                    const rows = XLSX.utils.sheet_to_json(ws, { header:1, defval:'' });
                    if(!rows || rows.length === 0){ alert('Uploaded sheet is empty.'); return; }
                    const headers = rows[0].map(h => (h || '').toString().trim());
                    const headersLower = headers.map(h => h.toLowerCase());
                    let idxLayout = headersLower.findIndex(h => h.includes('layout') || h.includes('dwg'));
                    let idxSheet = headersLower.findIndex(h => h.includes('sheet'));
                    let idxJoint = headersLower.findIndex(h => h.includes('joint'));
                    if(idxLayout < 0 && idxSheet < 0 && idxJoint < 0 && headers.length >= 3){
                        idxLayout = 0; idxSheet = 1; idxJoint = 2;
                    }
                    if(idxJoint < 0) idxJoint = headersLower.findIndex(h => h.includes('spool'));

                    const uploaded = [];
                    for(let i=1;i<rows.length;i++){
                        const r = rows[i] || [];
                        const layoutVal = idxLayout >=0 ? normalizeLayoutValue(r[idxLayout]) : '';
                        const sheetVal = idxSheet >=0 ? normalizeSheetValue(r[idxSheet]) : '';
                        const jointVal = idxJoint >=0 ? normalizeJointValue(r[idxJoint]) : '';
                        if(layoutVal || sheetVal || jointVal){
                            uploaded.push({ layout: layoutVal, sheet: sheetVal, joint: jointVal });
                        }
                    }
                    if(uploaded.length === 0){ alert('No Layout, Sheet, or Joint No values found in uploaded file.'); return; }
                    const uniqueLayouts = [...new Set(uploaded.map(u => u.layout).filter(Boolean))];
                    const uploadParams = new URLSearchParams();
                    selectedIds.forEach(function(id){ uploadParams.append('projectIds', id); });
                    uploadParams.append('projectId', pid);
                    uploadParams.append('isUpload', 'true');
                    uniqueLayouts.forEach(l => uploadParams.append('uploadedLayouts', l));
                    try{
                        const uploadRes = await fetch('/Home/GetHtSelectionData?' + uploadParams.toString());
                        const uploadData = await uploadRes.json();
                        if(uploadData?.lots){ rebuildLotOptions(uploadData.lots, uploadData?.defaultLotId); }
                        renderRows(uploadData?.rows || []);
                        renderStats(uploadData?.stats || []);
                        setTruncatedNotice(!!uploadData?.truncated);
                    }catch(loadErr){
                        renderRows([]); renderStats([]);
                        setTruncatedNotice(false);
                    }
                    applyUploadFilter(uploaded);
                    const allRows = document.querySelectorAll('#rtTable tbody tr:not(.empty)');
                    const visibleRows = Array.from(allRows).filter(tr => tr.style.display !== 'none');
                    const visibleCount = visibleRows.length;
                    let checkedCount = 0;
                    visibleRows.forEach(tr => {
                        const cb = tr.querySelector('.ht-toggle');
                        if(cb && !cb.checked){ cb.checked = true; checkedCount++; }
                    });
                    if(checkedCount > 0) markDirty();
                    showMessage(`Upload filter applied (Project ${pid}): ${visibleCount} joint(s) matched out of ${uploaded.length} uploaded. ${checkedCount} HT selection(s) checked.`, 'success');
                }catch(err){
                    showMessage('Failed to read uploaded file.', 'error');
                } finally {
                    toggleLoading(false);
                    document.getElementById('rtUpload')?.removeAttribute('disabled');
                    try{ uploadInput.value = ''; }catch{}
                }
            });

            document.getElementById('rtTemplate')?.addEventListener('click', () => {
                try{
                    const aoa = [['Layout','Sheet','Joint No'], ['DMW-10689','013','WS-01']];
                    const ws = XLSX.utils.aoa_to_sheet(aoa);
                    const wb = XLSX.utils.book_new();
                    XLSX.utils.book_append_sheet(wb, ws, 'Template');
                    const data = XLSX.write(wb, { bookType:'xlsx', type:'array' });
                    const blob = new Blob([data], { type:'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' });
                    const url = window.URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.href = url; a.download = 'HtSelectionTemplate.xlsx'; a.style.display='none';
                    document.body.appendChild(a); a.click(); document.body.removeChild(a);
                    window.URL.revokeObjectURL(url);
                }catch(err){ alert('Failed to download template.'); }
            });

            bulkFillSelectionDateBtn?.addEventListener('click', () => {
                const val = bulkSelectionDateInput?.value;
                if(!val){
                    showMessage('Choose a selection date to fill.', 'error');
                    return;
                }
                const selected = Array.from(document.querySelectorAll('.ht-toggle:checked'));
                if(selected.length === 0){
                    showMessage('Select at least one HT row first.', 'info');
                    return;
                }
                selected.forEach(cb => {
                    const input = cb.closest('tr')?.querySelector('.rt-selection-date');
                    if(input){ input.value = val; }
                });
                markDirty();
                showMessage('Selection date filled for checked rows. Save HT Selection to persist.', 'success');
            });

            attachHtHandlers();

            // ?? Multi-select dropdown behaviour ??????????????????????
            function initMs(wrap) {
                var toggle = wrap.querySelector('.ms-toggle');
                var panel = wrap.querySelector('.ms-panel');
                var search = wrap.querySelector('.ms-search');
                var placeholder = wrap.dataset.msPlaceholder || 'Select...';
                var labelSpan = toggle.querySelector('.ms-label');
                function updateLabel() {
                    var checked = wrap.querySelectorAll('.ms-option input:checked');
                    if (checked.length === 0) { labelSpan.textContent = placeholder; }
                    else if (checked.length === 1) { labelSpan.textContent = checked[0].parentElement.textContent.trim(); }
                    else { labelSpan.textContent = checked.length + ' selected'; }
                }
                if (!wrap.dataset.msInit) {
                    wrap.dataset.msInit = '1';
                    toggle.addEventListener('click', function (e) {
                        e.stopPropagation();
                        var wasOpen = wrap.classList.contains('ms-open');
                        closeAllMs();
                        if (!wasOpen) { wrap.classList.add('ms-open'); panel.style.display = 'block'; if (search) search.focus(); }
                    });
                    if (search) {
                        search.addEventListener('input', function () {
                            var q = search.value.toLowerCase();
                            wrap.querySelectorAll('.ms-option').forEach(function (opt) {
                                var match = opt.textContent.toLowerCase().indexOf(q) >= 0;
                                opt.classList.toggle('ms-hidden', !match);
                            });
                        });
                    }
                    wrap.querySelectorAll('.ms-actions button').forEach(function (b) {
                        b.addEventListener('click', function (e) {
                            e.preventDefault();
                            var action = b.dataset.action;
                            wrap.querySelectorAll('.ms-option').forEach(function (opt) {
                                if (!opt.classList.contains('ms-hidden')) {
                                    opt.querySelector('input').checked = (action === 'all');
                                }
                            });
                            updateLabel();
                        });
                    });
                    var optionsContainer = wrap.querySelector('.ms-options');
                    if (optionsContainer) {
                        optionsContainer.addEventListener('change', function () { updateLabel(); });
                    }
                }
                updateLabel();
            }
            function closeAllMs() {
                document.querySelectorAll('.ms-wrap').forEach(function (w) {
                    w.classList.remove('ms-open');
                    var p = w.querySelector('.ms-panel');
                    if (p) p.style.display = 'none';
                });
            }
            document.addEventListener('click', closeAllMs);
            document.querySelectorAll('.ms-wrap').forEach(initMs);

            function initialize(){
                if(lotSelect && lotSelect.value){
                    loadData({ skipAutoLotReload: true });
                } else {
                    loadData();
                }
            }

            document.getElementById('rtApply')?.addEventListener('click', loadData);
            document.getElementById('rtAutoSelect')?.addEventListener('click', autoSelectHt);
            document.getElementById('rtSave')?.addEventListener('click', saveAllHtSelections);
            document.getElementById('rtReset')?.addEventListener('click', () => {
                document.querySelector('input[name="rtLocation"][value="All"]')?.click();
                document.querySelector('input[name="rtLotCategory"][value="Welding"]')?.click();
                document.querySelector('input[name="rtHtMode"][value="WithoutPWHT"]')?.click();
                hasUserSelectedLot = false;
                if(lotSelect) lotSelect.value = '';
                if(pipeInput) pipeInput.value = '';
                if(welderInput) welderInput.value = '';
                if(layoutInput) layoutInput.value = '';
                if(sheetInput) sheetInput.value = '';
                if(jointInput) jointInput.value = '';
                renderWeldTypes(weldTypeOptions, defaultWeldTypes);
                clearUploadFilter();
                clearStatsFilter();
                loadData();
            });
            initialize();
        })();
    </script>
</body>
</html>
