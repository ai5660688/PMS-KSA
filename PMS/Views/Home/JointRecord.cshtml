@model PMS.Models.JointRecordViewModel
@using System.Text.Json
@{
    Layout = null;
    var rowsJson = JsonSerializer.Serialize(Model.Rows ?? new List<PMS.Models.JointRecordAnalysisRow>());
    var warningsJson = JsonSerializer.Serialize(Model.Warnings ?? new List<string>());
    var matDesJson = JsonSerializer.Serialize(Model.MaterialDescriptions ?? new List<string>());
    var materialsJson = JsonSerializer.Serialize(Model.Materials ?? new List<string>());
    var locationsJson = JsonSerializer.Serialize(Model.Locations ?? new List<string>());
    var weldTypesJson = JsonSerializer.Serialize(Model.WeldTypes ?? new List<string>());
    var gradesJson = JsonSerializer.Serialize(Model.Grades ?? new List<string>());
    var jAddJson = JsonSerializer.Serialize(Model.JAddOptions ?? new List<string>());
    var scopeValue = Model.Scope ?? "Joints";
    var modeValue = Model.Mode ?? "upload";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <title>PMS - Joint Record OCR</title>
    <link rel="icon" type="image/png" href="~/img/title_logo.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="~/css/DashboardStyle.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/JointRecord.css" asp-append-version="true" />
    <style>
        /* Enhanced validation styling */
        .jr-row-error {
            background-color: rgba(220, 53, 69, 0.1) !important;
            border-left: 4px solid #dc3545 !important;
        }

        .jr-row-warning {
            background-color: rgba(255, 193, 7, 0.1) !important;
            border-left: 4px solid #ffc107 !important;
        }

        .jr-filter-link {
            text-decoration: none;
            color: inherit;
            cursor: pointer;
            padding: 2px 8px;
            border-radius: 4px;
            transition: background-color 0.15s, color 0.15s;
        }

        .jr-filter-link:hover {
            background-color: #e2e6ea;
            text-decoration: none;
            color: #0056b3;
        }

        .jr-filter-link.jr-filter-selected {
            background-color: #0d6efd;
            color: #fff !important;
            border-radius: 4px;
        }

        .jr-filter-link.jr-filter-selected:hover {
            background-color: #0b5ed7;
            color: #fff !important;
        }

        .jr-filter-link.jr-filter-active {
            color: #dc3545;
            font-size: 12px;
            font-weight: 600;
        }

        .jr-filter-link.jr-filter-active:hover {
            background-color: #f8d7da;
            color: #dc3545;
        }

        .jr-cell-error {
            background-color: #f8d7da !important;
            border: 1px solid #f5c6cb !important;
        }

        .jr-cell-highlight {
            background-color: #fff3cd !important;
            border: 1px solid #ffeaa7 !important;
        }

        .jr-tooltip {
            position: relative;
            cursor: help;
        }

            .jr-tooltip:hover::after {
                content: attr(data-tooltip);
                position: absolute;
                bottom: 100%;
                left: 50%;
                transform: translateX(-50%);
                background: #333;
                color: white;
                padding: 5px 10px;
                border-radius: 4px;
                font-size: 12px;
                white-space: pre-line;
                z-index: 1000;
                min-width: 200px;
                max-width: 400px;
            }

        /* Enhanced table styling */
        .jr-table th {
            background-color: #2c3e50;
            color: white;
            font-weight: 600;
            position: sticky;
            top: 0;
            z-index: 10;
        }

        .jr-table td {
            vertical-align: middle;
            padding: 6px 8px !important;
        }

        .jr-table input {
            width: 100%;
            padding: 4px 6px;
            border: 1px solid #dee2e6;
            border-radius: 3px;
            font-size: 13px;
            transition: all 0.2s;
        }

            .jr-table input:focus {
                border-color: #80bdff;
                outline: 0;
                box-shadow: 0 0 0 0.2rem rgba(0,123,255,.25);
            }

            .jr-table input.error {
                border-color: #dc3545;
                background-color: #f8d7da;
            }

            .jr-table input.warning {
                border-color: #ffc107;
                background-color: #fff3cd;
            }

        .jr-table select {
            min-width: 120px;
            padding: 4px 6px;
            border: 1px solid #dee2e6;
            border-radius: 3px;
            font-size: 13px;
            transition: all 0.2s;
            background-color: #fff;
            cursor: pointer;
        }

            .jr-table select:focus {
                border-color: #80bdff;
                outline: 0;
                box-shadow: 0 0 0 0.2rem rgba(0,123,255,.25);
            }

            .jr-table select.error {
                border-color: #dc3545;
                background-color: #f8d7da;
            }

            .jr-table select.warning {
                border-color: #ffc107;
                background-color: #fff3cd;
            }

        /* Status indicators */
        .jr-status {
            padding: 3px 8px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: 600;
            margin-left: 10px;
        }

        .jr-status-success {
            background-color: #d4edda;
            color: #155724;
        }

        .jr-status-warning {
            background-color: #fff3cd;
            color: #856404;
        }

        .jr-status-error {
            background-color: #f8d7da;
            color: #721c24;
        }

        /* Bulk Analyze selection modal */
        .jr-modal-overlay {
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,0.5);
            z-index: 10000;
            display: flex;
            justify-content: center;
            align-items: center;
        }
        .jr-modal {
            background: #fff;
            border-radius: 8px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.25);
            width: 740px;
            max-width: 92vw;
            max-height: 80vh;
            display: flex;
            flex-direction: column;
        }
        .jr-modal-header {
            padding: 16px 20px;
            border-bottom: 1px solid #dee2e6;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-weight: 600;
            font-size: 16px;
        }
        .jr-modal-header .close-btn {
            background: none; border: none; font-size: 22px; cursor: pointer; color: #666;
        }
        .jr-modal-header .close-btn:hover { color: #333; }
        .jr-modal-toolbar {
            padding: 10px 20px;
            border-bottom: 1px solid #eee;
            display: flex;
            gap: 8px;
            align-items: center;
            flex-wrap: wrap;
        }
        .jr-modal-toolbar input[type="text"] {
            padding: 5px 8px;
            border: 1px solid #dee2e6;
            border-radius: 4px;
            font-size: 13px;
            background: #fff;
            max-width: 150px;
            min-width: 80px;
        }
        .jr-modal-toolbar input[type="text"]:focus {
            border-color: #80bdff;
            outline: 0;
            box-shadow: 0 0 0 0.2rem rgba(0,123,255,.25);
        }
        .jr-modal-toolbar label {
            font-size: 12px;
            font-weight: 600;
            color: #555;
            white-space: nowrap;
        }
        .jr-modal-filter-group {
            display: flex;
            align-items: center;
            gap: 4px;
        }
        .jr-modal-toolbar .btn-sm {
            padding: 4px 12px;
            font-size: 12px;
            border-radius: 4px;
            border: 1px solid #ccc;
            background: #f8f9fa;
            cursor: pointer;
        }
        .jr-modal-toolbar .btn-sm:hover { background: #e9ecef; }
        .jr-modal-body {
            overflow-y: auto;
            flex: 1;
            padding: 0;
        }
        .jr-modal-body table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }
        .jr-modal-body th {
            background: #f1f3f5;
            position: sticky; top: 0; z-index: 1;
            padding: 8px 10px;
            text-align: left;
            border-bottom: 2px solid #dee2e6;
        }
        .jr-modal-body td {
            padding: 6px 10px;
            border-bottom: 1px solid #eee;
        }
        .jr-modal-body tr:hover { background: #f8f9fa; }
        .jr-modal-body tr.selected-row { background: #e3f2fd; }
        .jr-modal-footer {
            padding: 12px 20px;
            border-top: 1px solid #dee2e6;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .jr-modal-footer .selection-count { font-size: 13px; color: #555; }

        /* Loading overlay */
        .jr-loading {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(255, 255, 255, 0.9);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            z-index: 9999;
        }

        .jr-spinner {
            width: 40px;
            height: 40px;
            border: 4px solid #f3f3f3;
            border-top: 4px solid #3498db;
            border-radius: 50%;
            animation: jr-spin 1s linear infinite;
            margin-bottom: 15px;
        }
        .jr-loading-status {
            font-size: 14px;
            color: #555;
            margin-top: 6px;
        }
        .jr-loading-progress {
            width: 260px;
            height: 6px;
            background: #e9ecef;
            border-radius: 3px;
            overflow: hidden;
            margin-top: 14px;
            display: none;
        }
        .jr-loading-progress-bar {
            height: 100%;
            width: 30%;
            background: linear-gradient(90deg, #3498db, #2980b9);
            border-radius: 3px;
            animation: jr-progress-indeterminate 1.4s ease-in-out infinite;
            transition: width 0.3s ease;
        }
        .jr-loading-progress.determinate .jr-loading-progress-bar {
            animation: none;
            margin-left: 0;
        }
        .jr-loading-percent {
            font-size: 13px;
            color: #3498db;
            font-weight: 600;
            margin-top: 6px;
            display: none;
        }
        @@keyframes jr-progress-indeterminate {
            0%   { margin-left: -30%; width: 30%; }
            50%  { margin-left: 50%;  width: 40%; }
            100% { margin-left: 110%; width: 30%; }
        }
    </style>
</head>
<body>
    @await Html.PartialAsync("~/Views/Shared/_DashboardHeader.cshtml")

    <div class="jr-container">
        <!-- Loading Overlay -->
        <div class="jr-loading" id="loadingOverlay" style="display: none;">
            <div class="jr-spinner"></div>
            <div id="loadingText">Processing... Please wait</div>
            <div class="jr-loading-status" id="loadingStatus"></div>
            <div class="jr-loading-progress" id="loadingProgress">
                <div class="jr-loading-progress-bar" id="loadingProgressBar"></div>
            </div>
            <div class="jr-loading-percent" id="loadingPercent"></div>
        </div>

        <!-- Main Card -->
        <div class="jr-card">
            <div class="jr-card-header">
                Joint Record OCR Intake System
            </div>

            <!-- Upload Form -->
            <div class="jr-form">
                <form id="jrForm" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()

                    <div class="jr-form-row">
                        <label for="projectSelect" class="jr-required">Project</label>
                        <select id="projectSelect" name="projectId" required>
                            @foreach (var p in Model.Projects)
                            {
                                var ls = p.LineSheet ?? string.Empty;
                                if (p.Id == Model.SelectedProjectId)
                                {
                                    <option value="@p.Id" data-linesheet="@ls" selected>@p.Id - @p.Name</option>
                                }
                                else
                                {
                                    <option value="@p.Id" data-linesheet="@ls">@p.Id - @p.Name</option>
                                }
                            }
                        </select>
                    </div>

                    <div style="display:flex; flex-wrap:wrap; gap:30px; margin-top:6px; margin-bottom:4px;">
                        <div class="jr-form-row" style="margin:0;">
                            <label>Scope</label>
                            <div style="display:flex; gap:16px; align-items:center;">
                                <label style="font-weight:normal;cursor:pointer;"><input type="radio" name="scope" value="LineList" @(scopeValue == "LineList" ? "checked" : "")> Line List</label>
                                <label style="font-weight:normal;cursor:pointer;"><input type="radio" name="scope" value="LineSheet" @(scopeValue == "LineSheet" ? "checked" : "")> Line / Sheet</label>
                                <label style="font-weight:normal;cursor:pointer;"><input type="radio" name="scope" value="Joints" @(scopeValue == "Joints" ? "checked" : "")> Joints</label>
                            </div>
                        </div>
                        <div class="jr-form-row" style="margin:0;">
                            <label>Mode</label>
                            <div style="display:flex; gap:16px; align-items:center;">
                                <label style="font-weight:normal;cursor:pointer;"><input type="radio" name="mode" value="upload" @(modeValue == "upload" ? "checked" : "")> Upload</label>
                                <label style="font-weight:normal;cursor:pointer;"><input type="radio" name="mode" value="edit" @(modeValue == "edit" ? "checked" : "")> Edit</label>
                            </div>
                        </div>
                    </div>

                    <!-- Edit mode filter fields -->
                    <div id="editFilters" style="display:@(modeValue == "edit" ? "flex" : "none"); flex-wrap:wrap; gap:15px; padding:10px 14px; background:#f0f8fb; border-radius:6px; border:1px solid #cce7ef;">
                        <div class="jr-form-row" style="margin:0;">
                            <label for="filterLayout" class="jr-required">Layout No</label>
                            <select id="filterLayout" class="jr-filter-select">
                                <option value="">-- Select Layout --</option>
                            </select>
                        </div>
                        <div id="sheetFilterRow" class="jr-form-row" style="margin:0; display:@(scopeValue == "LineList" ? "none" : "flex");">
                            <label for="filterSheet">Sheet No</label>
                            <select id="filterSheet" class="jr-filter-select">
                                <option value="">-- All Sheets --</option>
                            </select>
                        </div>
                    </div>

                    <!-- Upload mode file inputs -->
                    <div id="uploadFileInputs" style="display:@(modeValue == "upload" ? "flex" : "none"); flex-direction:column; gap:12px;">
                        <div class="jr-form-row">
                            <label for="drawingFile">Weld Map (PDF / OCR Source)</label>
                            <input type="file" id="drawingFile" name="drawingFile" accept=".pdf,.pcf,.sha,image/*">
                            <small style="color:#6c757d; margin-left:10px;">Upload construction drawings for OCR analysis (optional if using Excel template)</small>
                        </div>

                        <div class="jr-form-row">
                            <label for="excelFile">Excel Template (Optional)</label>
                            <input type="file" id="excelFile" name="excelFile" accept=".xlsx,.xls">
                            <small style="color:#6c757d; margin-left:10px;">Upload filled template for validation</small>
                        </div>

                        <div class="jr-form-row" style="flex-direction:row; align-items:center; gap:8px;">
                            <input type="checkbox" id="updateOnlyNonNull" name="updateOnlyNonNull" checked />
                            <label for="updateOnlyNonNull" style="font-weight:normal; cursor:pointer; margin:0;">Update only non-empty cells</label>
                            <small style="color:#6c757d;">(When updating existing records, skip blank/empty cells from the Excel template and keep existing DB values)</small>
                        </div>
                    </div>

                    <div class="jr-actions">
                        <!-- Upload mode buttons -->
                        <button type="button" id="analyzeBtn" class="btn btn-primary">
                            <span>Analyze Files</span>
                        </button>
                        <button type="button" id="bulkAnalyzeBtn" class="btn btn-primary" title="Analyze all latest drawing revisions for this project">
                            <span>Bulk Analyze (Latest)</span>
                        </button>
                        <button type="button" id="commitBtn" class="btn btn-primary" style="display:none;" disabled>
                            <span>Upload to DB</span>
                        </button>
                        <!-- Edit mode buttons -->
                        <button type="button" id="loadDataBtn" class="btn btn-primary" style="display:none;">
                            <span>Load Data</span>
                        </button>
                        <button type="button" id="saveChangesBtn" class="btn btn-primary" style="display:none;" disabled>
                            <span>Save Changes</span>
                        </button>
                        <!-- Common buttons -->
                        <button type="button" id="downloadTemplateBtn" class="btn btn-outline">
                            <span>Download Template</span>
                        </button>
                        <button type="button" id="downloadAnalysisBtn" class="btn btn-outline" disabled>
                            <span>Download Excel</span>
                        </button>
                        <button type="button" id="clearBtn" class="btn btn-outline">
                            <span>Clear All</span>
                        </button>
                    </div>
                </form>

                <!-- Warnings/Info Area -->
                <div id="jrMessages" class="jr-warnings" style="margin-top:6px;"></div>

                <!-- Summary Stats -->
                <div id="jrSummary" style="display:none; margin-top:6px; padding:8px 10px; background:#f8f9fa; border-radius:6px;">
                    <div style="display:flex; gap:20px; flex-wrap:wrap; align-items:center;">
                        <div><strong>Total Rows:</strong> <span id="rowCount">0</span></div>
                        <div><a href="#" id="filterWarningsLink" class="jr-filter-link" title="Click to show only rows with warnings"><strong>With Warnings:</strong> <span id="warningCount">0</span></a></div>
                        <div><a href="#" id="filterErrorsLink" class="jr-filter-link" title="Click to show only rows with errors"><strong>Errors:</strong> <span id="errorCount">0</span></a></div>
                        <div id="filterActiveLabel" style="display:none;"><a href="#" id="filterClearLink" class="jr-filter-link jr-filter-active" title="Click to show all rows">✖ Show All</a></div>
                        <div><strong>Source:</strong> <span id="sourceType">Unknown</span></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Data Table Card -->
        <div class="jr-card">
            <div class="jr-card-header">
                Extracted Joint Records
                <span id="tableStatus" class="jr-status jr-status-warning">No data</span>
            </div>

            <div class="jr-table-container">
                <table class="jr-table">
                    <thead id="jrTableHead">
                        <!-- Dynamically generated based on scope -->
                    </thead>
                    <tbody id="jrTableBody">
                        <tr>
                            <td colspan="26" class="jr-empty">
                                Upload a drawing or Excel template to see extracted data
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @await Html.PartialAsync("~/Views/Shared/_DashboardFooter.cshtml")

    <!-- Bulk Analyze Drawing Selection Modal -->
    <div id="bulkSelectModal" class="jr-modal-overlay" style="display:none;">
        <div class="jr-modal">
            <div class="jr-modal-header">
                <span>Select Drawings to Analyze</span>
                <button type="button" class="close-btn" id="bulkSelectClose">&times;</button>
            </div>
            <div class="jr-modal-toolbar">
                <div class="jr-modal-filter-group">
                    <label>Project:</label>
                    <span id="bulkFilterProject" style="font-size:13px;font-weight:600;color:#333;min-width:80px;">—</span>
                </div>
                <div class="jr-modal-filter-group">
                    <label for="bulkFilterLayout">Layout:</label>
                    <input type="text" id="bulkFilterLayout" placeholder="Search or !exclude" />
                </div>
                <div class="jr-modal-filter-group">
                    <label for="bulkFilterSheet">Sheet:</label>
                    <input type="text" id="bulkFilterSheet" placeholder="Search or !exclude" />
                </div>
                <div class="jr-modal-filter-group">
                    <label for="bulkFilterRev">Revision:</label>
                    <input type="text" id="bulkFilterRev" placeholder="Search or !exclude" />
                </div>
                <button type="button" class="btn-sm" id="bulkSelectAll">Select All</button>
                <button type="button" class="btn-sm" id="bulkDeselectAll">Deselect All</button>
            </div>
            <div class="jr-modal-body">
                <table>
                    <thead>
                        <tr>
                            <th style="width:36px;"><input type="checkbox" id="bulkSelectToggle" title="Toggle all" /></th>
                            <th>Layout No</th>
                            <th>Sheet</th>
                            <th>Revision</th>
                            <th>File Name</th>
                        </tr>
                    </thead>
                    <tbody id="bulkSelectBody"></tbody>
                </table>
            </div>
            <div class="jr-modal-footer">
                <span class="selection-count" id="bulkSelectCount">0 of 0 selected</span>
                <div style="display:flex;gap:8px;">
                    <button type="button" class="btn btn-secondary" id="bulkSelectCancel">Cancel</button>
                    <button type="button" class="btn btn-primary" id="bulkSelectConfirm" disabled>Analyze Selected</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Confirmation Modal -->
    <div id="confirmModal" class="jr-modal-overlay" style="display:none;">
        <div class="jr-modal" style="width:480px;">
            <div class="jr-modal-header">
                <span id="confirmModalTitle">Confirm Action</span>
                <button type="button" class="close-btn" id="confirmModalClose">&times;</button>
            </div>
            <div style="padding:20px 24px; font-size:14px; color:#333; line-height:1.6;">
                <p id="confirmModalMessage" style="margin:0;"></p>
            </div>
            <div class="jr-modal-footer" style="justify-content:flex-end;">
                <div style="display:flex;gap:8px;">
                    <button type="button" class="btn btn-secondary" id="confirmModalCancel">Cancel</button>
                    <button type="button" class="btn btn-primary" id="confirmModalOk">OK</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Hidden data containers -->
    <script id="rowsData" type="application/json">@Html.Raw(rowsJson)</script>
    <script id="warningsData" type="application/json">@Html.Raw(warningsJson)</script>
    <script id="matDesData" type="application/json">@Html.Raw(matDesJson)</script>
    <script id="materialsData" type="application/json">@Html.Raw(materialsJson)</script>
    <script id="locationsData" type="application/json">@Html.Raw(locationsJson)</script>
    <script id="weldTypesData" type="application/json">@Html.Raw(weldTypesJson)</script>
    <script id="gradesData" type="application/json">@Html.Raw(gradesJson)</script>
    <script id="jAddData" type="application/json">@Html.Raw(jAddJson)</script>
    <script id="schedulesEndpoint" type="text/plain">@Url.Action("GetSchedulesForDiameter", "Home")</script>

    <script>
        // Searchable dropdown widget for Project select
        function makeSearchableSelect(sel){
        if(!sel || sel._ssWidget) return;
        sel.style.display='none';
        var wrap=document.createElement('div'); wrap.className='ss-wrap' + (sel.classList.contains('jr-filter-select') ? ' ss-wrap-sm' : '');
        sel.parentNode.insertBefore(wrap,sel); wrap.appendChild(sel);
        var input=document.createElement('input'); input.type='text'; input.className='ss-input'; input.setAttribute('autocomplete','off'); input.setAttribute('spellcheck','false'); input.placeholder='';
        if(sel.hasAttribute('required')) input.setAttribute('required','');
        wrap.appendChild(input);
        var list=document.createElement('div'); list.className='ss-list'; wrap.appendChild(list);
        var items=[],highlighted=-1,open=false;
        function buildItems(){items=[];Array.from(sel.options).forEach(function(opt){items.push({value:opt.value,text:opt.text||opt.value});});}
        function syncInputText(){var idx=sel.selectedIndex;input.value=idx>=0&&sel.options[idx]?(sel.options[idx].text||sel.options[idx].value):'';}
        function render(filter){list.innerHTML='';highlighted=-1;var lc=(filter||'').toLowerCase();var count=0;
        items.forEach(function(item,i){if(lc&&!(item.text||'').toLowerCase().includes(lc))return;
        var div=document.createElement('div');div.className='ss-item';div.textContent=item.text;div.dataset.idx=String(i);
        if(item.value===sel.value)div.classList.add('ss-active');
        div.addEventListener('mousedown',function(e){e.preventDefault();pick(i);});list.appendChild(div);count++;});
        if(count===0){var em=document.createElement('div');em.className='ss-empty';em.textContent='No match';list.appendChild(em);}}
