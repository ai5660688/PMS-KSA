                    'OL Dia', 'OL Schedule', 'Material A', 'Material B', 'Grade A',
                    'Grade B', 'Delete / Cancel', 'Scope', 'System Remarks'
                ];
            }

            const isoRegex = /^(?:\d{1,3}["”′]?\s*[-_])?(?<fluid>[A-Z0-9]{1,4})[-_](?<line>\d{3,5})[-_](?<cls>[A-Z0-9]{3,})/i;

            function backfillFromIsoClient(r) {
                const iso = (r.ISO || '').trim();
                if (!iso) return;
                const m = isoRegex.exec(iso);
                if (!m) return;

                const cls = m.groups?.cls || '';
                if (cls && (!r.LineClass || r.LineClass.length < cls.length)) {
                    r.LineClass = cls;
                }

                if (!r.Fluid && m.groups?.fluid) r.Fluid = m.groups.fluid;
                if (!r.LineNo && m.groups?.line) r.LineNo = m.groups.line;
                if ((!r.LayoutNo || r.LayoutNo.length < 5) && r.Fluid && r.LineNo) {
                    r.LayoutNo = `${r.Fluid}-${r.LineNo}`;
                }
            }

            // Initialize from server data
            try {
                rows = JSON.parse(document.getElementById('rowsData')?.textContent || '[]');
                warnings = JSON.parse(document.getElementById('warningsData')?.textContent || '[]');
                materialDescriptions = JSON.parse(document.getElementById('matDesData')?.textContent || '[]');
                materialOptions = JSON.parse(document.getElementById('materialsData')?.textContent || '[]');
                locationOptions = JSON.parse(document.getElementById('locationsData')?.textContent || '[]');
                weldTypeOptions = JSON.parse(document.getElementById('weldTypesData')?.textContent || '[]');
                gradeOptions = JSON.parse(document.getElementById('gradesData')?.textContent || '[]');
                jAddOptions = JSON.parse(document.getElementById('jAddData')?.textContent || '[]');
                currentProjectId = parseInt(projectSelect.value) || 0;
                lineSheetMode = (projectSelect.selectedOptions[0]?.dataset?.linesheet || '').trim();
                rows.forEach(backfillFromIsoClient);
                rows.forEach(r => extractJAddFromWeldNumber(r));
                rows.forEach(r => r.Remarks = '');
            } catch (e) {
                console.error('Failed to parse initial data:', e);
                rows = [];
                warnings = [];
                materialDescriptions = [];
            }

            // Extract J-Add codes embedded in weld numbers (e.g. "01CS1" → Weld "01", J-Add "CS1")
            function extractJAddFromWeldNumber(row) {
                const weldNo = (row.WeldNumber || '').trim().toUpperCase();
                if (!weldNo) return false;

                // Skip if J-Add is already set to something other than NEW/empty
                const currentJAdd = (row.JAdd || '').trim().toUpperCase();
                if (currentJAdd && currentJAdd !== 'NEW') return false;

                // Sort options by length descending to match longest suffix first
                const allOpts = (jAddOptions.length > 0 ? jAddOptions : defaultJAdd);
                const sorted = allOpts
                    .filter(o => o && o.length > 0)
                    .map(o => ({ original: o, upper: o.toUpperCase() }))
                    .sort((a, b) => b.upper.length - a.upper.length);

                for (const opt of sorted) {
                    if (!weldNo.endsWith(opt.upper)) continue;

                    const cleanWeld = weldNo.slice(0, weldNo.length - opt.upper.length);

                    // Remaining part must be a valid weld number
                    if (cleanWeld.length === 0 || cleanWeld.length > 6) continue;
                    if (!/\d/.test(cleanWeld)) continue;
                    if (!/^[A-Z0-9]+$/i.test(cleanWeld)) continue;

                    // Normalize weld number (pad single digit to 2 digits)
                    const numMatch = cleanWeld.match(/^(\d+)$/);
                    row.WeldNumber = (numMatch && numMatch[1].length === 1)
                        ? '0' + numMatch[1]
                        : cleanWeld;
                    row.JAdd = opt.original;
                    return true;
                }
                return false;
            }

            // Revision normalization helpers (match C# NormalizeRev1/NormalizeRev2)
            function normalizeRev1(r) {
                r = (r || '').trim();
                if (!r) return '';
                const m = r.match(/^(\d+)([A-Za-z]*)$/);
                if (!m) return r.toUpperCase();
                let num = m[1], suf = (m[2] || '').toUpperCase();
                if (!num) return suf || '';
                if (num.length === 1) num = '0' + num;
                return num + suf;
            }

            function normalizeRev2(r) {
                r = (r || '').trim();
                if (!r) return '';
                const numVal = parseInt(r, 10);
                if (!isNaN(numVal) && r.length === 4 && r.endsWith('001')) {
                    const bucket = Math.max(0, Math.floor(numVal / 1000));
                    return bucket.toString().padStart(2, '0');
                }
                const m = r.match(/^(\d+)([A-Za-z]*)$/);
                if (!m) return r.toUpperCase();
                let num = m[1], suf = (m[2] || '').toUpperCase();
                if (!num) return suf;
                if (num.length === 1) num = '0' + num;
                return num + suf;
            }

            // Build compound revision tag matching Drawings controller's NormalizeRevisionTagForEquivalence
            function normalizeRevisionTagForEquivalence(tag) {
                const safe = (tag || '00_00').trim();
                const parts = safe.split('_').filter(p => p.length > 0);
                const p1Raw = parts.length > 0 ? parts[0] : '00';
                const p2Raw = parts.length > 1 ? parts[1] : '00';
                const tertiaryRaw = parts.length > 2 ? parts[2] : null;
                const primary = normalizeRev1(p1Raw);
                // When a tertiary segment exists (e.g., 00_0001_01F), use it as the
                // secondary – the middle segment is a legacy bucket code to skip.
                const secondary = tertiaryRaw
                    ? normalizeRev2(tertiaryRaw)
                    : normalizeRev2(p2Raw);
                return primary + '_' + secondary;
            }

            function normalizeRevisionValue(value) {
                let v = (value || '').trim().replace(/^[-_]+|[-_]+$/g, '');
                if (!v) return '';
                return normalizeRevisionTagForEquivalence(v);
            }

            // Revision is now a single compound tag (matching Drawings controller).
            // No more splitting into separate LRev/LSRev parts.
            function getRevisionValue(row) {
                // Use whichever field has a value; both carry the compound tag
                const raw = (row.LSRev || row.LRev || '').trim();
                if (!raw) return '';
                return normalizeRevisionTagForEquivalence(raw);
            }

            function applyRevisionValue(row, value) {
                const tag = normalizeRevisionValue(value);
                // Store compound tag in both fields (server expects either)
                row.LRev = tag || null;
                row.LSRev = tag || null;
                return tag;
            }

            function uniqueJointKey(row) {
                const parts = [
                    currentProjectId?.toString() || '',
                    (row.LineNo || '').trim(),
                    (row.LayoutNo || '').trim(),
                    (row.LSSheet || '').trim(),
                    (row.WeldNumber || '').trim(),
                    (row.JAdd || '').trim()
                ];
                return parts.map(p => p.toUpperCase()).join('|');
            }

            function getUniqueJointCount(rowsList) {
                const map = new Map();
                (rowsList || []).forEach(r => {
                    map.set(uniqueJointKey(r), true);
                });
                return map.size;
            }

            // Enhanced Validation Functions (scope-aware)
            function validateRow(row, index) {
                const errors = [];
                const warnings = [];
                const fields = getActiveFields();

                // Layout No — always required
                if (!row.LayoutNo || !row.LayoutNo.includes('-')) {
                    errors.push(`Layout No must be in format FLUID-LINENO (e.g., P-11645)`);
                } else if (!/^[A-Z0-9]{1,4}-\d{3,5}$/i.test(row.LayoutNo)) {
                    errors.push(`Invalid Layout No format: ${row.LayoutNo}`);
                }

                // Sheet No — required for LineSheet and Joints scopes
                if (fields.includes('LSSheet')) {
                    if (!row.LSSheet) {
                        errors.push(`Sheet No is required`);
                    }
                }

                // Weld No — required only for Joints scope
                if (fields.includes('WeldNumber')) {
                    if (!row.WeldNumber) {
                        errors.push(`Weld No is required`);
                    } else if (row.WeldNumber === '##') {
                        warnings.push(`Weld No placeholder detected`);
                    }
                }

                // J-Add — required only for Joints scope
                if (fields.includes('JAdd')) {
                    if (!row.JAdd) {
                        errors.push(`J-Add is required`);
                    } else if (!/^(NEW|[A-Z][A-Z0-9]*)$/i.test(row.JAdd)) {
                        errors.push(`Invalid J-Add: ${row.JAdd}`);
                    }
                }

                // Weld Type — validate format only if the field is in scope and has a value
                if (fields.includes('WeldType') && row.WeldType && !/^(BW|FW|SW|SOF|BR|LET|TH|SP|FJ)$/i.test(row.WeldType)) {
                    warnings.push(`Invalid Weld Type: ${row.WeldType}. Expected: BW, FW, SW, SOF, BR, LET, TH, SP, or FJ`);
                }

                // ISO format validation — applies to all scopes
                if (row.ISO && !/^[A-Z0-9]{1,4}-\d{3,5}-[A-Z0-9]{3,12}$/i.test(row.ISO)) {
                    warnings.push(`ISO format should be FLUID-LINENO-LINECLASS`);
                }

                // Weld type specific validation — only for Joints scope
                if (fields.includes('WeldType')) {
                    if (row.WeldType === 'BR' || row.WeldType === 'LET') {
                        if (!row.OLDiameter || row.OLDiameter === '##') {
                            warnings.push(`OL Diameter required for ${row.WeldType} weld`);
                        }
                        if (!row.OLSchedule || row.OLSchedule === '##') {
                            warnings.push(`OL Schedule required for ${row.WeldType} weld`);
                        }
                    }

                    if (row.Schedule === '##') {
                        warnings.push(`Schedule not specified`);
                    }
                }

                return { errors, warnings };
            }

            // Utility Functions
            function showConfirmModal(message, title) {
                return new Promise(resolve => {
                    const overlay = document.getElementById('confirmModal');
                    const msgEl = document.getElementById('confirmModalMessage');
                    const titleEl = document.getElementById('confirmModalTitle');
                    const okBtn = document.getElementById('confirmModalOk');
                    const cancelBtn = document.getElementById('confirmModalCancel');
                    const closeBtn = document.getElementById('confirmModalClose');

                    titleEl.textContent = title || 'Confirm Action';
                    msgEl.textContent = message;
                    overlay.style.display = 'flex';

                    function cleanup(result) {
                        overlay.style.display = 'none';
                        okBtn.removeEventListener('click', onOk);
                        cancelBtn.removeEventListener('click', onCancel);
                        closeBtn.removeEventListener('click', onCancel);
                        overlay.removeEventListener('click', onOverlay);
                        document.removeEventListener('keydown', onKey);
                        resolve(result);
                    }
                    function onOk() { cleanup(true); }
                    function onCancel() { cleanup(false); }
                    function onOverlay(e) { if (e.target === overlay) cleanup(false); }
                    function onKey(e) { if (e.key === 'Escape') cleanup(false); else if (e.key === 'Enter') cleanup(true); }

                    okBtn.addEventListener('click', onOk);
                    cancelBtn.addEventListener('click', onCancel);
                    closeBtn.addEventListener('click', onCancel);
                    overlay.addEventListener('click', onOverlay);
                    document.addEventListener('keydown', onKey);
                    okBtn.focus();
                });
            }

            function showLoading(show, message, statusText) {
                loadingOverlay.style.display = show ? 'flex' : 'none';
                document.getElementById('loadingText').textContent = message || 'Processing... Please wait';
                const statusEl = document.getElementById('loadingStatus');
