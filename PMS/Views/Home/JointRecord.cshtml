            function showMessage(type, message) {
                const div = document.createElement('div');
                div.className = type === 'error' ? 'jr-warning' : 'jr-info';
                div.textContent = message;
                messagesHost.appendChild(div);
                setTimeout(() => div.remove(), 5000);
            }

            // Determine whether a message targets a specific field (more conservative matching)
            function messageMatchesField(msg, field) {
                if (!msg || !field) return false;
                const m = msg.toLowerCase();
                switch (field) {
                    case 'LayoutNo':
                        return m.includes('layout no') || /[a-z0-9]{1,4}-\d{3,5}/i.test(msg);
                    case 'WeldNumber':
                        return m.includes('weld no') || m.includes('weld number') || /\bweld\s*no\b/i.test(msg);
                    case 'LSSheet':
                        return m.includes('sheet no') || /\bsheet\b/i.test(msg) && m.includes('no');
                    case 'WeldType':
                        return m.includes('weld type');
                    case 'JAdd':
                        return m.includes('j-add') || m.includes('j add') || m.includes('jadd') || /\bj[-\s]?add\b/i.test(msg);
                    case 'ISO':
                        return m.includes('iso') || /[A-Z0-9]{1,4}-\d{3,5}-[A-Z0-9]{3,12}/i.test(msg);
                    case 'Schedule':
                        return m.includes('schedule');
                    case 'OLDiameter':
                        return m.includes('ol diameter') || m.includes('ol dia');
                    case 'OLSchedule':
                        return m.includes('ol schedule');
                    case 'MaterialA':
                        return m.includes('material a');
                    case 'MaterialB':
                        return m.includes('material b');
                    default:
                        return false;
                }
            }

            function isWeldNoNumericMessage(msg) {
                return /weld\s*no\s*must\s*be\s*numeric/i.test(msg || '');
            }

            function isJAddRequiredMessage(msg) {
                return /j[-\s]?add\s+is\s+required/i.test(msg || '');
            }

            function dedupeRemarksText(text) {
                if (!text) return '';
                const parts = text
                    .split('|')
                    .map(s => s.trim())
                    .filter(Boolean);
                const seen = new Set();
                const unique = [];
                parts.forEach(p => {
                    const key = p.toLowerCase();
                    if (seen.has(key)) return;
                    seen.add(key);
                    unique.push(p);
                });
                return unique.join(' | ');
            }

            // Filter out internal/technical messages from a remarks string,
            // keeping only user-understandable notes (e.g., data mismatches).
            function cleanRemarksText(text) {
                if (!text) return '';
                const parts = text.split('|').map(s => s.trim()).filter(Boolean);
                const cleaned = parts.filter(part => {
                    if (isWeldNoNumericMessage(part)) return false;
                    if (isJAddRequiredMessage(part)) return false;
                    if (/is required$/i.test(part)) return false;
                    if (/^invalid /i.test(part)) return false;
                    if (/defaulting to /i.test(part)) return false;
                    if (/inferred from material/i.test(part)) return false;
                    if (/^flange joint with/i.test(part)) return false;
                    if (/^branch connection weld/i.test(part)) return false;
                    if (/^threaded connection$/i.test(part)) return false;
                    if (/^support pad weld$/i.test(part)) return false;
                    if (/^existing dfr record/i.test(part)) return false;
                    if (/using placeholder/i.test(part)) return false;
                    if (/parsed from file name/i.test(part)) return false;
                    if (/could not detect layout/i.test(part)) return false;
                    if (/not found in .+_tbl/i.test(part)) return false;
                    if (/not found in material_des/i.test(part)) return false;
                    if (/not found in material_tbl/i.test(part)) return false;
                    if (/not found in project lookup/i.test(part)) return false;
                    if (/^successfully imported/i.test(part)) return false;
                    if (/^final analysis contains/i.test(part)) return false;
                    if (/^extracted \d+ weld/i.test(part)) return false;
                    if (/^parsed (pcf|sha|pdf)/i.test(part)) return false;
                    if (/^used spatial word/i.test(part)) return false;
                    if (/ocr/i.test(part)) return false;
                    if (/^loaded \d+ records/i.test(part)) return false;
                    if (/not specified$/i.test(part)) return false;
                    if (/ol diameter required/i.test(part)) return false;
                    return true;
                });
                return dedupeRemarksText(cleaned.join(' | '));
            }

            // Display remarks: only user-understandable notes (validation shown via row/cell styling)
            function computeDisplayRemarks(row, index) {
                return cleanRemarksText(row.Remarks || '');
            }

            // Distribute warnings: validation warnings appear in the header messages area only.
            // Row Remarks are only populated after commit with rejection reasons.
            function renderWarnings(warningsList) {
                messagesHost.innerHTML = '';
                if (!warningsList || warningsList.length === 0) return;

                // Drop weld-number numeric notes entirely
                warningsList = warningsList.filter(w => !isWeldNoNumericMessage(w));
            }

            // Cached validation counts (recomputed on full data load or explicit refresh)
            let _cachedValidation = { warningCount: 0, errorCount: 0 };
            let _validationDirty = true;

            function recomputeValidationCounts() {
                let wc = 0, ec = 0;
                for (let i = 0; i < rows.length; i++) {
                    const v = validateRow(rows[i], i);
                    wc += v.warnings.length;
                    ec += v.errors.length;
                }
                _cachedValidation = { warningCount: wc, errorCount: ec };
                _validationDirty = false;
            }

            function updateSummary() {
                const rowCount = getUniqueJointCount(rows);

                // Full recompute only when flagged dirty (data load/bulk/clear);
                // incremental edits on a single row patch the cached counts cheaply.
                if (_validationDirty || rows.length <= PAGE_SIZE) {
                    recomputeValidationCounts();
                }
                const { warningCount, errorCount } = _cachedValidation;

                document.getElementById('rowCount').textContent = rowCount;
                document.getElementById('warningCount').textContent = warningCount;
                document.getElementById('errorCount').textContent = errorCount;
                document.getElementById('sourceType').textContent = rows.length > 0 ?
                    (rows[0].SourceFile || 'Unknown') : 'No data';

                summaryDiv.style.display = rowCount > 0 ? 'block' : 'none';

                // Update table status
                if (rowCount === 0) {
                    tableStatus.textContent = 'No data';
                    tableStatus.className = 'jr-status jr-status-warning';
                } else if (errorCount > 0) {
                    tableStatus.textContent = `${errorCount} errors`;
                    tableStatus.className = 'jr-status jr-status-error';
                } else if (warningCount > 0) {
                    tableStatus.textContent = `${warningCount} warnings`;
                    tableStatus.className = 'jr-status jr-status-warning';
                } else {
                    tableStatus.textContent = 'Ready';
                    tableStatus.className = 'jr-status jr-status-success';
                }

                return { rowCount, warningCount, errorCount };
            }

            function createSelect(value, field, index, options) {
                const select = document.createElement('select');
                select.dataset.field = field;
                select.dataset.index = index.toString();
                select.className = 'jr-input';

                // Empty option
                const emptyOpt = document.createElement('option');
                emptyOpt.value = '';
                emptyOpt.textContent = '-- Select --';
                select.appendChild(emptyOpt);

                const upperVal = (value || '').toUpperCase();
                options.forEach(opt => {
                    const o = document.createElement('option');
                    o.value = opt;
                    o.textContent = opt;
                    if (opt.toUpperCase() === upperVal) o.selected = true;
                    select.appendChild(o);
                });

                // If current value exists but is not in the list, add it so it stays visible
                if (upperVal && !options.some(o => o.toUpperCase() === upperVal)) {
                    const extra = document.createElement('option');
                    extra.value = value;
                    extra.textContent = value + ' ⚠';
                    extra.selected = true;
                    select.insertBefore(extra, emptyOpt.nextSibling);
                }

                // Validation styling
                const validation = validateRow(rows[index], index);
                if (validation.errors.some(e => messageMatchesField(e, field))) {
                    select.classList.add('error');
                } else if (validation.warnings.some(w => messageMatchesField(w, field))) {
                    select.classList.add('warning');
                }

                return select;
            }

            // ── Schedule floating menu (same pattern as Daily Fit-up) ──
            async function fetchSchedulesForDia(dia) {
                if (!schedulesForDiameterEndpoint || dia == null || isNaN(dia)) return [];
                const key = Number(dia).toString();
                if (scheduleCache.has(key)) return scheduleCache.get(key);
                try {
                    const res = await fetch(`${schedulesForDiameterEndpoint}?dia=${encodeURIComponent(key)}`, {
                        headers: { 'Accept': 'application/json' }
                    });
                    if (!res.ok) { scheduleCache.set(key, []); return []; }
                    const payload = await res.json();
                    const list = Array.isArray(payload)
                        ? payload.map(item => typeof item === 'string' ? item : (item?.sch ?? item?.Sch ?? item?.value ?? item?.Value ?? '')).filter(v => v.length > 0)
                        : [];
                    scheduleCache.set(key, list);
                    return list;
                } catch { scheduleCache.set(key, []); return []; }
            }

            function removeSchMenu(input) {
                const td = input?.closest('td');
                const menu = td?.querySelector('.jr-sch-float-menu');
                if (menu) menu.remove();
                if (input) { input.classList.remove('dropdown-open'); delete input.dataset.menuOpen; }
            }

            function removeAllSchMenus() {
                document.querySelectorAll('.jr-sch-float-menu').forEach(m => m.remove());
                tableBody.querySelectorAll('input.jr-sch-input').forEach(inp => {
                    inp.classList.remove('dropdown-open');
                    delete inp.dataset.menuOpen;
                });
            }

            function buildSchMenu(items, anchorInput, placeholder) {
                removeSchMenu(anchorInput);
                const menu = document.createElement('div');
                menu.className = 'jr-sch-float-menu';
                if (items && items.length) {
                    items.forEach(val => {
                        const entry = document.createElement('div');
                        entry.className = 'jr-sch-float-item';
                        entry.textContent = val;
                        entry.addEventListener('mousedown', (e) => {
                            e.preventDefault();
                            anchorInput.value = val;
                            anchorInput.dispatchEvent(new Event('input', { bubbles: true }));
                            anchorInput.dispatchEvent(new Event('change', { bubbles: true }));
                            removeSchMenu(anchorInput);
                        });
                        menu.appendChild(entry);
                    });
                } else {
                    const empty = document.createElement('div');
                    empty.className = 'jr-sch-float-item disabled';
                    empty.textContent = placeholder || 'No schedules';
                    menu.appendChild(empty);
                }
                const td = anchorInput.closest('td');
                (td || document.body).appendChild(menu);
                // Position below input
                const rect = anchorInput.getBoundingClientRect();
                const tdRect = (td || document.body).getBoundingClientRect();
                menu.style.top = `${rect.bottom - tdRect.top + 2}px`;
                menu.style.left = `${Math.max(0, rect.left - tdRect.left)}px`;
                menu.style.minWidth = `${rect.width}px`;
                menu.style.display = 'block';
                anchorInput.classList.add('dropdown-open');
                anchorInput.dataset.menuOpen = '1';
            }

            async function showSchMenu(input) {
                if (!input || input.disabled) return;
                removeAllSchMenus();
                const idx = parseInt(input.dataset.index);
                const row = rows[idx];
                if (!row) return;
                const field = input.dataset.field;
                let diaText = field === 'OLSchedule' ? (row.OLDiameter || row.Diameter) : (row.Diameter || '');
                const dia = parseFloat((diaText || '').trim());
                if (isNaN(dia)) { buildSchMenu([], input, 'Enter diameter first'); return; }
                const list = await fetchSchedulesForDia(dia);
                buildSchMenu(list, input, list.length === 0 ? 'No schedules' : '');
            }

            function createScheduleInput(value, field, index) {
                const input = document.createElement('input');
                input.type = 'text';
                input.value = value || '';
                input.dataset.field = field;
                input.dataset.index = index.toString();
                input.placeholder = field === 'OLSchedule' ? 'OL Sch' : 'Sch';
                input.className = 'jr-input jr-sch-input';

                // Validation styling
                const validation = validateRow(rows[index], index);
                if (validation.errors.some(e => messageMatchesField(e, field))) {
                    input.classList.add('error');
                } else if (validation.warnings.some(w => messageMatchesField(w, field))) {
                    input.classList.add('warning');
                }

                return input;
            }

            // Global event listeners for schedule floating menus
            document.addEventListener('focusin', (e) => {
                if (e.target && e.target.classList && e.target.classList.contains('jr-sch-input')) {
                    // Ensure caret indicator
                    const td = e.target.closest('td');
                    if (td) td.style.position = 'relative';
                } else {
                    removeAllSchMenus();
                }
            });
            document.addEventListener('click', (e) => {
                if (!e.target.closest('.jr-sch-float-menu') && !(e.target.classList && e.target.classList.contains('jr-sch-input'))) {
                    removeAllSchMenus();
                }
            });
            document.addEventListener('dblclick', (e) => {
                if (e.target && e.target.classList && e.target.classList.contains('jr-sch-input') && !e.target.disabled) {
                    if (e.target.dataset.menuOpen === '1') removeSchMenu(e.target); else showSchMenu(e.target);
                }
            });
            document.addEventListener('keydown', (e) => {
                if (!e.target || !e.target.classList || !e.target.classList.contains('jr-sch-input')) return;
                if (e.key === 'ArrowDown') { e.preventDefault(); showSchMenu(e.target); }
                else if (e.key === 'Escape') { removeSchMenu(e.target); }
            });

            function createInput(value, field, index) {
                // Delete / Cancel dropdown — enabled options depend on FitupDate
                if (field === 'DeleteCancel') {
                    const row = rows[index];
                    const hasFitup = !!(row.FitupDate && row.FitupDate.trim());
                    const select = document.createElement('select');
                    select.dataset.field = field;
                    select.dataset.index = index.toString();
                    select.className = 'jr-input';

                    const optNone = document.createElement('option');
                    optNone.value = '';
                    optNone.textContent = '';
                    select.appendChild(optNone);

                    const optDeleted = document.createElement('option');
                    optDeleted.value = 'Deleted';
                    optDeleted.textContent = 'Deleted';
                    optDeleted.disabled = !hasFitup;
                    if (!hasFitup) optDeleted.title = 'Requires Fitup Date';
                    select.appendChild(optDeleted);

                    const optCancelled = document.createElement('option');
                    optCancelled.value = 'Cancelled';
                    optCancelled.textContent = 'Cancelled';
                    optCancelled.disabled = hasFitup;
                    if (hasFitup) optCancelled.title = 'Only when no Fitup Date';
                    select.appendChild(optCancelled);

                    // Determine current value from row flags
                    const currentVal = row.Deleted ? 'Deleted' : row.Cancelled ? 'Cancelled' : '';
                    select.value = currentVal;

                    if (currentVal === 'Deleted') select.classList.add('jr-remark-blocked');
                    else if (currentVal === 'Cancelled') select.classList.add('jr-remark-blocked');

                    return select;
                }

                // Use dropdown selects for MaterialA / MaterialB
                if ((field === 'MaterialA' || field === 'MaterialB') && materialDescriptions.length > 0) {
                    return createSelect(value, field, index, materialDescriptions);
                }

                // Material dropdown (from Material_tbl.MAT)
                if (field === 'Material' && materialOptions.length > 0) {
                    return createSelect(value, field, index, materialOptions);
                }

                // Location dropdown (DB values with fallback)
                if (field === 'Location') {
                    const opts = locationOptions.length > 0 ? locationOptions : defaultLocations;
                    return createSelect(value, field, index, opts);
                }

                // J-Add dropdown (DB values with fallback, same as Daily Fit-up)
                if (field === 'JAdd') {
                    const opts = jAddOptions.length > 0 ? jAddOptions : defaultJAdd;
                    return createSelect(value, field, index, opts);
                }

                // Weld Type dropdown (DB values with fallback)
                if (field === 'WeldType') {
                    const opts = weldTypeOptions.length > 0 ? weldTypeOptions : defaultWeldTypes;
                    return createSelect(value, field, index, opts);
                }

                // Schedule / OL Schedule: text input with floating schedule menu (same as Daily Fit-up)
                if (field === 'Schedule' || field === 'OLSchedule') {
                    return createScheduleInput(value, field, index);
                }

                // Grade A / Grade B dropdown (DB values)
                if ((field === 'GradeA' || field === 'GradeB') && gradeOptions.length > 0) {
                    return createSelect(value, field, index, gradeOptions);
                }

                const input = document.createElement('input');
                input.type = 'text';
                input.value = value || '';
                input.dataset.field = field;
                input.dataset.index = index.toString();
                input.placeholder = getPlaceholder(field);
                input.className = 'jr-input';
                if (field === 'Remarks') {
                    input.readOnly = true;
                    input.classList.add('jr-input-readonly');
                    const v = (value || '').trim();
                    if (v === 'Upload') {
                        input.classList.add('jr-remark-upload');
                    } else if (v === 'Update') {
                        input.classList.add('jr-remark-update');
                    } else if (v === 'Delete' || v === 'Cancel') {
                        input.classList.add('jr-remark-blocked');
                    } else if (v.startsWith('Cannot update')) {
                        input.classList.add('jr-remark-blocked');
                    }
                }

                // Add validation classes — map messages to fields using messageMatchesField
                const reqFields = getRequiredFields();
                const validation = validateRow(rows[index], index);

                if (validation.errors.some(e => messageMatchesField(e, field))) {
                    input.classList.add('error');
                } else if (validation.warnings.some(w => messageMatchesField(w, field))) {
                    input.classList.add('warning');
                }

                if (field === 'OLDiameter' && value === '##') {
                    input.classList.add('jr-cell-highlight');
                }

                return input;
            }

            function getPlaceholder(field) {
                const placeholders = {
                    'LayoutNo': 'e.g., P-11645',
                    'ISO': 'e.g., 60C-10100-1CS2U01',
                    'Schedule': 'SCH40 or ##',
                    'OLDiameter': '## for non-branch',
                    'MaterialA': 'MATD_Description',
                    'GradeA': 'MAT_GRADE'
                };
                return placeholders[field] || '';
            }

            function renderTableHeaders() {
                tableHead.innerHTML = '';
                const tr = document.createElement('tr');
                const headers = getActiveHeaders();
                const fields = getActiveFields();
                const reqFields = getRequiredFields();
                headers.forEach((header, i) => {
                    const th = document.createElement('th');
                    th.textContent = header;
                    if (reqFields[fields[i]]) th.classList.add('jr-required');
                    tr.appendChild(th);
                });
                tableHead.appendChild(tr);
            }

            function getFilteredRows() {
                if (rowFilter === 'all') {
                    return rows.map((row, i) => ({ row, index: i }));
                }
                return rows.map((row, i) => ({ row, index: i, validation: validateRow(row, i) }))
                    .filter(item => {
                        if (rowFilter === 'errors') return item.validation.errors.length > 0;
                        if (rowFilter === 'warnings') return item.validation.warnings.length > 0 || item.validation.errors.length > 0;
                        return true;
                    });
            }

            function renderTable() {
                renderTableHeaders();
                tableBody.innerHTML = '';
                const fields = getActiveFields();

                if (rows.length === 0) {
                    const tr = document.createElement('tr');
                    const td = document.createElement('td');
                    td.colSpan = fields.length;
                    td.className = 'jr-empty';
                    td.textContent = currentMode === 'edit'
                        ? 'Select a layout and click Load Data to see existing records'
                        : 'Upload a drawing or Excel template to see extracted data';
                    tr.appendChild(td);
                    tableBody.appendChild(tr);
                    renderPaginationControls();
                    return;
                }

                const filtered = getFilteredRows();

                if (filtered.length === 0 && rowFilter !== 'all') {
                    const tr = document.createElement('tr');
                    const td = document.createElement('td');
                    td.colSpan = fields.length;
                    td.className = 'jr-empty';
                    td.textContent = `No rows with ${rowFilter} found`;
                    tr.appendChild(td);
                    tableBody.appendChild(tr);
                    renderPaginationControls();
                    return;
                }

                const totalPages = Math.ceil(filtered.length / PAGE_SIZE);
                if (currentPage >= totalPages) currentPage = Math.max(0, totalPages - 1);
                const startIdx = currentPage * PAGE_SIZE;
                const endIdx = Math.min(startIdx + PAGE_SIZE, filtered.length);
                const pageItems = filtered.slice(startIdx, endIdx);

                const frag = document.createDocumentFragment();
                pageItems.forEach(item => {
                    const index = item.index;
                    const row = item.row;
                    const tr = document.createElement('tr');

                    // Apply validation styling
                    const validation = item.validation || validateRow(row, index);
                    if (validation.errors.length > 0) {
                        tr.classList.add('jr-row-error');
                        tr.dataset.tooltip = validation.errors.join('\n');
                        tr.classList.add('jr-tooltip');
                    } else if (validation.warnings.length > 0) {
                        tr.classList.add('jr-row-warning');
                        tr.dataset.tooltip = validation.warnings.join('\n');
                        tr.classList.add('jr-tooltip');
                    }

                    fields.forEach(field => {
                        const td = document.createElement('td');
                        let input;

                        if (field === 'Revision') {
                            const revValue = getRevisionValue(row);
                            input = createInput(revValue, field, index);
                        } else {
                            input = createInput(row[field] || '', field, index);
                        }

                        td.appendChild(input);

                        // Highlight critical missing fields
                        const activeReqFields = getRequiredFields();
                        if (activeReqFields[field] && !row[field]) {
                            td.classList.add('jr-cell-error');
                        }

                        tr.appendChild(td);
                    });

                    frag.appendChild(tr);
                });
                tableBody.appendChild(frag);
                renderPaginationControls();
            }

            function renderPaginationControls() {
                let paginationDiv = document.getElementById('jrPagination');
                if (!paginationDiv) {
                    paginationDiv = document.createElement('div');
                    paginationDiv.id = 'jrPagination';
                    paginationDiv.style.cssText = 'display:flex;align-items:center;justify-content:center;gap:10px;padding:8px 0;font-size:13px;';
                    const tableContainer = tableBody.closest('.jr-table-container');
                    if (tableContainer) tableContainer.parentNode.insertBefore(paginationDiv, tableContainer.nextSibling);
                }
                const filtered = getFilteredRows();
                const totalFiltered = filtered.length;
                const totalPages = Math.ceil(totalFiltered / PAGE_SIZE);
                if (totalFiltered <= PAGE_SIZE) {
                    paginationDiv.style.display = 'none';
                    return;
                }
                paginationDiv.style.display = 'flex';
                const startIdx = currentPage * PAGE_SIZE;
                const endIdx = Math.min(startIdx + PAGE_SIZE, totalFiltered);
                const filterLabel = rowFilter !== 'all' ? ` [filtered: ${rowFilter}]` : '';
                paginationDiv.innerHTML = `
                    <button type="button" class="btn-sm" ${currentPage === 0 ? 'disabled' : ''} data-page="first">&laquo; First</button>
                    <button type="button" class="btn-sm" ${currentPage === 0 ? 'disabled' : ''} data-page="prev">&lsaquo; Prev</button>
                    <span>Rows ${startIdx + 1}–${endIdx} of ${totalFiltered}${filterLabel} (Page ${currentPage + 1} / ${totalPages})</span>
                    <button type="button" class="btn-sm" ${currentPage >= totalPages - 1 ? 'disabled' : ''} data-page="next">Next &rsaquo;</button>
                    <button type="button" class="btn-sm" ${currentPage >= totalPages - 1 ? 'disabled' : ''} data-page="last">Last &raquo;</button>
                `;
                paginationDiv.querySelectorAll('button[data-page]').forEach(btn => {
                    btn.addEventListener('click', () => {
                        const action = btn.dataset.page;
                        if (action === 'first') currentPage = 0;
                        else if (action === 'prev') currentPage = Math.max(0, currentPage - 1);
                        else if (action === 'next') currentPage = Math.min(totalPages - 1, currentPage + 1);
                        else if (action === 'last') currentPage = totalPages - 1;
                        renderTable();
                    });
                });
            }

            function syncInputToState(event) {
                const target = event.target;
                if (!target.dataset || !target.dataset.field || target.dataset.index === undefined) return;

                const index = parseInt(target.dataset.index);
                const field = target.dataset.field;
                let value = target.value.trim();

                // Normalize revision field
                if (field === 'Revision') {
                    value = applyRevisionValue(rows[index], value);
                    target.value = value;
                }

                if (isNaN(index) || !field || !rows[index]) return;

                // Update the state
                if (field === 'DeleteCancel') {
                    rows[index].Deleted = (value === 'Deleted');
                    rows[index].Cancelled = (value === 'Cancelled');
                    // Update System Remarks to reflect the resolved action
                    const currentRemarks = (rows[index].Remarks || '').trim();
                    if (value === 'Deleted') {
                        rows[index].Remarks = 'Delete';
                    } else if (value === 'Cancelled') {
                        rows[index].Remarks = 'Cancel';
                    } else {
                        // Clearing delete/cancel — restore original remark
                        const hasFitup = !!(rows[index].FitupDate && rows[index].FitupDate.trim());
                        if (currentRemarks === 'Delete' || currentRemarks === 'Cancel') {
                            rows[index].Remarks = hasFitup
                                ? 'Cannot update \u2014 Fitup already completed (' + rows[index].FitupDate + ')'
                                : 'Update';
                        }
                    }
                    renderTable();
                    return;
                } else if (field !== 'Revision') {
                    rows[index][field] = value;
                }

                // When WeldNumber changes, try to extract embedded J-Add
                if (field === 'WeldNumber') {
                    const extracted = extractJAddFromWeldNumber(rows[index]);
                    if (extracted) {
                        // Update the displayed WeldNumber input
                        target.value = rows[index].WeldNumber;
                        // Find and update the J-Add select for this row
                        const jAddSelect = tableBody.querySelector(`select[data-field="JAdd"][data-index="${index}"]`);
                        if (jAddSelect) {
                            const upperVal = (rows[index].JAdd || '').toUpperCase();
                            const optExists = Array.from(jAddSelect.options).some(o => o.value.toUpperCase() === upperVal);
                            if (!optExists && rows[index].JAdd) {
                                const extra = document.createElement('option');
                                extra.value = rows[index].JAdd;
                                extra.textContent = rows[index].JAdd;
                                jAddSelect.insertBefore(extra, jAddSelect.options[1]);
                            }
                            jAddSelect.value = rows[index].JAdd;
                        }
                    }
                }

                // Update UI validation
                updateValidationUI();
                updateSummary();
            }

            function updateValidationUI() {
                const inputs = tableBody.querySelectorAll('input, select');
                inputs.forEach(input => {
                    const index = parseInt(input.dataset.index);
                    const field = input.dataset.field;
                    const row = rows[index];

                    if (!row) return;

                    // Clear previous validation classes
                    input.classList.remove('error', 'warning', 'jr-cell-highlight');

                    // Apply new validation
                    const validation = validateRow(row, index);

                    if (validation.errors.some(e => messageMatchesField(e, field))) {
                        input.classList.add('error');
                    } else if (validation.warnings.some(w => messageMatchesField(w, field))) {
                        input.classList.add('warning');
                    }

                    // Highlight placeholders
                    if (field === 'OLDiameter' && input.value === '##') {
                        input.classList.add('jr-cell-highlight');
                    }
                });

                // Update row styling
                const tableRows = tableBody.querySelectorAll('tr');
                tableRows.forEach((tr, index) => {
                    if (index >= rows.length) return;

                    const row = rows[index];
                    const validation = validateRow(row, index);

                    // Clear previous classes
                    tr.classList.remove('jr-row-error', 'jr-row-warning', 'jr-tooltip');
                    tr.removeAttribute('data-tooltip');

                    // Apply new classes
                    if (validation.errors.length > 0) {
                        tr.classList.add('jr-row-error', 'jr-tooltip');
                        tr.dataset.tooltip = validation.errors.join('\n');
                    } else if (validation.warnings.length > 0) {
                        tr.classList.add('jr-row-warning', 'jr-tooltip');
                        tr.dataset.tooltip = validation.warnings.join('\n');
                    }
                });
            }

            // Event Listeners
            tableBody.addEventListener('input', syncInputToState);
            tableBody.addEventListener('change', syncInputToState); // for <select> dropdowns (MaterialA/B)
            projectSelect.addEventListener('change', () => {
                lineSheetMode = (projectSelect.selectedOptions[0]?.dataset?.linesheet || '').trim();
                currentProjectId = parseInt(projectSelect.value) || 0;
                renderTable();
                updateSummary();
                if (currentMode === 'edit') loadLayoutOptions();
            });

            // Scope radio change
            document.querySelectorAll('input[name="scope"]').forEach(radio => {
                radio.addEventListener('change', () => {
                    currentScope = radio.value;
                    sheetFilterRow.style.display = currentScope === 'LineList' ? 'none' : 'flex';
                    rows = [];
                    warnings = [];
                    renderTable();
                    updateSummary();
                    updateModeUI();
                    if (currentMode === 'edit') loadLayoutOptions();
                });
            });

            // Mode radio change
            document.querySelectorAll('input[name="mode"]').forEach(radio => {
                radio.addEventListener('change', () => {
                    currentMode = radio.value;
                    rows = [];
                    warnings = [];
                    renderTable();
                    updateSummary();
                    updateModeUI();
                    if (currentMode === 'edit') loadLayoutOptions();
                });
            });

            // Filter layout change -> load sheets
            filterLayoutSelect.addEventListener('change', async () => {
                filterSheetSelect.innerHTML = '<option value="">-- All Sheets --</option>';
                const layout = filterLayoutSelect.value;
                if (!layout || currentScope === 'LineList') return;
                try {
                    const pid = projectSelect.value;
                    const resp = await fetch(`@Url.Action("GetJointRecordSheets", "Home")?projectId=${pid}&scope=${currentScope}&layout=${encodeURIComponent(layout)}`);
                    if (resp.ok) {
                        const sheets = await resp.json();
                        sheets.forEach(s => {
                            const opt = document.createElement('option');
                            opt.value = s;
                            opt.textContent = s;
                            filterSheetSelect.appendChild(opt);
                        });
                    }
                } catch (e) { console.error('Failed to load sheets', e); }
            });

            function updateModeUI() {
                const isUpload = currentMode === 'upload';
                editFiltersDiv.style.display = isUpload ? 'none' : 'flex';
                uploadFileInputsDiv.style.display = isUpload ? 'flex' : 'none';
                analyzeBtn.style.display = isUpload ? '' : 'none';
                bulkAnalyzeBtn.style.display = isUpload ? '' : 'none';
                commitBtn.style.display = isUpload ? '' : 'none';
                loadDataBtn.style.display = isUpload ? 'none' : '';
                saveChangesBtn.style.display = isUpload ? 'none' : '';
                commitBtn.disabled = rows.length === 0;
                saveChangesBtn.disabled = rows.length === 0;
            }

            async function loadLayoutOptions() {
                filterLayoutSelect.innerHTML = '<option value="">-- Select Layout --</option>';
                filterSheetSelect.innerHTML = '<option value="">-- All Sheets --</option>';
                try {
                    const pid = projectSelect.value;
                    const resp = await fetch(`@Url.Action("GetJointRecordLayouts", "Home")?projectId=${pid}&scope=${currentScope}`);
                    if (resp.ok) {
                        const layouts = await resp.json();
                        layouts.forEach(l => {
                            const opt = document.createElement('option');
                            opt.value = l;
                            opt.textContent = l;
                            filterLayoutSelect.appendChild(opt);
                        });
                    }
                } catch (e) { console.error('Failed to load layouts', e); }
            }

            async function loadData() {
                const layout = filterLayoutSelect.value;
                if (!layout) {
                    showMessage('error', 'Please select a Layout No');
                    return;
                }

                showLoading(true);
                try {
                    const pid = projectSelect.value;
                    const sheet = filterSheetSelect.value || '';
                    const url = `@Url.Action("LoadJointRecordData", "Home")?projectId=${pid}&scope=${currentScope}&layout=${encodeURIComponent(layout)}&sheet=${encodeURIComponent(sheet)}`;
                    const resp = await fetch(url);
                    if (!resp.ok) throw new Error(`HTTP ${resp.status}`);

                    const data = await resp.json();
                    rows = data.rows || data.Rows || [];
                    warnings = data.warnings || data.Warnings || [];
                    currentPage = 0;
                    _validationDirty = true;

                    rows.forEach(backfillFromIsoClient);
                    rows.forEach(r => extractJAddFromWeldNumber(r));
                    rows.forEach(r => r.Remarks = '');
                    renderWarnings(warnings);
                    renderTable();
                    updateSummary();
                    saveChangesBtn.disabled = rows.length === 0;
                    downloadAnalysisBtn.disabled = rows.length === 0;

                    if (rows.length > 0) {
                        showMessage('info', `Loaded ${rows.length} records for editing`);
                    } else {
                        showMessage('warning', 'No data found for the selected filter.');
                    }
                } catch (e) {
                    console.error('Load failed:', e);
                    showMessage('error', 'Failed to load data. Please try again.');
                } finally {
                    showLoading(false);
                }
            }

            async function commitToDb() {
                if (rows.length === 0) {
                    showMessage('error', 'No data to commit');
                    return;
                }

                const scopeLabel = { LineList: 'Line List', LineSheet: 'Line / Sheet', Joints: 'Joints' }[currentScope] || currentScope;
                const modeLabel = currentMode === 'upload' ? 'Upload (new + update if Fitup not completed)' : 'Update (existing records)';
                if (!(await showConfirmModal(
                    `${modeLabel}: Commit ${rows.length} rows to database (${scopeLabel} scope)?`,
                    'Upload to Database'
                ))) return;

                const totalRows = rows.length;
                const batchSize = 50;
                const totalBatches = Math.ceil(totalRows / batchSize);

                showLoading(true, 'Uploading to database...', `Committing ${totalRows} record${totalRows !== 1 ? 's' : ''} \u2014 please wait`);
                updateLoadingProgress(0, totalRows, `Starting batch 1 of ${totalBatches}...`);

                let totalCreated = 0;
                let totalUpdated = 0;
                let totalSkipped = 0;
                let allErrors = [];
                let allWarnings = [];
                let committed = 0;

                try {
                    for (let i = 0; i < totalRows; i += batchSize) {
                        const batchRows = rows.slice(i, i + batchSize);
                        const batchNum = Math.floor(i / batchSize) + 1;

                        updateLoadingProgress(committed, totalRows, `Processing batch ${batchNum} of ${totalBatches} (${batchRows.length} rows)...`);

                        // Yield to UI thread so the browser can repaint
                        await new Promise(r => setTimeout(r, 0));

                        const payload = {
                            projectId: parseInt(projectSelect.value) || 0,
                            scope: currentScope,
                            mode: currentMode,
                            updateOnlyNonNull: document.getElementById('updateOnlyNonNull')?.checked || false,
                            rows: batchRows
                        };

                        const batchController = new AbortController();
                        const batchTimeout = setTimeout(() => batchController.abort(), 120000);
                        const resp = await fetch('@Url.Action("CommitJointRecord", "Home")', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'RequestVerificationToken': tokenInput.value
                            },
                            body: JSON.stringify(payload),
                            signal: batchController.signal
                        });
                        clearTimeout(batchTimeout);

                        if (!resp.ok) throw new Error(`HTTP ${resp.status} on batch ${batchNum}`);
                        const result = await resp.json();

                        totalCreated += (result.created || result.Created || 0);
                        totalUpdated += (result.updated || result.Updated || 0);
                        totalSkipped += (result.skipped || result.Skipped || 0);

                        // Clear Remarks for all rows in this batch first, then
                        // apply server-side skip/error reasons from RowRemarks.
                        for (let j = i; j < Math.min(i + batchSize, totalRows); j++) {
                            rows[j].Remarks = '';
                        }
                        const rowRemarks = result.rowRemarks || result.RowRemarks || {};
                        Object.keys(rowRemarks).forEach(localIdx => {
                            const globalIdx = i + parseInt(localIdx);
                            if (globalIdx < totalRows) {
                                rows[globalIdx].Remarks = rowRemarks[localIdx] || '';
                            }
                        });

                        const batchErrors = result.errors || result.Errors || [];
                        if (batchErrors.length > 0) {
                            allErrors = allErrors.concat(batchErrors);
                        }
                        const batchWarnings = result.warnings || result.Warnings || [];
                        if (batchWarnings.length > 0) {
                            allWarnings = allWarnings.concat(batchWarnings);
                        }

                        committed += batchRows.length;
                        updateLoadingProgress(committed, totalRows, `Completed ${committed} of ${totalRows} rows`);
                    }

                    renderTable();

                    if (allErrors.length > 0) {
                        allErrors.forEach(e => showMessage('error', e));
                    }
                    if (allWarnings.length > 0) {
                        allWarnings.forEach(w => showMessage('info', w));
                    }
                    if (totalSkipped === 0 && allErrors.length === 0) {
                        showMessage('info', `Successfully committed: ${totalCreated} created, ${totalUpdated} updated.`);
                        tableStatus.textContent = 'Committed';
                        tableStatus.className = 'jr-status jr-status-success';
                    } else {
                        showMessage('warning', `Partially committed: ${totalCreated} created, ${totalUpdated} updated, ${totalSkipped} skipped.`);
                    }
                } catch (e) {
                    console.error('Commit failed:', e);
                    showMessage('error', `Failed to commit data to database after ${committed} of ${totalRows} rows.`);
                    if (committed > 0) {
                        showMessage('info', `Partial commit: ${totalCreated} created, ${totalUpdated} updated before failure.`);
                        renderTable();
                    }
                } finally {
                    showLoading(false);
                }
            }

            async function analyzeFiles() {
                const projectId = projectSelect.value;
                if (!projectId) {
                    showMessage('error', 'Please select a project');
                    return;
                }

                const drawingFile = document.getElementById('drawingFile').files[0];
                const excelFile = document.getElementById('excelFile').files[0];
                if (!drawingFile && !excelFile) {
                    showMessage('error', 'Please select a drawing file or Excel template');
                    return;
                }

                const sourceLabel = drawingFile ? drawingFile.name : excelFile.name;
                showLoading(true, 'Analyzing files...', `Processing ${sourceLabel} \u2014 this may take a moment`);

                const formData = new FormData();
                formData.append('projectId', projectId);
                formData.append('scope', currentScope);
                if (drawingFile) {
                    formData.append('drawingFile', drawingFile);
                }

                if (excelFile) {
                    formData.append('excelFile', excelFile);
                }

                try {
                    const response = await fetch('@Url.Action("AnalyzeJointRecord", "Home")', {
                        method: 'POST',
                        headers: {
                            'RequestVerificationToken': tokenInput.value
                        },
                        body: formData
                    });

                    if (!response.ok) {
                        throw new Error(`HTTP ${response.status}`);
                    }

                    const data = await response.json();

                    rows = data.rows || data.Rows || [];
                    warnings = data.warnings || data.Warnings || [];
                    currentProjectId = data.projectId || projectId;
                    currentPage = 0;
                    _validationDirty = true;

                    rows.forEach(backfillFromIsoClient);
                    rows.forEach(r => extractJAddFromWeldNumber(r));

                    renderWarnings(warnings);
                    renderTable();
                    const summary = updateSummary();

                    // Enable buttons
                    downloadAnalysisBtn.disabled = rows.length === 0;
                    commitBtn.disabled = rows.length === 0;

                    if (rows.length > 0) {
                        showMessage('info', `Successfully analyzed ${rows.length} records with ${summary.warningCount} warnings`);
                    } else {
                        showMessage('warning', 'No data extracted. Please check file formats.');
                    }

                } catch (error) {
                    console.error('Analysis failed:', error);
                    showMessage('error', 'Failed to analyze files. Please try again.');
                } finally {
                    showLoading(false);
                }
            }

            async function downloadAnalysis() {
                if (rows.length === 0) {
                    showMessage('error', 'No data to download');
                    return;
                }

                showLoading(true);

                const payload = {
                    projectId: currentProjectId,
                    analysisName: `JointRecord_${new Date().toISOString().slice(0,19).replace(/[:]/g,'')}`,
                    rows: rows
                };

                try {
                    const response = await fetch('@Url.Action("DownloadJointRecordAnalysis", "Home")', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': tokenInput.value
                        },
                        body: JSON.stringify(payload)
                    });

                    if (!response.ok) {
                        throw new Error(`HTTP ${response.status}`);
                    }

                    const blob = await response.blob();
                    const url = window.URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.href = url;
                    a.download = `JointRecord_Analysis_${new Date().toISOString().slice(0,10)}.xlsx`;
                    document.body.appendChild(a);
                    a.click();
                    a.remove();
                    window.URL.revokeObjectURL(url);

                } catch (error) {
                    console.error('Download failed:', error);
                    showMessage('error', 'Failed to download analysis');
                } finally {
                    showLoading(false);
                }
            }

            async function clearAll() {
                if (rows.length > 0 && !(await showConfirmModal('Clear all data? This cannot be undone.', 'Clear All'))) {
                    return;
                }

                rows = [];
                warnings = [];
                currentPage = 0;
                rowFilter = 'all';
                _validationDirty = true;
                form.reset();
                // Restore scope/mode radios after form reset
                document.querySelector(`input[name="scope"][value="${currentScope}"]`).checked = true;
                document.querySelector(`input[name="mode"][value="${currentMode}"]`).checked = true;
                messagesHost.innerHTML = '';
                renderTable();
                updateSummary();
                updateModeUI();
                updateFilterUI();

                downloadAnalysisBtn.disabled = true;
                commitBtn.disabled = true;
                saveChangesBtn.disabled = true;

                showMessage('info', 'All data cleared');
            }

            // ── Bulk Analyze with multi-select modal ──
            let _bulkDrawings = [];
            const bulkFilterLayout = document.getElementById('bulkFilterLayout');
            const bulkFilterSheet = document.getElementById('bulkFilterSheet');
            const bulkFilterRev = document.getElementById('bulkFilterRev');

            function _field(d, key) {
                return d[key] || d[key.charAt(0).toUpperCase() + key.slice(1)] || '';
            }

            function getBulkFilters() {
                return {
                    layout: bulkFilterLayout.value.trim().toLowerCase(),
                    sheet: bulkFilterSheet.value.trim().toLowerCase(),
                    rev: bulkFilterRev.value.trim().toLowerCase()
                };
            }

            function drawingMatchesFilters(d, filters) {
                if (filters.layout && !_matchFilter(_field(d, 'layout'), filters.layout)) return false;
                if (filters.sheet && !_matchFilter(_field(d, 'sheet'), filters.sheet)) return false;
                if (filters.rev && !_matchFilter(_field(d, 'revisionTag'), filters.rev)) return false;
                return true;
            }

            // Supports "!term" for not-contains and plain "term" for contains (case-insensitive)
            function _matchFilter(fieldValue, filterTerm) {
                const val = fieldValue.toLowerCase();
                if (filterTerm.startsWith('!')) {
                    const exclude = filterTerm.substring(1);
                    if (!exclude) return true;
                    return !val.includes(exclude);
                }
                return val.includes(filterTerm);
            }

            function openBulkSelectModal(drawings) {
                _bulkDrawings = drawings;
                // Show current project in the modal toolbar
                const selOpt = projectSelect.selectedOptions[0];
                document.getElementById('bulkFilterProject').textContent = selOpt ? selOpt.textContent : '\u2014';
                // Clear search boxes
                bulkFilterLayout.value = '';
                bulkFilterSheet.value = '';
                bulkFilterRev.value = '';
                renderBulkSelectRows();
                document.getElementById('bulkSelectModal').style.display = 'flex';
                updateBulkSelectCount();
            }

            function closeBulkSelectModal() {
                document.getElementById('bulkSelectModal').style.display = 'none';
            }

            function renderBulkSelectRows() {
                const body = document.getElementById('bulkSelectBody');
                const filters = getBulkFilters();
                body.innerHTML = '';
                let visibleCount = 0;
                let visibleChecked = 0;
                _bulkDrawings.forEach((d, idx) => {
                    if (!drawingMatchesFilters(d, filters)) return;
                    const layout = _field(d, 'layout');
                    const sheet = _field(d, 'sheet');
                    const rev = _field(d, 'revisionTag');
                    const file = _field(d, 'fileName');
                    const id = d.drawingId || d.DrawingId || 0;
                    const isChecked = d._selected !== false;
                    visibleCount++;
                    if (isChecked) visibleChecked++;
                    const tr = document.createElement('tr');
                    tr.dataset.idx = idx;
                    tr.dataset.id = id;
                    if (isChecked) tr.classList.add('selected-row');
                    tr.innerHTML = `<td><input type="checkbox" class="bulk-chk" data-idx="${idx}" ${isChecked ? 'checked' : ''} /></td>`
                        + `<td>${layout}</td><td>${sheet || '\u2014'}</td><td>${rev || '\u2014'}</td><td title="${file}">${file.length > 40 ? file.substring(0, 37) + '...' : file}</td>`;
                    tr.addEventListener('click', e => {
                        if (e.target.tagName === 'INPUT') return;
                        const chk = tr.querySelector('.bulk-chk');
                        chk.checked = !chk.checked;
                        chk.dispatchEvent(new Event('change'));
                    });
                    const chk = tr.querySelector('.bulk-chk');
                    chk.addEventListener('change', () => {
                        _bulkDrawings[idx]._selected = chk.checked;
                        tr.classList.toggle('selected-row', chk.checked);
                        updateBulkSelectCount();
                    });
                    body.appendChild(tr);
                });
                document.getElementById('bulkSelectToggle').checked =
                    visibleCount > 0 && visibleChecked === visibleCount;
            }

            function updateBulkSelectCount() {
                const total = _bulkDrawings.length;
                const selected = _bulkDrawings.filter(d => d._selected !== false).length;
                document.getElementById('bulkSelectCount').textContent = `${selected} of ${total} selected`;
                document.getElementById('bulkSelectConfirm').disabled = selected === 0;
            }

            function getSelectedDrawingIds() {
                return _bulkDrawings
                    .filter(d => d._selected !== false)
                    .map(d => d.drawingId || d.DrawingId || 0)
                    .filter(id => id > 0);
            }

            // Modal event wiring
            document.getElementById('bulkSelectClose').addEventListener('click', closeBulkSelectModal);
            document.getElementById('bulkSelectCancel').addEventListener('click', closeBulkSelectModal);
            document.getElementById('bulkSelectModal').addEventListener('click', e => {
                if (e.target === e.currentTarget) closeBulkSelectModal();
            });
            bulkFilterLayout.addEventListener('input', renderBulkSelectRows);
            bulkFilterSheet.addEventListener('input', renderBulkSelectRows);
            bulkFilterRev.addEventListener('input', renderBulkSelectRows);
            document.getElementById('bulkSelectAll').addEventListener('click', () => {
                const filters = getBulkFilters();
                _bulkDrawings.forEach(d => {
                    if (drawingMatchesFilters(d, filters)) d._selected = true;
                });
                renderBulkSelectRows();
                updateBulkSelectCount();
            });
            document.getElementById('bulkDeselectAll').addEventListener('click', () => {
                const filters = getBulkFilters();
                _bulkDrawings.forEach(d => {
                    if (drawingMatchesFilters(d, filters)) d._selected = false;
                });
                renderBulkSelectRows();
                updateBulkSelectCount();
            });
            document.getElementById('bulkSelectToggle').addEventListener('change', e => {
                const checked = e.target.checked;
                const filters = getBulkFilters();
                _bulkDrawings.forEach(d => {
                    if (drawingMatchesFilters(d, filters)) d._selected = checked;
                });
                renderBulkSelectRows();
                updateBulkSelectCount();
            });

            document.getElementById('bulkSelectConfirm').addEventListener('click', async () => {
                closeBulkSelectModal();
                const selectedIds = getSelectedDrawingIds();
                if (selectedIds.length === 0) return;
                await runBulkAnalysis(selectedIds);
            });

            async function bulkAnalyze() {
                const projectId = projectSelect.value;
                if (!projectId) {
                    showMessage('error', 'Please select a project');
                    return;
                }

                showLoading(true, 'Loading drawings...', 'Fetching latest drawings from the project');
                try {
                    // Step 1: Fetch available latest drawings (30s timeout)
                    const controller = new AbortController();
                    const timeoutId = setTimeout(() => controller.abort(), 30000);
                    const previewResp = await fetch(
                        `@Url.Action("GetBulkAnalyzeDrawings", "Home")?projectId=${projectId}`,
                        { signal: controller.signal }
                    );
                    clearTimeout(timeoutId);
                    if (!previewResp.ok) throw new Error(`HTTP ${previewResp.status}`);
                    const drawings = await previewResp.json();

                    if (!drawings || drawings.length === 0) {
                        showMessage('warning', 'No latest drawings found for this project in the Drawings system.');
                        return;
                    }

                    // Mark all as selected by default
                    drawings.forEach(d => d._selected = true);

                    showLoading(false);
                    // Step 2: Show selection modal
                    openBulkSelectModal(drawings);
                } catch (error) {
                    console.error('Failed to load drawings list:', error);
                    if (error.name === 'AbortError') {
                        showMessage('error', 'Request timed out loading drawings list. Please try again.');
                    } else {
                        showMessage('error', 'Failed to load drawings list. Please try again.');
                    }
                } finally {
                    showLoading(false);
                }
            }

            async function runBulkAnalysis(drawingIds) {
                const projectId = projectSelect.value;
                const totalDrawings = drawingIds.length;
                const batchSize = 5;
                const totalBatches = Math.ceil(totalDrawings / batchSize);

                showLoading(true, 'Analyzing drawings...', `Processing ${totalDrawings} drawing${totalDrawings !== 1 ? 's' : ''} \u2014 this may take a moment`);
                updateLoadingProgress(0, totalDrawings, `Starting batch 1 of ${totalBatches}...`);

                let allRows = [];
                let allWarnings = [];
                let totalSuccessful = 0;
                let totalFailed = 0;
                let processed = 0;

                try {
                    for (let i = 0; i < totalDrawings; i += batchSize) {
                        const batchIds = drawingIds.slice(i, i + batchSize);
                        const batchNum = Math.floor(i / batchSize) + 1;

                        updateLoadingProgress(processed, totalDrawings, `Processing batch ${batchNum} of ${totalBatches} (${batchIds.length} drawings)...`);

                        // Yield to UI thread so the browser can repaint and stay responsive
                        await new Promise(r => setTimeout(r, 0));

                        const batchController = new AbortController();
                        const batchTimeout = setTimeout(() => batchController.abort(), 120000);
                        const resp = await fetch('@Url.Action("BulkAnalyzeJointRecord", "Home")', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'RequestVerificationToken': tokenInput.value
                            },
                            body: JSON.stringify({
                                projectId: parseInt(projectId),
                                scope: currentScope,
                                drawingIds: batchIds
                            }),
                            signal: batchController.signal
                        });
                        clearTimeout(batchTimeout);

                        if (!resp.ok) throw new Error(`HTTP ${resp.status} on batch ${batchNum}`);
                        const data = await resp.json();

                        const batchRows = data.rows || data.Rows || [];
                        const batchWarnings = data.warnings || data.Warnings || [];
                        allRows = allRows.concat(batchRows);
                        allWarnings = allWarnings.concat(batchWarnings);
                        totalSuccessful += (data.successfulDrawings || data.SuccessfulDrawings || 0);
                        totalFailed += (data.failedDrawings || data.FailedDrawings || 0);

                        processed += batchIds.length;
                        updateLoadingProgress(processed, totalDrawings, `Completed ${processed} of ${totalDrawings} drawings`);
                    }

                    rows = allRows;
                    warnings = allWarnings;
                    currentProjectId = parseInt(projectId) || 0;
                    currentPage = 0;
                    _validationDirty = true;

                    rows.forEach(backfillFromIsoClient);
                    rows.forEach(r => extractJAddFromWeldNumber(r));

                    renderWarnings(warnings);
                    renderTable();
                    const summary = updateSummary();

                    downloadAnalysisBtn.disabled = rows.length === 0;
                    commitBtn.disabled = rows.length === 0;

                    if (rows.length > 0) {
                        showMessage('info',
                            `Bulk analysis: ${totalSuccessful}/${totalDrawings} drawings processed, ${rows.length} records extracted` +
                            (totalFailed > 0 ? ` (${totalFailed} failed)` : ''));
                    } else {
                        showMessage('warning', 'No data extracted from any drawings.');
                    }
                } catch (error) {
                    console.error('Bulk analysis failed:', error);
                    showMessage('error', `Bulk analysis failed after ${processed} of ${totalDrawings} drawings. Please try again.`);
                    if (allRows.length > 0) {
                        rows = allRows;
                        warnings = allWarnings;
                        currentPage = 0;
                        _validationDirty = true;
                        rows.forEach(backfillFromIsoClient);
                        rows.forEach(r => extractJAddFromWeldNumber(r));
                        renderWarnings(warnings);
                        renderTable();
                        updateSummary();
                        downloadAnalysisBtn.disabled = false;
                        commitBtn.disabled = false;
                        showMessage('info', `Partial results: ${allRows.length} records extracted from ${processed} drawings before failure.`);
                    }
                } finally {
                    showLoading(false);
                }
            }

            // Initialize buttons
            document.getElementById('analyzeBtn').addEventListener('click', analyzeFiles);
            document.getElementById('bulkAnalyzeBtn').addEventListener('click', bulkAnalyze);
            document.getElementById('commitBtn').addEventListener('click', commitToDb);
            document.getElementById('loadDataBtn').addEventListener('click', loadData);
            document.getElementById('saveChangesBtn').addEventListener('click', commitToDb);
            document.getElementById('downloadTemplateBtn').addEventListener('click', () => {
                window.location.href = '@Url.Action("DownloadJointRecordTemplate", "Home")';
            });
            document.getElementById('downloadAnalysisBtn').addEventListener('click', downloadAnalysis);
            document.getElementById('clearBtn').addEventListener('click', clearAll);

            // Row filter links (With Warnings / Errors / Show All)
            document.getElementById('filterWarningsLink').addEventListener('click', (e) => {
                e.preventDefault();
                rowFilter = rowFilter === 'warnings' ? 'all' : 'warnings';
                currentPage = 0;
                updateFilterUI();
                renderTable();
            });
            document.getElementById('filterErrorsLink').addEventListener('click', (e) => {
                e.preventDefault();
                rowFilter = rowFilter === 'errors' ? 'all' : 'errors';
                currentPage = 0;
                updateFilterUI();
                renderTable();
            });
            document.getElementById('filterClearLink').addEventListener('click', (e) => {
                e.preventDefault();
                rowFilter = 'all';
                currentPage = 0;
                updateFilterUI();
                renderTable();
            });

            function updateFilterUI() {
                const warnLink = document.getElementById('filterWarningsLink');
                const errLink = document.getElementById('filterErrorsLink');
                const clearLabel = document.getElementById('filterActiveLabel');
                warnLink.classList.toggle('jr-filter-selected', rowFilter === 'warnings');
                errLink.classList.toggle('jr-filter-selected', rowFilter === 'errors');
                clearLabel.style.display = rowFilter !== 'all' ? '' : 'none';
            }

            // Add keyboard shortcuts
            document.addEventListener('keydown', (e) => {
                if ((e.ctrlKey || e.metaKey) && e.key === 'd') {
                    e.preventDefault();
                    if (!downloadAnalysisBtn.disabled) downloadAnalysis();
                }
            });

            // Initial render
            renderWarnings(warnings);
            renderTable();
            updateSummary();
            updateModeUI();
            if (currentMode === 'edit') loadLayoutOptions();

            // Enable save/download if we have initial data
            if (rows.length > 0) {
                downloadAnalysisBtn.disabled = false;
                commitBtn.disabled = false;
                saveChangesBtn.disabled = false;
            }

        })();
    </script>
</body>
</html>