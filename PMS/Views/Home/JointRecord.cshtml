            const defaultLocations = ['WS', 'FW'];

            // Scope-based field and header definitions
            // Revision visibility depends on Projects_tbl.Line_Sheet for Line List / Line+Sheet scopes:
            //   lineSheetMode === 'line'  → show Revision in LineList and LineSheet
            //   lineSheetMode === 'sheet' → show Revision in LineSheet only (not LineList)
            //   lineSheetMode is empty    → hide Revision in LineList and LineSheet
            //   Joints scope              → always show Revision
            function shouldShowRevision() {
                const mode = (lineSheetMode || '').toLowerCase();
                if (currentScope === 'Joints') return true;
                if (currentScope === 'LineList') return mode === 'line';
                if (currentScope === 'LineSheet') return mode === 'line' || mode === 'sheet';
