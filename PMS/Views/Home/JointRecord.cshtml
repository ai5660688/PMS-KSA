                const percentEl = document.getElementById('loadingPercent');
                statusEl.textContent = statusText || '';
                progressEl.style.display = statusText ? 'block' : 'none';
                if (!show) {
                    progressEl.classList.remove('determinate');
                    percentEl.style.display = 'none';
                    percentEl.textContent = '';
                    document.getElementById('loadingProgressBar').style.width = '30%';
                }
            }

            function updateLoadingProgress(current, total, statusText) {
                const progressEl = document.getElementById('loadingProgress');
                const barEl = document.getElementById('loadingProgressBar');
                const percentEl = document.getElementById('loadingPercent');
                const statusEl = document.getElementById('loadingStatus');
                progressEl.style.display = 'block';
                progressEl.classList.add('determinate');
                percentEl.style.display = 'block';
                const pct = total > 0 ? Math.min(100, Math.round((current / total) * 100)) : 0;
                barEl.style.width = pct + '%';
                percentEl.textContent = `${pct}% (${current} / ${total})`;
                if (statusText) statusEl.textContent = statusText;
