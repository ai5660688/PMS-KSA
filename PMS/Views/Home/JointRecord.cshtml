            }

            function getRequiredFields() {
                if (currentScope === 'LineList') return { LayoutNo: true };
                if (currentScope === 'LineSheet') return { LayoutNo: true, LSSheet: true };
                return { LayoutNo: true, WeldNumber: true, LSSheet: true, JAdd: true };
            }

            function getActiveFields() {
                const showRev = shouldShowRevision();
