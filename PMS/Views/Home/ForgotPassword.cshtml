@{
    ViewData["Title"] = "Account Recovery";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <title>@ViewData["Title"]</title>
    <link rel="icon" type="image/png" href="~/img/title_logo.png">
    <link rel="stylesheet" href="~/css/ForgotPasswordStyle.css">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body>
    <h1>
        <img src="~/img/PMS_logo.png" alt="PMS logo" class="main-logo">
    </h1>
    <div class="container-wrapper">
        <div class="forgot-container">
            <h2>Recover Your Account</h2>
            <p style="text-align:center;">Select what you need help with and enter your registered email.</p>
            <form method="post" action="@Url.Action("ForgotPassword", "Home")" autocomplete="off">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label for="email"><b>Registered Email</b></label>
                    <input type="email" id="email" name="email" value="" required placeholder="you@example.com" />
                </div>
                <fieldset class="form-group" style="border:none;padding:0;margin:0 0 12px 0;">
                    <legend style="font-size:0.95em;margin-bottom:4px;">Recovery Type</legend>
                    <label style="display:block;margin-bottom:4px;">
                        <input type="radio" name="recoveryType" value="password" checked /> Reset Password
                    </label>
                    <label style="display:block;">
                        <input type="radio" name="recoveryType" value="username" /> Send Username Reminder
                    </label>
                </fieldset>
                <button type="submit" class="submit-btn">Submit</button>
            </form>
            @if (!string.IsNullOrEmpty(ViewBag.Message))
            {
                <p class="message">@ViewBag.Message</p>
            }
            <div class="back-to-login-container">
                <a href="@Url.Action("Login", "Home")" class="back-to-login-link">Back to Login</a>
            </div>
        </div>
    </div>
    <div class="footer">
        <div class="footer-left">
            <a href="@Url.Action("ContactUs", "Home")">Contact us</a>
        </div>
        <div class="footer-center">
            This system is strictly restricted to authorized users only.<br>
            © 2025 Piping Management System. All rights reserved.
        </div>
        <div class="footer-right">
            <img src="~/img/work-smarter-not-harder.jpg?v=3" alt="Footer logo" class="footer-logo" />
        </div>
    </div>
</body>
</html>