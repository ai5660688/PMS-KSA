@* Plan:
   - Show success message after SignUp and auto-redirect.
   - Replace spinner with animated three dots "..." after the message.
   - Keep redirect via setTimeout using ViewBag.ReturnUrl and ViewBag.DelayMs.
*@
@{
    Layout = null;
    var message = (string)(ViewBag.Message ?? "Your account has been created. It will be activated after approval.");
    var returnUrl = ViewBag.ReturnUrl ?? Url.Action("Login", "Home");
    var delayMs = ViewBag.DelayMs ?? 2500;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>PMS - Loading</title>
    <link rel="icon" type="image/png" href="~/img/title_logo.png">
    <link rel="stylesheet" href="~/css/LoadingToLDashboardStyle.css">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        .loading-wrap { max-width: 900px; margin: 0 auto; background:#fff; border-radius:12px; padding:24px; box-shadow:0 10px 30px rgba(0,0,0,0.08); }
        .center { text-align:center; }
        .ellipsis { display:inline-block; min-width: 2ch; color: #187A35; } /* match message color */
        .success-message { color: #187A35; } /* updated to requested green */
        #dots { color: #187A35 !important; } /* ensure same color even if overridden */
    </style>
</head>
<body>
    <h1>
        <img src="~/img/PMS_logo.png" alt="Logo" class="main-logo">
    </h1>

    <div class="container-wrapper">
        <div class="loading-wrap">
            <div class="center">
                <img src="~/img/jafurah.jpg" alt="Jafurah" class="project-image" />
                <h2><span class="success-message">@message</span><span id="dots" class="ellipsis"></span></h2>
            </div>
        </div>
    </div>

    <div class="footer">
        <div class="footer-center">
            This system is strictly restricted to authorized users only.<br>
            © 2025 Piping Management System. All rights reserved.
        </div>
        <div class="footer-right">
            <img src="~/img/work-smarter-not-harder.jpg?v=3" alt="Logo" class="footer-logo" />
        </div>
    </div>
    <script>
        (function () {
            const d = document.getElementById('dots');
            if (!d) return;
            let i = 0;
            setInterval(() => { d.textContent = '.'.repeat((i++ % 3) + 1); }, 450);
        })();
        setTimeout(function(){ window.location.href = '@returnUrl'; }, @delayMs);
    </script>
</body>
</html>