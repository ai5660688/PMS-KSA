<!DOCTYPE html>
<html>
<head>
    <title>PMS - Login</title>
    <link rel="icon" type="image/png" href="~/img/title_logo.png">
    <link rel="stylesheet" href="~/css/LoginStyle.css">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body>
    <h1>
        <img src="~/img/PMS_logo.png" alt="PMS logo" class="main-logo">
    </h1>
    <div class="container-wrapper">
        <div class="container">
            <h2>Welcome to the Piping Management System</h2>
            @if (TempData["SuccessMessage"] is string ok)
            {
                <div class="msg">@ok</div>
            }
            <form method="post" action="@Url.Action("Login", "Home")" autocomplete="off">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label for="username"><b>Username</b></label>
                    <input type="text" id="username" name="username"
                           value="@(ViewBag.ClearLoginFields == true ? "" : (ViewBag.Username ?? ""))"
                           autocomplete="off" required>
                </div>
                <div class="form-group">
                    <label for="password"><b>Password</b></label>
                    <input type="password" id="password" name="password"
                           value="@(ViewBag.ClearLoginFields == true ? "" : (ViewBag.Password ?? ""))"
                           autocomplete="new-password" required>
                </div>
                <div class="form-inline-right">
                    <input type="checkbox" id="rememberMe" name="rememberMe" value="true"
                           @(ViewBag.RememberMe != null && (bool)ViewBag.RememberMe ? "checked" : "") />
                    <label for="rememberMe">Remember me</label>
                </div>
                <div style="width: 100%; text-align: right; margin-bottom: 18px;">
                    <a class="forgot-link" href="@Url.Action("ForgotPassword", "Home")">Forgot Username or Password?</a>
                </div>
                <div class="button-container">
                    <button type="submit">Login</button>
                    <a href="@Url.Action("SignUp", "Home")" class="signup-btn">Sign Up</a>
                </div>
            </form>
            @if (!string.IsNullOrEmpty(ViewBag.ErrorMessage))
            {
                <p class="error-text">@ViewBag.ErrorMessage</p>
            }
            <p style="text-align: center;">Please enter your credentials to access the system.</p>
        </div>
    </div>
    <div class="footer">
        <div class="footer-left">
            <a href="@Url.Action("ContactUs", "Home")">Contact us</a>
            <span class="footer-separator">|</span>
            <a href="@Url.Action("AboutUs", "Home")">About us</a>
        </div>
        <div class="footer-center">
            This system is strictly restricted to authorized users only.<br>
            © 2025 Piping Management System. All rights reserved.
        </div>
        <div class="footer-right">
            <img src="~/img/work-smarter-not-harder.jpg?v=3" alt="Footer logo" class="footer-logo" />
        </div>
    </div>
    <script src="~/js/site.js"></script>
    @if (ViewBag.ClearLoginFields == true)
    {
        <script>
            window.addEventListener('DOMContentLoaded', function () {
                const u = document.getElementById('username');
                const p = document.getElementById('password');
                const r = document.getElementById('rememberMe');
                if (u) { u.value = ''; u.setAttribute('autocomplete', 'off'); }
                if (p) { p.value = ''; p.setAttribute('autocomplete', 'new-password'); }
                if (r) r.checked = false;
            });
        </script>
    }
</body>
</html>