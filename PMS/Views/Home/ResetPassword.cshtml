@{
    ViewData["Title"] = "Reset Password";
    var error = ViewBag.ErrorMessage as string;
    var token = ViewBag.Token as string;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="icon" type="image/png" href="~/img/title_logo.png">
    <link rel="stylesheet" href="~/css/ForgotPasswordStyle.css">
</head>
<body>
    <h1>
        <img src="~/img/PMS_logo.png" alt="PMS logo" class="main-logo">
    </h1>
    <div class="container-wrapper">
        <div class="forgot-container">
            <h2>@ViewData["Title"]</h2>
            <form method="post" action="@Url.Action("ResetPassword", "Home")" autocomplete="off" id="resetForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="token" value="@token" />
                <div class="form-group">
                    <label for="newPassword">New Password</label>
                    <input type="password" id="newPassword" name="newPassword" minlength="8" maxlength="20" pattern="^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[^\da-zA-Z])(?=\S+$).{8,20}$" autocomplete="new-password" required />
                    <ul class="password-rules" id="pwdRules">
                        <li data-rule="length">8û20 characters</li>
                        <li data-rule="upper">At least one uppercase letter (AûZ)</li>
                        <li data-rule="lower">At least one lowercase letter (aûz)</li>
                        <li data-rule="digit">At least one number (0û9)</li>
                        <li data-rule="special">At least one special character (!&#64;&#35;&#36;&hellip;)</li>
                        <li data-rule="space">No spaces</li>
                    </ul>
                </div>
                <div class="form-group confirm-password">
                    <label for="confirmPassword">Confirm Password</label>
                    <input type="password" id="confirmPassword" name="confirmPassword" maxlength="20" autocomplete="new-password" required />
                    <p id="passwordMismatch" class="error-text password-match-error">Passwords do not match.</p>
                </div>
                <button type="submit" class="submit-btn">Reset Password</button>
            </form>
            @if (!string.IsNullOrWhiteSpace(error))
            {
                <p class="message">@error</p>
            }
        </div>
    </div>
    <div class="footer">
        <div class="footer-left">
            <a href="@Url.Action("ContactUs", "Home")">Contact us</a>
        </div>
        <div class="footer-center">
            This system is strictly restricted to authorized users only.<br>
            ® 2025 Piping Management System. All rights reserved.
        </div>
        <div class="footer-right">
            <img src="~/img/work-smarter-not-harder.jpg?v=3" alt="Footer logo" class="footer-logo" />
        </div>
    </div>

    <script>
        (function () {
            const pwd = document.getElementById('newPassword');
            const cpwd = document.getElementById('confirmPassword');
            const msg = document.getElementById('passwordMismatch');
            const group = document.querySelector('.form-group.confirm-password');
            const form = document.getElementById('resetForm');
            const rules = {
                length: val => val.length >= 8 && val.length <= 20,
                upper: val => /[A-Z]/.test(val),
                lower: val => /[a-z]/.test(val),
                digit: val => /\d/.test(val),
                special: val => /[^\da-zA-Z]/.test(val),
                space: val => !/\s/.test(val)
            };
            const rulesList = document.getElementById('pwdRules');

            function updateRules() {
                if (!pwd || !rulesList) return true;
                const val = pwd.value || '';
                let ok = true;
                Object.keys(rules).forEach(key => {
                    const li = rulesList.querySelector(`li[data-rule="${key}"]`);
                    const pass = rules[key](val);
                    if (li) { li.classList.toggle('valid', pass); li.classList.toggle('invalid', !pass); }
                    ok = ok && pass;
                });
                return ok;
            }

            function validateMatch() {
                if (!pwd || !cpwd || !msg) return true;
                const same = pwd.value === cpwd.value;
                msg.style.display = same ? 'none' : 'block';
                if (group) group.classList.toggle('has-error', !same);
                return same;
            }

            if (pwd) pwd.addEventListener('input', () => { updateRules(); validateMatch(); });
            if (cpwd) cpwd.addEventListener('input', validateMatch);

            if (form) {
                form.addEventListener('submit', function (e) {
                    const passOk = updateRules();
                    const matchOk = validateMatch();
                    if (!passOk || !matchOk) e.preventDefault();
                });
            }
            updateRules();
        })();
    </script>
</body>
</html>
