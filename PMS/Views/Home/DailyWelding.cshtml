@model PMS.Models.DfrDailyFitupViewModel
@using System.Globalization
@{
    Layout = null;
    var antiForgery = Html.AntiForgeryToken();
    var headerView = Context.Request.Query["headerView"].ToString();
    if(string.IsNullOrWhiteSpace(headerView)) { headerView = "DWG"; }
    var headerViewDisplay = headerView;

    // Prepare values for date inputs
    string dateFilterSubmitValue = string.Empty;
    string dateFilterDisplayValue = string.Empty;
    DateTime? parsedDateFilter = null;
    if(!string.IsNullOrWhiteSpace(Model?.SearchFitupDate))
    {
        var acceptedFilterFormats = new[]{ "yyyy-MM-dd", "dd-MMM-yyyy", "dd-MMM - yyyy", "dd/MM/yyyy", "MM/dd/yyyy" };
        if(DateTime.TryParseExact(Model.SearchFitupDate.Trim(), acceptedFilterFormats, CultureInfo.InvariantCulture, DateTimeStyles.None, out var _dfParsed))
        {
            parsedDateFilter = _dfParsed.Date;
            dateFilterSubmitValue = _dfParsed.ToString("yyyy-MM-dd");
            dateFilterDisplayValue = _dfParsed.ToString("dd-MMM-yyyy");
        }
    }

    string fitupHeaderDateValue = Model?.FitupDateHeader ?? string.Empty;
    DateTime? parsedHeaderDate = null;
    if(!string.IsNullOrWhiteSpace(fitupHeaderDateValue))
    {
        var fmt = new[] { "dd-MMM-yyyy hh:mm tt", "dd-MMM-yyyy H:mm", "yyyy-MM-dd'T'HH:mm", "yyyy-MM-dd HH:mm", "dd-MMM-yyyy" };
        if(DateTime.TryParseExact(fitupHeaderDateValue, fmt, CultureInfo.InvariantCulture, DateTimeStyles.None, out var _fhParsed))
        {
            parsedHeaderDate = _fhParsed;
            fitupHeaderDateValue = _fhParsed.ToString("yyyy-MM-dd'T'HH:mm");
        }
    }

    // If we're in Date view and a date filter exists, use its date for the header (preserve header time if present)
    if(string.Equals(headerView, "Date", StringComparison.OrdinalIgnoreCase) && parsedDateFilter.HasValue)
    {
        var baseDate = parsedDateFilter.Value.Date;
        var timeOfDay = parsedHeaderDate?.TimeOfDay ?? TimeSpan.Zero;
        var combined = baseDate.Add(timeOfDay);
        fitupHeaderDateValue = combined.ToString("yyyy-MM-dd'T'HH:mm");
    }

    // If in Date view and no filter provided, default filter to header's date
    if(string.Equals(headerView, "Date", StringComparison.OrdinalIgnoreCase) && !parsedDateFilter.HasValue && parsedHeaderDate.HasValue)
    {
        dateFilterSubmitValue = parsedHeaderDate.Value.ToString("yyyy-MM-dd");
        dateFilterDisplayValue = parsedHeaderDate.Value.ToString("dd-MMM-yyyy");
    }

    // Prepare lists for client
    var sortedLocationOptions = (Model?.LocationOptions ?? new List<string>()).ToList();
    var jAddOptionsOrdered = (Model?.JAddOptions ?? new List<string>()).ToList();
    var weldTypeOptionsOrdered = (Model?.WeldTypeOptions ?? new List<string>()).ToList();
    var sortedMaterialDescriptions = (Model?.MaterialDescriptions ?? new List<string>()).ToList();
    var sortedMaterialGrades = (Model?.MaterialGrades ?? new List<string>()).ToList();

    // Filter RFI options to Welding / activity 3.9
    var rfiAll = Model?.RfiOptions ?? new List<PMS.Models.RfiOption>();
    var filteredRfi = rfiAll.Where(r => {
        try {
            var t = r.GetType();
            var sdProp = t.GetProperty("SubDiscipline") ?? t.GetProperty("SUB_DISCIPLINE") ?? t.GetProperty("SUBDISCIPLINE");
            var actProp = t.GetProperty("Activity") ?? t.GetProperty("ACTIVITY");
            var sdVal = sdProp?.GetValue(r)?.ToString() ?? string.Empty;
            var actVal = actProp?.GetValue(r)?.ToString() ?? string.Empty;
            return sdVal.IndexOf("Welding", StringComparison.OrdinalIgnoreCase) >= 0 && (actVal == "3.9" || actVal == "3.90" || actVal == "3.900");
        } catch { return false; }
    }).ToList();
    var rfiToUse = filteredRfi.Any() ? filteredRfi : rfiAll;

    // Ensure header-friendly display values: prefer 'WS | ' or 'FW | '.
    // Preserve existing explicit 'WS | ' or 'FW | ' prefixes when present; if 'TH | ' present, strip and map to 'FW | '.
    var rfiForHeader = rfiToUse.Select(rr => {
        var raw = string.IsNullOrWhiteSpace(rr.Display) ? (rr.Id.ToString() ?? string.Empty) : rr.Display;
        var disp = raw.Trim();
        string? explicitPrefix = null;
        // Detect explicit prefixes (case-insensitive)
        if(disp.StartsWith("WS | ", StringComparison.OrdinalIgnoreCase)) { explicitPrefix = "WS | "; disp = disp.Substring(5).Trim(); }
        else if(disp.StartsWith("FW | ", StringComparison.OrdinalIgnoreCase)) { explicitPrefix = "FW | "; disp = disp.Substring(5).Trim(); }
        else if(disp.StartsWith("TH | ", StringComparison.OrdinalIgnoreCase)) { /* strip TH, map later */ disp = disp.Substring(5).Trim(); }

        // determine location from RFI properties; prefer explicit prefix if present
        string? locVal = null;
        try{
            var t = rr.GetType();
            var locProp = t.GetProperty("RfiLocation") ?? t.GetProperty("RFI_LOCATION") ?? t.GetProperty("RFI_LOCATION_NAME") ?? t.GetProperty("Location") ?? t.GetProperty("RFI_LOC");
            locVal = locProp?.GetValue(rr)?.ToString();
        } catch { }

        string prefix;
        if(!string.IsNullOrWhiteSpace(explicitPrefix)){
            prefix = explicitPrefix; // respect explicit header prefix already present
        }
        else if(!string.IsNullOrWhiteSpace(locVal) && locVal.IndexOf("Workshop", StringComparison.OrdinalIgnoreCase) >= 0){
            prefix = "WS | ";
        } else {
            prefix = "FW | ";
        }

        return new { Id = rr.Id, Display = prefix + disp };
    }).ToList();

    // If no explicit SelectedRfiId provided, default to the most recent RFI (first in list, ordered by Date/Time desc)
    object? initialSelectedRfi = Model?.SelectedRfiId;
    try
    {
        if((initialSelectedRfi == null || string.IsNullOrWhiteSpace(initialSelectedRfi.ToString())) && rfiForHeader.Any())
        {
            initialSelectedRfi = rfiForHeader.First().Id;
        }
    }
    catch { }

    var hasThWeld = weldTypeOptionsOrdered.Any(wt => !string.IsNullOrWhiteSpace(wt) && wt.IndexOf("TH", StringComparison.OrdinalIgnoreCase) >= 0);
    if(hasThWeld && !sortedLocationOptions.Any(x => string.Equals(x, "Threaded", StringComparison.OrdinalIgnoreCase))) { sortedLocationOptions.Add("Threaded"); }

    // Build default header Welding Report value(s) from DWR_tbl.POST_VISUAL_INSPECTION_QR_NO present in loaded rows
    // Use controller-provided DWR QR values (controller queries DWR_tbl.POST_VISUAL_INSPECTION_QR_NO)
    string dwrQrShop = Model?.FitupReportShop ?? string.Empty;
    string dwrQrField = Model?.FitupReportField ?? string.Empty;
    string dwrQrThreaded = Model?.FitupReportThreaded ?? string.Empty;
    string dwrQrHeaderSingle = Model?.FitupReportHeader ?? string.Empty;

    // Compose combined for All location
    var dwrQrCombined = string.Join(" / ", new[]{ dwrQrShop ?? string.Empty, dwrQrField ?? string.Empty, dwrQrThreaded ?? string.Empty }.Where(x => !string.IsNullOrWhiteSpace(x)));
    var isAllLocation = string.Equals(Model?.SelectedLocation, "All", StringComparison.OrdinalIgnoreCase);

    // Compute header input defaults for rendering: prefer DWR POST_VISUAL_INSPECTION_QR_NO, fall back to Model values
    var headerCombinedValue = !string.IsNullOrWhiteSpace(dwrQrCombined)
        ? dwrQrCombined
        : string.Join(" / ", new[]{ Model?.FitupReportShop ?? string.Empty, Model?.FitupReportField ?? string.Empty, Model?.FitupReportThreaded ?? string.Empty }.Where(x => !string.IsNullOrWhiteSpace(x)));

    var selLocForHeader = (Model?.SelectedLocation ?? string.Empty).Trim();
    var headerSingleValue = string.Empty;
    if(string.Equals(selLocForHeader, "Shop", StringComparison.OrdinalIgnoreCase))
    {
        headerSingleValue = !string.IsNullOrWhiteSpace(dwrQrShop) ? dwrQrShop : (Model?.FitupReportShop ?? string.Empty);
    }
    else if(string.Equals(selLocForHeader, "Field", StringComparison.OrdinalIgnoreCase))
    {
        headerSingleValue = !string.IsNullOrWhiteSpace(dwrQrField) ? dwrQrField : (Model?.FitupReportField ?? string.Empty);
    }
    else if(string.Equals(selLocForHeader, "Threaded", StringComparison.OrdinalIgnoreCase))
    {
        headerSingleValue = !string.IsNullOrWhiteSpace(dwrQrThreaded) ? dwrQrThreaded : (Model?.FitupReportThreaded ?? string.Empty);
    }
    // Global fallback
    if(string.IsNullOrWhiteSpace(headerSingleValue))
    {
        headerSingleValue = !string.IsNullOrWhiteSpace(dwrQrHeaderSingle) ? dwrQrHeaderSingle : (Model?.FitupReportHeader ?? string.Empty);
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <title>PMS - Daily Welding</title>
    <link rel="icon" type="image/png" href="~/img/title_logo.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="~/css/DashboardStyle.css" />
    <link rel="stylesheet" href="~/css/DailyWelding.css" />
    <style>
        /* Critical: Force light theme on header dropdowns immediately (prevents black background flash) */
        :root { color-scheme: light !important; }
        #dailywelding-root .fitup-header,
        .fitup-header {
            color-scheme: light !important;
        }
        #dailywelding-root .fitup-header select,
        #dailywelding-root .fitup-header select option,
        .fitup-header select,
        .fitup-header select option {
            background: #fff !important;
            color: #176d8a !important;
            -webkit-appearance: auto;
            appearance: auto;
        }
        #dailywelding-root .fitup-header select option:checked,
        #dailywelding-root .fitup-header select option:hover,
        .fitup-header select option:checked,
        .fitup-header select option:hover {
            background: #e6f6fa !important;
        }
        
        /* Loading indicator for header/title logo used when 'Load' is pressed */
        .title-logo-loading { position: relative; opacity: 0.6; }
        .title-logo-loading::after {
            content: '';
            position: absolute;
            width: 18px; height: 18px;
            /* subtle ring using the Daily Welding accent color */
            border: 2px solid rgba(23,109,138,0.15); /* #176d8a at low opacity */
            border-top-color: #176d8a; /* match "Daily Welding" title color */
            border-radius: 50%;
            animation: pms-logo-spin 0.8s linear infinite;
            right: -22px;
            top: 50%;
            transform: translateY(-50%);
            background: transparent;
            pointer-events: none;
        }
        /* keyframes moved to ~/wwwroot/css/DailyWelding.css to avoid Razor/CSS analyzer warnings */
    </style>
</head>
<body>
    @await Html.PartialAsync("~/Views/Shared/_DashboardHeader.cshtml")
    <div id="dailywelding-root">
        <!-- Inline header/filter UI (copied from DailyFitup) but labelled for Welding page -->
        <div class="fitup-header">
            <form method="get" asp-action="DailyWelding" asp-controller="Home" id="filterForm">
                @antiForgery
                <input type="hidden" name="doLoad" id="doLoadInput" value="@Context.Request.Query["doLoad"].ToString()" />
                <div class="row">
                    <label for="projectSelect">Project No.</label>
                    <select name="projectId" id="projectSelect" class="header-fixed w350 searchable-select" asp-for="SelectedProjectId" asp-items="@(Model?.Projects != null ? new SelectList(Model.Projects.Select(p => new { Id = p.Id, Display = p.Id + " - " + p.Name }), "Id", "Display", Model.SelectedProjectId) : new SelectList(System.Linq.Enumerable.Empty<object>()))"></select>
                    <label for="headerViewSelect">View</label>
                    <select name="headerView" id="headerViewSelect" class="header-fixed view-select">
                        @{
                            string[] hvOpts = new[]{"DWG","Date","Report"};
                            foreach(var hv in hvOpts){
                                if(string.Equals(hv, headerView, System.StringComparison.OrdinalIgnoreCase)){
                                    <option value="@hv" selected>@hv</option>
                                } else {
                                    <option value="@hv">@hv</option>
                                }
                            }
                        }
                    </select>
                    <label for="locationSelect">Location</label>
                    <select name="location" id="locationSelect">
                        @{
                            // Keep All/Shop/Field choices for header behavior and include 'Threaded' if TH weld type exists
                            var locs = hasThWeld ? new[] {"All","Shop","Field","Threaded"} : new[] {"All","Shop","Field"};
                            foreach(var loc in locs)
                            {
                                if(string.Equals(Model?.SelectedLocation, loc, System.StringComparison.OrdinalIgnoreCase))
                                {
                                    <option value="@loc" selected="selected">@loc</option>
                                } else {
                                    <option value="@loc">@loc</option>
                                }
                            }
                        }
                    </select>
                    @if(headerView=="DWG"){
                        <label for="layoutSelect">Layout</label>
                        <select name="layout" id="layoutSelect" class="header-fixed w130 searchable-select">
                            @foreach (var l in Model?.LayoutOptions ?? new List<string>()){
                                if(string.Equals(l, Model?.SearchLayout, System.StringComparison.OrdinalIgnoreCase)){
                                    <option value="@l" selected>@l</option>
                                } else { <option value="@l">@l</option> }
                            }
                        </select>
                        <label for="sheetSelect">Sheet</label>
                        <select name="sheet" id="sheetSelect" class="header-fixed searchable-select">
                            @foreach (var s in Model?.SheetOptions ?? new List<string>()){
                                if(string.Equals(s, Model?.SearchSheet, System.StringComparison.OrdinalIgnoreCase)){
                                    <option value="@s" selected>@s</option>
                                } else { <option value="@s">@s</option> }
                            }
                        </select>
                        if(!string.IsNullOrWhiteSpace(Model?.SearchLayout) && string.IsNullOrWhiteSpace(Model?.SearchSheet)){
                            <span class="hint">All sheets for layout will be loaded</span>
                        }
                    } else if(headerView=="Date") {
                        <label class="alt-filter-label" for="actualDateFilter">Actual Date</label>
                        <input id="actualDateFilter" type="date" name="actualDateFilter" class="header-fixed w150" value="@dateFilterSubmitValue" />
                    } else if(headerView=="Report") {
                        <label class="alt-filter-label" for="fitupReportFilter">Welding Report</label>
                        <input id="fitupReportFilter" name="fitupReportFilter" class="header-fixed w130" value="@Model?.SearchFitupReport" placeholder="Report No" />
                    }
                </div>

                <div class="row ref-line">
                    <div class="ref-boxes">
                        <div class="ref-box"><span>Line Class: @Model?.LineClass</span></div>
                        <div class="ref-box"><span>Material: @Model?.LineMaterial</span></div>
                        <div class="ref-box"><span>Category: @Model?.LineCategory</span></div>
                        <div class="ref-box"><span>RT Shop: @(Model?.RtShop is double rs ? (rs * 100).ToString("0.##") + "%" : null)</span></div>
                        <div class="ref-box"><span>RT Field: @(Model?.RtField is double rf ? (rf * 100).ToString("0.##") + "%" : null)</span></div>
                        <div class="ref-box"><span>PWHT Y/N: @(Model?.PwhtYN == true ? "Y" : Model?.PwhtYN == false ? "N" : null)</span></div>
                        <div class="ref-box"><span>PWHT >20mm: @(Model?.Pwht20mm is bool p20 ? (p20 ? "Y" : "N") : null)</span></div>
                        <div class="ref-box"><span>REV: @Model?.LsRev</span></div>
                    </div>
                </div>

                <div class="row section-band">
                    <label id="weldingReportLabel" for="@(isAllLocation ? "weldingReportCombinedInput" : "weldingReportHeaderInput")">@(isAllLocation ? "Welding Report (WS/FW/TH)" : "Welding Report")</label>
                    <input id="weldingReportCombinedInput" name="WeldingReportCombined" class="header-fixed w230" title="Workshop / Field / Threaded" value="@headerCombinedValue" style="display:@(isAllLocation ? "" : "none")" @(isAllLocation?null:"disabled") autocomplete="off" />
                    <input id="weldingReportHeaderInput" name="WeldingReportHeader" class="header-fixed w110" value="@headerSingleValue" style="display:@(isAllLocation ? "none" : "")" @(isAllLocation?"disabled":null) autocomplete="off" />
                    <label for="rfiSelect">RFI No.</label>
                    <select name="SelectedRfiId" asp-for="SelectedRfiId" id="rfiSelect" class="header-fixed w580" asp-items="@(new SelectList(rfiForHeader, "Id", "Display", initialSelectedRfi))">
                        <option value="" selected="@(initialSelectedRfi == null || string.IsNullOrWhiteSpace(initialSelectedRfi.ToString()) ? "selected" : null)"></option>
                    </select>
                    <label for="FitupDate">Welding Date</label>
                    <input id="fitupDateInput" type="datetime-local" name="date" class="header-fixed w180" value="@fitupHeaderDateValue" />
                    <label for="ActualDate">Actual Date</label>
                    <input id="actualDateInput" type="datetime-local" name="actualDate" class="header-fixed w180" value="@fitupHeaderDateValue" />
                    <div class="tacker-row">
                        <div class="tacker-item">
                            <label for="tackerRootASelect">Root A</label>
                            <select name="SelectedTackerRootA" asp-for="SelectedTackerRootA" id="tackerRootASelect" class="header-fixed w110 searchable-select tacker-select" asp-items="@(new SelectList(Model?.TackerOptions ?? new System.Collections.Generic.List<PMS.Models.WelderSymbolOption>(), "Symbol", "Symbol", Model?.SelectedTackerRootA))"></select>
                        </div>
                        <div class="tacker-item">
                            <label for="tackerRootBSelect">Root B</label>
                            <select name="SelectedTackerRootB" asp-for="SelectedTackerRootB" id="tackerRootBSelect" class="header-fixed w110 searchable-select tacker-select" asp-items="@(new SelectList(Model?.TackerOptions ?? new System.Collections.Generic.List<PMS.Models.WelderSymbolOption>(), "Symbol", "Symbol", Model?.SelectedTackerRootB))"></select>
                        </div>
                        <div class="tacker-item">
                            <label for="tackerFillASelect">Fill A</label>
                            <select name="SelectedTackerFillA" asp-for="SelectedTackerFillA" id="tackerFillASelect" class="header-fixed w110 searchable-select tacker-select" asp-items="@(new SelectList(Model?.TackerOptions ?? new System.Collections.Generic.List<PMS.Models.WelderSymbolOption>(), "Symbol", "Symbol", Model?.SelectedTackerFillA))"></select>
                        </div>
                        <div class="tacker-item">
                            <label for="tackerFillBSelect">Fill B</label>
                            <select name="SelectedTackerFillB" asp-for="SelectedTackerFillB" id="tackerFillBSelect" class="header-fixed w110 searchable-select tacker-select" asp-items="@(new SelectList(Model?.TackerOptions ?? new System.Collections.Generic.List<PMS.Models.WelderSymbolOption>(), "Symbol", "Symbol", Model?.SelectedTackerFillB))"></select>
                        </div>
                        <div class="tacker-item">
                            <label for="tackerCapASelect">Cap A</label>
                            <select name="SelectedTackerCapA" asp-for="SelectedTackerCapA" id="tackerCapASelect" class="header-fixed w110 searchable-select tacker-select" asp-items="@(new SelectList(Model?.TackerOptions ?? new System.Collections.Generic.List<PMS.Models.WelderSymbolOption>(), "Symbol", "Symbol", Model?.SelectedTackerCapA))"></select>
                        </div>
                        <div class="tacker-item">
                            <label for="tackerCapBSelect">Cap B</label>
                            <select name="SelectedTackerCapB" asp-for="SelectedTackerCapB" id="tackerCapBSelect" class="header-fixed w110 searchable-select tacker-select" asp-items="@(new SelectList(Model?.TackerOptions ?? new System.Collections.Generic.List<PMS.Models.WelderSymbolOption>(), "Symbol", "Symbol", Model?.SelectedTackerCapB))"></select>
                        </div>
                    </div>
                </div>
             </form>
             <div class="weld-filters" id="weldFilters">
                 <strong>Weld Type</strong>
                 @{
                     var dynamicWeldTypes = (weldTypeOptionsOrdered != null && weldTypeOptionsOrdered.Count >0)
                         ? weldTypeOptionsOrdered
                         : new List<string>{"BW","SW","BR","LET","FW","SP","RP","SOF","DM","TH","FJ"};
                     var defaultChecked = new HashSet<string>(
                         ((Model?.DefaultWeldTypes?.Count ?? 0) > 0) ? Model!.DefaultWeldTypes! :
                         (!string.IsNullOrWhiteSpace(Model?.DefaultWeldType) ? new[]{Model!.DefaultWeldType!} :
                         ((Model?.WeldTypeOptions?.Count ?? 0) > 0 ? new[]{Model!.WeldTypeOptions![0]} :
                         new[]{"BW","SW","BR","LET","FW","SP","RP","SOF","DM"}))
                     );
                     foreach(var wt in dynamicWeldTypes){
                         var isChecked = defaultChecked.Contains(wt);
                         if(isChecked){
                             <label title="@wt"><input type="checkbox" class="wt-filter" value="@wt" checked="checked" />@wt</label>
                         } else {
                             <label title="@wt"><input type="checkbox" class="wt-filter" value="@wt" />@wt</label>
                         }
                     }
                 }
                 <div class="wf-actions">
                     <button type="button" id="wfAll">All</button>
                     <button type="button" id="wfNone">None</button>
                     <button type="button" id="wfDefault">Default</button>
                 </div>
             </div>
             <button type="button" id="filterToggle" class="filter-toggle-btn" aria-expanded="true">Hide Filters</button>
         </div>

         <div class="toolbar">
             <div class="tb-left">
                 @if(headerView=="DWG"){
                     <button id="addRowBtn" type="button" class="btn btn-primary">Add Joint</button>
                 }
                 <button id="saveAllBtn" type="button" class="btn btn-primary">Save</button>
                 <button id="completeBtn" type="button" class="btn btn-primary">Daily Welding Completed</button>
                 <button id="confirmBtn" type="button" class="btn btn-primary">Daily Welding Confirmed</button>
                 @if(headerView=="DWG"){
                     <button id="openDwgBtn" type="button" class="btn btn-outline">Open DWG</button>
                 }
                 <button id="downloadDwgBtn" type="button" class="btn btn-outline">Download DWG</button>
                 <span id="statusMsg" style="font-weight:600; margin-left:10px;"></span>
             </div>
             <div class="tb-title">Daily Welding (@headerViewDisplay)</div>
             <div class="tb-right">
                 @if(headerView != "DWG"){
                     <button id="clearRemarksBtn" type="button" class="btn btn-primary">Clear Remarks</button>
                     <button id="confirmAllBtn" type="button" class="btn btn-outline">Confirm All</button>
                     <button id="unconfirmAllBtn" type="button" class="btn btn-outline">Unconfirm All</button>
                 }
                 <button id="loadBtn" type="button" form="filterForm" class="btn btn-primary">Load</button>
             </div>
         </div>

         @* Client-side placeholder for pending reload *@
         @{
             var didLoad = string.Equals(Context.Request.Query["doLoad"], "1", StringComparison.OrdinalIgnoreCase);
             var rowsNull = (Model?.Rows == null);
             var rowsCount = rowsNull ? 0 : (Model?.Rows?.Count ?? 0);
             var layoutMissing = string.IsNullOrWhiteSpace(Model?.SearchLayout);
             var sheetMissing = string.IsNullOrWhiteSpace(Model?.SearchSheet);
             bool showClientNoData;
             if(headerView == "DWG")
             {
                 // Show if not loaded yet OR no rows, and layout/sheet not both specified
                 showClientNoData = (rowsNull || rowsCount == 0 || !didLoad) && (layoutMissing || sheetMissing);
             }
             else // Date or Report views
             {
                 // Show until an explicit load with at least one row
                 showClientNoData = rowsNull || rowsCount == 0 || !didLoad;
             }
         }
         <div id="clientNoData" class="no-data" style="@(showClientNoData ? string.Empty : "display:none;")">
             @if(headerView=="DWG"){ <text>No rows loaded. Enter layout &amp; sheet then Load.</text> } else if(headerView=="Date"){ <text>Select Date view then press Load.</text> } else if(headerView=="Report"){ <text>Select Report view, enter a report filter (optional) then press Load.</text> }
         </div>

         <!-- Container where only the DWR table fragment will be injected -->
         <div id="dwr-table-root"></div>
     </div>
     @await Html.PartialAsync("~/Views/Shared/_DashboardFooter.cshtml")

    <!-- Confirm unconfirmed rows modal (mirrors Daily Fit-up) -->
    <div class="modal" id="confirmUnconfirmedRowsModal" aria-hidden="true">
        <div class="modal-content" role="dialog" aria-modal="true" aria-labelledby="confirmUnconfirmedRowsTitle">
            <div class="modal-header">
                <h2 id="confirmUnconfirmedRowsTitle" class="modal-title">Confirm All</h2>
                <button class="close-modal" type="button" aria-label="Close" onclick="closeConfirmUnconfirmedRowsModal()">&times;</button>
            </div>
            <p id="confirmUnconfirmedRowsMessage" style="color:#176d8a; margin:0 0 16px 0;"></p>
            <div class="modal-actions">
                <button type="button" class="btn btn-outline" onclick="closeConfirmUnconfirmedRowsModal()">Cancel</button>
                <button type="button" class="btn btn-primary" id="confirmUnconfirmedRowsOk">Confirm All</button>
            </div>
        </div>
    </div>

    <script>
        // Load DWG helpers used by shared partial and initialize with controller endpoints (match DailyFitup behavior)
        (function(){
            const openLatestDwgUrl = '@Url.Action("OpenLatestDrawing","Home")';
            const downloadLatestDwgUrl = '@Url.Action("DownloadLatestDrawing","Home")';
            const downloadZipUrl = '@Url.Action("DownloadLatestDrawingsZip","Home")';
            const script = document.createElement('script');
            script.src = '/js/dailyfitup-dwg.js';
            script.onload = function(){ try{ if(window.__dailyfitupDwgInit) window.__dailyfitupDwgInit(openLatestDwgUrl, downloadLatestDwgUrl, downloadZipUrl, '@headerView'); }catch(e){ console.error('dailyfitup-dwg init failed', e);} };
            script.onerror = function(){ console.error('Failed to load dailyfitup-dwg.js'); };
            document.head.appendChild(script);
        })();
        // Force filter form to post to DailyWelding so controller returns DwrForm on Load
        (function(){
            try{
                var filterForm = document.getElementById('filterForm');
                if(filterForm){
                    filterForm.action = '@Url.Action("DailyWelding","Home")';
                    // Use setAttribute to ensure attribute is present for all browsers
                    var targetUrl = '@Url.Action("DailyWelding","Home")';
                    filterForm.setAttribute('action', targetUrl);
                    filterForm.setAttribute('method', 'get');

                    // Ensure doLoad hidden input exists and is set when submitting
                    var doLoadInput = document.getElementById('doLoadInput');
                    if(!doLoadInput){
                        doLoadInput = document.createElement('input');
                        doLoadInput.type = 'hidden';
                        doLoadInput.name = 'doLoad';
                        doLoadInput.id = 'doLoadInput';
                        filterForm.appendChild(doLoadInput);
                    }

                    // Persist Actual Date filter header value
                    var actualDateFilterInput = document.getElementById('actualDateFilter');
                    function actualDateStorageKey(){
                        try{
                            var pid = document.getElementById('projectSelect')?.value || '0';
                            var hvVal = document.getElementById('headerViewSelect')?.value || '@headerView';
                            return 'PMS:DailyWelding:ActualDateFilter:' + pid + ':' + hvVal;
                        }catch{ return 'PMS:DailyWelding:ActualDateFilter'; }
                    }
                    function restoreActualDateFilter(){
                        if(!actualDateFilterInput) return;
                        try{
                            var stored = localStorage.getItem(actualDateStorageKey());
                            if(stored && !actualDateFilterInput.value){
                                actualDateFilterInput.value = stored;
                            }
                        }catch{}
                    }
                    function saveActualDateFilter(){
                        if(!actualDateFilterInput) return;
                        try{ localStorage.setItem(actualDateStorageKey(), actualDateFilterInput.value || ''); }catch{}
                    }
                    restoreActualDateFilter();
                    if(actualDateFilterInput){ actualDateFilterInput.addEventListener('change', function(){ saveActualDateFilter(); }); }

                    // Container to inject the table fragment
                    var dwrRoot = document.getElementById('dwr-table-root');

                    // Preserve initial header fitup date so pending message can restore it
                    if(typeof window.__initialHeaderFitupDate === 'undefined'){
                        var hdr = document.getElementById('fitupDateInput');
                        if(hdr) window.__initialHeaderFitupDate = hdr.value || '';
                    }
                    // Preserve initial header actual date so pending message can restore it
                    if(typeof window.__initialHeaderActualDate === 'undefined'){
                        var aHdr = document.getElementById('actualDateInput');
                        if(aHdr) window.__initialHeaderActualDate = aHdr.value || '';
                    }

                    // Helper to show pending/no-data placeholder (mirror DailyFitup behavior)
                    function showPendingNoData(resetDate){
                        try{
                            // Hide fragment content
                            if(dwrRoot){ dwrRoot.style.display = 'none'; }
                            // Hide any fragment scroll area if present
                            var fragScroll = document.getElementById('scrollSync');
                            if(fragScroll) fragScroll.style.display = 'none';
                            var bottom = document.getElementById('bottomScroll'); if(bottom) bottom.style.display = 'none';
                            var status = document.getElementById('statusMsg'); if(status) status.textContent = '';
                            // Show the shared client no-data placeholder from DailyFitup
                            var nd = document.getElementById('clientNoData'); if(nd){ nd.style.display = 'block'; }
                            if(resetDate){ var fitHdr=document.getElementById('fitupDateInput'); if(fitHdr && typeof window.__initialHeaderFitupDate !== 'undefined'){ fitHdr.value = window.__initialHeaderFitupDate; try{ fitHdr.dispatchEvent(new Event('change',{bubbles:true})); }catch{} } }
                            if(resetDate){ var actHdr=document.getElementById('actualDateInput'); if(actHdr && typeof window.__initialHeaderActualDate !== 'undefined'){ actHdr.value = window.__initialHeaderActualDate; try{ actHdr.dispatchEvent(new Event('change',{bubbles:true})); }catch{} } }
                        }catch(e){ console.debug('showPendingNoData', e); }
                    }

                    // Helper to execute scripts inside fragment
                    async function executeFragmentScripts(fragmentEl){
                        try{
                            var scripts = Array.from(fragmentEl.querySelectorAll('script'));
                            for(var i=0;i<scripts.length;i++){
                                var old = scripts[i];
                                await new Promise(function(resolve){
                                   try{
                                       var s = document.createElement('script');
                                       if(old.attributes){
                                           for(var j=0;j<old.attributes.length;j++){
                                               var attr = old.attributes[j];
                                               s.setAttribute(attr.name, attr.value);
                                           }
                                       }
                                       var src = s.getAttribute('src');
                                       if(src){
                                           s.async = false;
                                           var done = function(){
                                               try{ if(s.parentNode){ s.parentNode.removeChild(s); } }catch{};
                                               resolve();
                                           };
                                           s.onload = done;
                                           s.onerror = done;
                                           document.body.appendChild(s);
                                       } else {
                                           var txt = old.textContent || old.innerText || '';
                                           if(txt) s.appendChild(document.createTextNode(txt));
                                           document.body.appendChild(s);
                                           document.body.removeChild(s);
                                           resolve();
                                       }
                                   }catch(err){ console.warn('exec frag script', err); resolve(); }
                               });
                            }
                        }catch(e){ console.warn('exec frag script', e); }
                    }

                    // Initialize bottom scroll and frozen columns for injected fragment
                    function initFragmentLayout(root){
                        try{
                            if(!root) return;
                            // Find elements inside the injected fragment root
                            var table = root.querySelector('#fitupTable');
                            var tableWrapper = root.querySelector('#tableWrapper');
                            var bottom = root.querySelector('#bottomScroll');
                            var bottomInner = root.querySelector('#bottomScrollInner');
                            if(table && bottomInner){
                                bottomInner.style.width = table.scrollWidth + 'px';
                            }
                            if(bottom && tableWrapper && !bottom.dataset.bound){
                                // sync scroll
                                bottom.addEventListener('scroll', function(){ tableWrapper.scrollLeft = bottom.scrollLeft; });
                                tableWrapper.addEventListener('scroll', function(){ bottom.scrollLeft = tableWrapper.scrollLeft; });
                                bottom.dataset.bound = '1';
                            }
                            // Compute frozen lefts for sticky columns inside fragment
                            var thead = table ? table.querySelector('thead tr') : null;
                            if(thead){
                                var frozenCells = Array.from(thead.querySelectorAll('[data-frozen="1"], .frozen-col'));
                                var left = 0;
                                frozenCells.forEach(function(cell){
                                    var w = cell.getBoundingClientRect().width;
                                    var cls = Array.from(cell.classList).find(function(c){ return c.indexOf('col-')===0; });
                                    if(cls){
                                        table.querySelectorAll('th.'+cls+', td.'+cls).forEach(function(c){ c.style.position='sticky'; c.style.left = left + 'px'; });
                                    }
                                    left += w;
                                });
                            }
                            // Make WPS selects searchable like DailyFitup
                            try {
                                var wpsSelects = Array.from(root.querySelectorAll('select.wps-select'));
                                if(wpsSelects && wpsSelects.length){
                                    wpsSelects.forEach(function(sel){ if(window.__makeSearchableSelect) { window.__makeSearchableSelect(sel); } });
                                }
                            } catch(e) { }
                        }catch(e){ console.debug('initFragmentLayout', e); }
                    }

                    // Fetch and inject fragment by form data (GET)
                    async function fetchAndInjectFragment(){
                        // Preserve current Fitup (Welding) and Actual Date so Load does not reset them
                        var preLoadFitup = (document.getElementById('fitupDateInput') || { value: '' }).value || '';
                        var preLoadActual = (document.getElementById('actualDateInput') || { value: '' }).value || '';
                        var preLoadActualFilter = actualDateFilterInput ? (actualDateFilterInput.value || '') : '';

                        // Visual feedback: indicate loading on title/logo
                        function findTitleLogoEl(){
                            return document.getElementById('titleLogo') || document.querySelector('.title-logo') || document.getElementById('logo') || document.querySelector('.logo') || document.querySelector('.tb-title');
                        }
                        function showLogoLoading(){ try{ var el=findTitleLogoEl(); if(el) el.classList.add('title-logo-loading'); }catch(e){} }
                        function hideLogoLoading(){ try{ var el=findTitleLogoEl(); if(el) el.classList.remove('title-logo-loading'); }catch(e){} }

                        var loadBtn = document.getElementById('loadBtn');
                        try{
                            // Disable load button while loading (no cursor change)
                            if(loadBtn) loadBtn.disabled = true;
                            // show logo loading indicator
                            showLogoLoading();

                            // Ensure doLoad flag present
                            doLoadInput.value = '1';
                            // Build query from form
                            var params = new URLSearchParams(new FormData(filterForm));
                            var url = targetUrl + '?' + params.toString();
                            const res = await fetch(url, { credentials: 'same-origin', headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                            if(!res.ok){ // fallback to full navigation
                                if(loadBtn) loadBtn.disabled = false;
                                window.location.href = url; return;
                            }
                            const text = await res.text();
                            var parser = new DOMParser();
                            var doc = parser.parseFromString(text, 'text/html');
                            var frag = doc.getElementById('dwr-table-fragment');
                            if(!frag){ // fallback: if server returned full DWR page without fragment, do full navigation
                                if(loadBtn) loadBtn.disabled = false;
                                window.location.href = url; return;
                            }
                           // Copy header inputs from server response into current page so header reflects server-calculated DWR QR values
                          try{
                               var serverCombined = doc.getElementById('weldingReportCombinedInput');
                               var serverHeader = doc.getElementById('weldingReportHeaderInput');
                               var localCombined = document.getElementById('weldingReportCombinedInput');
                               var localHeader = document.getElementById('weldingReportHeaderInput');
                               var locBeforeLoad = document.getElementById('locationSelect');
                               var preserveCombinedHeader = !!(locBeforeLoad && (locBeforeLoad.value || '').toLowerCase() === 'all');
                               var combinedValueBeforeLoad = localCombined ? (localCombined.value || '') : '';

                               function copyInputAttributes(serverEl, localEl, options){
                                   try{
                                       if(!serverEl || !localEl) return;
                                       const opts = options || {};
                                       const localVal = localEl.value || '';
                                       const shouldCopyValue = !opts.preserveExistingValue || !localVal;
                                       if(shouldCopyValue){
                                           localEl.value = serverEl.value || '';
                                       }
                                       // preserve explicit style.display from server fragment when present
                                       try{ localEl.style.display = serverEl.style.display || ''; }catch(e){}
                                       localEl.disabled = !!serverEl.disabled;
                                       // copy common attributes that affect header logic/appearance
                                       if(serverEl.hasAttribute && serverEl.hasAttribute('name')) localEl.setAttribute('name', serverEl.getAttribute('name'));
                                       if(serverEl.hasAttribute && serverEl.hasAttribute('title')) localEl.setAttribute('title', serverEl.getAttribute('title'));
                                       if(serverEl.hasAttribute && serverEl.hasAttribute('placeholder')) localEl.setAttribute('placeholder', serverEl.getAttribute('placeholder'));
                                       // copy class list (preserve any existing classes if server doesn't provide)
                                       try{ if(serverEl.className) localEl.className = serverEl.className; }catch(e){}

                                   }catch(e){ /* ignore copy errors */ }
                               }

                               copyInputAttributes(serverCombined, localCombined, { preserveExistingValue: true });
                               copyInputAttributes(serverHeader, localHeader, { preserveExistingValue: true });

                                 // Restore pre-load Fitup and Actual Date if they had values
                                 try {
                                     var localFitup = document.getElementById('fitupDateInput');
                                     if (localFitup && preLoadFitup) {
                                         localFitup.value = preLoadFitup;
                                     }
                                     var localActual = document.getElementById('actualDateInput');
                                     if (localActual && preLoadActual) {
                                         localActual.value = preLoadActual;
                                     }
                                 } catch(e){}

                               // Update label 'for' attribute and text content if present
                               try{
                                    var serverLabel = doc.getElementById('weldingReportLabel');
                                    var localLabel = document.getElementById('weldingReportLabel');
                                    if(serverLabel && localLabel){ localLabel.setAttribute('for', serverLabel.getAttribute('for') || localLabel.getAttribute('for')); localLabel.textContent = serverLabel.textContent || localLabel.textContent; }
                               }catch(e){}

                               // Copy reference header boxes (Line Class, Material, Category, RT, PWHT, REV) so header updates on AJAX Load
                               try{
                                   var serverRef = doc.querySelector('.ref-line .ref-boxes');
                                   var localRef = document.querySelector('.ref-line .ref-boxes');
                                   if(serverRef && localRef){ localRef.innerHTML = serverRef.innerHTML; }
                               }catch(e){}

                               // Re-run location change handler so the client-side logic (which toggles Welding Report inputs, updates RFI options and picks sensible defaults)
                               // runs with the server-provided values. This keeps defaults consistent before and after fragment load.
                               try{
                                     var locSel = document.getElementById('locationSelect');
                                     if(locSel){ locSel.dispatchEvent(new Event('change',{bubbles:true})); }
                                 }catch(e){}

                                // Re-apply Fitup and Actual Date after any location-driven updates
                                try {
                                    var localFitup2 = document.getElementById('fitupDateInput');
                                    if (localFitup2 && preLoadFitup) {
                                        localFitup2.value = preLoadFitup;
                                    }
                                    var localActual2 = document.getElementById('actualDateInput');
                                    if (localActual2 && preLoadActual) {
                                        localActual2.value = preLoadActual;
                                    }
                                } catch(e){}

                                // Restore Actual Date filter header value (persist across load/email)
                                try {
                                    if (actualDateFilterInput) {
                                        if (preLoadActualFilter) {
                                            actualDateFilterInput.value = preLoadActualFilter;
                                        } else {
                                            restoreActualDateFilter();
                                        }
                                        saveActualDateFilter();
                                    }
                                } catch(e){}
                           }catch(e){ console.debug('copy header inputs failed', e); }

                           // Inject fragment content
                           if(dwrRoot){
                               // Hide shared no-data placeholder
                               var nd = document.getElementById('clientNoData'); if(nd){ nd.style.display = 'none'; }

                               dwrRoot.innerHTML = '';
                               // clone children into dwrRoot
                               var nodes = Array.from(frag.childNodes);
                               nodes.forEach(function(n){ dwrRoot.appendChild(document.importNode(n,true)); });
                               // ensure fragment visible
                               dwrRoot.style.display = '';
                               // execute any scripts inside the fragment (re-run inline and external)
                               await executeFragmentScripts(dwrRoot);
                               // Run additional initializers for layout/scrolling and WPS select enhancement
                               initFragmentLayout(dwrRoot);
                               // Initialize per-row RFI selects using centralized initializer (idempotent)
                               try{
                                   if(window.dailyWelding && typeof window.dailyWelding.initTableFragment === 'function'){
                                       await window.dailyWelding.initTableFragment(dwrRoot);
                                   }
                               }catch(e){ console.debug('initTableFragment failed', e); }
                               // Re-apply Weld Type filter after fragment injection so rows reflect current filter
                               try { if(window.applyWeldTypeFilter) { window.applyWeldTypeFilter(); } } catch(e) { console.debug('applyWeldTypeFilter after inject failed', e); }
                               // Optionally scroll to injected table
                               try{ dwrRoot.scrollIntoView({behavior:'smooth'}); }catch(e){}

                               // Focus on the first empty fitup date cell in the new rows (common UX polish for Fit/Up)
                               try{
                                   var firstEmptyDateCell = Array.from(dwrRoot.querySelectorAll('input[name="date"],input[name="ActualDate"]')).find(input => !input.value);
                                   if(firstEmptyDateCell){
                                       firstEmptyDateCell.focus({preventScroll:true});
                                       var row = firstEmptyDateCell.closest('tr');
                                       if(row){
                                           // Optionally, ensure the row is visible in the viewport
                                           var rect = row.getBoundingClientRect();
                                           if(rect.top < 0 || rect.bottom > window.innerHeight){
                                               row.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                                           }
                                       }
                                   }
                               }catch(e){}
                           }
                        }catch(e){ console.error('Load DWR fragment failed', e); try{ filterForm.submit(); }catch{} }
                        finally{
                            // enable load button and clear logo loading indicator
                            if(loadBtn) loadBtn.disabled = false;
                            try{ hideLogoLoading(); }catch(e){}
                        }
                    }
                    // Expose AJAX fragment loader so other scripts (auto-submit) can call it
                    try{ window.__dwrFetchAndInject = fetchAndInjectFragment; }catch(e){}

                    // Intercept only the explicit Load button click to fetch fragment via AJAX.
                    var loadBtn = document.getElementById('loadBtn');
                    if(loadBtn){
                        loadBtn.addEventListener('click', function(e){
                            try{
                                e.preventDefault();
                                // ensure doLoad flag present for server-side if needed
                                var d = document.getElementById('doLoadInput'); if(d) d.value = '1';
                                // update action to DailyWelding explicitly
                                try{ filterForm.setAttribute('action', targetUrl); }catch(e) {}
                                fetchAndInjectFragment();
                            }catch(err){ console.debug('Load click override failed', err); try{ filterForm.submit(); }catch{} }
                        });
                    }

                    // Mirror DailyFitup behavior: show pending/no-data when header filters change
                    (function(){
                        try{
                            // Capture elements
                            var layout = document.getElementById('layoutSelect') || document.getElementById('layoutInput');
                            var sheet = document.getElementById('sheetSelect') || document.getElementById('sheetInput');
                            var dateFilter = document.querySelector('input[name="actualDateFilter"][type="date"]');
                            var reportFilter = document.querySelector('input[name="fitupReportFilter"]');
                            if(layout) layout.addEventListener('change', function(){ showPendingNoData(true); });
                            if(sheet) sheet.addEventListener('change', function(){ showPendingNoData(true); });
                            if(dateFilter) dateFilter.addEventListener('change', function(){ showPendingNoData(true); });
                            if(reportFilter) reportFilter.addEventListener('input', function(){ showPendingNoData(true); });
                            // Also mark pending on Location change but do NOT auto-load
                            var locSel = document.getElementById('locationSelect');
                            if(locSel) locSel.addEventListener('change', function(){ showPendingNoData(true); var d=document.getElementById('doLoadInput'); if(d) d.value=''; });
                        }catch(e){ console.debug('attach pending listeners failed', e); }
                    })();

                }
            }catch(e){ console.debug('DailyWelding: failed to adjust filter form action', e); }
        })();
        // Rename UI from Fit-up to Welding on this page and after dynamic updates
        (function(){
            function rename(){ try{
                var title = document.querySelector('.tb-title'); if(title && title.textContent){ title.textContent = title.textContent.replace(/Fit-?up/gi, 'Welding'); }
                var completeBtn = document.getElementById('completeBtn'); if(completeBtn && completeBtn.textContent){ completeBtn.textContent = completeBtn.textContent.replace(/Fit-?up/gi, 'Welding'); }
                var confirmBtn = document.getElementById('confirmBtn'); if(confirmBtn && confirmBtn.textContent){ confirmBtn.textContent = confirmBtn.textContent.replace(/Fit-?up/gi, 'Welding'); }
                document.querySelectorAll('button, label, span').forEach(function(el){ if(el && el.textContent && /Fit-?up/i.test(el.textContent)){ el.textContent = el.textContent.replace(/Fit-?up/gi, 'Welding'); } });
            }catch(e){}}
            if(document.readyState==='loading') document.addEventListener('DOMContentLoaded', rename); else rename();
            // Patch uc.setButtonsText to keep labels
            (function(){ try{ if(window.uc && typeof window.uc.setButtonsText==='function' && !window.uc.__dwPatched){ var orig = window.uc.setButtonsText.bind(window.uc); window.uc.setButtonsText = function(){ try{ orig.apply(window.uc, arguments); }catch(e){} try{ rename(); }catch(e){} }; window.uc.__dwPatched = true; } }catch(e){} })();
        })();
    </script>
    <script>
        window.dailyWeldingUcConfig = {
            headerView: '@headerView',
            endpoints: {
                exists: '@Url.Action("GetDailyWeldingExists", "Home")',
                complete: '@Url.Action("CompleteDailyWelding", "Home")',
                confirm: '@Url.Action("CompleteDailyWelding", "Home")',
                mail: '@Url.Action("SendDailyWeldingEmail", "Home")'
            }
        };
    </script>
     <script src="~/js/dailywelding.js"></script>
     <script>
          // Weld Type filter buttons (All, None, Default) - same behavior as DailyFitup
    (function(){
        const allBtn = document.getElementById('wfAll');
        const noneBtn = document.getElementById('wfNone');
        const defaultBtn = document.getElementById('wfDefault');
        const checkboxes = () => Array.from(document.querySelectorAll('#weldFilters input.wt-filter'));
        // Default weld types from server model (serialized at render time)
        const defaultWeldTypes = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
           ((Model?.DefaultWeldTypes?.Count ?? 0) > 0) ? (object)Model!.DefaultWeldTypes! :
           (!string.IsNullOrWhiteSpace(Model?.DefaultWeldType) ? (object)new[] { Model!.DefaultWeldType! } :
           (((Model?.WeldTypeOptions?.Count ?? 0) > 0) ? (object)new[] { Model!.WeldTypeOptions![0] } :
           (object)new[] { "BW","SW","BR","LET","FW","SP","RP","SOF","DM" }))
        ))
        function storageKey(){
            const pid = document.getElementById('projectSelect')?.value || '0';
            const view = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(headerView ?? "DWG"))
            // Use DailyWelding namespace in key to avoid overlap with Fit-up page
            return `PMS:DailyWelding:WeldType:${pid}:${view}`;
        }
        function selectedValues(){
            return Array.from(document.querySelectorAll('#weldFilters input.wt-filter:checked')).map(cb => (cb.value||'').trim());
        }
        function setSelections(values){
            const set = new Set((values||[]).map(v => String(v)));
            const all = document.querySelectorAll('#weldFilters input.wt-filter');
            let any=false;
            all.forEach(cb=>{ const on = set.has(cb.value); cb.checked = on; any = any || on; });
            return all;
        }
        function save(){ try { localStorage.setItem(storageKey(), JSON.stringify(selectedValues())); } catch {} }
        function restore(){
            try {
                const raw = localStorage.getItem(storageKey());
                if(!raw) return false;
                const vals = JSON.parse(raw);
                if(!Array.isArray(vals)) return false;
                return setSelections(vals);
            } catch { return false; }
        }
        function apply(){
            const selected = Array.from(document.querySelectorAll('#weldFilters input.wt-filter:checked')).map(cb=> (cb.value||'').toUpperCase().trim());
            const rows = document.querySelectorAll('#fitupTable tbody tr');
            rows.forEach(r=>{
                // prefer explicit select for WeldType, but fall back to reading text from the cell when the row renders plain text
                let wt = '';
                try{
                    const wtSel = r.querySelector('select[data-name="WeldType"]');
                    if(wtSel && wtSel.value) wt = wtSel.value.toUpperCase().trim();
                    else {
                        const wtCell = r.querySelector('.col-wtype');
                        if(wtCell) wt = (wtCell.textContent || '').toUpperCase().trim();
                    }
                }catch(e){ wt = ''; }
                r.style.display = (selected.length===0 || selected.includes(wt)) ? '' : 'none';
            });
        }
        window.applyWeldTypeFilter = apply;
        window.saveWeldTypeFilterSelection = save;
        // Immediate restore BEFORE content flashes default checked
        const hadSavedEarly = restore();
        if(hadSavedEarly){ apply(); }
        document.addEventListener('DOMContentLoaded', ()=>{ if(!hadSavedEarly){ restore(); } apply(); });
        document.addEventListener('change', e=>{ if(e.target && e.target.matches('#weldFilters input.wt-filter')){ save(); apply(); } });
        allBtn?.addEventListener('click', ()=>{ checkboxes().forEach(c=> c.checked=true); save(); apply(); });
        noneBtn?.addEventListener('click', ()=>{ checkboxes().forEach(c=> c.checked=false); save(); apply(); });
        defaultBtn?.addEventListener('click', ()=>{ setSelections(defaultWeldTypes); save(); apply(); });
    })();

    // Auto submit + header select enhancements and layout->sheet loading (from DailyFitup)
    (function(){
        const form=document.getElementById('filterForm');
        const hv=document.getElementById('headerViewSelect');
        const proj=document.querySelector('select[name="projectId"]');
        const loc=document.getElementById('locationSelect');
        const rfiSel=document.getElementById('rfiSelect');
        const repCombined=document.getElementById('weldingReportCombinedInput');
        const repSingle=document.getElementById('weldingReportHeaderInput');
        const reportLabel=document.getElementById('weldingReportLabel');
        const qrDefaults = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new {
            shop = dwrQrShop,
            field = dwrQrField,
            threaded = dwrQrThreaded,
            combined = dwrQrCombined,
            single = dwrQrHeaderSingle,
            modelShop = Model?.FitupReportShop ?? string.Empty,
            modelField = Model?.FitupReportField ?? string.Empty,
            modelThreaded = Model?.FitupReportThreaded ?? string.Empty,
            modelCombined = string.IsNullOrWhiteSpace(string.Join(" / ", new[]{Model?.FitupReportShop??string.Empty, Model?.FitupReportField??string.Empty, Model?.FitupReportThreaded??string.Empty}.Where(x=>!string.IsNullOrWhiteSpace(x)))) ? string.Empty : string.Join(" / ", new[]{Model?.FitupReportShop??string.Empty, Model?.FitupReportField??string.Empty, Model?.FitupReportThreaded??string.Empty}.Where(x=>!string.IsNullOrWhiteSpace(x))),
            modelHeader = Model?.FitupReportHeader ?? string.Empty
        }))
        // Cache original RFI options so we can rebuild filtered lists client-side
        const originalRfiOptions = rfiSel ? Array.from(rfiSel.options).map(o=>({ value: o.value, text: o.text })) : null;
        function rebuildRfiOptions(prefixes){
            if(!rfiSel || !originalRfiOptions) return;
            // when prefixes is falsy, restore full list
            if(!prefixes){
                rfiSel.innerHTML = '';
                originalRfiOptions.forEach(item => {
                    const opt = document.createElement('option'); opt.value = item.value; opt.text = item.text; rfiSel.appendChild(opt);
                });
                return;
            }
            // normalize to array
            const prefs = Array.isArray(prefixes) ? prefixes : [prefixes];
            // gather matches in order of prefs
            let ordered = [];
            prefs.forEach(p => {
                originalRfiOptions.forEach(o => {
                    if((o.text||'').startsWith(p) && !ordered.some(x=> x.value===o.value)) ordered.push(o);
                });
            });
            // if none matched, fall back to any options that start with any of the prefs (case-insensitive) or full list
            if(ordered.length===0){
                // try case-insensitive matching
                prefs.forEach(p => {
                    const lower = p.toLowerCase();
                    originalRfiOptions.forEach(o => {
                        if((o.text||'').toLowerCase().startsWith(lower) && !ordered.some(x=> x.value===o.value)) ordered.push(o);
                    });
                });
            }
            if(ordered.length===0){
                // fallback to original full list
                originalRfiOptions.forEach(o=>{ if(!ordered.some(x=> x.value===o.value)) ordered.push(o); });
            }

            // Try to extract dates from option text and sort by most recent first
            function extractDateFromText(txt){
                if(!txt) return null;
                // Try ISO yyyy-MM-dd
                const isoMatch = txt.match(/(\d{4}-\d{2}-\d{2})/);
                if(isoMatch){ const d = new Date(isoMatch[1]); if(!isNaN(d)) return d; }
                // Try dd-MMM-yyyy (e.g. 02-Feb-2024)
                const dmyMatch = txt.match(/(\b\d{1,2}-[A-Za-z]{3}-\d{4}\b)/);
                if(dmyMatch){ try{ const parts = dmyMatch[1].split('-'); const day = parseInt(parts[0],10); const mon = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'].indexOf(parts[1].substr(0,3)); const year = parseInt(parts[2],10); if(mon>=0){ const dt = new Date(year, mon, day); if(!isNaN(dt)) return dt; } }catch{} }
                // Try dd/MM/yyyy or dd.MM.yyyy
                const slashMatch = txt.match(/(\b\d{1,2}[\/\.]{1}\d{1,2}[\/]\d{4}\b)/);
                if(slashMatch){ try{ const s = slashMatch[1].replace(/\./g,'/'); const parts = s.split('/'); const day = parseInt(parts[0],10); const month = parseInt(parts[1],10)-1; const year = parseInt(parts[2],10); return new Date(year, month, day); }catch(e){} }
                return null;
            }

            // Map to include dates and sort descending when dates are present
            const mapped = ordered.map(o=>({ v:o, d: extractDateFromText(o.text) }));
            // If any date found, sort by date desc placing dated items first
            if(mapped.some(m=> m.d)){ mapped.sort((a,b)=>{ if(a.d && b.d) return b.d - a.d; if(a.d) return -1; if(b.d) return 1; return 0; }); ordered = mapped.map(m=>m.v); }

            // replace select options preserving selection if possible
            const cur = rfiSel.value || '';
            rfiSel.innerHTML = '';
            ordered.forEach(item => {
                const opt = document.createElement('option'); opt.value = item.value; opt.text = item.text; rfiSel.appendChild(opt);
            });
            if(cur){ const found = Array.from(rfiSel.options).some(o=> o.value===cur); if(found) rfiSel.value = cur; }
        }

        function clearLoadFlag(){ var el = document.getElementById('doLoadInput'); if(el) el.value=''; }
        function ensurePlaceholderOption(sel, text){
            if(!sel) return;
            let placeholder = sel.querySelector('option[data-placeholder="1"]');
            if(!placeholder){
                placeholder = document.createElement('option');
                placeholder.value = '';
                placeholder.textContent = text;
                placeholder.setAttribute('data-placeholder','1');
                sel.insertBefore(placeholder, sel.firstChild);
            }
        }
        function resetLayoutAndSheet(){
            const layoutSel = document.getElementById('layoutSelect');
            const sheetSel = document.getElementById('sheetSelect');
            if(layoutSel){
                ensurePlaceholderOption(layoutSel, '-- Select Layout --');
                layoutSel.value = '';
                layoutSel.selectedIndex = 0;
            }
            if(sheetSel){
                ensurePlaceholderOption(sheetSel, '-- Select Sheet --');
                sheetSel.value = '';
                sheetSel.selectedIndex = 0;
                while(sheetSel.options.length > 1){
                    sheetSel.remove(1);
                }
            }
        }
        function autoSubmit(){ if(form){ clearLoadFlag(); try{ form.submit(); }catch(e){ form.dispatchEvent(new Event('submit',{bubbles:true})); } } }
        if(proj) proj.addEventListener('change', function(){ resetLayoutAndSheet(); autoSubmit(); });
        if(hv) hv.addEventListener('change', autoSubmit);

        function toTrimmed(val){
            if(val === null || val === undefined) return '';
            return String(val).trim();
        }
        function pickFirstNonEmpty(values){
            for(let i=0;i<values.length;i++){
                const candidate = toTrimmed(values[i]);
                if(candidate) return candidate;
            }
            return '';
        }
        function buildCombinedFromParts(){
            const live = ['shop','field','threaded'].map(k => toTrimmed(qrDefaults[k])).filter(Boolean);
            if(live.length) return live.join(' / ');
            const model = ['modelShop','modelField','modelThreaded'].map(k => toTrimmed(qrDefaults[k])).filter(Boolean);
            if(model.length) return model.join(' / ');
            return '';
        }
        function normalizeLocation(value){
            const raw = toTrimmed(value).toLowerCase();
            if(raw === 'shop') return 'Shop';
            if(raw === 'field' ) return 'Field';
            if(raw === 'threaded' ) return 'Threaded';
            if(raw === 'all' || !raw) return 'All';
            return raw.charAt(0).toUpperCase() + raw.slice(1);
        }

        const fallbackSingleValue = pickFirstNonEmpty([repSingle ? repSingle.value : '', qrDefaults.single, qrDefaults.modelHeader]);
        let fallbackCombinedValue = pickFirstNonEmpty([repCombined ? repCombined.value : '', qrDefaults.combined, qrDefaults.modelCombined]);
        if(!fallbackCombinedValue){ fallbackCombinedValue = buildCombinedFromParts() || fallbackSingleValue; }

        const headerCache = {};
        let currentLocationKey = normalizeLocation(loc ? loc.value : 'All');
        headerCache.All = repCombined ? repCombined.value || fallbackCombinedValue : fallbackCombinedValue;
        if(repSingle && currentLocationKey !== 'All'){
            headerCache[currentLocationKey] = repSingle.value || fallbackSingleValue;
        }

        const rfiCache = {};
        if(rfiSel){
            rfiCache[currentLocationKey] = rfiSel.value || '';
        }

        function getHeaderDefault(key){
            switch(key){
                case 'Shop': return pickFirstNonEmpty([qrDefaults.shop, qrDefaults.modelShop, fallbackSingleValue]);
                case 'Field': return pickFirstNonEmpty([qrDefaults.field, qrDefaults.modelField, fallbackSingleValue]);
                case 'Threaded': return pickFirstNonEmpty([qrDefaults.threaded, qrDefaults.modelThreaded, fallbackSingleValue]);
                case 'All': default: return pickFirstNonEmpty([fallbackCombinedValue, buildCombinedFromParts(), fallbackSingleValue]);
            }
        }
        function rememberHeaderValue(key){
            if(!key) return;
            if(key === 'All' && repCombined){
                headerCache.All = repCombined.value || '';
            } else if(key !== 'All' && repSingle){
                headerCache[key] = repSingle.value || '';
            }
        }
        function rememberRfiValue(key){
            if(!rfiSel || !key) return;
            rfiCache[key] = rfiSel.value || '';
        }
        function applyRfiForLocation(key){
            if(!rfiSel) return;
            const before = rfiSel.value;
            const prefixMap = { Shop: ['WS | '], Field: ['FW | '], Threaded: ['FW | '] };
            rebuildRfiOptions(prefixMap[key] || null);
            let nextValue;
            if(Object.prototype.hasOwnProperty.call(rfiCache, key)){
                nextValue = rfiCache[key];
            }
            if(nextValue && !Array.from(rfiSel.options).some(o => o.value === nextValue)){
                nextValue = '';
            }
            if(nextValue === undefined || nextValue === ''){
                const firstReal = Array.from(rfiSel.options).find(o => (o.value || '').trim() !== '');
                if(firstReal){
                    nextValue = firstReal.value;
                } else if(rfiSel.options.length){
                    nextValue = rfiSel.options[0].value;
                }
            }
            if(nextValue !== undefined){
                rfiSel.value = nextValue;
                rfiCache[key] = rfiSel.value || '';
            } else {
                rfiSel.value = '';
                rfiCache[key] = '';
            }
            if(rfiSel.value !== before){
                try{ rfiSel.dispatchEvent(new Event('change',{ bubbles:true })); }catch(e){}
            }
        }
        function applyHeaderUi(key){
            const locKey = key || 'All';
            const isAll = locKey === 'All';
            if(reportLabel){
                reportLabel.textContent = isAll ? 'Welding Report (WS/FW/TH)' : 'Welding Report';
                reportLabel.setAttribute('for', isAll ? 'weldingReportCombinedInput' : 'weldingReportHeaderInput');
            }
            if(repCombined){
                repCombined.style.display = isAll ? '' : 'none';
                repCombined.disabled = !isAll;
                if(isAll){
                    const hasCached = Object.prototype.hasOwnProperty.call(headerCache, 'All');
                    const val = hasCached ? headerCache.All : getHeaderDefault('All');
                    headerCache.All = val;
                    repCombined.value = val || '';
                }
            }
            if(repSingle){
                repSingle.style.display = isAll ? 'none' : '';
                repSingle.disabled = isAll;
                if(!isAll){
                    const hasCached = Object.prototype.hasOwnProperty.call(headerCache, locKey);
                    const val = hasCached ? headerCache[locKey] : getHeaderDefault(locKey);
                    headerCache[locKey] = val;
                    repSingle.value = val || '';
                }
            }
            applyRfiForLocation(locKey);
        }

        applyHeaderUi(currentLocationKey);

        if(loc){
            loc.addEventListener('change', function(){
                const nextKey = normalizeLocation(loc.value);
                rememberHeaderValue(currentLocationKey);
                rememberRfiValue(currentLocationKey);
                currentLocationKey = nextKey;
                applyHeaderUi(currentLocationKey);
            });
        }
        if(repCombined){
            repCombined.addEventListener('input', function(){
                headerCache.All = repCombined.value || '';
            });
        }
        if(repSingle){
            repSingle.addEventListener('input', function(){
                if(currentLocationKey !== 'All'){
                    headerCache[currentLocationKey] = repSingle.value || '';
                }
            });
        }
        if(rfiSel){
            rfiSel.addEventListener('change', function(){
                rfiCache[currentLocationKey] = rfiSel.value || '';
            });
        }
     })();
     (function(){
         if('@headerView' !== 'DWG') return;
         const layoutSel=document.getElementById('layoutSelect');
         const sheetSel=document.getElementById('sheetSelect');
         const form=document.getElementById('filterForm');
         async function loadSheets(){
             if(!layoutSel || !sheetSel) return;
             const layout=layoutSel.value.trim();
             const prevSelected = sheetSel.value || '';

             while(sheetSel.options.length > 0) {
                 sheetSel.remove(0);
             }
             if(!layout){ sheetSel.disabled=false; return; }
             const projectId = form.projectId ? form.projectId.value : '';
             if(!projectId){ sheetSel.disabled=false; return; }
             sheetSel.disabled=true;
             try {
                 const url='@Url.Action("GetSheetsForLayout","Home")'+`?projectId=${encodeURIComponent(projectId)}&layout=${encodeURIComponent(layout)}`;
                 const res=await fetch(url,{headers:{'Accept':'application/json'}});
                 if(!res.ok) throw new Error();
                 const data=await res.json();
                 if(Array.isArray(data)){
                     data.forEach(s=>{ const opt=document.createElement('option'); opt.value=s; opt.textContent=s; sheetSel.appendChild(opt); });
                     if(prevSelected && Array.from(sheetSel.options).some(o=> o.value===prevSelected)){
                         sheetSel.value = prevSelected;
                     }
                 }
             } catch { }
             finally { sheetSel.disabled=false; }
         }
         layoutSel?.addEventListener('change', loadSheets);
         if(layoutSel && layoutSel.value && sheetSel && sheetSel.options.length===0){ loadSheets(); }
     })();
 
     (function(){
         function makeSearchableSelect(sel){
             if(!sel || sel.dataset.searchable) return;
             let buffer='';
             let last=0;
             sel.addEventListener('keydown', (e)=>{
                 const now=Date.now();
                 if(now - last >800) buffer='';
                 last=now;
                 if(e.key === 'Backspace'){
                     buffer = buffer.slice(0, -1);
                     e.preventDefault();
                 } else if(e.key && e.key.length===1 && !e.ctrlKey && !e.metaKey && !e.altKey){
                     buffer += e.key.toLowerCase();
                 } else { return; }
                 const opts = Array.from(sel.options);
                 if(opts.length===0) return;
                 const start = sel.selectedIndex >=0 ? sel.selectedIndex : -1;
                 const findIdx = (from)=>{

                     for(let i=from+1;i<opts.length;i++){ if((opts[i].text||'').toLowerCase().includes(buffer)) return i; }
                     for(let i=0;i<=from;i++){ if((opts[i].text||'').toLowerCase().includes(buffer)) return i; }
                     return -1;
                 };
                 const idx = findIdx(start);
                 if(idx>=0){ sel.selectedIndex=idx; sel.dispatchEvent(new Event('change',{bubbles:true})); }
             });
             sel.dataset.searchable='1';
         }
         window.__makeSearchableSelect = makeSearchableSelect;
         ['layoutSelect','sheetSelect','tackerRootASelect','tackerRootBSelect','tackerFillASelect','tackerFillBSelect','tackerCapASelect','tackerCapBSelect','projectSelect'].forEach(id=>{ const el=document.getElementById(id); if(el) makeSearchableSelect(el); });
     })();
 
     // Two-way sync between filter Welding Date and header Welding Date
     (function(){
         try{
             var dateFilter = document.getElementById('fitupDateFilter'); // yyyy-MM-dd (exists only in Date view)
             var fitHdr = document.getElementById('fitupDateInput');
             var display = document.getElementById('fitupDateFilterDisplay');
             var actualHdr = document.getElementById('actualDateInput');  // mirror of fitHdr
             if(!fitHdr) return;
             var syncing = false;
             function ensureTimePart(val){
                 if(!val) return 'T00:00';
                 var parts = String(val).split('T');
                 if(parts.length===2){ return 'T' + (parts[1].length>5 ? parts[1].slice(0,5) : parts[1]); }
                 return 'T00:00';
             }
             function formatDisplayDate(ymd){
                 try{
                     if(!ymd) return '';
                     var p = ymd.split('-'); if(p.length!==3) return ymd;
                     var y=+p[0], m=+p[1], d=+p[2];
                     var dt = new Date(Date.UTC(y, m-1, d));
                     return dt.toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' }).replace(/\s/g,'-');
                 }catch{ return ymd; }
             }
             if(dateFilter){
                 dateFilter.addEventListener('change', function(){
                     if(syncing) return; syncing = true;
                     try{
                         var d = dateFilter.value;
                         if(d){
                             var tp = ensureTimePart(fitHdr.value);
                             fitHdr.value = d + tp;
                             if(actualHdr) actualHdr.value = fitHdr.value;
                             if(display){ display.textContent = formatDisplayDate(d); }
                         }
                     }finally{ syncing = false; }
                 });
             }
             fitHdr.addEventListener('change', function(){
                 if(syncing) return; syncing = true;
                 try{
                     if(!dateFilter) return;
                     var v = fitHdr.value || '';
                     var d = v.split('T')[0] || '';
                     dateFilter.value = d;
                     if(actualHdr) actualHdr.value = fitHdr.value;
                     if(display){ display.textContent = formatDisplayDate(d); }
                 }finally{ syncing = false; }
             });
             // On Date view load: if filter empty, copy from header; otherwise copy filter to header
             if('@headerView' === 'Date' && dateFilter){
                 try{
                     if(!dateFilter.value){
                         var dFromHdr = (fitHdr.value||'').split('T')[0] || '';
                         if(dFromHdr){ dateFilter.value = dFromHdr; if(display){ display.textContent = formatDisplayDate(dFromHdr); } }
                     } else {
                         var tp = ensureTimePart(fitHdr.value);
                         fitHdr.value = dateFilter.value + tp;
                         if(actualHdr) actualHdr.value = fitupHeaderDateValue;
                         if(display){ display.textContent = formatDisplayDate(dateFilter.value); }
                     }
                 }catch(e){}
             }
         }catch(e){ console.debug('Welding date sync init failed', e); }
     })();
     (function(){
         try{
             const rfiSel = document.getElementById('rfiSelect');
             const fitHdr = document.getElementById('fitupDateInput');
             const actualHdr = document.getElementById('actualDateInput');
             if(!rfiSel || ! fitHdr) return;
 
             function parseDateFromText(txt){
                 if(!txt) return null;
                 // ISO yyyy-MM-dd
                 const isoMatch = txt.match(/(\d{4}-\d{2}-\d{2})/);
                 if(isoMatch){ const parts = isoMatch[1].split('-'); return new Date(+parts[0], +parts[1]-1, +parts[2]); }
                 // dd-MMM-yyyy (e.g. 02-Feb-2024)
                 const dmyMatch = txt.match(/(\b\d{1,2}-[A-Za-z]{3}-\d{4}\b)/);
                 if(dmyMatch){ try{ const parts = dmyMatch[1].split('-'); const day = parseInt(parts[0],10); const mon = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'].indexOf(parts[1].substr(0,3)); const year = parseInt(parts[2],10); if(mon>=0){ return new Date(year, mon, day); } }catch(e){} }
                 // dd/MM/yyyy or dd.MM.yyyy
                const slashMatch = txt.match(/(\b\d{1,2}[\/\.]\d{1,2}[\/]\d{4}\b)/);
                if(slashMatch){ try{ const s = slashMatch[1].replace(/\./g,'/'); const parts = s.split('/'); const day = parseInt(parts[0],10); const month = parseInt(parts[1],10)-1; const year = parseInt(parts[2],10); return new Date(year, month, day); }catch(e){} }
                return null;
             }
 
             function pad(n){ return n < 10 ? '0' + n : String(n); }
 
             function setFitHdrDateFromDate(dt){
                 if(!dt) return;
                 // preserve time from existing header if present (keep HH:mm when possible)
                 let timePart = 'T00:00';
                 const cur = fitHdr.value || '';
                 if(cur && cur.indexOf('T') >= 0){ const t = cur.split('T')[1]; timePart = 'T' + (t.length > 5 ? t.slice(0,5) : (t + '00').slice(0,5)); }
                 const y = dt.getFullYear(); const m = pad(dt.getMonth()+1); const d = pad(dt.getDate());
                 const dateTimeValue = `${y}-${m}-${d}${timePart}`;
                 // set both Fitup and Actual headers to the same datetime value (datetime-local format yyyy-MM-ddTHH:mm)
                 fitHdr.value = dateTimeValue;
                 if(actualHdr) actualHdr.value = dateTimeValue;
                 try{ fitHdr.dispatchEvent(new Event('change',{bubbles:true})); }catch(e){}
 
                 // Update date-only filter (if present) with yyyy-MM-dd and display string
                 try{
                     var fitupDateEl = document.getElementById('fitupDateFilter');
                     if(fitupDateEl) { fitupDateEl.value = `${y}-${m}-${d}`; var display = document.getElementById('fitupDateFilterDisplay'); if(display) display.textContent = `${pad(d)}-${["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"][dt.getMonth()]}-${y}`; }
                 }catch(e){}
             }
 
             rfiSel.addEventListener('change', function(){
                 try{
                     const opt = rfiSel.options[rfiSel.selectedIndex];
                     const txt = opt ? (opt.text || opt.value || '') : (rfiSel.value || '');
                     const parsed = parseDateFromText(txt) || parseDateFromText(rfiSel.value || '');
                     if(parsed) setFitHdrDateFromDate(parsed);
                 }catch(e){}
             });
 
             // apply on initial load if an RFI is already selected
             (function(){
                 try{
                     if(rfiSel.value){ const opt = rfiSel.options[rfiSel.selectedIndex]; const txt = opt ? (opt.text || opt.value || '') : (rfiSel.value || ''); const parsed = parseDateFromText(txt) || parseDateFromText(rfiSel.value || ''); if(parsed) setFitHdrDateFromDate(parsed); }
                 }catch(e){}
             })();
 
         }catch(e){ /* ignore */ }
     })();
     (function(){
         // Improved robust syncing: delegation and smarter matching

        function getOtherIds(){ return ['tackerRootBSelect','tackerFillASelect','tackerFillBSelect','tackerCapASelect','tackerCapBSelect']; }

        function tryMatchOption(el, sourceValue){
            if(!el) return null;
            const opts = Array.from(el.options);
            // exact value
            let m = opts.find(o => o.value === sourceValue);
            if(m) return m.value;
            // exact text (trim, case-insensitive)
            m = opts.find(o => (o.text||'').trim().toLowerCase() === (sourceValue||'').trim().toLowerCase());
            if(m) return m.value;
            // contains text (case-insensitive)
            m = opts.find(o => (o.text||'').toLowerCase().includes((sourceValue||'').toLowerCase()));
            if(m) return m.value;
            return null;
        }
        function syncOthers(value){
            if(value == null) return;
            getOtherIds().forEach(id => {
                try{
                    const el = document.getElementById(id);
                    if(!el) return;
                    const matchVal = tryMatchOption(el, value);
                    if(matchVal !== null){
                        el.value = matchVal;
                        el.dispatchEvent(new Event('change',{bubbles:true}));
                    }
                }catch(e){}
 
            });
        }
 
        // Delegated listener so it still works if the select is replaced dynamically
        document.addEventListener('change', function(e){
            try{
                const t = e.target;
                if(!t) return;
                if(t.id === 'tackerRootASelect'){
                    syncOthers(t.value);
                }
            }catch(err){ }
        });
 
        // initial sync on load
        (function(){
            try{
                const r = document.getElementById('tackerRootASelect');
                if(r && r.value) syncOthers(r.value);
            }catch(e){}
        })();
     })();
    </script>
