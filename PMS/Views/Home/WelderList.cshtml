@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model IEnumerable<PMS.Models.WelderListRow>
@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = "Welders";
}

@section Head {
    <style>
        h1 { color:#176d8a; }
        .toolbar { margin-bottom:12px; display:flex; gap:10px; align-items:center; flex-wrap:wrap;}
        .layout { width:90%; margin:20px auto; }
        table { width:100%; border-collapse:collapse; background:#fff; box-shadow:0 2px 6px rgba(0,0,0,.1)}
        th,td { padding:8px 10px; border:1px solid #e6f6fa; font-size:.9rem; }
        th { background:#f0fbff; text-align:left; }
        tr:hover { background:#f8fcff; }
        .btn { padding:6px 12px; border:none; border-radius:4px; cursor:pointer; font-weight:600; text-decoration:none; }
        a.btn, a.btn:link, a.btn:visited, a.btn:hover, a.btn:focus, a.btn:active { text-decoration:none; }
        .btn-primary { background:#1f99be; color:#fff;}
        .btn-primary:hover { background:#176d8a;}
        .btn-danger { background:#cc0000; color:#fff;}
        .btn-danger:hover { opacity:.85;}
        .btn-outline { background:#fff; color:#176d8a; border:1px solid #1f99be; }
        .btn-outline:hover { background:#1f99be; color:#fff; }
        .btn-small { padding:4px 8px; font-size:.7rem; }
        /* Make flash messages match inline validation appearance; default is neutral — errors use .text-danger */
        .msg { margin:0 0 12px 0; font-weight:400; font-size:0.875rem; display:block; }
        .msg.text-danger { color: #cc0000; }
        .msg-success { color: #27ae60; font-weight:400; font-size:0.875rem; display:block; }
        .search { padding:6px 10px; border:1px solid #cce7ef; border-radius:4px; }
        .actions form { display:inline; }
        .actions { display:flex; gap:8px; justify-content:flex-end; align-items:center; padding-right:8px; }
        .status { font-weight:600; }
        th.col-name, td.col-name { width:18%; }
        .nowrap { white-space:nowrap; }
        .mono { font-family:Consolas,monaco,monospace; font-size:.8rem; }
        /* Modal styles (updated to match Edit Welder) */
        .modal { display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:10000; align-items:center; justify-content:center; }
        .modal-content { background:#fff; padding:25px; border-radius:8px; width:90%; max-width:520px; max-height:80vh; overflow-y:auto; box-shadow:0 4px 20px rgba(0,0,0,0.15); }
        .modal-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:16px; padding-bottom:10px; border-bottom:1px solid #e6f6fa; }
        .modal-title { font-size:1.3rem; margin:0; color:#176d8a; }
        .close-modal { background:none; border:none; font-size:1.5rem; line-height:1; cursor:pointer; padding:0 4px; color:#176d8a; }
        .modal-actions { display:flex; gap:10px; justify-content:flex-end; margin-top:18px; padding-top:12px; border-top:1px solid #e6f6fa; }
        /* Continuity due highlighting */
        tr.due-soon:not(.overdue) { background:#fff6e1; }
        td.col-next .badge { margin-left:6px; padding:2px 6px; border-radius:12px; font-size:.65rem; font-weight:600; letter-spacing:.5px; }
        td.col-next .badge.due { background:#ffa726; color:#442200; }
        td.col-next .badge.over { background:#e53935; color:#fff; }
        label.filter-inline { font-size:.75rem; display:flex; align-items:center; gap:4px; background:#f0fbff; padding:4px 8px; border-radius:4px; border:1px solid #cce7ef; }
        .col-serial { width:55px; text-align:center; font-weight:600; }
        .searchable-select { font-family: inherit; font-size: .95rem; color: #176d8a; background: #fff; border:1px solid #e6f6fa; padding:6px 10px; line-height:1.4; -webkit-appearance: auto; appearance: auto; border-radius:4px; box-sizing: border-box; }
        select.searchable-select option { font-family: inherit; font-size: .86rem; color: #176d8a; white-space: nowrap; }
        .searchable-select:focus, .searchable-select:active { border-color: #000 !important; outline: none; }
        select.searchable-select::-webkit-scrollbar { width:12px; height:12px; }
        select.searchable-select::-webkit-scrollbar-thumb { background: #176d8a; border-radius:8px; border:3px solid #fff; }
        select.searchable-select::-webkit-scrollbar-thumb:hover { background: #125a6e; }
        select.searchable-select { scrollbar-width: thin; scrollbar-color: #176d8a #f0fbff; }
        .header-fixed { vertical-align: middle; }
        .w350 { width:350px; max-width:100%; }
        /* Searchable select dropdown widget (matches Drawings) */
        .ss-wrap { position:relative; display:inline-block; vertical-align:middle; }
        .ss-wrap.w350 { width:350px; min-width:350px; }
        .ss-input { width:100%; box-sizing:border-box; cursor:pointer; padding:6px 10px; border:1px solid #cce7ef; border-radius:4px; background:#fff; color:#176d8a; font-family:inherit; font-size:.95rem; line-height:1.4; }
        .ss-input:focus { cursor:text; outline:none; border-color:#1f99be; box-shadow:0 0 2px rgba(31,153,190,.2); }
        .ss-list { display:none; position:absolute; left:0; right:0; top:100%; z-index:200; background:#fff; border:1px solid #1f99be; border-top:none; border-radius:0 0 6px 6px; max-height:220px; overflow-y:auto; box-shadow:0 4px 10px rgba(0,0,0,.12); }
        .ss-item { padding:6px 10px; cursor:pointer; font-size:.9rem; color:#176d8a; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
        .ss-item:hover, .ss-item.ss-highlight { background:#e6f6fa; }
        .ss-item.ss-active { font-weight:700; }
        .ss-empty { padding:6px 10px; font-size:.85rem; color:#999; font-style:italic; }
        .ss-open .ss-input { border-radius:4px 4px 0 0; border-color:#1f99be; }
    </style>
}

<div class="layout">
    <h1>Welder Register</h1>
    @* Only show messages other than "Successfully Saved" *@
    @if (TempData["Msg"] is string msg && !string.Equals(msg, "Successfully Saved", StringComparison.OrdinalIgnoreCase))
    {
        var isSuccess = System.Text.RegularExpressions.Regex.IsMatch(msg ?? "", "(successfully|saved|uploaded)", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        var css = isSuccess ? "msg msg-success" : "msg text-danger";
        <div class="@css" role="status" aria-live="polite">@msg</div>
    }
    @{ var projects = ViewBag.ProjectsSelect as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>(); var defaultPid = ViewBag.DefaultProjectId as int?; }
    @* Split search: project, general text + separate Batch No search *@
    <div class="toolbar">
        <select id="projectBox" class="search header-fixed w350 searchable-select" title="Project">
            @foreach (var p in projects)
            {
                var label = (p.Label ?? string.Empty).ToString();
                var val = p.Id.ToString();
                if (defaultPid.HasValue && p.Id == defaultPid.Value)
                {
                    <option value="@val" selected>@label</option>
                }
                else
                {
                    <option value="@val">@label</option>
                }
            }
        </select>
        <input id="filterBox" class="search" placeholder="Search (symbol, name, status, process, date)" />
        <input id="batchFilter" class="search" placeholder="Batch No" inputmode="numeric" style="max-width:110px;" />
        <label class="filter-inline"><input type="checkbox" id="dueSoonOnly" /> Due / Overdue (?10d)</label>
        <a class="btn btn-primary" asp-action="EditWelder" asp-controller="Home">Add New Welder</a>
        <button id="downloadWelders" type="button" class="btn btn-outline">Download Excel</button>
    </div>

    <table id="weldersTable">
        <thead>
            <tr>
                <th scope="col" class="col-serial">S/N</th>
                <th scope="col">Symbol</th>
                <th scope="col" class="col-name">Name</th>
                <th scope="col">Location</th>
                <th scope="col">Welding Processes</th>
                <th scope="col">Status</th>
                <th scope="col">Project No.</th>
                <th scope="col">Batch Nos.</th>
                <th scope="col">Next Continuity</th>
                <th scope="col" style="width:220px;">Actions</th>
            </tr>
        </thead>
        <tbody>
        @{ var __rowIndex = 0; }
        @foreach (var r in Model)
        {
            __rowIndex++;
            <tr>
                <td class="col-serial">@__rowIndex</td>
                <td class="col-symbol">@r.Welder_Symbol</td>
                <td class="col-name">@r.Name</td>
                <td class="col-location">@r.Welder_Location</td>
                <td class="col-wp">@r.Welding_Process</td>
                <td class="status col-status">@r.Status</td>
                <td class="col-project">@(@r.Project_Welder ?? "")</td>
                <td class="col-batch mono">@(!string.IsNullOrWhiteSpace(r.Batch_Nos) ? r.Batch_Nos : (r.Batch_No?.ToString() ?? ""))</td>
                <td class="col-next nowrap">@(r.Demobilization_Date.HasValue ? "(Demobilized)" : (r.Next_Continuity?.ToString("yyyy-MM-dd") ?? ""))</td>
                <td class="actions">
                    <a class="btn btn-primary"
                       asp-action="EditWelder"
                       asp-controller="Home"
                       asp-route-id="@r.Welder_ID">Edit</a>
                    <form method="post"
                          asp-action="DeleteWelder"
                          asp-controller="Home"
                          class="delete-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@r.Welder_ID" />
                        <button type="submit" class="btn btn-danger">Del</button>
                    </form>
                    @if (!string.IsNullOrWhiteSpace(r.Welder_Symbol))
                    {
                        <a class="btn btn-outline btn-small" title="Download all WQT files" href="@Url.Action("DownloadWelderQualifications", "Home", new { symbol = r.Welder_Symbol })">Download WQT</a>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

<div class="modal" id="confirmDeleteModal">
    <div class="modal-content" role="dialog" aria-modal="true" aria-labelledby="confirmDeleteTitle">
        <div class="modal-header">
            <h2 id="confirmDeleteTitle" class="modal-title">Confirm Delete</h2>
            <button class="close-modal" type="button" aria-label="Close" onclick="closeDeleteModal()">&times;</button>
        </div>
        <p id="confirmDeleteMessage" style="color:#176d8a; margin:0 0 16px 0;"></p>
        <div class="modal-actions">
            <button type="button" class="btn" onclick="closeDeleteModal()">Cancel</button>
            <button type="button" class="btn btn-danger" onclick="confirmDelete()">Delete</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function makeSearchableSelect(sel){
            if(!sel || sel.dataset.searchable) return;
            sel.dataset.searchable='1';
            sel.style.display='none';
            var wrap = document.createElement('div');
            wrap.className = 'ss-wrap';
            if(sel.classList.contains('w350')) wrap.classList.add('w350');
            sel.parentNode.insertBefore(wrap, sel);
            wrap.appendChild(sel);

            var input = document.createElement('input');
            input.type = 'text';
            input.className = 'ss-input';
            input.setAttribute('autocomplete','off');
            input.setAttribute('spellcheck','false');
            input.placeholder = 'Search project...';
            wrap.appendChild(input);

            var list = document.createElement('div');
            list.className = 'ss-list';
            wrap.appendChild(list);

            var items = [];
            var highlighted = -1;
            var open = false;

            function buildItems(){
                items = [];
                Array.from(sel.options).forEach(function(opt){
                    items.push({ value: opt.value, text: opt.text || opt.value });
                });
            }
            function syncInputText(){
                var idx = sel.selectedIndex;
                input.value = idx >= 0 && sel.options[idx] ? (sel.options[idx].text || sel.options[idx].value) : '';
            }
            function render(filter){
                list.innerHTML = '';
                highlighted = -1;
                var lc = (filter || '').toLowerCase();
                var count = 0;
                items.forEach(function(item, i){
                    if(lc && !(item.text||'').toLowerCase().includes(lc)) return;
                    var div = document.createElement('div');
                    div.className = 'ss-item';
                    div.textContent = item.text;
                    div.dataset.idx = String(i);
                    if(item.value === sel.value) div.classList.add('ss-active');
                    div.addEventListener('mousedown', function(e){
                        e.preventDefault();
                        pick(i);
                    });
                    list.appendChild(div);
                    count++;
                });
                if(count === 0){
                    var empty = document.createElement('div');
                    empty.className = 'ss-empty';
                    empty.textContent = 'No match';
                    list.appendChild(empty);
                }
            }
            function pick(idx){
                if(idx < 0 || idx >= items.length) return;
                sel.value = items[idx].value;
                syncInputText();
                closeList();
                sel.dispatchEvent(new Event('change', { bubbles: true }));
            }
            function showList(){
                if(open) return;
                open = true;
                render(input.value !== (items[sel.selectedIndex]?.text || '') ? input.value : '');
                list.style.display = 'block';
                wrap.classList.add('ss-open');
            }
            function closeList(){
                open = false;
                list.style.display = 'none';
                wrap.classList.remove('ss-open');
                highlighted = -1;
            }
            function highlightItem(dir){
                var visible = list.querySelectorAll('.ss-item');
                if(!visible.length) return;
                if(dir === 'down') highlighted = highlighted < visible.length - 1 ? highlighted + 1 : 0;
                else highlighted = highlighted > 0 ? highlighted - 1 : visible.length - 1;
                visible.forEach(function(el, i){ el.classList.toggle('ss-highlight', i === highlighted); });
                if(visible[highlighted]) visible[highlighted].scrollIntoView({ block:'nearest' });
            }
            input.addEventListener('focus', function(){
                buildItems();
                input.select();
                showList();
            });
            input.addEventListener('input', function(){
                buildItems();
                showList();
                render(input.value);
            });
            input.addEventListener('keydown', function(e){
                if(e.key === 'ArrowDown'){
                    e.preventDefault();
                    if(!open){ showList(); render(''); }
                    highlightItem('down');
                } else if(e.key === 'ArrowUp'){
                    e.preventDefault();
                    highlightItem('up');
                } else if(e.key === 'Enter'){
                    e.preventDefault();
                    if(open && highlighted >= 0){
                        var visible = list.querySelectorAll('.ss-item');
                        if(visible[highlighted]){
                            var idx = parseInt(visible[highlighted].dataset.idx, 10);
                            pick(idx);
                        }
                    }
                } else if(e.key === 'Escape'){
                    syncInputText();
                    closeList();
                    input.blur();
                } else if(e.key === 'Tab'){
                    syncInputText();
                    closeList();
                }
            });
            input.addEventListener('blur', function(){
                setTimeout(function(){
                    if(!wrap.contains(document.activeElement)){
                        syncInputText();
                        closeList();
                    }
                }, 150);
            });
            buildItems();
            syncInputText();
        }
        function getSelectedValueOrText(id){ var el=document.getElementById(id); if(!el) return ''; var opt = el.selectedOptions && el.selectedOptions[0]; if(opt){ var t=(opt.text||'').trim(); if(t) return t; } return el.value||''; }
        function reloadForProject(sel){ if(!sel) return; var val = (sel.value||'').trim(); var url = new URL(window.location.href); if(val) url.searchParams.set('projectId', val); else url.searchParams.delete('projectId'); window.location.href = url.toString(); }

        const projectBox = document.getElementById('projectBox');
        const box = document.getElementById('filterBox');
        const batchBox = document.getElementById('batchFilter');
        const dueSoonOnly = document.getElementById('dueSoonOnly');
        const rowsEls = [...document.querySelectorAll('#weldersTable tbody tr')];

        makeSearchableSelect(projectBox);

        function markContinuities() {
            const today = new Date();
            rowsEls.forEach(tr => {
                const cell = tr.querySelector('.col-next');
                if (!cell) return;
                const txt = cell.textContent.trim();
                tr.classList.remove('due-soon','overdue');
                cell.querySelectorAll('.badge').forEach(b=>b.remove());
                if (!txt || txt === '(Demobilized)') { tr.dataset.dueflag = '0'; return; }
                const parts = txt.split('-');
                if (parts.length !== 3) { tr.dataset.dueflag = '0'; return; }
                const dt = new Date(parts[0], parts[1]-1, parts[2]);
                if (isNaN(dt)) { tr.dataset.dueflag = '0'; return; }
                const msPerDay = 86400000;
                const diffDays = Math.floor((dt - today) / msPerDay);
                let badge = null;
                if (diffDays < 0) { tr.classList.add('overdue'); badge = makeBadge('OVERDUE','over'); }
                else if (diffDays <= 10) { tr.classList.add('due-soon'); badge = makeBadge('DUE','due'); }
                if (badge) cell.appendChild(badge);
                tr.dataset.dueflag = diffDays < 0 || diffDays <= 10 ? '1' : '0';
            });
        }
        function makeBadge(text, cls) { const s = document.createElement('span'); s.className = 'badge ' + cls; s.textContent = text; return s; }

        function renumberVisibleRows() {
            let i = 1;
            document.querySelectorAll('#weldersTable tbody tr').forEach(tr => {
                if (tr.style.display === 'none') return; // skip hidden after filter
                const cell = tr.querySelector('.col-serial');
                if (cell) cell.textContent = i++;
            });
        }

        function applyFilters() {
            const projectVal = (projectBox?.value || '').trim().toLowerCase();
            const projectLabel = getSelectedValueOrText('projectBox').toLowerCase().trim();
            const q = (box?.value || '').toLowerCase().trim();
            const b = (batchBox?.value || '').trim();
            const wantDueOnly = dueSoonOnly?.checked;
            rowsEls.forEach(tr => {
                const cols = [ '.col-symbol', '.col-name', '.col-status', '.col-location', '.col-project', '.col-wp', '.col-batch', '.col-next' ];
                const hay = cols.map(sel => tr.querySelector(sel)?.innerText?.toLowerCase() ?? '').join(' ');
                const batchText = (tr.querySelector('.col-batch')?.innerText || '').split(',').map(s=>s.trim());
                const projectText = (tr.querySelector('.col-project')?.innerText || '').trim().toLowerCase();
                const textOk = q.length === 0 || hay.includes(q);
                const projectOk = projectVal.length === 0
                    || projectText === projectVal
                    || projectText === projectLabel
                    || projectText.includes(projectVal)
                    || projectVal.includes(projectText);
                const batchOk = b.length === 0 || batchText.includes(b);
                const dueOk = !wantDueOnly || tr.dataset.dueflag === '1';
                tr.style.display = (textOk && projectOk && batchOk && dueOk) ? '' : 'none';
            });
            renumberVisibleRows();
        }
        function debounce(fn, ms = 120) { let h; return (...args) => { clearTimeout(h); h = setTimeout(() => fn(...args), ms); }; }
        const debouncedApply = debounce(applyFilters, 120);
        projectBox?.addEventListener('change', () => { reloadForProject(projectBox); });
        box?.addEventListener('input', debouncedApply);
        batchBox?.addEventListener('input', debouncedApply);
        dueSoonOnly?.addEventListener('change', applyFilters);

        // Download button with filters => query params
        document.getElementById('downloadWelders')?.addEventListener('click', () => {
            const params = new URLSearchParams();
            const p = (projectBox?.value || '').trim(); if (p) params.append('projectId', p);
            const qv = (box?.value || '').trim(); if (qv) params.append('q', qv);
            const bv = (batchBox?.value || '').trim(); if (bv) params.append('batch', bv);
            if (dueSoonOnly?.checked) params.append('due', 'true');
            const qs = params.toString();
            window.location = '/Home/ExportWelders' + (qs ? ('?' + qs) : '');
        });

        // Delete modal behavior
        let pendingDeleteForm = null;
        function openDeleteModal(form) {
            pendingDeleteForm = form;
            const tr = form.closest('tr');
            const symbol = tr?.querySelector('.col-symbol')?.textContent?.trim() || '';
            const name = tr?.querySelector('.col-name')?.textContent?.trim() || '';
            const msg = symbol || name ? `Are you sure you want to delete welder "${symbol} ${name}"?` : 'Are you sure you want to delete this welder?';
            document.getElementById('confirmDeleteMessage').textContent = msg;
            const modal = document.getElementById('confirmDeleteModal');
            modal.style.display = 'flex';
            modal.querySelector('.close-modal')?.focus();
        }
        function closeDeleteModal() { const m = document.getElementById('confirmDeleteModal'); m.style.display = 'none'; pendingDeleteForm = null; }
        function confirmDelete() { if (pendingDeleteForm) pendingDeleteForm.submit(); closeDeleteModal(); }
        document.querySelectorAll('form.delete-form').forEach(f => { f.addEventListener('submit', function (e) { e.preventDefault(); openDeleteModal(this); }); });
        window.addEventListener('click', function (event) { const modal = document.getElementById('confirmDeleteModal'); if (event.target === modal) closeDeleteModal(); });
        window.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') {
                const modal = document.getElementById('confirmDeleteModal');
                if (modal && modal.style.display === 'flex') closeDeleteModal();
            }
        });

        document.addEventListener('DOMContentLoaded', function(){
            markContinuities();
            applyFilters();
            renumberVisibleRows();
        });
    </script>
}