@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model IEnumerable<PMS.Models.Rfi>
@{
    Layout = null;
    ViewData["Title"] = "RFI Log";
    var projectMap = (ViewBag.ProjectMap as Dictionary<int, string>) ?? new Dictionary<int, string>();
    var defaultProjectId = ViewBag.DefaultProjectId as int?;
    var distinctContractors = Model
        .Where(r => !string.IsNullOrWhiteSpace(r.RFI_CONTRACTOR))
        .Select(r => r.RFI_CONTRACTOR!.Trim())
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(c => c)
        .ToList();
    var distinctSubContractors = Model
        .Where(r => !string.IsNullOrWhiteSpace(r.Sub_Contractor))
        .Select(r => r.Sub_Contractor!.Trim())
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(c => c)
        .ToList();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - PMS</title>
    <link rel="icon" type="image/png" href="~/img/title_logo.png">
    <link rel="stylesheet" href="~/css/DashboardStyle.css" asp-append-version="true">
    <style>
        .page { width:95%; margin:20px auto; background:#fff; border-radius:8px; box-shadow:0 4px 12px rgba(0,0,0,.1); padding:20px; }
        .page-title { color:#176d8a; margin:0 0 16px 0; padding-bottom:10px; border-bottom:2px solid #e6f6fa; font-size:2em; }
        label { font-weight:600; color:#176d8a; font-size:.9rem; }
        .form-control { padding:8px 12px; border:1px solid #cce7ef; border-radius:4px; background:#fff; color:#176d8a; font-size:.9rem; width:100%; box-sizing:border-box; }
        .form-control:focus { outline:none; border-color:#1f99be; box-shadow:0 0 0 2px rgba(31,153,190,.2); }
        .grid { display:grid; grid-template-columns: repeat(auto-fill,minmax(220px,1fr)); gap:12px; }
        .form-group { display:flex; flex-direction:column; gap:6px; }
        .actions { display:flex; gap:8px; justify-content:flex-end; margin-top:12px; }
        .btn { padding:8px 14px; border:none; border-radius:4px; cursor:pointer; font-weight:600; transition:.2s; }
        .btn-primary { background:#1f99be; color:#fff; } .btn-primary:hover{ background:#176d8a; }
        .btn-danger { background:#cc0000; color:#fff; } .btn-danger:hover{ background:#a30000; }
        .btn-secondary { background:#7a9aa8; color:#fff; }
        .btn-outline { background:#fff; color:#176d8a; border:1px solid #1f99be; }
        .btn-outline:hover { background:#1f99be; color:#fff; }
        .btn-success { background:#27ae60; color:#fff; } .btn-success:hover { background:#1e8c4c; }
        .user-table { width:100%; border-collapse:collapse; margin-top:10px; }
        .user-table th { background-color:#e6f6fa; color:#176d8a; padding:10px 12px; text-align:left; position:sticky; top:0; z-index:2; white-space:nowrap; }
        .user-table td { padding:10px 12px; border-bottom:1px solid #e6f6fa; color:#1a6d86; white-space:nowrap; }
        .msg { margin:0 0 12px 0; font-weight:400; font-size:0.875rem; display:block; border:none; outline:none; box-shadow:none; background:transparent; }
        .msg.text-danger { color:#cc0000; }
        .msg-success { margin:0 0 12px 0; color:#27ae60; font-weight:400; font-size:0.875rem; display:block; border:none; outline:none; box-shadow:none; background:transparent; }
        .row-actions { display:flex; gap:8px; }
        .filter-bar { display:flex; gap:10px; flex-wrap:wrap; align-items:center; margin-top:25px; }
        .filter-bar input[type="text"] { flex:1 1 260px; }
        .count { font-size:.8rem; color:#176d8a; }
        .filter-actions { display:flex; gap:8px; align-items:center; }
        .col-actions, td.row-actions { width:90px; max-width:90px; }
        /* PDF button group */
        .pdf-btns { display:inline-flex; gap:0; border-radius:4px; overflow:hidden; border:1px solid #1f99be; }
        .pdf-btns .pbtn { padding:4px 7px; font-size:.75rem; font-weight:600; border:none; cursor:pointer; white-space:nowrap; transition:.15s; text-decoration:none; display:inline-flex; align-items:center; gap:3px; line-height:1; }
        .pdf-btns .pbtn + .pbtn { border-left:1px solid rgba(31,153,190,.3); }
        .pdf-btns .pbtn-open  { background:#1f99be; color:#fff; }
        .pdf-btns .pbtn-open:hover { background:#176d8a; }
        .pdf-btns .pbtn-save  { background:#fff; color:#176d8a; }
        .pdf-btns .pbtn-save:hover { background:#e6f6fa; }
        .pdf-btns .pbtn-upload { background:#fff; color:#176d8a; }
        .pdf-btns .pbtn-upload:hover { background:#e6f6fa; }
        .pdf-btns .pbtn.disabled { opacity:.4; pointer-events:none; cursor:default; background:#eee; color:#aaa; }
        .table-scroll { overflow:auto; max-height:65vh; }
        /* Scrollbar styling – table scroll */
        .table-scroll::-webkit-scrollbar { width:10px; height:10px; }
        .table-scroll::-webkit-scrollbar-track { background:#f0fbff; border-radius:8px; }
        .table-scroll::-webkit-scrollbar-thumb { background:#1f99be; border-radius:8px; border:2px solid #f0fbff; }
        .table-scroll::-webkit-scrollbar-thumb:hover { background:#176d8a; }
        .table-scroll::-webkit-scrollbar-corner { background:transparent; }
        /* Scrollbar styling – modal content */
        .modal-content::-webkit-scrollbar { width:10px; }
        .modal-content::-webkit-scrollbar-track { background:#f0fbff; border-radius:8px; }
        .modal-content::-webkit-scrollbar-thumb { background:#1f99be; border-radius:8px; border:2px solid #f0fbff; }
        .modal-content::-webkit-scrollbar-thumb:hover { background:#176d8a; }
        /* Firefox scrollbar */
        .table-scroll { scrollbar-width:thin; scrollbar-color:#1f99be #f0fbff; }
        .modal-content { scrollbar-width:thin; scrollbar-color:#1f99be #f0fbff; }
        .import-section { margin-top:20px; padding:16px; border:1px dashed #cce7ef; border-radius:8px; background:#f9fdfe; }
        .import-section label { display:block; margin-bottom:8px; }
        .import-row { display:flex; gap:10px; align-items:center; flex-wrap:wrap; }
        .modal { display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:10000; justify-content:center; align-items:center; }
        .modal-content { background:#fff; padding:25px; border-radius:8px; width:90%; max-width:780px; max-height:85vh; overflow-y:auto; box-shadow:0 4px 20px rgba(0,0,0,0.15); }
        .modal-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:16px; padding-bottom:10px; border-bottom:1px solid #e6f6fa; }
        .modal-title { color:#176d8a; font-size:1.3rem; margin:0; }
        .close-modal { background:none; border:none; font-size:1.5rem; cursor:pointer; color:#176d8a; }
        .modal-actions { display:flex; justify-content:flex-end; gap:10px; margin-top:18px; padding-top:12px; border-top:1px solid #e6f6fa; }
        .fitup-header { display:flex; gap:12px; flex-wrap:wrap; align-items:center; padding:10px 0; }
        .fitup-header label { margin-right:4px; }
        .header-fixed { width:auto; display:inline-block; }
        .w350 { width:350px; min-width:350px; }
        .ss-wrap { position:relative; display:inline-block; vertical-align:middle; }
        .ss-wrap.w350 { width:350px; min-width:350px; }
        .w180 { width:180px; min-width:180px; }
        .ss-wrap.w180 { width:180px; min-width:180px; }
        .ss-input { width:100%; box-sizing:border-box; cursor:pointer; padding:8px 12px; border:1px solid #cce7ef; border-radius:4px; color:#176d8a; font-size:.9rem; background:#fff; }
        .ss-input:focus { cursor:text; border-color:#1f99be; outline:none; }
        .ss-list { display:none; position:absolute; left:0; right:0; top:100%; z-index:1200; background:#fff; border:1px solid #1f99be; border-top:none; border-radius:0 0 6px 6px; max-height:220px; overflow-y:auto; box-shadow:0 4px 10px rgba(0,0,0,.12); }
        .ss-item { padding:6px 10px; cursor:pointer; font-size:.9rem; color:#176d8a; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
        .ss-item:hover, .ss-item.ss-highlight { background:#e6f6fa; }
        .ss-item.ss-active { font-weight:700; }
        .ss-empty { padding:6px 10px; font-size:.85rem; color:#999; font-style:italic; }
        .ss-open .ss-input { border-radius:4px 4px 0 0; border-color:#1f99be; }
    </style>
</head>
<body>
    @await Html.PartialAsync("_DashboardHeader")

    <div class="page">
        <h1 class="page-title">RFI Log</h1>

        @if (TempData["Msg"] is string m && !string.IsNullOrWhiteSpace(m))
        {
            var isSuccessMsg = System.Text.RegularExpressions.Regex.IsMatch(m, "(successfully|saved|uploaded|updated|added|complete|deleted)", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            var flashClass = isSuccessMsg ? "msg msg-success" : "msg text-danger";
            <div id="topFlashMsg" class="@flashClass" role="status" aria-live="polite">@m</div>
        }

        <!-- Project filter -->
        <div class="fitup-header">
            <form method="get" asp-action="RfiLog" asp-controller="Home" id="rfiFilterForm">
                <label for="projectSelect">Project</label>
                <select id="projectSelect" name="projectId" class="form-control header-fixed w350 searchable-select">
                    @foreach (var p in (IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)ViewBag.FilterProjects)
                    {
                        <option value="@p.Value" selected="@p.Selected">@p.Text</option>
                    }
                </select>
            </form>
            <button type="button" class="btn btn-primary" onclick="openAddModal()">+ Add RFI</button>
        </div>

        <!-- Import / Append by Excel -->
        <div class="import-section">
            <label>Import / Append from Excel</label>
            <form asp-action="ImportRfi" asp-controller="Home" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="projectId" value="@(defaultProjectId)" />
                <div class="import-row">
                    <input type="file" name="excelFile" accept=".xlsx,.xls" class="form-control" style="flex:1 1 300px;" required />
                    <button type="submit" class="btn btn-success">Upload &amp; Import</button>
                    <a asp-action="DownloadRfiTemplate" asp-controller="Home" class="btn btn-outline" style="margin-left:4px;">Download Template</a>
                </div>
                <small style="color:#7a9aa8; margin-top:6px; display:block;">
                    Expected columns: Discipline, Sub Contractor, SubCon RFI No, Location, Description, Date, etc.
                    Rows with an existing RFI ID will be updated; new rows will be appended.
                </small>
            </form>
        </div>

        <!-- Bulk PDF Upload / Download -->
        <div class="import-section" style="margin-top:12px;">
            <label>Bulk PDF Upload &amp; Download</label>
            <form asp-action="BulkUploadRfiPdfs" asp-controller="Home" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="projectId" value="@(defaultProjectId)" />
                <div class="import-row">
                    <input type="file" name="pdfFiles" accept=".pdf" multiple class="form-control" style="flex:1 1 300px;" required />
                    <button type="submit" class="btn btn-success">Bulk Upload PDFs</button>
                    <a href="/Home/BulkDownloadRfiPdfs?projectId=@(defaultProjectId)" class="btn btn-outline" id="bulkDownloadPdfBtn" style="margin-left:4px;">⬇ Download All PDFs</a>
                </div>
                <small style="color:#7a9aa8; margin-top:6px; display:block;">
                    Select multiple PDF files. Each file is matched to an RFI row if its filename contains the <strong>SubCon RFI No</strong> value.
                    Bulk download exports all attached PDFs for the current project as a ZIP.
                </small>
            </form>
        </div>

        <div class="filter-bar">
            <input id="searchBox" class="form-control" type="text" placeholder="Search all columns..." autocomplete="off" />
            <div class="filter-actions">
                <select id="bulkInspStatus" class="form-control w180 searchable-select" data-allow-custom="true" style="width:180px;">
                    <option value="">-- Insp Status --</option>
                    <option value="Closed">Closed</option>
                    <option value="Cancelled">Cancelled</option>
                    <option value="Under Sub Contractor">Under Sub Contractor</option>
                    <option value="Under Contractor / PID SIGN">Under Contractor / PID SIGN</option>
                    <option value="PMT SIGN BALANCE">PMT SIGN BALANCE</option>
                    <option value="Under Scanning">Under Scanning</option>
                </select>
                <button id="bulkFillInspBtn" type="button" class="btn btn-primary" title="Apply Inspection Status to all filtered rows">Bulk Fill Status</button>
                <button id="downloadBtn" type="button" class="btn btn-outline">Download Excel</button>
                <span id="rowCount" class="count"></span>
            </div>
        </div>

        <div class="table-scroll">
            <table class="user-table" id="rfiTable">
                <thead>
                    <tr>
                        <th>RFI ID</th>
                        <th>Discipline</th>
                        <th>Sub Contractor</th>
                        <th>Sub Discipline</th>
                        <th>Contractor</th>
                        <th>SubCon RFI No</th>
                        <th>EPM No</th>
                        <th>SATIP</th>
                        <th>SAIC</th>
                        <th>Activity</th>
                        <th>Location</th>
                        <th>Unit</th>
                        <th>Element</th>
                        <th>Description</th>
                        <th>Inspection Date</th>
                        <th>Time</th>
                        <th>Co. Insp</th>
                        <th>Contr. Insp</th>
                        <th>SubCon Insp</th>
                        <th>TR QC</th>
                        <th>Sub Con QC</th>
                        <th>PID</th>
                        <th>PMT</th>
                        <th>Inspection Status</th>
                        <th>Ref Drawing No</th>
                        <th>Scan Copy</th>
                        <th>Remarks</th>
                        <th class="col-actions">Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var r in Model)
                {
                    <tr data-id="@r.RFI_ID"
                        data-project-id="@r.RFI_Project_No"
                        data-discipline="@r.DISCIPLINE"
                        data-sub-contractor="@r.Sub_Contractor"
                        data-sub-discipline="@r.SubDiscipline"
                        data-rfi-contractor="@r.RFI_CONTRACTOR"
                        data-subcon-rfi-no="@r.SubCon_RFI_No"
                        data-epm-no="@r.EPMNo"
                        data-satip="@r.SATIP"
                        data-saic="@r.SAIC"
                        data-activity="@r.ACTIVITY"
                        data-location="@r.RFI_LOCATION"
                        data-unit="@r.UNIT"
                        data-element="@r.ELEMENT"
                        data-description="@r.RFI_DESCRIPTION"
                        data-date="@(r.Date.HasValue ? r.Date.Value.ToString("yyyy-MM-dd") : "")"
                        data-time="@(r.Time.HasValue ? r.Time.Value.ToString("HH:mm") : "")"
                        data-company-insp="@r.COMPANY_INSPECTION_LEVEL"
                        data-contractor-insp="@r.CONTRACTOR_INSPECTION_LEVEL"
                        data-subcon-insp="@r.SUBCON_INSPECTION_LEVEL"
                        data-tr-qc="@r.TR_QC"
                        data-sub-con-qc="@r.SUB_CON_QC"
                        data-pid="@r.PID"
                        data-pmt="@r.PMT"
                        data-insp-status="@r.INSPECTION_STATUS"
                        data-ref-drawing="@r.REFRENCE_DRAWING_No"
                        data-scan-copy="@r.SCAN_COPY"
                        data-remarks="@r.REMARKS"
                        data-qr-code="@r.QR_Code_Link"
                        data-file-name="@r.RFI_FileName"
                        data-blob-name="@r.RFI_BlobName">
                        <td>@r.RFI_ID</td>
                        <td>@r.DISCIPLINE</td>
                        <td>@r.Sub_Contractor</td>
                        <td>@r.SubDiscipline</td>
                        <td>@r.RFI_CONTRACTOR</td>
                        <td>@r.SubCon_RFI_No</td>
                        <td>@r.EPMNo</td>
                        <td>@r.SATIP</td>
                        <td>@r.SAIC</td>
                        <td>@r.ACTIVITY</td>
                        <td>@r.RFI_LOCATION</td>
                        <td>@r.UNIT</td>
                        <td>@r.ELEMENT</td>
                        <td title="@r.RFI_DESCRIPTION">@(r.RFI_DESCRIPTION != null && r.RFI_DESCRIPTION.Length > 60 ? r.RFI_DESCRIPTION[..60] + "…" : r.RFI_DESCRIPTION)</td>
                        <td>@(r.Date.HasValue ? r.Date.Value.ToString("dd-MMM-yyyy") : "")</td>
                        <td>@(r.Time.HasValue ? r.Time.Value.ToString("HH:mm") : "")</td>
                        <td>@r.COMPANY_INSPECTION_LEVEL</td>
                        <td>@r.CONTRACTOR_INSPECTION_LEVEL</td>
                        <td>@r.SUBCON_INSPECTION_LEVEL</td>
                        <td>@r.TR_QC</td>
                        <td>@r.SUB_CON_QC</td>
                        <td>@r.PID</td>
                        <td>@r.PMT</td>
                        <td data-field="inspStatus">@r.INSPECTION_STATUS</td>
                        <td>@r.REFRENCE_DRAWING_No</td>
                        <td>
                            @r.SCAN_COPY
                            @{ var hasPdf = !string.IsNullOrWhiteSpace(r.RFI_BlobName); }
                            <div class="pdf-btns" style="margin-top:2px;">
                                @if (hasPdf)
                                {
                                    <a href="/Home/OpenRfiFile?id=@r.RFI_ID" target="_blank" title="Open @r.RFI_FileName" class="pbtn pbtn-open">&#128196; Open</a>
                                    <a href="/Home/DownloadRfiFile?id=@r.RFI_ID" title="Download @r.RFI_FileName" class="pbtn pbtn-save">⬇ Save</a>
                                }
                                else
                                {
                                    <span class="pbtn disabled">&#128196; Open</span>
                                    <span class="pbtn disabled">⬇ Save</span>
                                }
                                <button type="button" class="pbtn pbtn-upload btn-upload-pdf" data-rfi-id="@r.RFI_ID" title="@(hasPdf ? "Replace PDF" : "Upload PDF")">&#128228;</button>
                            </div>
                        </td>
                        <td>@r.REMARKS</td>
                        <td class="row-actions">
                            <button type="button" class="btn btn-primary" onclick="editRfi(this)">Edit</button>
                            <button type="button" class="btn btn-danger delete-rfi" data-id="@r.RFI_ID">Del</button>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>

    @await Html.PartialAsync("_DashboardFooter")

    <!-- Hidden delete form -->
    <form id="deleteRfiForm" method="post" asp-action="DeleteRfi" asp-controller="Home" style="display:none;">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" id="deleteRfiId" />
    </form>

    <!-- Hidden inline PDF upload form -->
    <form id="inlinePdfUploadForm" method="post" asp-action="UploadRfiFile" asp-controller="Home" enctype="multipart/form-data" style="display:none;">
        @Html.AntiForgeryToken()
        <input type="hidden" name="rfiId" id="inlinePdfRfiId" />
        <input type="file" name="pdfFile" id="inlinePdfFileInput" accept=".pdf" />
    </form>

    <!-- Confirm delete modal -->
    <div class="modal" id="confirmDeleteRfiModal" role="dialog" aria-modal="true" aria-labelledby="rfiDeleteTitle" aria-hidden="true">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title" id="rfiDeleteTitle">Confirm Delete</h2>
                <button class="close-modal" type="button" aria-label="Close" onclick="closeDeleteModal()">&times;</button>
            </div>
            <p id="confirmDeleteRfiMessage" style="color:#176d8a; margin:0 0 16px 0;"></p>
            <div class="modal-actions">
                <button type="button" class="btn" onclick="closeDeleteModal()">Cancel</button>
                <button type="button" class="btn btn-danger" onclick="confirmRfiDelete()">Delete</button>
            </div>
        </div>
    </div>

    <!-- Add / Edit modal -->
    <div class="modal" id="rfiEditModal" role="dialog" aria-modal="true" aria-labelledby="rfiEditTitle" aria-hidden="true">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title" id="rfiEditTitle">Add RFI</h2>
                <button class="close-modal" type="button" aria-label="Close" onclick="closeEditModal()">&times;</button>
            </div>
            <form asp-action="SaveRfi" asp-controller="Home" method="post" id="rfiForm">
                @Html.AntiForgeryToken()
                <input type="hidden" id="fRFI_ID" name="RFI_ID" value="0" />
                <input type="hidden" id="fRFI_Project_No" name="RFI_Project_No" value="@(defaultProjectId)" />
                <div class="grid">
                    <div class="form-group">
                        <label for="fDISCIPLINE">Discipline</label>
                        <input class="form-control" id="fDISCIPLINE" name="DISCIPLINE" maxlength="25" />
                    </div>
                    <div class="form-group">
                        <label for="fSub_Contractor">Sub Contractor</label>
                        <input class="form-control" id="fSub_Contractor" name="Sub_Contractor" maxlength="255" />
                    </div>
                    <div class="form-group">
                        <label for="fSubDiscipline">Sub Discipline</label>
                        <input class="form-control" id="fSubDiscipline" name="SubDiscipline" maxlength="25" />
                    </div>
                    <div class="form-group">
                        <label for="fRFI_CONTRACTOR">Contractor</label>
                        <input class="form-control" id="fRFI_CONTRACTOR" name="RFI_CONTRACTOR" maxlength="255" />
                    </div>
                    <div class="form-group">
                        <label for="fSubCon_RFI_No">SubCon RFI No</label>
                        <input class="form-control" id="fSubCon_RFI_No" name="SubCon_RFI_No" maxlength="10" />
                    </div>
                    <div class="form-group">
                        <label for="fEPMNo">EPM No</label>
                        <input class="form-control" id="fEPMNo" name="EPMNo" type="number" />
                    </div>
                    <div class="form-group">
                        <label for="fSATIP">SATIP</label>
                        <input class="form-control" id="fSATIP" name="SATIP" maxlength="25" />
                    </div>
                    <div class="form-group">
                        <label for="fSAIC">SAIC</label>
                        <input class="form-control" id="fSAIC" name="SAIC" maxlength="25" />
                    </div>
                    <div class="form-group">
                        <label for="fACTIVITY">Activity</label>
                        <input class="form-control" id="fACTIVITY" name="ACTIVITY" type="number" step="0.01" />
                    </div>
                    <div class="form-group">
                        <label for="fRFI_LOCATION">Location</label>
                        <input class="form-control" id="fRFI_LOCATION" name="RFI_LOCATION" maxlength="25" />
                    </div>
                    <div class="form-group">
                        <label for="fUNIT">Unit</label>
                        <input class="form-control" id="fUNIT" name="UNIT" maxlength="15" />
                    </div>
                    <div class="form-group">
                        <label for="fELEMENT">Element</label>
                        <input class="form-control" id="fELEMENT" name="ELEMENT" maxlength="150" />
                    </div>
                    <div class="form-group" style="grid-column:1/-1;">
                        <label for="fRFI_DESCRIPTION">Description</label>
                        <textarea class="form-control" id="fRFI_DESCRIPTION" name="RFI_DESCRIPTION" rows="3"></textarea>
                    </div>
                    <div class="form-group">
                        <label for="fDate">Date</label>
                        <input class="form-control" id="fDate" name="Date" type="date" />
                    </div>
                    <div class="form-group">
                        <label for="fTime">Time</label>
                        <input class="form-control" id="fTime" name="Time" type="time" />
                    </div>
                    <div class="form-group">
                        <label for="fCOMPANY_INSPECTION_LEVEL">Company Insp Level</label>
                        <input class="form-control" id="fCOMPANY_INSPECTION_LEVEL" name="COMPANY_INSPECTION_LEVEL" maxlength="4" />
                    </div>
                    <div class="form-group">
                        <label for="fCONTRACTOR_INSPECTION_LEVEL">Contractor Insp Level</label>
                        <input class="form-control" id="fCONTRACTOR_INSPECTION_LEVEL" name="CONTRACTOR_INSPECTION_LEVEL" maxlength="4" />
                    </div>
                    <div class="form-group">
                        <label for="fSUBCON_INSPECTION_LEVEL">SubCon Insp Level</label>
                        <input class="form-control" id="fSUBCON_INSPECTION_LEVEL" name="SUBCON_INSPECTION_LEVEL" maxlength="4" />
                    </div>
                    <div class="form-group">
                        <label for="fTR_QC">TR QC</label>
                        <input class="form-control" id="fTR_QC" name="TR_QC" maxlength="30" />
                    </div>
                    <div class="form-group">
                        <label for="fSUB_CON_QC">Sub Con QC</label>
                        <input class="form-control" id="fSUB_CON_QC" name="SUB_CON_QC" maxlength="30" />
                    </div>
                    <div class="form-group">
                        <label for="fPID">PID</label>
                        <input class="form-control" id="fPID" name="PID" maxlength="30" />
                    </div>
                    <div class="form-group">
                        <label for="fPMT">PMT</label>
                        <input class="form-control" id="fPMT" name="PMT" maxlength="30" />
                    </div>
                    <div class="form-group">
                        <label for="fINSPECTION_STATUS">Inspection Status</label>
                        <input class="form-control" id="fINSPECTION_STATUS" name="INSPECTION_STATUS" maxlength="50" />
                    </div>
                    <div class="form-group">
                        <label for="fREFRENCE_DRAWING_No">Ref Drawing No</label>
                        <input class="form-control" id="fREFRENCE_DRAWING_No" name="REFRENCE_DRAWING_No" maxlength="50" />
                    </div>
                    <div class="form-group">
                        <label for="fSCAN_COPY">Scan Copy</label>
                        <input class="form-control" id="fSCAN_COPY" name="SCAN_COPY" maxlength="8" />
                    </div>
                    <div class="form-group" style="grid-column:1/-1;">
                        <label for="fREMARKS">Remarks</label>
                        <input class="form-control" id="fREMARKS" name="REMARKS" maxlength="100" />
                    </div>
                    <div class="form-group" style="grid-column:1/-1;">
                        <label for="fQR_Code_Link">QR Code Link</label>
                        <input class="form-control" id="fQR_Code_Link" name="QR_Code_Link" maxlength="500" />
                    </div>
                </div>
                <div class="modal-actions">
                    <button type="button" class="btn" onclick="closeEditModal()">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>

            <!-- PDF upload (separate form, only visible when editing an existing RFI) -->
            <div id="pdfSection" style="display:none; margin-top:16px; padding-top:14px; border-top:1px solid #e6f6fa;">
                <label style="font-weight:700; color:#176d8a; font-size:.95rem;">PDF Attachment</label>
                <div id="pdfExisting" style="display:none; margin:8px 0; align-items:center; gap:10px; flex-wrap:wrap;">
                    <a id="pdfOpenLink" href="#" target="_blank" class="btn btn-primary" style="padding:5px 10px; font-size:.85rem; text-decoration:none;">&#128196; Open <span id="pdfFileLabel"></span></a>
                    <a id="pdfDownloadLink" href="#" class="btn btn-outline" style="padding:5px 10px; font-size:.85rem; text-decoration:none;">⬇ Save</a>
                    <form method="post" asp-action="DeleteRfiFile" asp-controller="Home" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="rfiId" id="pdfDeleteRfiId" />
                        <button type="submit" class="btn btn-danger" style="padding:4px 10px; font-size:.8rem;" onclick="return confirm('Remove this PDF?');">Remove</button>
                    </form>
                </div>
                <form method="post" asp-action="UploadRfiFile" asp-controller="Home" enctype="multipart/form-data" style="margin-top:8px;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="rfiId" id="pdfUploadRfiId" />
                    <div style="display:flex; gap:8px; align-items:center; flex-wrap:wrap;">
                        <input type="file" name="pdfFile" accept=".pdf" class="form-control" style="flex:1 1 260px;" />
                        <button type="submit" class="btn btn-success" style="padding:6px 12px;">Upload PDF</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            try {
                var msg = document.getElementById('topFlashMsg');
                if (msg) { msg.tabIndex = -1; msg.focus(); window.scrollTo({ top: 0, behavior: 'smooth' }); }
            } catch (e) { }

            // Row count
            updateRowCount();
        });

        function byId(id) { return document.getElementById(id); }

        /* ── Searchable select widget ── */
        (function () {
            function makeSearchableSelect(sel) {
                if (!sel || sel.dataset.searchable) return;
                sel.dataset.searchable = '1';
                sel.style.display = 'none';
                var wrap = document.createElement('div');
                wrap.className = 'ss-wrap';
                if (sel.classList.contains('w350')) wrap.classList.add('w350');
                if (sel.classList.contains('w180')) wrap.classList.add('w180');
                sel.parentNode.insertBefore(wrap, sel);
                wrap.appendChild(sel);
                var input = document.createElement('input');
                input.type = 'text'; input.className = 'ss-input form-control';
                input.setAttribute('autocomplete', 'off'); input.setAttribute('spellcheck', 'false');
                wrap.appendChild(input);
                var list = document.createElement('div');
                list.className = 'ss-list'; wrap.appendChild(list);
                var items = [], highlighted = -1, open = false;
                function buildItems() { items = []; Array.from(sel.options).forEach(function (opt) { items.push({ value: opt.value, text: opt.text || opt.value }); }); }
                function syncInputText() { var idx = sel.selectedIndex; input.value = idx >= 0 && sel.options[idx] ? (sel.options[idx].text || sel.options[idx].value) : ''; }
                function render(filter) {
                    list.innerHTML = ''; highlighted = -1; var lc = (filter || '').toLowerCase(); var count = 0;
                    items.forEach(function (item, i) {
                        if (lc && !(item.text || '').toLowerCase().includes(lc)) return;
                        var div = document.createElement('div'); div.className = 'ss-item'; div.textContent = item.text; div.dataset.idx = String(i);
                        if (item.value === sel.value) div.classList.add('ss-active');
                        div.addEventListener('mousedown', function (e) { e.preventDefault(); pick(i); });
                        list.appendChild(div); count++;
                    });
                    if (!count) { var em = document.createElement('div'); em.className = 'ss-empty'; em.textContent = 'No matches'; list.appendChild(em); }
                }
                function openList() { if (open) return; open = true; wrap.classList.add('ss-open'); buildItems(); render(''); list.style.display = 'block'; }
                function closeList() {
                    if (!open) return; open = false; wrap.classList.remove('ss-open'); list.style.display = 'none';
                    if (sel.dataset.allowCustom === 'true') {
                        var typed = input.value.trim();
                        if (typed) {
                            var match = Array.from(sel.options).find(function (o) { return o.text === typed || o.value === typed; });
                            if (!match) {
                                var opt = document.createElement('option'); opt.value = typed; opt.text = typed;
                                sel.appendChild(opt);
                                sel.value = typed;
                                sel.dispatchEvent(new Event('change', { bubbles: true }));
                                buildItems();
                            } else { sel.value = match.value; }
                        }
                    }
                    syncInputText();
                }
                function pick(idx) { sel.selectedIndex = idx; syncInputText(); sel.dispatchEvent(new Event('change', { bubbles: true })); closeList(); }
                input.addEventListener('focus', function () { openList(); input.select(); });
                input.addEventListener('input', function () { render(input.value); });
                input.addEventListener('blur', function () { closeList(); });
                input.addEventListener('keydown', function (e) {
                    var visible = list.querySelectorAll('.ss-item');
                    if (e.key === 'ArrowDown') { e.preventDefault(); highlighted = Math.min(highlighted + 1, visible.length - 1); setHighlight(visible); }
                    else if (e.key === 'ArrowUp') { e.preventDefault(); highlighted = Math.max(highlighted - 1, 0); setHighlight(visible); }
                    else if (e.key === 'Enter') { e.preventDefault(); if (highlighted >= 0 && visible[highlighted]) pick(Number(visible[highlighted].dataset.idx)); else { closeList(); input.blur(); } }
                    else if (e.key === 'Escape') { closeList(); input.blur(); }
                });
                function setHighlight(visible) { visible.forEach(function (d, i) { d.classList.toggle('ss-highlight', i === highlighted); if (i === highlighted) d.scrollIntoView({ block: 'nearest' }); }); }
                buildItems(); syncInputText();
            }
            document.querySelectorAll('select.searchable-select').forEach(makeSearchableSelect);
        })();

        /* ── Project filter auto-submit ── */
        var projSel = byId('projectSelect');
        if (projSel) projSel.addEventListener('change', function () { byId('rfiFilterForm').submit(); });

        /* ── Keep bulk download link in sync (defensive – page reloads on change anyway) ── */
        if (projSel) projSel.addEventListener('change', function () {
            var bdl = byId('bulkDownloadPdfBtn');
            if (bdl) bdl.href = '/Home/BulkDownloadRfiPdfs?projectId=' + encodeURIComponent(projSel.value);
        });

        /* ── Search ── */
        var searchBox = byId('searchBox');
        if (searchBox) {
            searchBox.addEventListener('input', function () {
                var term = this.value.toLowerCase();
                var rows = document.querySelectorAll('#rfiTable tbody tr');
                rows.forEach(function (tr) { tr.style.display = tr.textContent.toLowerCase().includes(term) ? '' : 'none'; });
                updateRowCount();
            });
        }

        /* ── Row count ── */
        function updateRowCount() {
            var rows = document.querySelectorAll('#rfiTable tbody tr');
            var n = 0;
            rows.forEach(function (tr) { if (tr.style.display !== 'none') n++; });
            var c = byId('rowCount');
            if (c) c.textContent = n + ' record(s)';
        }

        /* ── Bulk fill Inspection Status ── */
        var bulkFillBtn = byId('bulkFillInspBtn');
        if (bulkFillBtn) {
            bulkFillBtn.addEventListener('click', function () {
                var sel = byId('bulkInspStatus');
                var newStatus = sel ? sel.value : '';
                if (!newStatus) { alert('Please select an Inspection Status value first.'); return; }
                var rows = document.querySelectorAll('#rfiTable tbody tr');
                var ids = [];
                rows.forEach(function (tr) { if (tr.style.display !== 'none') ids.push(tr.dataset.id); });
                if (ids.length === 0) { alert('No visible rows to update.'); return; }
                if (!confirm('Set Inspection Status to "' + newStatus + '" for ' + ids.length + ' filtered row(s)?')) return;
                var token = document.querySelector('input[name=__RequestVerificationToken]').value;
                fetch('/Home/BulkUpdateInspectionStatus', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                    body: JSON.stringify({ ids: ids.map(Number), status: newStatus })
                })
                .then(function (resp) { return resp.json(); })
                .then(function (data) {
                    if (data && data.success) {
                        rows.forEach(function (tr) {
                            if (tr.style.display !== 'none') {
                                tr.dataset.inspStatus = newStatus;
                                var cell = tr.querySelector('td[data-field="inspStatus"]');
                                if (cell) cell.textContent = newStatus;
                            }
                        });
                        alert('Updated ' + data.count + ' row(s).');
                    } else {
                        alert('Update failed: ' + (data.message || 'Unknown error'));
                    }
                })
                .catch(function (err) { alert('Request failed: ' + err); });
            });
        }

        /* ── Download Excel ── */
        var dlBtn = byId('downloadBtn');
        if (dlBtn) {
            dlBtn.addEventListener('click', function () {
                var projId = projSel ? projSel.value : '';
                var q = searchBox ? searchBox.value : '';
                var url = '/Home/ExportRfi?projectId=' + encodeURIComponent(projId) + '&q=' + encodeURIComponent(q);
                window.location.href = url;
            });
        }

        /* ── Delete ── */
        var pendingDeleteId = null;
        document.querySelectorAll('.delete-rfi').forEach(function (btn) {
            btn.addEventListener('click', function () {
                pendingDeleteId = this.dataset.id;
                byId('confirmDeleteRfiMessage').textContent = 'Are you sure you want to delete RFI #' + pendingDeleteId + '?';
                byId('confirmDeleteRfiModal').style.display = 'flex';
            });
        });
        function closeDeleteModal() { byId('confirmDeleteRfiModal').style.display = 'none'; pendingDeleteId = null; }
        function confirmRfiDelete() {
            if (!pendingDeleteId) return;
            byId('deleteRfiId').value = pendingDeleteId;
            byId('deleteRfiForm').submit();
        }

        /* ── Add / Edit modal ── */
        function openAddModal() {
            byId('rfiEditTitle').textContent = 'Add RFI';
            byId('rfiForm').reset();
            byId('fRFI_ID').value = '0';
            byId('fRFI_Project_No').value = projSel ? projSel.value : '';
            byId('pdfSection').style.display = 'none';
            byId('rfiEditModal').style.display = 'flex';
        }

        function editRfi(btn) {
            var tr = btn.closest('tr');
            byId('rfiEditTitle').textContent = 'Edit RFI #' + tr.dataset.id;
            byId('fRFI_ID').value = tr.dataset.id;
            byId('fRFI_Project_No').value = tr.dataset.projectId || '';
            byId('fDISCIPLINE').value = tr.dataset.discipline || '';
            byId('fSub_Contractor').value = tr.dataset.subContractor || '';
            byId('fSubDiscipline').value = tr.dataset.subDiscipline || '';
            byId('fRFI_CONTRACTOR').value = tr.dataset.rfiContractor || '';
            byId('fSubCon_RFI_No').value = tr.dataset.subconRfiNo || '';
            byId('fEPMNo').value = tr.dataset.epmNo || '';
            byId('fSATIP').value = tr.dataset.satip || '';
            byId('fSAIC').value = tr.dataset.saic || '';
            byId('fACTIVITY').value = tr.dataset.activity || '';
            byId('fRFI_LOCATION').value = tr.dataset.location || '';
            byId('fUNIT').value = tr.dataset.unit || '';
            byId('fELEMENT').value = tr.dataset.element || '';
            byId('fRFI_DESCRIPTION').value = tr.dataset.description || '';
            byId('fDate').value = tr.dataset.date || '';
            byId('fTime').value = tr.dataset.time || '';
            byId('fCOMPANY_INSPECTION_LEVEL').value = tr.dataset.companyInsp || '';
            byId('fCONTRACTOR_INSPECTION_LEVEL').value = tr.dataset.contractorInsp || '';
            byId('fSUBCON_INSPECTION_LEVEL').value = tr.dataset.subconInsp || '';
            byId('fTR_QC').value = tr.dataset.trQc || '';
            byId('fSUB_CON_QC').value = tr.dataset.subConQc || '';
            byId('fPID').value = tr.dataset.pid || '';
            byId('fPMT').value = tr.dataset.pmt || '';
            byId('fINSPECTION_STATUS').value = tr.dataset.inspStatus || '';
            byId('fREFRENCE_DRAWING_No').value = tr.dataset.refDrawing || '';
            byId('fSCAN_COPY').value = tr.dataset.scanCopy || '';
            byId('fREMARKS').value = tr.dataset.remarks || '';
            byId('fQR_Code_Link').value = tr.dataset.qrCode || '';

            // PDF section
            var pdfSec = byId('pdfSection');
            var pdfEx = byId('pdfExisting');
            pdfSec.style.display = 'block';
            byId('pdfUploadRfiId').value = tr.dataset.id;
            byId('pdfDeleteRfiId').value = tr.dataset.id;
            if (tr.dataset.blobName) {
                pdfEx.style.display = 'flex';
                byId('pdfFileLabel').textContent = tr.dataset.fileName || 'PDF';
                byId('pdfOpenLink').href = '/Home/OpenRfiFile?id=' + tr.dataset.id;
                byId('pdfDownloadLink').href = '/Home/DownloadRfiFile?id=' + tr.dataset.id;
            } else {
                pdfEx.style.display = 'none';
            }

            byId('rfiEditModal').style.display = 'flex';
        }

        function closeEditModal() { byId('rfiEditModal').style.display = 'none'; }

        // Close modals on Escape
        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') { closeDeleteModal(); closeEditModal(); }
        });

        /* ── Inline PDF upload from table row ── */
        (function () {
            var fileInput = byId('inlinePdfFileInput');
            var rfiIdInput = byId('inlinePdfRfiId');
            var uploadForm = byId('inlinePdfUploadForm');
            document.querySelectorAll('.btn-upload-pdf').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    rfiIdInput.value = this.dataset.rfiId;
                    fileInput.value = '';
                    fileInput.click();
                });
            });
            if (fileInput) {
                fileInput.addEventListener('change', function () {
                    if (this.files && this.files.length > 0) {
                        uploadForm.submit();
                    }
                });
            }
        })();
    </script>
</body>
</html>
