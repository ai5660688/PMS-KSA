            modelField = Model?.FitupReportField ?? string.Empty,
            modelThreaded = Model?.FitupReportThreaded ?? string.Empty,
            modelCombined = string.IsNullOrWhiteSpace(string.Join(" / ", new[] { Model?.FitupReportShop ?? string.Empty, Model?.FitupReportField ?? string.Empty, Model?.FitupReportThreaded ?? string.Empty }.Where(x => !string.IsNullOrWhiteSpace(x)))) ? string.Empty : string.Join(" / ", new[] { Model?.FitupReportShop ?? string.Empty, Model?.FitupReportField ?? string.Empty, Model?.FitupReportThreaded ?? string.Empty }.Where(x => !string.IsNullOrWhiteSpace(x))),
            modelHeader = Model?.FitupReportHeader ?? string.Empty
        };
    }
    <script id="qrDefaultsData" type="application/json">
        @Html.Raw(System.Text.Json.JsonSerializer.Serialize(qrDefaultsObj))
    </script>

    <script>
        // --- Header RFI / Report sync and RFI options rebuilding (adapted from DailyWelding) ---
        (function(){
            try {
                const form = document.getElementById('filterForm');
                const hv = document.getElementById('headerViewSelect');
                const proj = document.querySelector('select[name="projectId"]');
                const loc = document.getElementById('locationSelect');
                const rfiSel = document.getElementById('rfiSelect');
                const repCombined = document.getElementById('fitupReportCombinedInput');
                const repSingle = document.getElementById('fitupReportHeaderInput');
                const reportLabel = document.getElementById('fitupReportLabel');

                const qrDefaults = JSON.parse(document.getElementById('qrDefaultsData').textContent);

                // Cache original full RFI options for rebuilding
                const originalRfiOptions = rfiSel ? Array.from(rfiSel.options).map(o=>({ value: o.value, text: o.text })) : null;

                function rebuildRfiOptions(prefixes){
                    if(!rfiSel || !originalRfiOptions) return;
                    if(!prefixes){
                        rfiSel.innerHTML = '';
                        originalRfiOptions.forEach(item => {
                            const opt = document.createElement('option'); opt.value = item.value; opt.text = item.text; rfiSel.appendChild(opt);
                        });
                        return;
                    }
                    const prefs = Array.isArray(prefixes) ? prefixes : [prefixes];
                    let ordered = [];
                    prefs.forEach(p => {
                        originalRfiOptions.forEach(o => {
                            if((o.text||'').startsWith(p) && !ordered.some(x=> x.value===o.value)) ordered.push(o);
                        });
                    });
                    if(ordered.length===0){
                        prefs.forEach(p=>{
                            const lower = p.toLowerCase();
                            originalRfiOptions.forEach(o=>{
                                if((o.text||'').toLowerCase().startsWith(lower) && !ordered.some(x=> x.value===o.value)) ordered.push(o);
                            });
                        });
                    }
                    if(ordered.length===0){ originalRfiOptions.forEach(o=>{ if(!ordered.some(x=> x.value===o.value)) ordered.push(o); }); }

                    // Try to extract dates and sort desc
                    function extractDateFromText(txt){
                        if(!txt) return null;
                        const isoMatch = txt.match(/(\d{4}-\d{2}-\d{2})/);
                        if(isoMatch){ const d = new Date(isoMatch[1]); if(!isNaN(d)) return d; }
                        const dmyMatch = txt.match(/(\b\d{1,2}-[A-Za-z]{3}-\d{4}\b)/);
                        if(dmyMatch){ try{ const parts = dmyMatch[1].split('-'); const day = parseInt(parts[0],10); const mon = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'].indexOf(parts[1].substr(0,3)); const year = parseInt(parts[2],10); if(mon>=0){ const dt = new Date(year, mon, day); if(!isNaN(dt)) return dt; } }catch{} }
                        const slashMatch = txt.match(/(\b\d{1,2}[\/\.]\d{1,2}[\/]\d{4}\b)/);
                        if(slashMatch){ try{ const s = slashMatch[1].replace(/\./g,'/'); const parts = s.split('/'); const day = parseInt(parts[0],10); const month = parseInt(parts[1],10)-1; const year = parseInt(parts[2],10); return new Date(year, month, day); }catch(e){} }
                        return null;
                    }

                    const mapped = ordered.map(o=>({ v:o, d: extractDateFromText(o.text) }));
                    if(mapped.some(m=> m.d)){ mapped.sort((a,b)=>{ if(a.d && b.d) return b.d - a.d; if(a.d) return -1; if(b.d) return 1; return 0; }); ordered = mapped.map(m=>m.v); }

                    const cur = rfiSel.value || '';
                    rfiSel.innerHTML = '';
                    ordered.forEach(item => { const opt = document.createElement('option'); opt.value = item.value; opt.text = item.text; rfiSel.appendChild(opt); });
                    if(cur){ const found = Array.from(rfiSel.options).some(o=> o.value===cur); if(found) rfiSel.value = cur; }
                }

                // Utilities
                function toTrimmed(val){ if(val === null || val === undefined) return ''; return String(val).trim(); }
                function pickFirstNonEmpty(values){ for(let i=0;i<values.length;i++){ const candidate = toTrimmed(values[i]); if(candidate) return candidate; } return ''; }
                function normalizeLocation(value){ const raw = toTrimmed(value).toLowerCase(); if(raw === 'shop') return 'Shop'; if(raw === 'field') return 'Field'; if(raw === 'threaded') return 'Threaded'; if(raw === 'all' || !raw) return 'All'; return raw.charAt(0).toUpperCase() + raw.slice(1); }

                const fallbackSingleValue = pickFirstNonEmpty([repSingle ? repSingle.value : '', qrDefaults.single, qrDefaults.modelHeader]);
                let fallbackCombinedValue = pickFirstNonEmpty([repCombined ? repCombined.value : '', qrDefaults.combined, qrDefaults.modelCombined]);
                if(!fallbackCombinedValue){ fallbackCombinedValue = [qrDefaults.shop, qrDefaults.field, qrDefaults.threaded].map(x=>toTrimmed(x)).filter(Boolean).join(' / ') || fallbackSingleValue; }

                const headerCache = {};
                let currentLocationKey = normalizeLocation(loc ? loc.value : 'All');
                headerCache.All = repCombined ? repCombined.value || fallbackCombinedValue : fallbackCombinedValue;
                if(repSingle && currentLocationKey !== 'All'){
                    headerCache[currentLocationKey] = repSingle.value || fallbackSingleValue;
                }

                const rfiCache = {};
                if(rfiSel){ rfiCache[currentLocationKey] = rfiSel.value || ''; }

                function getHeaderDefault(key){
                    switch(key){
                        case 'Shop': return pickFirstNonEmpty([qrDefaults.shop, qrDefaults.modelShop, fallbackSingleValue]);
                        case 'Field': return pickFirstNonEmpty([qrDefaults.field, qrDefaults.modelField, fallbackSingleValue]);
                        case 'Threaded': return pickFirstNonEmpty([qrDefaults.threaded, qrDefaults.modelThreaded, fallbackSingleValue]);
                        case 'All': default: return pickFirstNonEmpty([fallbackCombinedValue, fallbackSingleValue]);
                    }
                }

                function rememberHeaderValue(key){ if(!key) return; if(key === 'All' && repCombined){ headerCache.All = repCombined.value || ''; } else if(key !== 'All' && repSingle){ headerCache[key] = repSingle.value || ''; } }
                function rememberRfiValue(key){ if(!rfiSel || !key) return; rfiCache[key] = rfiSel.value || ''; }

                function applyRfiForLocation(key){ if(!rfiSel) return; const before = rfiSel.value; const prefixMap = { Shop: ['WS | '], Field: ['FW | '], Threaded: ['FW | '] };
                    rebuildRfiOptions(prefixMap[key] || null);
                    let nextValue;
                    if(Object.prototype.hasOwnProperty.call(rfiCache, key)) nextValue = rfiCache[key];
                    if(nextValue && !Array.from(rfiSel.options).some(o => o.value === nextValue)) nextValue = '';
                    if((nextValue === undefined || nextValue === '') && rfiSel.options.length){ nextValue = rfiSel.options[0].value; }
                    if(nextValue !== undefined){ rfiSel.value = nextValue; rfiCache[key] = rfiSel.value || ''; } else { rfiSel.value = ''; rfiCache[key] = ''; }
                    if(rfiSel.value !== before){ try{ rfiSel.dispatchEvent(new Event('change',{ bubbles:true })); }catch(e){} }
                }

                function applyHeaderUi(key){ const locKey = key || 'All'; const isAll = locKey === 'All'; if(reportLabel){ reportLabel.textContent = isAll ? 'Fit-up Report (WS/FW/TH)' : 'Fit-up Report'; reportLabel.setAttribute('for', isAll ? 'fitupReportCombinedInput' : 'fitupReportHeaderInput'); }
                    if(repCombined){ repCombined.style.display = isAll ? '' : 'none'; repCombined.disabled = !isAll; if(isAll){ const hasCached = Object.prototype.hasOwnProperty.call(headerCache, 'All'); const val = hasCached ? headerCache.All : getHeaderDefault('All'); headerCache.All = val; repCombined.value = val || ''; } }
                    if(repSingle){ repSingle.style.display = isAll ? 'none' : ''; repSingle.disabled = isAll; if(!isAll){ const hasCached = Object.prototype.hasOwnProperty.call(headerCache, locKey); const val = hasCached ? headerCache[locKey] : getHeaderDefault(locKey); headerCache[locKey] = val; repSingle.value = val || ''; } }
                    applyRfiForLocation(locKey);
                }

                applyHeaderUi(currentLocationKey);

                if(loc){ loc.addEventListener('change', function(){ const nextKey = normalizeLocation(loc.value); rememberHeaderValue(currentLocationKey); rememberRfiValue(currentLocationKey); currentLocationKey = nextKey; applyHeaderUi(currentLocationKey); }); }
                if(repCombined){ repCombined.addEventListener('input', function(){ headerCache.All = repCombined.value || ''; }); }
                if(repSingle){ repSingle.addEventListener('input', function(){ if(currentLocationKey !== 'All'){ headerCache[currentLocationKey] = repSingle.value || ''; } }); }
                if(rfiSel){ rfiSel.addEventListener('change', function(){ rfiCache[currentLocationKey] = rfiSel.value || ''; }); }

            } catch (e) { console.debug('Header RFI sync init failed', e); }
        })();
    </script>

    <script src="~/js/dailyfitup-dwg.js" asp-append-version="true" defer></script>
