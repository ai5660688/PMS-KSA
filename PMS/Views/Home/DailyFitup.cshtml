@model PMS.Models.DfrDailyFitupViewModel
@{
    Layout = null;
    var antiForgery = Html.AntiForgeryToken();
    var headerView = string.IsNullOrWhiteSpace(Model.HeaderView)
        ? "DWG"
        : Model.HeaderView!.Trim();
    // Removed Released DFR (AllHold) mapping
    var headerViewDisplay = headerView; // direct
    // Prepare values for date inputs
    string dateFilterSubmitValue = string.Empty;
    if (!string.IsNullOrWhiteSpace(Model.SearchFitupDate) && DateTime.TryParse(Model.SearchFitupDate, out var _dfParsed))
    {
        dateFilterSubmitValue = _dfParsed.ToString("yyyy-MM-dd"); // for HTML date input
    }
    string fitupHeaderDateValue = Model.FitupDateHeader ?? string.Empty; // expecting dd-MMM-yyyy hh:mm tt
    if (!string.IsNullOrWhiteSpace(fitupHeaderDateValue) && DateTime.TryParse(fitupHeaderDateValue, out var _fhParsed))
    {
        // datetime-local expects: yyyy-MM-dd'T'HH:mm (24h)
        fitupHeaderDateValue = _fhParsed.ToString("yyyy-MM-dd'T'HH:mm");
    }

    // Prepare sorted lists to ensure consistent ordering on client
    var sortedLocationOptions = (Model.LocationOptions ?? new List<string>()).ToList(); // preserve DB order by LO_ID; do not sort alphabetically
    var jAddOptionsOrdered = (Model.JAddOptions ?? new List<string>()).ToList(); // preserve DB order by Add_ID; do not sort alphabetically
    // IMPORTANT: preserve server-provided weld type order (by PMS_Weld_Type_tbl.W_Type_ID ASC); do NOT sort here
    var weldTypeOptionsOrdered = (Model.WeldTypeOptions ?? new List<string>()).ToList();
    // Preserve controller order (MATD_SN asc) - do not resort here
    var sortedMaterialDescriptions = (Model.MaterialDescriptions ?? new List<string>()).ToList();
    // Preserve controller order (Material_tbl.MAT_SN asc) - do NOT sort here
    var sortedMaterialGrades = (Model.MaterialGrades ?? new List<string>()).ToList();

    // Precompute default weld type selections for reuse in UI + JS serialization
    var defaultWeldTypeList = (Model.DefaultWeldTypes != null && Model.DefaultWeldTypes.Count > 0)
        ? Model.DefaultWeldTypes.ToList()
        : (!string.IsNullOrWhiteSpace(Model.DefaultWeldType)
            ? new List<string> { Model.DefaultWeldType }
            : ((Model.WeldTypeOptions != null && Model.WeldTypeOptions.Count > 0)
                ? new List<string> { Model.WeldTypeOptions[0] }
                : new List<string> { "BW", "SW", "BR", "LET", "FW", "SP", "RP", "SOF", "DM" }));

    var rfiOptions = Model.RfiOptions ?? new List<PMS.Models.RfiOption>();
    // Use full RFI Display for header dropdown (preserve prefixes like 'WS | ', 'FW | ', 'TH | ')
    var rfiForHeader = rfiOptions
        .Select(rr => new
        {
            Id = rr.Id,
            Display = string.IsNullOrWhiteSpace(rr.Display) ? (rr.Id.ToString() ?? string.Empty) : rr.Display
        })
        .ToList();

    // If TH weld type exists in options, ensure 'Threaded' appears in location options (header only)
    var hasThWeld = weldTypeOptionsOrdered.Any(wt => !string.IsNullOrWhiteSpace(wt) && wt.IndexOf("TH", StringComparison.OrdinalIgnoreCase) >= 0);
    if (hasThWeld && !sortedLocationOptions.Any(x => string.Equals(x, "Threaded", StringComparison.OrdinalIgnoreCase))) { sortedLocationOptions.Add("Threaded"); }
    var showConfirmButton = string.Equals(headerView, "Date", StringComparison.OrdinalIgnoreCase);
}

<!DOCTYPE html>
<html lang="en">
<head>
    <title>PMS - Daily Fit-up</title>
    <link rel="icon" type="image/png" href="~/img/title_logo.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="~/css/DashboardStyle.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/DailyFitup.css" asp-append-version="true" />
</head>
<body>
    @await Html.PartialAsync("~/Views/Shared/_DashboardHeader.cshtml")

    <div class="fitup-header">
        <form method="get" asp-action="DailyFitup" asp-controller="Home" id="filterForm">
            <input type="hidden" name="doLoad" id="doLoadInput" value="@Context.Request.Query["doLoad"].ToString()" />
            <div class="row">
                <label for="projectSelect">Project No.</label>
                <select name="projectId" id="projectSelect" class="header-fixed w350 searchable-select" asp-for="SelectedProjectId" asp-items="@(new SelectList(Model.Projects.Select(p => new { Id = p.Id, Display = p.Id + " - " + p.Name }), "Id", "Display", Model.SelectedProjectId))"></select>
                <label for="headerViewSelect">View</label>
                <select name="headerView" id="headerViewSelect" class="header-fixed view-select">
                    @{
                        string[] hvOpts = new[] { "DWG", "Date", "Report" };
                        foreach (var hv in hvOpts)
                        {
                            if (string.Equals(hv, headerView, System.StringComparison.OrdinalIgnoreCase))
                            {
                                <option value="@hv" selected="selected">@hv</option>
                            }
                            else
                            {
                                <option value="@hv">@hv</option>
                            }
                        }
                    }
                </select>
                <label for="locationSelect">Location</label>
                <select name="location" id="locationSelect">
                    @{
                        // Keep All/Shop/Field choices for header behavior and include 'Threaded' if TH weld type exists
                        var locs = hasThWeld ? new[] { "All", "Shop", "Field", "Threaded" } : new[] { "All", "Shop", "Field" };
                        foreach (var loc in locs)
                        {
                            if (string.Equals(Model.SelectedLocation, loc, System.StringComparison.OrdinalIgnoreCase))
                            {
                                <option value="@loc" selected="selected">@loc</option>
                            }
                            else
                            {
                                <option value="@loc">@loc</option>
                            }
                        }
                    }
                </select>
                @if (headerView == "DWG")
                {
                    <label for="layoutSelect">Layout</label>
                    <select name="layout" id="layoutSelect" class="header-fixed w130 searchable-select">
                        @foreach (var l in Model.LayoutOptions ?? new List<string>())
                        {
                            if (string.Equals(l, Model.SearchLayout, System.StringComparison.OrdinalIgnoreCase))
                            {
                                <option value="@l" selected="selected">@l</option>
                            }
                            else
                            {
                                <option value="@l">@l</option>
                            }
                        }
                    </select>
                    <label for="sheetSelect">Sheet</label>
                    <select name="sheet" id="sheetSelect" class="header-fixed searchable-select">
                        @foreach (var s in Model.SheetOptions ?? new List<string>())
                        {
                            if (string.Equals(s, Model.SearchSheet, System.StringComparison.OrdinalIgnoreCase))
                            {
                                <option value="@s" selected="selected">@s</option>
                            }
                            else
                            {
                                <option value="@s">@s</option>
                            }
                        }
                        }
                    </select>
                    if (!string.IsNullOrWhiteSpace(Model.SearchLayout) && string.IsNullOrWhiteSpace(Model.SearchSheet))
                    {
                        <span class="hint">All sheets for layout will be loaded</span>
                    }
                }
                else if (headerView == "Date")
                {
                    <label class="alt-filter-label" for="fitupDateFilter">Fit-up Date</label>
                    <input id="fitupDateFilter" type="date" name="fitupDateFilter" class="header-fixed w150" value="@dateFilterSubmitValue" />
                }
                else if (headerView == "Report")
                {
                    <label class="alt-filter-label" for="fitupReportFilter">Fit-up Report</label>
                    <input id="fitupReportFilter" name="fitupReportFilter" class="header-fixed w130" value="@Model.SearchFitupReport" placeholder="Report No" />
                }
            </div>
            <div class="row ref-line">
                <div class="ref-boxes">
                    <div class="ref-box"><span>Line Class: @Model.LineClass</span></div>
                    <div class="ref-box"><span>Material: @Model.LineMaterial</span></div>
                    <div class="ref-box"><span>Category: @Model.LineCategory</span></div>
                    <div class="ref-box"><span>RT Shop: @(Model.RtShop.HasValue ? (Model.RtShop.Value * 100).ToString("0.##") + "%" : null)</span></div>
                    <div class="ref-box"><span>RT Field: @(Model.RtField.HasValue ? (Model.RtField.Value * 100).ToString("0.##") + "%" : null)</span></div>
                    <div class="ref-box"><span>PWHT Y/N: @(Model.PwhtYN == true ? "Y" : Model.PwhtYN == false ? "N" : null)</span></div>
                    <div class="ref-box"><span>PWHT >20mm: @(Model.Pwht20mm.HasValue ? (Model.Pwht20mm.Value ? "Y" : "N") : null)</span></div>
                    <div class="ref-box"><span>REV: @Model.LsRev</span></div>
                </div>
            </div>
            <div class="row section-band">
                @if (Model.SelectedLocation == "All")
                {
                    <label for="fitupReportCombinedInput">Fit-up Report (WS/FW/TH)</label>
                    <input id="fitupReportCombinedInput" name="FitupReportCombined" class="header-fixed w230" value="@(                                                                                                              string.IsNullOrWhiteSpace(Model.FitupReportShop) && string.IsNullOrWhiteSpace(Model.FitupReportField) && string.IsNullOrWhiteSpace(Model.FitupReportThreaded)
                                                                                                              ? string.Empty
                                                                                                              : string.Join(" / ", new[] { Model.FitupReportShop ?? string.Empty, Model.FitupReportField ?? string.Empty, Model.FitupReportThreaded ?? string.Empty })
                                                                                                           )" title="Workshop / Field / Threaded" />
                }
                else
                {
                    <label for="fitupReportHeaderInput">Fit-up Report</label>
                    <input id="fitupReportHeaderInput" name="FitupReportHeader" class="header-fixed w110" value="@Model.FitupReportHeader" />
                }
                <label for="rfiSelect">RFI No.</label>
                <select name="SelectedRfiId" asp-for="SelectedRfiId" id="rfiSelect" class="header-fixed w580" asp-items="@(new SelectList(rfiForHeader, "Id", "Display", Model.SelectedRfiId))">
                    <option value="" selected="@(Model.SelectedRfiId == null || string.IsNullOrWhiteSpace(Model.SelectedRfiId.ToString()) ? "selected" : null)"></option>
                </select>
                <label for="FitupDate">Fit-up Date</label>
                <input id="fitupDateInput" type="datetime-local" name="date" class="header-fixed w180" value="@fitupHeaderDateValue" />
                <label for="tackerSelect">Tacker</label>
                <select name="SelectedTacker" asp-for="SelectedTacker" id="tackerSelect" class="header-fixed w110 searchable-select" asp-items="@(new SelectList(Model.TackerOptions, "Symbol", "Symbol", Model.SelectedTacker))"></select>
            </div>
        </form>
        <div class="weld-filters" id="weldFilters">
            <strong>Weld Type</strong>
            @{
                // Derive dynamic list of weld types (project / dataset specific or fallback set)
                var dynamicWeldTypes = (weldTypeOptionsOrdered != null && weldTypeOptionsOrdered.Count > 0)
                ? weldTypeOptionsOrdered
                : new List<string> { "BW", "SW", "BR", "LET", "FW", "SP", "RP", "SOF", "DM", "TH", "FJ" };
                // Default checked precedence:
                //1. If a list DefaultWeldTypes is provided and non-empty, use exactly those
                //2. Else if a single DefaultWeldType provided, use that
                //3. Else if project-specific WeldTypeOptions exist, use only the first (avoid auto-checking all)
                //4. Else fallback to legacy subset for generic list
                var defaultChecked = new HashSet<string>(defaultWeldTypeList ?? new List<string> { });
                foreach (var wt in dynamicWeldTypes)
                {
                    var isChecked = defaultChecked.Contains(wt);
                    if (isChecked)
                    {
                        <label title="@wt"><input type="checkbox" class="wt-filter" value="@wt" checked="checked" />@wt</label>
                    }
                    else
                    {
                        <label title="@wt"><input type="checkbox" class="wt-filter" value="@wt" />@wt</label>
                    }
                }
            }
            <div class="wf-actions">
                <button type="button" id="wfAll">All</button>
                <button type="button" id="wfNone">None</button>
                <button type="button" id="wfDefault">Default</button>
            </div>
        </div>
        <button type="button" id="filterToggle" class="filter-toggle-btn" aria-expanded="true">Hide Filters</button>
    </div>

    <div class="toolbar">
        <div class="tb-left">
            @if (headerView == "DWG")
            {
                <button id="addRowBtn" type="button" class="btn btn-primary">Add Joint</button>
            }
            <button id="saveAllBtn" type="button" class="btn btn-primary">Save</button>
            <button id="completeBtn" type="button" class="btn btn-primary">Daily Fit-up Completed</button>
            @if (showConfirmButton)
            {
                <button id="confirmBtn" type="button" class="btn btn-primary">Daily Fit-up Confirmed</button>
            }
            @* New DWG buttons *@
            @if (headerView == "DWG")
            {
                <button id="openDwgBtn" type="button" class="btn btn-outline">Open DWG</button>
            }
            <button id="downloadDwgBtn" type="button" class="btn btn-outline">Download DWG</button>
            <span id="statusMsg" style="font-weight:600; margin-left:10px;"></span>
        </div>
        <div class="tb-title">Daily Fit-up (@headerViewDisplay)</div>
        <div class="tb-right">
            @if (headerView != "DWG")
            {
                <button id="clearRemarksBtn" type="button" class="btn btn-primary">Clear Remarks</button>
                <button id="confirmAllBtn" type="button" class="btn btn-outline">Confirm All</button>
                <button id="unconfirmAllBtn" type="button" class="btn btn-outline">Unconfirm All</button>
            }
            <button id="loadBtn" type="submit" form="filterForm" name="doLoad" value="1" class="btn btn-primary">Load</button>
        </div>
    </div>

    @if (Model?.IsTruncated == true && Model.RowLimit > 0)
    {
        <div class="alert info" style="margin:8px 16px;">Showing first @Model.RowLimit rows. Refine filters to view a smaller, complete set.</div>
    }

    @* Client-side placeholder for pending reload *@
    @{
        var showClientNoData = (Model?.Rows == null || Model.Rows.Count == 0);
    }
    <div id="clientNoData" class="no-data" style="@(showClientNoData ? string.Empty : "display:none;")">
        No data loaded. @if(headerView=="DWG"){
        <text>Select Layout (and optionally Sheet) then press Load.</text>
                } else if (headerView == "Date")
        {

            <text>Select Date view then press Load.</text>
        }
        else if (headerView == "Report")
        {

            <text>Select Report view, enter a report filter (optional) then press Load.</text>
        }
    </div>

    @if (Model?.Rows == null || Model.Rows.Count == 0)
    {
    }
    else
    {
        <div class="scroll-sync" id="scrollSync">
            <div class="table-wrapper" id="tableWrapper">
                <div class="table-inner" id="tableInner">
                    <table class="fitup" id="fitupTable">
                        <thead>
                            <tr>
                                <th class="col-sn">S/N</th>
                                @if (headerView != "DWG")
                                {
                                    <th class="col-layout">Layout</th>
                                }
                                <th class="col-location">Location</th>
                                <th class="col-jointno">Joint No.</th>
                                <th class="col-jadd">J-Add</th>
                                <th class="col-wtype">Weld Type</th>
                                <th class="col-sheet">Sheet</th>
                                <th class="col-rev">REV.</th>
                                <th class="col-spno">SP. No.</th>
                                <th class="col-dia">Dia. In.</th>
                                <th class="col-sch">Sch.</th>
                                <th class="col-matA">Material A</th>
                                <th class="col-matB">Material B</th>
                                <th class="col-gradeA">Grade A</th>
                                <th class="col-gradeB">Grade B</th>
                                <th class="col-heatA">Heat Number A</th>
                                <th class="col-heatB">Heat Number B</th>
                                <th class="col-frep">Fit-up Report</th>
                                <th class="col-rfi">RFI No.</th>
                                <th class="col-fdate">Fit-up Date</th>
                                <th class="col-wps">WPS</th>
                                <th class="col-tacker">Tack Welder</th>
                                <th class="col-olDia">OL Dia. In.</th>
                                <th class="col-olSch">OL Sch.</th>
                                <th class="col-olThick">Actual Thick.</th>
                                <th class="col-del">Deleted</th>
                                <th class="col-can">Cancelled</th>
                                <th class="col-conf">Confirmed</th>
                                <th class="col-remarks">Remarks</th>
                                <th class="col-updby">Updated By</th>
                                <th class="col-upddate">Updated Date</th>
                                @if (headerView != "DWG")
                                {
                                    <th class="col-dwg">DWG</th>
                                }
                                <th class="col-clear">Clear</th>
                                <th class="col-delbtn">Delete</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var sn = 0;
                                foreach (var r in Model.Rows)
                                {
                                    var locked = r.FitupConfirmed;
                                    string rowFitupDateVal = r.FitupDate ?? string.Empty;
                                    if (!string.IsNullOrWhiteSpace(rowFitupDateVal) && DateTime.TryParse(rowFitupDateVal, out var _rowFdt))
                                    {
                                        rowFitupDateVal = _rowFdt.ToString("yyyy-MM-dd'T'HH:mm");
                                    }
                                    <tr data-id="@r.JointId" data-lineclass="@r.LineClass" class="@(locked ? "locked" : null)">
                                        <td class="col-sn">@(++sn)</td>
                                        @if (headerView != "DWG")
                                        {
                                            <td class="col-layout">@r.LayoutNumber</td>
                                        }
                                        <td class="col-location">
                                            @if (locked)
                                            {
                                                <select data-name="Location" name="Location" id="Location_@r.JointId" disabled>
                                                    <option value="@r.Location">@r.Location</option>
                                                </select>
                                            }
                                            else
                                            {
                                                var locList = (sortedLocationOptions != null && sortedLocationOptions.Count > 0) ? new List<string>(sortedLocationOptions) : new List<string>();
                                                // Remove 'Threaded' from row-level dropdown options
                                                locList = locList.Where(x => !string.Equals(x, "Threaded", StringComparison.OrdinalIgnoreCase)).ToList();
                                                if (!string.IsNullOrWhiteSpace(r.Location) && !locList.Any(x => string.Equals(x, r.Location, System.StringComparison.OrdinalIgnoreCase))) { locList.Add(r.Location!); }
                                                <select data-name="Location" name="Location" id="Location_@r.JointId">
                                                    @foreach (var locOpt in locList)
                                                    {
                                                        if (string.Equals(locOpt, r.Location, System.StringComparison.OrdinalIgnoreCase))
                                                        {
                                                            <option value="@locOpt" selected="selected">@locOpt</option>
                                                        }
                                                        else
                                                        {
                                                            <option value="@locOpt">@locOpt</option>
                                                        }
                                                    }
                                                </select>
                                            }
                                        </td>
                                        <td class="col-jointno @(r.DfrOnHold ? "hold-alert" : null)">@if(locked){
                                        <input data-name="WeldNumber" name="WeldNumber" id="WeldNumber_@r.JointId" value="@r.WeldNumber" disabled />
                                    } else
                                    {

                                        <input data-name="WeldNumber" name="WeldNumber" id="WeldNumber_@r.JointId" value="@r.WeldNumber" />
                                    }
        </td>
                                    <td class="col-jadd">
                                        <select data-name="JAdd" name="JAdd" id="JAdd_@r.JointId" @(locked ? "disabled" : null)>
                                            @{
                                                var jAddList = (jAddOptionsOrdered != null && jAddOptionsOrdered.Count > 0) ? new List<string>(jAddOptionsOrdered) : new List<string>();
                                                if (!string.IsNullOrWhiteSpace(r.JAdd) && !string.Equals(r.JAdd, "NEW", System.StringComparison.OrdinalIgnoreCase) && !jAddList.Any(x => string.Equals(x, r.JAdd, System.StringComparison.OrdinalIgnoreCase))) { jAddList.Add(r.JAdd!); }
                                            }
                                            @foreach (var j in jAddList)
                                            {
                                                if (string.Equals(j, r.JAdd, System.StringComparison.OrdinalIgnoreCase))
                                                {
                                                    <option value="@j" selected="selected">@j</option>
                                                }
                                                else
                                                {
                                                    <option value="@j">@j</option>
                                                }
                                            }
                                        </select>
                                    </td>
                                    <td class="col-wtype">
                                        <select data-name="WeldType" name="WeldType" id="WeldType_@r.JointId" @(locked ? "disabled" : null)>
                                            @{
                                                var wtOpts = (weldTypeOptionsOrdered != null && weldTypeOptionsOrdered.Count > 0) ? new List<string>(weldTypeOptionsOrdered) : new List<string>();
                                                if (!string.IsNullOrWhiteSpace(r.WeldType) && !wtOpts.Any(x => string.Equals(x, r.WeldType, System.StringComparison.OrdinalIgnoreCase))) { wtOpts.Add(r.WeldType!); }
                                                var fallbackDefault = Model.DefaultWeldType
                                                ?? (Model.DefaultWeldTypes != null && Model.DefaultWeldTypes.Count > 0 ? Model.DefaultWeldTypes[0] : null)
                                                ?? wtOpts.FirstOrDefault()
                                                ?? string.Empty;
                                                var selectedWeldType = string.IsNullOrWhiteSpace(r.WeldType) ? fallbackDefault : r.WeldType;
                                            }
                                            @foreach (var wt in wtOpts)
                                            {
                                                if (string.Equals(wt, selectedWeldType, System.StringComparison.OrdinalIgnoreCase))
                                                {
                                                    <option value="@wt" selected="selected">@wt</option>
                                                }
                                                else
                                                {
                                                    <option value="@wt">@wt</option>
                                                }
                                            }
                                        </select>
                                    </td>
                                    <td class="col-sheet @(r.SheetOnHold ? "hold-alert" : null)">@if(locked){
                                    <input data-name="Sheet" name="Sheet" id="Sheet_@r.JointId" value="@r.Sheet" disabled />
                                } else
                                {

                                    <input data-name="Sheet" name="Sheet" id="Sheet_@r.JointId" value="@r.Sheet" />
                                }
    </td>
                                <td><input data-name="Rev" name="Rev" id="Rev_@r.JointId" value="@r.Rev" @(locked ? "disabled" : null) /></td>
                                <td class="col-spno @(r.SpOnHold ? "hold-alert" : null)"><input data-name="SpoolNo" name="SpoolNo" id="SpoolNo_@r.JointId" value="@r.SpoolNo" @(locked ? "disabled" : null) /></td>
                                <td class="col-dia"><input data-name="DiaIn" name="DiaIn" id="DiaIn_@r.JointId" value="@r.DiaIn" @(locked ? "disabled" : null) class="dia-input" /></td>
                                <td class="col-sch"><input data-name="Sch" name="Sch" id="Sch_@r.JointId" value="@r.Sch" @(locked ? "disabled" : null) class="sch-input" /></td>
                                <td>
                                    @{

                                        var matListA = (sortedMaterialDescriptions != null && sortedMaterialDescriptions.Count > 0) ? new List<string>(sortedMaterialDescriptions) : new List<string>();
                                        var curMatA = r.MaterialA ?? string.Empty;
                                        if (!string.IsNullOrWhiteSpace(curMatA) && !matListA.Any(x => string.Equals(x, curMatA, StringComparison.OrdinalIgnoreCase))) { matListA.Add(curMatA); }
                                    }
                                    <select data-name="MaterialA" name="MaterialA" id="MaterialA_@r.JointId" class="searchable-select" @(locked ? "disabled" : null)>
                                        @foreach (var m in matListA)
                                        {
                                            if (string.Equals(m, r.MaterialA, StringComparison.OrdinalIgnoreCase))
                                            {
                                                <option value="@m" selected>@m</option>
                                            }
                                            else
                                            {
                                                <option value="@m">@m</option>
                                            }
                                        }
                                        @if (string.IsNullOrWhiteSpace(r.MaterialA))
                                        {
                                            <option value="" selected></option>
                                        }
                                        else
                                        {
                                            <option value=""></option>
                                        }
                                    </select>
                                </td>
                                <td>
                                    @{

                                        var matListB = (sortedMaterialDescriptions != null && sortedMaterialDescriptions.Count > 0) ? new List<string>(sortedMaterialDescriptions) : new List<string>();
                                        var curMatB = r.MaterialB ?? string.Empty;
                                        if (!string.IsNullOrWhiteSpace(curMatB) && !matListB.Any(x => string.Equals(x, curMatB, StringComparison.OrdinalIgnoreCase))) { matListB.Add(curMatB); }
                                    }
                                    <select data-name="MaterialB" name="MaterialB" id="MaterialB_@r.JointId" class="searchable-select" @(locked ? "disabled" : null)>
                                        @foreach (var m in matListB)
                                        {
                                            if (string.Equals(m, r.MaterialB, StringComparison.OrdinalIgnoreCase))
                                            {
                                                <option value="@m" selected>@m</option>
                                            }
                                            else
                                            {
                                                <option value="@m">@m</option>
                                            }
                                        }
                                        @if (string.IsNullOrWhiteSpace(r.MaterialB))
                                        {
                                            <option value="" selected></option>
                                        }
                                        else
                                        {
                                            <option value=""></option>
                                        }
                                    </select>
                                </td>
                                <td>
                                    @{

                                        var gradeListA = (sortedMaterialGrades != null && sortedMaterialGrades.Count > 0) ? new List<string>(sortedMaterialGrades) : new List<string>();
                                        var curGa = r.GradeA ?? string.Empty;
