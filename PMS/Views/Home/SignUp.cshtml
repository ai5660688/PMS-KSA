<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PMS - Sign Up</title>
    <link rel="icon" type="image/png" href="~/img/title_logo.png">
    <link rel="stylesheet" href="~/css/SignUpStyle.css" asp-append-version="true">
</head>
<body>
    <h1>
        <img src="~/img/PMS_logo.png" alt="Logo" class="main-logo">
    </h1>

    <div class="container-wrapper">
        <div class="signup-container">
            <h2>Create New Account</h2>
            @if (!string.IsNullOrEmpty(ViewBag.ErrorMessage))
            {
                <p class="error-text">@ViewBag.ErrorMessage</p>
            }
            @if (ViewBag.Message != null)
            {
                <div class="alert-success">@ViewBag.Message</div>
            }
            <form asp-action="SignUp" asp-controller="Home" method="post">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label for="firstName">First Name</label>
                    <input type="text" id="firstName" name="firstName" required>
                </div>
                <div class="form-group">
                    <label for="lastName">Last Name</label>
                    <input type="text" id="lastName" name="lastName" required>
                </div>
                <div class="form-group">
                    <label for="email">Email</label>
                    <input type="email" id="email" name="email" required>
                </div>
                <div class="form-group">
                    <label for="username">Username</label>
                    <input type="text" id="username" name="username" required>
                </div>
                <div class="form-group">
                    <label for="password">Password</label>
                    <input
                        type="password"
                        id="password"
                        name="password"
                        minlength="8"
                        maxlength="20"
                        autocomplete="new-password"
                        pattern="^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[^\da-zA-Z])(?=\S+$).{8,20}$"
                        required>
                    <ul class="password-rules" id="pwdRules">
                        <li data-rule="length">8–20 characters</li>
                        <li data-rule="upper">At least one uppercase letter (A–Z)</li>
                        <li data-rule="lower">At least one lowercase letter (a–z)</li>
                        <li data-rule="digit">At least one number (0–9)</li>
                        <li data-rule="special">At least one special character (!&#64;&#35;&#36;&hellip;)</li>
                        <li data-rule="space">No spaces</li>
                    </ul>
                </div>
                <div class="form-group confirm-password">
                    <label for="confirmPassword">Confirm Password</label>
                    <input type="password" id="confirmPassword" name="confirmPassword" maxlength="20" autocomplete="new-password" required>
                    <p id="passwordMismatch" class="error-text password-match-error">Passwords do not match.</p>
                </div>
                <div class="form-group">
                    <label for="position">Position</label>
                    <input type="text" id="position" name="position" maxlength="50" required>
                </div>
                <div class="form-group">
                    <label for="company">Company</label>
                    <input type="text" id="company" name="company" maxlength="20" required>
                </div>

                <div class="button-container">
                    <button type="submit" id="registerBtn">Register</button>
                </div>
            </form>

            <div class="back-to-login-container">
                <a asp-action="Login" asp-controller="Home" class="back-to-login-link">Back to Login</a>
            </div>
        </div>
    </div>

    <div class="footer">
        <div class="footer-center">
            This system is strictly restricted to authorized users only.<br>
            © 2025 Piping Management System. All rights reserved.
        </div>
        <div class="footer-right">
            <img src="~/img/work-smarter-not-harder.jpg?v=3" alt="Logo" class="footer-logo" />
        </div>
    </div>

    <script>
        (function () {
            const pwd = document.getElementById('password');
            const cpwd = document.getElementById('confirmPassword');
            const msg = document.getElementById('passwordMismatch');
            const group = document.querySelector('.form-group.confirm-password');
            const form = document.querySelector('form[method="post"]');
            const rules = {
                length: val => val.length >= 8 && val.length <= 20,
                upper: val => /[A-Z]/.test(val),
                lower: val => /[a-z]/.test(val),
                digit: val => /\d/.test(val),
                special: val => /[^\da-zA-Z]/.test(val),
                space: val => !/\s/.test(val)
            };
            const rulesList = document.getElementById('pwdRules');

            function updateRules() {
                if (!pwd || !rulesList) return true;
                const val = pwd.value || '';
                let ok = true;
                Object.keys(rules).forEach(key => {
                    const li = rulesList.querySelector(`li[data-rule="${key}"]`);
                    const pass = rules[key](val);
                    if (li) { li.classList.toggle('valid', pass); li.classList.toggle('invalid', !pass); }
                    ok = ok && pass;
                });
                return ok;
            }

            function validateMatch() {
                if (!pwd || !cpwd || !msg) return true;
                const same = pwd.value === cpwd.value;
                msg.style.display = same ? 'none' : 'block';
                if (group) group.classList.toggle('has-error', !same); // shrink space when shown
                return same;
            }

            if (pwd) pwd.addEventListener('input', () => { updateRules(); validateMatch(); });
            if (cpwd) cpwd.addEventListener('input', validateMatch);

            if (form) {
                form.addEventListener('submit', function (e) {
                    const passOk = updateRules();
                    const matchOk = validateMatch();
                    if (!passOk || !matchOk) e.preventDefault();
                });
            }
            updateRules();
        })();
    </script>
</body>
</html>