@using Microsoft.AspNetCore.Html;
@using System.Text.Json;
@model PMS.Models.WelderEditViewModel
@{
    Layout = "_LayoutDashboard";
    ViewData["Title"] = (Model?.IsNew == true) ? "Add Welder" : "Edit Welder";
    var isNew = Model?.IsNew == true;
}
@section Head {
    <link rel="stylesheet" href="~/css/edit-welder.css" asp-append-version="true" />
    <script type="application/json" id="editWelderConfig">
        @Html.Raw(JsonSerializer.Serialize(new
            {
                defaultWqtAgency = (string?)(ViewBag.DefaultWqtAgency ?? string.Empty),
                routes = new
                {
                    saveWelder = Url.Action("SaveWelder", "Home"),
                    suggestLocation = Url.Action("SuggestWelderLocation", "Home"),
                    suggestWqt = Url.Action("SuggestWqtAgency", "Home"),
                    suggestTestDate = Url.Action("SuggestQualTestDate", "Home"),
                    findWelder = Url.Action("FindWelderBySymbol", "Home"),
                    getQualifications = Url.Action("GetQualifications", "Home"),
                    getQualOptions = Url.Action("GetQualOptionsAdvanced", "Home"),
                    nextJcc = Url.Action("NextJccNo", "Home")
                }
            }))
    </script>
}
<div class="container">
    <h1 class="page-title">@ViewData["Title"]</h1>

    @if (TempData["Msg"] is string flash && !string.IsNullOrWhiteSpace(flash))
    {
        var isSuccessMsg = System.Text.RegularExpressions.Regex.IsMatch(flash, "(successfully|saved|uploaded|updated|added)", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        var flashClass = isSuccessMsg ? "msg msg-success" : "msg text-danger";
        <div id="topFlashMsg" class="@flashClass" role="status" aria-live="polite">@flash</div>
    }

    <form id="welderForm" method="post" asp-action="SaveWelder" asp-controller="Home" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="All" class="text-danger"></div>

        <!-- Single Welder_ID field - fixed duplicate issue -->
        <input type="hidden" asp-for="Welder.Welder_ID" id="Welder_Welder_ID" />

        <!-- Control flags for server-side logic -->
        <input type="hidden" name="IsAddFlow" id="IsAddFlow" value="@isNew.ToString().ToLower()" />
        <input type="hidden" name="AddNewQualification" id="AddNewQualification" value="@((Model?.IsNew == true).ToString().ToLower())" />

        <div class="section">
            <h2>Welder Information</h2>
            <div class="grid">
                <div class="form-group">
                    <label asp-for="Welder.Welder_Symbol" class="required">Welder Symbol</label>
                    <input asp-for="Welder.Welder_Symbol" class="form-control" maxlength="12"
                           placeholder="Enter unique symbol" autofocus autocomplete="off" />
                    <span asp-validation-for="Welder.Welder_Symbol" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label for="Iqama_No">Iqama No</label>
                    <input asp-for="Welder.Iqama_No" class="form-control" id="Iqama_No" maxlength="24" autocomplete="off" />
                </div>
                <div class="form-group">
                    <label asp-for="Welder.Name" class="required"></label>
                    <input asp-for="Welder.Name" class="form-control" maxlength="100" autocomplete="name" />
                    <span asp-validation-for="Welder.Name" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label for="Welder_Location">Welder Location</label>
                    @{
                        var locations = (IEnumerable<string>)(ViewBag.WelderLocations ?? new List<string>());
                        var modelLoc = Model?.Welder?.Welder_Location;
                        var suggested = (string)(ViewBag.SuggestedLocation ?? string.Empty);
                        if (isNew && string.IsNullOrWhiteSpace(modelLoc) && !string.IsNullOrWhiteSpace(suggested))
                        {
                            modelLoc = suggested;
                        }
                        var hasModelLoc = false;
                    }
                    <select class="form-control" id="Welder_Location" name="Welder.Welder_Location">
                        @foreach (var s in locations)
                        {
                            var selected = (!string.IsNullOrWhiteSpace(modelLoc) && string.Equals(s, modelLoc, StringComparison.OrdinalIgnoreCase)) ? "selected" : null;
                            if (string.Equals(s, modelLoc, StringComparison.OrdinalIgnoreCase)) { hasModelLoc = true; }
                            <option value="@s" selected="@selected">@s</option>
                        }
                        @if (!string.IsNullOrWhiteSpace(modelLoc) && !hasModelLoc)
                        {
                            <option value="@modelLoc" selected="selected">@modelLoc</option>
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label class="@(isNew ? "required" : "")" for="Project_Welder">Project Welder</label>
                    <select asp-for="Welder.Project_Welder"
                            class="form-control"
                            id="Project_Welder"
                            asp-items="ViewBag.Projects"
                            required="@(isNew ? "required" : null)">
                    </select>
                    <span asp-validation-for="Welder.Project_Welder" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label for="Passport">Passport</label>
                    <input asp-for="Welder.Passport" class="form-control" id="Passport" maxlength="24" autocomplete="off" />
                </div>
                <div class="form-group">
                    <label for="Mobile_No">Mobile No</label>
                    <input asp-for="Welder.Mobile_No" class="form-control" id="Mobile_No" maxlength="12" inputmode="tel" autocomplete="tel" />
                </div>
                <div class="form-group">
                    <label for="Email">Email</label>
                    <input asp-for="Welder.Email"
                           class="form-control"
                           id="Email"
                           type="email"
                           maxlength="50"
                           autocomplete="email" />
                    <span asp-validation-for="Welder.Email" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label for="Mobilization_Date">Mobilization Date</label>
                    <input asp-for="Welder.Mobilization_Date" class="form-control" id="Mobilization_Date" type="date" />
                </div>
                <div class="form-group" id="Demobilization_Group" style="display:@(isNew ? "none" : "block")">
                    <label for="Demobilization_Date">Demobilization Date</label>
                    <input asp-for="Welder.Demobilization_Date" class="form-control" id="Demobilization_Date" type="date" />
                </div>
                <div class="form-group">
                    <label for="Welder_Status">Status</label>
                    @{
                        var currentStatus = Model?.Welder?.Status;
                        // Ensure Add flow defaults to Waiting for Approval when no explicit status provided
                        if (isNew && string.IsNullOrWhiteSpace(currentStatus))
                        {
                            // set on model so tag helpers and binding respect the default
                            if (Model?.Welder != null) { Model.Welder.Status = "Waiting for Approval"; currentStatus = Model.Welder.Status; }
                        }
                        var statusToSelect = isNew
                        ? (string.IsNullOrWhiteSpace(currentStatus) ? "Waiting for Approval" : currentStatus)
                        : currentStatus;
                        var statusOptions = (IEnumerable<string>)(ViewBag.Statuses ?? new[] { "Waiting for Approval", "Active", "Inactive", "On Leave" });
                    }
                    <select asp-for="Welder.Status"
                            class="form-control"
                            id="Welder_Status"
                            maxlength="35"
                            data-init-value="@(statusToSelect ?? string.Empty)">
                        @foreach (var s in statusOptions)
                        {
                            var sel = string.Equals(s, statusToSelect, StringComparison.OrdinalIgnoreCase) ? "selected" : null;
                            <option value="@s" selected="@sel">@s</option>
                        }
                        <option value="__new__">+ Add new...</option>
                    </select>
                    <input class="form-control" id="Welder_Status_New" type="text" maxlength="35" placeholder="Type new Status" style="display:none;margin-top:6px;" />
                </div>
            </div>
        </div>

        <div class="section" id="existingQualsAdd" style="display:none;">
            <h2>Existing Qualifications</h2>
            <div class="table-wrap">
                <table class="table" aria-label="Existing qualifications for this welder symbol">
                    <thead>
                        <tr>
                            <th>JCC No</th>
                            <th>Welding Process</th>
                            <th>Material P No</th>
                            <th>Diameter Range</th>
                            <th>Max Thickness</th>
                        </tr>
                    </thead>
                    <tbody id="existingQualsAddBody"><tr><td colspan="5" style="text-align:center;color:#7a9aa8;">None</td></tr></tbody>
                </table>
            </div>
        </div>

        @if (!isNew && (Model?.Qualifications?.Any() == true))
        {
            <div class="section">
                <h2>Existing Qualifications</h2>
                <div class="table-wrap">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>JCC No</th>
                                <th>Welding Process</th>
                                <th>Material P No</th>
                                <th>Diameter Range</th>
                                <th>Max Thickness</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var q in Model.Qualifications)
                            {
                                var isSel = string.Equals(q.JCC_No, Model.SelectedJcc, StringComparison.OrdinalIgnoreCase);
                                <tr>
                                    <td>@q.JCC_No</td>
                                    <td>@q.Welding_Process</td>
                                    <td>@q.Material_P_No</td>
                                    <td>@q.Diameter_Range</td>
                                    <td>@q.Max_Thickness</td>
                                    <td>
                                        <span class="inline-actions">
                                            <a class="badgelink" asp-action="EditWelder" asp-route-id="@Model.Welder.Welder_ID" asp-route-jcc="@q.JCC_No">@(isSel ? "Editing" : "Edit")</a>
                                            <button type="button" class="btn btn-danger btn-sm delete-qual" data-welder="@Model.Welder.Welder_ID" data-jcc="@q.JCC_No">Del</button>
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        <div class="section" id="qualSection">
            <h2>Qualification Information</h2>
            <div class="grid">
                <div class="form-group">
                    <label class="required" for="JCC_No">JCC No</label>
                    <input class="form-control"
                           id="JCC_No"
                           name="Qualification.JCC_No"
                           maxlength="18"
                           placeholder="Focus field to generate next JCC No"
                           value="@(Model?.Qualification?.JCC_No ?? string.Empty)" />
                </div>
                <div class="form-group">
                    <label for="Test_Date">Test Date</label>
                    <input class="form-control" id="Test_Date" name="Qualification.Test_Date" type="date" value="@(Model?.Qualification?.Test_Date?.ToString("yyyy-MM-dd") ?? "")">
                </div>

                <div class="form-group">
                    <label for="Welding_Process">Welding Process</label>
                    <select asp-for="Qualification.Welding_Process"
                            class="form-control"
                            id="Qualification_Welding_Process"
                            data-init-value="@(Model?.Qualification?.Welding_Process ?? string.Empty)">
                        @if (ViewBag.WeldingProcesses != null)
                        {
                            foreach (var item in (IEnumerable<string>)ViewBag.WeldingProcesses)
                            {
                                var selected = Model?.Qualification?.Welding_Process == item ? "selected" : "";
                                <option value="@item" selected="@selected">@item</option>
                            }
                        }
                        <option value="__new__">+ Add new...</option>
                    </select>
                    <input class="form-control" id="Qualification_Welding_Process_New" type="text" maxlength="30" placeholder="Type new Welding Process" style="display:none;margin-top:6px;" />
                    <span asp-validation-for="Qualification.Welding_Process" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label for="Material_P_No">Material P No</label>
                    <select asp-for="Qualification.Material_P_No"
                            class="form-control"
                            id="Qualification_Material_P_No"
                            data-init-value="@(Model?.Qualification?.Material_P_No ?? string.Empty)">
                        @if (ViewBag.MaterialPNos != null)
                        {
                            foreach (var item in (IEnumerable<string>)ViewBag.MaterialPNos)
                            {
                                var selected = Model?.Qualification?.Material_P_No == item ? "selected" : "";
                                <option value="@item" selected="@selected">@item</option>
                            }
                        }
                        <option value="__new__">+ Add new...</option>
                    </select>
                    <input class="form-control" id="Qualification_Material_P_No_New" type="text" maxlength="100" placeholder="Type new Material P No" style="display:none;margin-top:6px;" />
                    <span asp-validation-for="Qualification.Material_P_No" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label for="Code_Reference">Code Reference</label>
                    <select asp-for="Qualification.Code_Reference"
                            class="form-control"
                            id="Qualification_Code_Reference"
                            data-init-value="@(Model?.Qualification?.Code_Reference ?? string.Empty)">
                        @if (ViewBag.CodeReferences != null)
                        {
                            foreach (var item in (IEnumerable<string>)ViewBag.CodeReferences)
                            {
                                var selected = Model?.Qualification?.Code_Reference == item ? "selected" : "";
                                <option value="@item" selected="@selected">@item</option>
                            }
                        }
                        <option value="__new__">+ Add new...</option>
                    </select>
                    <input class="form-control" id="Qualification_Code_Reference_New" type="text" maxlength="75" placeholder="Type new Code Reference" style="display:none;margin-top:6px;" />
                    <span asp-validation-for="Qualification.Code_Reference" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label for="Consumable_Root_F_No">Consumable Root F No</label>
                    <select class="form-control"
                            id="Qualification_Consumable_Root_F_No"
                            data-init-value="@(Model?.Qualification?.Consumable_Root_F_No ?? string.Empty)"
                            asp-for="Qualification.Consumable_Root_F_No">
                        @if (ViewBag.RootFNos != null)
                        {
                            foreach (var item in (IEnumerable<string>)ViewBag.RootFNos)
                            {
                                var selected = Model?.Qualification?.Consumable_Root_F_No == item ? "selected" : "";
                                <option value="@item" selected="@selected">@item</option>
                            }
                        }
                        <option value="__new__">+ Add new...</option>
                    </select>
                    <input class="form-control" id="Qualification_Consumable_Root_F_No_New" type="text" maxlength="20" placeholder="Type new Root F No" style="display:none;margin-top:6px;" />
                    <span asp-validation-for="Qualification.Consumable_Root_F_No" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label for="Consumable_Root_Spec">Consumable Root Spec</label>
                    <select class="form-control"
                            id="Qualification_Consumable_Root_Spec"
                            data-init-value="@(Model?.Qualification?.Consumable_Root_Spec ?? string.Empty)"
                            asp-for="Qualification.Consumable_Root_Spec">
                        @if (ViewBag.RootSpecs != null)
                        {
                            foreach (var item in (IEnumerable<string>)ViewBag.RootSpecs)
                            {
                                var selected = Model?.Qualification?.Consumable_Root_Spec == item ? "selected" : "";
                                <option value="@item" selected="@selected">@item</option>
                            }
                        }
                        <option value="__new__">+ Add new...</option>
                    </select>
                    <input class="form-control" id="Qualification_Consumable_Root_Spec_New" type="text" maxlength="40" placeholder="Type new Root Spec" style="display:none;margin-top:6px;" />
                    <span asp-validation-for="Qualification.Consumable_Root_Spec" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label for="Consumable_Filling_Cap_F_No">Consumable Filling Cap F No</label>
                    <select class="form-control"
                            id="Qualification_Consumable_Filling_Cap_F_No"
                            data-init-value="@(Model?.Qualification?.Consumable_Filling_Cap_F_No ?? string.Empty)"
                            asp-for="Qualification.Consumable_Filling_Cap_F_No">
                        @if (ViewBag.FillCapFNos != null)
                        {
                            foreach (var item in (IEnumerable<string>)ViewBag.FillCapFNos)
                            {
                                var selected = Model?.Qualification?.Consumable_Filling_Cap_F_No == item ? "selected" : "";
                                <option value="@item" selected="@selected">@item</option>
                            }
                        }
                        <option value="__new__">+ Add new...</option>
                    </select>
                    <input class="form-control" id="Qualification_Consumable_Filling_Cap_F_No_New" type="text" maxlength="100" placeholder="Type new Filling Cap F No" style="display:none;margin-top:6px;" />
                    <span asp-validation-for="Qualification.Consumable_Filling_Cap_F_No" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label for="Consumable_Filling_Cap_Spec">Consumable Filling Cap Spec</label>
                    <select class="form-control"
                            id="Qualification_Consumable_Filling_Cap_Spec"
                            data-init-value="@(Model?.Qualification?.Consumable_Filling_Cap_Spec ?? string.Empty)"
                            asp-for="Qualification.Consumable_Filling_Cap_Spec">
                        @if (ViewBag.FillCapSpecs != null)
                        {
                            foreach (var item in (IEnumerable<string>)ViewBag.FillCapSpecs)
                            {
                                var selected = Model?.Qualification?.Consumable_Filling_Cap_Spec == item ? "selected" : "";
                                <option value="@item" selected="@selected">@item</option>
                            }
                        }
                        <option value="__new__">+ Add new...</option>
                    </select>
                    <input class="form-control" id="Qualification_Consumable_Filling_Cap_Spec_New" type="text" maxlength="100" placeholder="Type new Filling Cap Spec" style="display:none;margin-top:6px;" />
                    <span asp-validation-for="Qualification.Consumable_Filling_Cap_Spec" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label for="Position_Progression">Position Progression</label>
                    <select class="form-control"
                            id="Qualification_Position_Progression"
                            data-init-value="@(Model?.Qualification?.Position_Progression ?? string.Empty)"
                            asp-for="Qualification.Position_Progression">
                        @if (ViewBag.PositionProgressions != null)
                        {
                            foreach (var item in (IEnumerable<string>)ViewBag.PositionProgressions)
                            {
                                var selected = Model?.Qualification?.Position_Progression == item ? "selected" : "";
                                <option value="@item" selected="@selected">@item</option>
                            }
                        }
                        <option value="__new__">+ Add new...</option>
                    </select>
                    <input class="form-control" id="Qualification_Position_Progression_New" type="text" maxlength="100" placeholder="Type new Position Progression" style="display:none;margin-top:6px;" />
                    <span asp-validation-for="Qualification.Position_Progression" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label for="Diameter_Range">Diameter Range</label>
                    <select class="form-control"
                            id="Qualification_Diameter_Range"
                            data-init-value="@(Model?.Qualification?.Diameter_Range ?? string.Empty)"
                            asp-for="Qualification.Diameter_Range">
                        @if (ViewBag.DiameterRanges != null)
                        {
                            foreach (var item in (IEnumerable<string>)ViewBag.DiameterRanges)
                            {
                                var selected = Model?.Qualification?.Diameter_Range == item ? "selected" : "";
                                <option value="@item" selected="@selected">@item</option>
                            }
                        }
                        <option value="__new__">+ Add new...</option>
                    </select>
                    <input class="form-control" id="Qualification_Diameter_Range_New" type="text" maxlength="60" placeholder="Type new Diameter Range" style="display:none;margin-top:6px;" />
                    <span asp-validation-for="Qualification.Diameter_Range" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label for="Max_Thickness">Max Thickness</label>
                    <select class="form-control"
                            id="Qualification_Max_Thickness"
                            data-init-value="@(Model?.Qualification?.Max_Thickness ?? string.Empty)"
                            asp-for="Qualification.Max_Thickness">
                        @if (ViewBag.MaxThicknesses != null)
                        {
                            foreach (var item in (IEnumerable<string>)ViewBag.MaxThicknesses)
                            {
                                var selected = Model?.Qualification?.Max_Thickness == item ? "selected" : "";
                                <option value="@item" selected="@selected">@item</option>
                            }
                        }
                        <option value="__new__">+ Add new...</option>
                    </select>
                    <input class="form-control" id="Qualification_Max_Thickness_New" type="text" maxlength="60" placeholder="Type new Max Thickness" style="display:none;margin-top:6px;" />
                    <span asp-validation-for="Qualification.Max_Thickness" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label for="Qualification_Cert_Ref_No">Qualification Cert Ref No</label>
                    <input class="form-control"
                           id="Qualification_Cert_Ref_No"
                           name="Qualification.Qualification_Cert_Ref_No"
                           maxlength="17"
                           value="@(Model?.Qualification?.Qualification_Cert_Ref_No ?? string.Empty)" />
                    <span asp-validation-for="Qualification.Qualification_Cert_Ref_No" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label for="WQT_Agency">WQT Agency</label>
                    @{
                        var wqtAgencies = (IEnumerable<string>)(ViewBag.WQTagencies ?? new List<string>());
                        var wqtSelected = Model?.Qualification?.WQT_Agency ?? string.Empty;
                    }
                    <select class="form-control"
                            id="Qualification_WQT_Agency"
                            data-init-value="@(Model?.Qualification?.WQT_Agency ?? string.Empty)"
                            asp-for="Qualification.WQT_Agency">
                        @if (ViewBag.WQTagencies != null)
                        {
                            foreach (var item in (IEnumerable<string>)ViewBag.WQTagencies)
                            {
                                var selected = Model?.Qualification?.WQT_Agency == item ? "selected" : "";
                                <option value="@item" selected="@selected">@item</option>
                            }
                        }
                        <option value="__new__">+ Add new...</option>
                    </select>
                    <input class="form-control" id="Qualification_WQT_Agency_New" type="text" maxlength="30" placeholder="Type new WQT Agency" style="display:none;margin-top:6px;" />
                    <span asp-validation-for="Qualification.WQT_Agency" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label for="Batch_No">Batch No</label>
                    @{
                        var existing = Model?.Qualification?.Batch_No ?? 0;
                        var maxBatch = (int)(ViewBag.MaxBatchNo ?? 0);
                        var batchDefault = existing > 0 ? existing : maxBatch;
                    }
                    <input class="form-control"
                           id="Batch_No"
                           name="Qualification.Batch_No"
                           type="number"
                           inputmode="numeric"
                           step="1"
                           min="0"
                           data-max-batch="@ViewBag.MaxBatchNo"
                           value="@batchDefault" />
                </div>

                <div class="form-group">
                    <label for="Date_Issued">Date Issued</label>
                    <input class="form-control" id="Date_Issued" name="Qualification.Date_Issued" type="date" value="@(Model?.Qualification?.Date_Issued?.ToString("yyyy-MM-dd") ?? "")">
                </div>

                <div class="form-group">
                    <label for="Remarks">Remarks</label>
                    <input class="form-control" id="Remarks" name="Qualification.Remarks" maxlength="40" value="@(Model?.Qualification?.Remarks ?? string.Empty)" />
                </div>
                <div class="form-group">
                    <label for="DATE_OF_LAST_CONTINUITY">Date of Last Continuity</label>
                    <input class="form-control" id="DATE_OF_LAST_CONTINUITY" name="Qualification.DATE_OF_LAST_CONTINUITY" type="date" value="@(Model?.Qualification?.DATE_OF_LAST_CONTINUITY?.ToString("yyyy-MM-dd") ?? "")">
                </div>
                <div class="form-group">
                    <label for="RECORDING_THE_CONTINUITY_RECORD">Recording the Continuity Record</label>
                    <input class="form-control" id="RECORDING_THE_CONTINUITY_RECORD" name="Qualification.RECORDING_THE_CONTINUITY_RECORD" maxlength="20" value="@(Model?.Qualification?.RECORDING_THE_CONTINUITY_RECORD ?? string.Empty)" />
                </div>

                <!-- Received_from_Aramco now shown for both Add and Edit -->
                <div class="form-group">
                    <label asp-for="Qualification.Received_from_Aramco">Received from Aramco</label>
                    @{
                        var existingRec = (IEnumerable<string>)(ViewBag.RecivedFromAramco ?? new List<string>());
                        var recSelected = Model?.Qualification?.Received_from_Aramco ?? string.Empty;
                        if (string.Equals(recSelected, "REJECTED", StringComparison.OrdinalIgnoreCase))
                        {
                            recSelected = string.Empty;
                        }
                    }
                    <select class="form-control"
                            id="Qualification_Received_from_Aramco"
                            data-init-value="@recSelected"
                            name="Qualification.Received_from_Aramco">
                        <option value="" selected="@(string.IsNullOrWhiteSpace(recSelected) ? "selected" : null)">--Select--</option>
                        @if (ViewBag.RecivedFromAramco != null)
                        {
                            foreach (var item in (IEnumerable<string>)ViewBag.RecivedFromAramco)
                            {
                                var selected = recSelected == item ? "selected" : null;
                                <option value="@item" selected="@selected">@item</option>
                            }
                        }
                        <option value="__new__">+ Add new...</option>
                    </select>
                    <input class="form-control" id="Qualification_Received_from_Aramco_New" type="text" placeholder="Type new value" style="display:none;margin-top:6px;" />
                    <span asp-validation-for="Qualification.Received_from_Aramco" class="text-danger"></span>
                </div>

                @if (!isNew)
                {
                    <div class="form-group">
                        <label>Qualification Updated By</label>
                        <input class="form-control qual-meta"
                               value="@(Model?.QualificationUpdatedByName ?? Model?.Qualification?.Welder_List_Updated_By?.ToString() ?? "")"
                               readonly />
                    </div>
                    <div class="form-group">
                        <label>Qualification Updated Date</label>
                        <input class="form-control qual-meta"
                               value="@(Model?.Qualification?.Welder_List_Updated_Date?.ToString("yyyy-MM-dd HH:mm") ?? "")"
                               readonly />
                    </div>
                    <div class="form-group">
                        <label>Qualification File</label>
                        <div class="file-actions">
                            <label for="UploadQualFile" class="btn btn-secondary btn-sm" id="chooseQualFileBtn">Choose File</label>
                            <span class="file-name" id="UploadQualFileName">No file chosen</span>
                            <button type="submit" class="btn btn-primary btn-sm" id="UploadQualSubmit" form="uploadQualForm" disabled>Upload</button>
                            @if (Model?.HasQualificationFile == true)
                            {
                                <a class="btn btn-success btn-sm" href="@Url.Action("OpenQualificationFile", "Home", new { jcc = Model!.Qualification!.JCC_No, welderId = Model!.Welder!.Welder_ID })" target="_blank">Open</a>
                                <a class="btn btn-secondary btn-sm" href="@Url.Action("DownloadQualificationFile", "Home", new { jcc = Model!.Qualification!.JCC_No, welderId = Model!.Welder!.Welder_ID })">Download</a>
                                <button type="button" class="btn btn-danger btn-sm delete-qual-file" id="deleteQualFileBtn" data-jcc="@Model.Qualification.JCC_No" data-welder="@Model.Welder.Welder_ID">Delete File</button>
                            }
                        </div>

                        @if (Model?.HasQualificationFile == true)
                        {
                            <div class="file-meta">
                                File: @Model.Qualification.JCC_FileName (@(Model.Qualification.JCC_FileSize ?? 0) bytes)<br />
                                Uploaded: @Model.Qualification.JCC_UploadDate?.ToString("yyyy-MM-dd HH:mm") by @Model.QualificationUploadedByName
                            </div>
                        }
                        else
                        {
                            <div class="file-meta">No file uploaded.</div>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="actions">
            <a class="btn btn-secondary" asp-action="WelderList" asp-controller="Home">Cancel</a>
            @if (!isNew)
            {
                <button type="button" class="btn btn-success" id="addQualificationBtn">Add New Qualification</button>
            }
            <button type="submit" class="btn btn-primary" id="saveBtn">Save Changes</button>
        </div>

        <!-- Hidden for selected JCC to persist on post -->
        <input type="hidden" name="SelectedJcc" id="SelectedJcc" value="@(Model?.SelectedJcc ?? Model?.Qualification?.JCC_No ?? "")" />
    </form>

    <!-- Hidden upload form (placed outside main form to prevent nested form issues) -->
    <form id="uploadQualForm" method="post" asp-action="UploadQualificationFile" asp-controller="Home" enctype="multipart/form-data" style="display:inline-block;">
        @Html.AntiForgeryToken()
        <input type="hidden" name="jcc" id="uploadFormJcc" value="@(Model?.Qualification?.JCC_No ?? string.Empty)" />
        <input type="hidden" name="welderId" id="uploadFormWelderId" value="@(Model?.Welder?.Welder_ID ?? 0)" />
        <input type="file" id="UploadQualFile" name="file" class="visually-hidden" />
    </form>

    <!-- Hidden delete qualification form (single, avoids nested form issue) -->
    <form id="deleteQualForm" method="post" asp-action="DeleteQualification" asp-controller="Home" style="display:none;">
        @Html.AntiForgeryToken()
        <input type="hidden" name="welderId" id="deleteWelderId" />
        <input type="hidden" name="jcc" id="deleteJcc" />
    </form>

    <!-- Hidden delete qualification FILE form -->
    <form id="deleteQualFileForm" method="post" asp-action="DeleteQualificationFile" asp-controller="Home" style="display:none;">
        @Html.AntiForgeryToken()
        <input type="hidden" name="jcc" id="deleteFileJcc" />
        <input type="hidden" name="welderId" id="deleteFileWelderId" />
    </form>
</div>

<!-- Modal for deleting qualification -->
<div class="modal" id="confirmDeleteQualModal" role="dialog" aria-modal="true" aria-labelledby="qualDeleteTitle" aria-hidden="true">
    <div class="modal-content">
        <div class="modal-header">
            <h2 class="modal-title" id="qualDeleteTitle">Confirm Delete</h2>
            <button class="close-modal" type="button" aria-label="Close" onclick="closeQualDeleteModal()">&times;</button>
        </div>
        <p id="confirmDeleteQualMessage" style="color:#176d8a; margin:0 0 16px 0;"></p>
        <div class="modal-actions">
            <button type="button" class="btn" onclick="closeQualDeleteModal()">Cancel</button>
            <button type="button" class="btn btn-danger" onclick="confirmQualDelete()">Delete</button>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/edit-welder-core.js" asp-append-version="true"></script>
    <script src="~/js/edit-welder-modal.js" asp-append-version="true"></script>
    <script src="~/js/edit-welder-submit.js" asp-append-version="true"></script>
}