                    </div>
                </div>
                <div class="submenu-parent" style="position: relative;">
                    <a href="#" class="has-submenu">RFI <span class="submenu-arrow">&#9654;</span></a>
                    <div class="submenu">
                        @if (!(currentAction == "RfiLog" && currentController == "Home"))
                        {
                            <a asp-controller="Home" asp-action="RfiLog">Log</a>
                        }
