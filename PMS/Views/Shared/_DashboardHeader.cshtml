                        }
                        @if (!(currentAction == "ControlLookups" && currentController == "Home"))
                        {
                            <a asp-action="ControlLookups" asp-controller="Home">Control Lookups</a>
                        }
                        <!-- Maintenance Mode Toggle -->
                            <div class="maintenance-toggle-item" style="padding:8px 16px; border-top:1px solid #eee; margin-top:4px;">
                                <label style="display:flex; align-items:center; gap:8px; cursor:pointer; white-space:nowrap; font-size:0.92em; color:#333;">
                                    <span>Maintenance Mode</span>
                                    <span class="maint-switch" id="maintSwitch" title="Toggle maintenance mode">
                                        <input type="checkbox" id="maintToggle" style="display:none;" />
                                        <span class="maint-slider"></span>
                                    </span>
                                    <span id="maintStatusBadge" class="maint-badge maint-badge-off">OFF</span>
                                </label>
                                <!-- Duration picker (shown only when enabling) -->
                                <div id="maintDurationRow" style="display:none; margin-top:6px; padding-top:6px; border-top:1px dashed #ddd;">
                                    <label style="display:flex; align-items:center; gap:6px; font-size:0.85em; color:#555; white-space:nowrap;">
                                        <span>Est. duration</span>
                                        <input type="number" id="maintDuration" min="1" max="1440" placeholder="min"
                                               style="width:58px; padding:3px 5px; border:1px solid #bbb; border-radius:3px; font-size:0.95em; color:#176d8a; text-align:center;" />
                                        <span style="color:#999;">min</span>
                                    </label>
                                </div>
                            </div>
                    </div>
                </div>
            }
    </div>

    <div class="user-section">
        <span class="welcome-user">Welcome, <a asp-action="Profile" asp-controller="Home" class="user-name profile-link" title="View Profile">@headerFullName</a></span>
        <form asp-action="Logout" asp-controller="Home" method="post" style="display:inline;">
            @Html.AntiForgeryToken()
            <button type="submit" class="logout-btn">Logout</button>
        </form>
    </div>
</div>

@if (isAdmin)
{
<style>
    /* ===== MAINTENANCE TOGGLE SWITCH ===== */
    .maint-switch {
        position: relative;
        display: inline-block;
        width: 38px;
        height: 20px;
        flex-shrink: 0;
    }
    .maint-slider {
        position: absolute;
        cursor: pointer;
        top: 0; left: 0; right: 0; bottom: 0;
        background-color: #ccc;
        border-radius: 20px;
        transition: background-color 0.3s;
    }
    .maint-slider::before {
        content: "";
        position: absolute;
        height: 14px;
        width: 14px;
        left: 3px;
        bottom: 3px;
        background-color: #fff;
        border-radius: 50%;
        transition: transform 0.3s;
    }
    .maint-switch.active .maint-slider {
        background-color: #e74c3c;
    }
    .maint-switch.active .maint-slider::before {
        transform: translateX(18px);
    }
    .maint-badge {
        font-size: 0.75em;
        font-weight: 700;
        padding: 2px 7px;
        border-radius: 4px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .maint-badge-off { background: #d4edda; color: #155724; }
    .maint-badge-on  { background: #f8d7da; color: #721c24; }
</style>
<script>
(function () {
    var toggle = document.getElementById('maintToggle');
    var switchEl = document.getElementById('maintSwitch');
    var badge = document.getElementById('maintStatusBadge');
    var durationRow = document.getElementById('maintDurationRow');
    var durationInput = document.getElementById('maintDuration');
    if (!toggle || !switchEl || !badge) return;

    var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';

    // Load initial state
    fetch('/Home/MaintenanceStatus')
        .then(function (r) { return r.json(); })
        .then(function (d) { applyState(d.enabled); })
        .catch(function () { /* silently ignore */ });

    switchEl.addEventListener('click', function (e) {
        e.preventDefault();
        e.stopPropagation();

        var enabling = !toggle.checked;

        // If enabling and no duration entered yet, show the duration row and wait
        if (enabling && durationRow.style.display === 'none') {
            durationRow.style.display = 'block';
            durationInput.focus();
            return;
        }

        var body = new URLSearchParams();
        body.append('enable', enabling);
        body.append('__RequestVerificationToken', token);

        if (enabling) {
            var mins = parseInt(durationInput.value, 10);
            if (mins > 0) body.append('durationMinutes', mins);
        }

        fetch('/Home/ToggleMaintenance', { method: 'POST', body: body })
            .then(function (r) { return r.json(); })
            .then(function (d) { applyState(d.enabled); })
            .catch(function () { alert('Failed to toggle maintenance mode.'); });
    });

    // Also allow Enter key in the duration input to confirm
    if (durationInput) {
        durationInput.addEventListener('keydown', function (e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                switchEl.click();
            }
        });
        // Prevent dropdown from closing when clicking the input
        durationInput.addEventListener('click', function (e) { e.stopPropagation(); });
        durationRow.addEventListener('click', function (e) { e.stopPropagation(); });
    }

    function applyState(enabled) {
        toggle.checked = enabled;
        if (enabled) {
            switchEl.classList.add('active');
            badge.textContent = 'ON';
            badge.className = 'maint-badge maint-badge-on';
            durationRow.style.display = 'none';
            durationInput.value = '';
        } else {
            switchEl.classList.remove('active');
            badge.textContent = 'OFF';
            badge.className = 'maint-badge maint-badge-off';
            durationRow.style.display = 'none';
            durationInput.value = '';
        }
    }
})();
</script>
}