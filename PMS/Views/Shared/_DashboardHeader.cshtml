                        {
                            <a asp-action="DailyFitup" asp-controller="Home">Daily Fit-up</a>
                        }
                        @if (!(currentAction == "DailyWelding" && currentController == "Home"))
                        {
                            <a asp-action="DailyWelding" asp-controller="Home">Daily Welding</a>
                        }
