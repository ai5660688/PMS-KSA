@{
    var access = (Context.Session.GetString("Access") ?? string.Empty).Trim();
    var role = access.ToUpperInvariant();
    var normalized = role.Replace(' ', '_');
    var isAdmin = normalized == "ADMIN";
    var canSeeEngineering = normalized == "ADMIN" || normalized == "FULL" || normalized == "ENGINEERING" || normalized == "PLANNING" || normalized == "PLANING"; // PLANING legacy
    var canSeeWps = normalized == "ADMIN" || normalized == "FULL" || normalized == "QC_MANAGER" || normalized == "QC_SUPERVISOR" || normalized == "QC_DCC" || normalized == "WELDING_ENGINEER"; 
    var currentAction = (ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty);
    var currentController = (ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty);

    // Compute a reliable display name for the header. Prefer ViewBag.FullName, then session FullName,
    // then combine FirstName+LastName from session, then fall back to UserName and finally a generic label.
    var headerFullName = (ViewBag.FullName as string) ?? string.Empty;
    if (string.IsNullOrWhiteSpace(headerFullName))
    {
        headerFullName = Context.Session.GetString("FullName") ?? string.Empty;
    }
    if (string.IsNullOrWhiteSpace(headerFullName))
    {
        var sf = Context.Session.GetString("FirstName") ?? string.Empty;
        var sl = Context.Session.GetString("LastName") ?? string.Empty;
        var comb = (sf + " " + sl).Trim();
        if (!string.IsNullOrWhiteSpace(comb)) headerFullName = comb;
    }
    if (string.IsNullOrWhiteSpace(headerFullName))
    {
        headerFullName = Context.Session.GetString("UserName") ?? string.Empty;
    }
    if (string.IsNullOrWhiteSpace(headerFullName)) headerFullName = "User";
}
<div class="header-bar">
    <a asp-action="Dashboard" asp-controller="Home" aria-label="Go to Dashboard">
        <img src="~/img/PMS_logo_2.png" alt="Logo" class="main-logo">
    </a>
    <div class="nav-titles">
